    <TranslationEntry name="F890269BAE8E3CD82352B5EFF3DDA69A" translateForJs="false">Wybierz tryb uzbrojenia strefy, używając klawisza 1, 2 lub 3.</TranslationEntry>
    <TranslationEntry name="C52BCCE93E2A0B08DAC74A48B0DE1E00" translateForJs="false">Tryb pełnego uzbrojenia</TranslationEntry>
    <TranslationEntry name="A4D02978D239EE7A23DD222B7495CF64" translateForJs="false">Uzbraja całą strefę z opóźnieniem na wyjście. Używaj, gdy nikt nie będzie przebywać w strefie.</TranslationEntry>
    <TranslationEntry name="268808C8B041058C5C1B37E143F84A91" translateForJs="false">Tryb uzbrojenia zewnętrznego</TranslationEntry>
    <TranslationEntry name="C5409CEB08D0904D63A15CDEEFACF5AE" translateForJs="false">Uzbraja tylko obwód zewnętrzny strefy. Używaj, gdy osoby przebywają w strefie i mogą wchodzić lub wychodzić.</TranslationEntry>
    <TranslationEntry name="DDADE87B1B1E7EAE146678330EFFAF7E" translateForJs="false">Tryb nocnego uzbrojenia</TranslationEntry>
    <TranslationEntry name="4AA92746D523A474278D18AADBDD7D6B" translateForJs="false">Tak samo jak uzbrojenie zewnętrzne, z natychmiastowym alarmem po aktywacji obwodu zewnętrznego.</TranslationEntry>
    <TranslationEntry name="B1BA336B4975256D148C3BA1EE8B26F4" translateForJs="false">Uzbrojenie nieudane</TranslationEntry>
    <TranslationEntry name="2E8DF247A6EFDA400B1F69B86D434143" translateForJs="false" rules="unique=OSDPPresetControl" notes="Must be unique amongst all &quot;OSDPPresetControl&quot; entries">Strefa uzbrojona</TranslationEntry>
    <TranslationEntry name="C952A439CCCB7E9F23813BED48AE8BC2" translateForJs="false">Opuść strefę teraz</TranslationEntry>
    <TranslationEntry name="816B1A13E23C181202545A46507A6C40" translateForJs="false">Elementy niezabezpieczone</TranslationEntry>
    <TranslationEntry name="A1B0362778FC985F8F2BD15A43188CB1" translateForJs="false">Problemy z modułem</TranslationEntry>
    <TranslationEntry name="6E2391541A7F1D6FBE4C607F59022CB3" translateForJs="false">Problemy z raportowaniem</TranslationEntry>
    <TranslationEntry name="75DC05382C140F7978C541B53405CB98" translateForJs="false">Istnieją problemy z komunikacją alarmową. Naciśnij ON, aby pominąć</TranslationEntry>
    <TranslationEntry name="C96C13C6E95023A760A3CB5490EF123F" translateForJs="false">Naciśnij ON, aby ominąć problemy i spróbować ponownie uzbroić</TranslationEntry>
    <TranslationEntry name="95A0CF2E6D191AAEC9605A61CD5DF450" translateForJs="false">Zastąpienie nie powiodło się</TranslationEntry>
    <TranslationEntry name="C5D1B65AF2361C8C6271EC9D58CFA4F8" translateForJs="false">Rozbrojenie nieudane</TranslationEntry>
    <TranslationEntry name="5F5B787E29FF53E3DC09DE2AC9D572B4" translateForJs="false">Bieżąca strefa:</TranslationEntry>
    <TranslationEntry name="6672265B36E45787E1A4125575D28A07" translateForJs="false" rules="unique=WebPageType" notes="Must be unique amongst all &quot;WebPageType&quot; entries">Steruj strefami</TranslationEntry>
    <TranslationEntry name="FE1CE7FD8EBCB6A13D9637D3349971D8" translateForJs="false">Naciśnij GÓRA lub DÓŁ, aby wybrać strefę do sterowania</TranslationEntry>
    <TranslationEntry name="01BC55F7918066D7EBD1DE98DBFEF39A" translateForJs="false">Naciśnij ON, aby uzbroić (zabezpieczyć) i OFF, aby rozbroić (odblokować) strefę</TranslationEntry>
    <TranslationEntry name="77677D296B3581106881D3A2CEF69D7D" translateForJs="false">Naciśnij klawisze numeryczne, aby wyszukiwać strefy tekstowo</TranslationEntry>
    <TranslationEntry name="BF6569C3149F686CBE3BEEB9F62D6053" translateForJs="false">Naciśnij OK, aby wysłać</TranslationEntry>
    <TranslationEntry name="81D2CC08E2BA65C5FE2E6EC10154A5CB" translateForJs="false">Ręczna wiadomość testowa</TranslationEntry>
    <TranslationEntry name="F8FAAB5AA11E804C4F3489A93A5D53C0" translateForJs="false">Brak raportowania </TranslationEntry>
    <TranslationEntry name="537C34978A313515F24958D15943127E" translateForJs="false">Dostępne ścieżki</TranslationEntry>
    <TranslationEntry name="AF4E9459B18B2811C2D68F778D4E05F5" translateForJs="false">Wysłano do stacji monitorowania</TranslationEntry>
    <TranslationEntry name="C289EB268056543FE8FCF62E76D501E0" translateForJs="false">Test komunikacji</TranslationEntry>
    <TranslationEntry name="7589BCB4D0F3CEFB28C4D49950F08CD6" translateForJs="false">Testowanie komunikacji wysyła testowy komunikat do stacji monitorowania. Potwierdź, czy go odebrali.</TranslationEntry>
    <TranslationEntry name="BF3324C66080C0B764136797D841A2BC" fullContext="BF3324C66080C0B764136797D841A2BC" translateForJs="false">Linie wyjściowe</TranslationEntry>
    <TranslationEntry name="EFEA31143EC2ACD162C47D4A66F18E58" fullContext="EFEA31143EC2ACD162C47D4A66F18E58" translateForJs="false" rules="unique=WebPageType" notes="Must be unique amongst all &quot;WebPageType&quot; entries">Przejścia</TranslationEntry>
    <TranslationEntry name="7EB1F1BBAF31EA92B0C7272B2B363EE1" fullContext="7EB1F1BBAF31EA92B0C7272B2B363EE1" translateForJs="false" rules="unique=EntityChangeNotifications" notes="Must be unique amongst all &quot;EntityChangeNotifications&quot; entries">Strefy</TranslationEntry>
    <TranslationEntry name="EE611C8B9DFBBC792A9318C9837B2BCD" fullContext="EE611C8B9DFBBC792A9318C9837B2BCD" translateForJs="false">Linie wejściowe</TranslationEntry>
    <TranslationEntry name="A1595ABBB4C3A326636DD178757CD6C1" fullContext="A1595ABBB4C3A326636DD178757CD6C1" translateForJs="false" rules="unique=WebPageType" notes="Must be unique amongst all &quot;WebPageType&quot; entries">Sterowanie</TranslationEntry>
    <TranslationEntry name="5A468D71ECCBBD2D7339C32F91491B8D" translateForJs="false">Menu sterowania</TranslationEntry>
    <TranslationEntry name="A27A5CFA373A8F0A8749F138B9ACA868" translateForJs="false">Naciśnij cyfrę, aby wybrać typ elementów do sterowania</TranslationEntry>
    <TranslationEntry name="FCBC8294E4092838984D1F8FA629FBCE" translateForJs="false">Wyświetlaj stan i steruj liniami wyjściowymi. Można je włączać i wyłączać</TranslationEntry>
    <TranslationEntry name="BAC4CE887A49DF198D619DEB563347D2" translateForJs="false">Wyświetl stan i steruj przejściami. Można je odblokować, zablokować lub krótko odblokować</TranslationEntry>
    <TranslationEntry name="8AF8F2757083387CAEF7363737399558" translateForJs="false">Wyświetl stan i steruj strefami. Mogą być uzbrojone lub rozbrojone</TranslationEntry>
    <TranslationEntry name="515E9FF7AC32F33F063545E5F1572C51" translateForJs="false">Wyświetlaj stan i steruj liniami wejściowymi. Można je izolować lub odizolowywać</TranslationEntry>
    <TranslationEntry name="9680ABA0AFFC29AD1706C291EA76396C" fullContext="1D3A600D943D0FBD2A31F5C07AE102D8" translateForJs="false">Wszystkie przejścia</TranslationEntry>
    <TranslationEntry name="4CDD05964077F6B264333884A0A72F6A" translateForJs="false">Brak przejść</TranslationEntry>
    <TranslationEntry name="73D710D8079A9AF78E855328165EC20D" translateForJs="false">Brak skonfigurowanych przejść dla tego kontrolera</TranslationEntry>
    <TranslationEntry name="C4803D9185E26947FBF28227A0DE5DEB" translateForJs="false">Nie masz uprawnień do wyświetlania żadnych przejść w systemie.</TranslationEntry>
    <TranslationEntry name="9097CB0BBFA4BC61CCC7AC910881BB65" translateForJs="false">Jest </TranslationEntry>
    <TranslationEntry name="04E9328DE01908B60AA9A46FD912427E" translateForJs="true">Sterowanie nieudane</TranslationEntry>
    <TranslationEntry name="D182854844224DE8150D71A45F2FC221" translateForJs="false">Aktualne przejście:</TranslationEntry>
    <TranslationEntry name="819B93CC5DB3F5911D8A69EB68F2C9A8" translateForJs="false" rules="unique=WebPageType" notes="Must be unique amongst all &quot;WebPageType&quot; entries">Steruj przejściami</TranslationEntry>
    <TranslationEntry name="0CFCCFE96B0A529F597A209920434642" translateForJs="false">Naciśnij GÓRA lub DÓŁ, aby wybrać przejście do sterowania</TranslationEntry>
    <TranslationEntry name="CB19C255C171A80C9F4C4499FE11494D" translateForJs="false">Naciśnij ON, aby zablokować, OFF, aby odblokować i OK, aby uzyskać dostęp przez przejście</TranslationEntry>
    <TranslationEntry name="10CF53C5D3E3B572688BE4C15439C1EB" translateForJs="false">Naciśnij klawisze numeryczne, aby wyszukiwać przejście tekstowo</TranslationEntry>
    <TranslationEntry name="BB962098745177A4812DEB980C361DAE" translateForJs="false">Zezwól na dostęp użytkownika poziomu 3</TranslationEntry>
    <TranslationEntry name="8684B3872B24D6D65061E1251E79198A" translateForJs="false">Wprowadź anti-kod</TranslationEntry>
    <TranslationEntry name="D1BE377656960ED04F1564DA21D80C8D" translateForJs="false">Instalator</TranslationEntry>
    <TranslationEntry name="B1C94CA2FBC3E78FC30069C8D0F01680" translateForJs="false" rules="unique=ModuleHealthStates" notes="Must be unique amongst all &quot;ModuleHealthStates&quot; entries">Wszystkie</TranslationEntry>
    <TranslationEntry name="2FAE32629D4EF4FC6341F1751B405E45" fullContext="2FAE32629D4EF4FC6341F1751B405E45" translateForJs="false">Zabezpieczenia</TranslationEntry>
    <TranslationEntry name="BF733D8A933C1601697F364223FC7ECB" fullContext="BF733D8A933C1601697F364223FC7ECB" translateForJs="false">Dostęp</TranslationEntry>
    <TranslationEntry name="3C02A379965AB0DFCD77B1C484450433" fullContext="3C02A379965AB0DFCD77B1C484450433" translateForJs="false" rules="unique=WebPageType" notes="Must be unique amongst all &quot;WebPageType&quot; entries">Sprzęt</TranslationEntry>
    <TranslationEntry name="EDA63B570DB82E05C2FD7B5F0C3BB20F" fullContext="EDA63B570DB82E05C2FD7B5F0C3BB20F" translateForJs="false">Audyt</TranslationEntry>
    <TranslationEntry name="C20311CF04A93848BAA2C7DDDB3B2099" translateForJs="false">Dzienniki zdarzeń:</TranslationEntry>
    <TranslationEntry name="670A5DB972B8028369BC5A2EEDB1A6A0" translateForJs="false">Menu zdarzeń</TranslationEntry>
    <TranslationEntry name="4CB02E5EFB2414BB8511D54EE7C51DC7" translateForJs="false">Naciśnij cyfrę, aby wybrać typ zdarzeń do wyświetlenia</TranslationEntry>
    <TranslationEntry name="CFC4DFDE00425CD72719D90F1BD0DBEA" translateForJs="false">Wyświetl wszystkie zdarzenia</TranslationEntry>
    <TranslationEntry name="92CAE135A96DD93512FE1C03A92F0AC2" translateForJs="false">Przeglądaj komunikaty bezpieczeństwa, takie jak zdarzenia alarmowe</TranslationEntry>
    <TranslationEntry name="8385D9E25F939861C2C06BDE90DBD820" translateForJs="false">Przeglądaj komunikaty dostępu, takie jak żądania dostępu do przejścia</TranslationEntry>
    <TranslationEntry name="0EAAEFAAA475F4D8F4A3F38635EBF21E" translateForJs="false">Wyświetl komunikaty systemowe, takie jak aktualizacje połączeń i stan techniczny systemu</TranslationEntry>
    <TranslationEntry name="95065E35319AE84F8836DC533462FB5E" translateForJs="false">Wyświetl komunikaty sprzętowe, takie jak aktywność modułów i połączeń</TranslationEntry>
    <TranslationEntry name="B883AD83AFE7BA48961381CFE5FB8021" translateForJs="false">Wyświetl komunikaty audytu dotyczące zmian konfiguracji</TranslationEntry>
    <TranslationEntry name="4ACC5BC1D808688958A9D6BB8A7F6B9A" translateForJs="false">&lt; Osiągnięto koniec &gt;</TranslationEntry>
    <TranslationEntry name="8844596852700F8990660336F9A16B71" translateForJs="false">&lt; Brak nowości &gt;</TranslationEntry>
    <TranslationEntry name="115936A15ADE09A85E92DEACDABA3A87" translateForJs="false">&lt;Brak zdarzeń&gt;</TranslationEntry>
    <TranslationEntry name="87F9F735A1D36793CEAECD4E47124B63" translateForJs="false">Zdarzenia</TranslationEntry>
    <TranslationEntry name="69A570C97533FE0851A063994E8A4C1A" translateForJs="false">Naciśnij strzałkę GÓRA lub DÓŁ, aby przewijać zdarzenia</TranslationEntry>
    <TranslationEntry name="1A23A5DD4089B78B63B16DD9EE381E2E" translateForJs="false">Test łączności alarmowej</TranslationEntry>
    <TranslationEntry name="4D1E5BCE534173AE686D14DB5FD64978" translateForJs="false">Test ogólny</TranslationEntry>
    <TranslationEntry name="A671757B6AAFBEE3513BE7EA9DFDDD51" translateForJs="false">Menu ogólne</TranslationEntry>
    <TranslationEntry name="0D358A98031E8321D3FB1B59B2B19998" translateForJs="false">Testuj ścieżki komunikacji alarmowej do stacji monitorowania</TranslationEntry>
    <TranslationEntry name="709E2AA1A7E05C720ABFB4DC238DDEC8" translateForJs="false">Brak linii wejściowych</TranslationEntry>
    <TranslationEntry name="6D973CE6FFEE18D7DC3BF826A7633D46" translateForJs="false">W systemie nie skonfigurowano żadnych linii wejściowych</TranslationEntry>
    <TranslationEntry name="3E0E4D8A6DD4D6A2FD334B18BA34D1F2" translateForJs="false">Bieżąca linia wejściowa:</TranslationEntry>
    <TranslationEntry name="045402825CA824D9495E792CB8BE1A93" fullContext="045402825CA824D9495E792CB8BE1A93" translateForJs="false" rules="unique=WebPageType" notes="Must be unique amongst all &quot;WebPageType&quot; entries">Linie wejściowe sterujące</TranslationEntry>
    <TranslationEntry name="9BFA2ABD77CC77C6624505F54416A960" translateForJs="false">Naciśnij GÓRA lub DÓŁ, aby wybrać linię wejściową do sterowania</TranslationEntry>
    <TranslationEntry name="455F53102F7B708A7AB93F4E49FA2DDE" translateForJs="false">Naciśnij WŁ., aby odizolować, i WYŁ., aby zaizolować linię wejściową. Izolacja zatrzymuje monitorowanie linii wejściowej</TranslationEntry>
    <TranslationEntry name="14A208871B023B5C0360465B2AA18EAB" translateForJs="false">Naciśnij klawisze numeryczne, aby wyszukać linię wejściową</TranslationEntry>
    <TranslationEntry name="505A83F220C02DF2F85C3810CD9CEB38" translateForJs="false">Sukces</TranslationEntry>
    <TranslationEntry name="1FF9DC99AE5FBABC7FEE68A0A8BB05D7" translateForJs="false" rules="paramCheck=true" notes="This string contains special formatting parameters (e.g. &quot;{0}&quot;) that must be preserved in the translation">Pomyślnie wykonano kopię zapasową bazy danych do {0} na napędzie USB.</TranslationEntry>
    <TranslationEntry name="902B0D55FDDEF6F8D651FE1035B7D4BD" translateForJs="false">Błąd</TranslationEntry>
    <TranslationEntry name="4539BF0667C532A4336319474D05782F" translateForJs="false">Nie udało się wykonać kopii zapasowej bazy danych na dysk USB.</TranslationEntry>
    <TranslationEntry name="E7CD969A4E9D8C35911F6F1F86DD6071" translateForJs="false">Kopia zapasowa na dysk USB</TranslationEntry>
    <TranslationEntry name="0EE09E9A23A0ACD2613398CEDBEE11D0" translateForJs="false">Przywróć z dysku USB</TranslationEntry>
    <TranslationEntry name="E307DB07B3975FEF922A80D07455EE5E" translateForJs="false">Baza danych</TranslationEntry>
    <TranslationEntry name="0190157D9D8E3FCB57CECED29A43F2D8" translateForJs="false">Menu bazy danych</TranslationEntry>
    <TranslationEntry name="74C527E9AF10177E48728C39FD531698" translateForJs="false">Utwórz kopię zapasową bazy danych</TranslationEntry>
    <TranslationEntry name="4D215397F73ADB4DC55AF7417E2318AC" translateForJs="false">Utwórz kopię zapasową bazy danych na podłączonym napędzie USB</TranslationEntry>
    <TranslationEntry name="256B1E3E677D9101B25F7DC289FBCB65" translateForJs="false">Przywróć bazę danych</TranslationEntry>
    <TranslationEntry name="D3EBBDD1B43A996BE76967935C9D3C33" translateForJs="false">Wybierz kopię zapasową z podłączonego dysku USB i przywróć ją.</TranslationEntry>
    <TranslationEntry name="3DCCDB6467EE101EC9A4012C8A2DC420" translateForJs="false">Typ EOL linii wejściowej:</TranslationEntry>
    <TranslationEntry name="D10692729DB367C8E7B290BC2A362559" translateForJs="false">EOL linii wejściowej</TranslationEntry>
    <TranslationEntry name="0CADC358B9B683578AEE5959B33748F0" translateForJs="false">Naciśnij W GÓRĘ lub W DÓŁ, aby wybrać opcję EOL</TranslationEntry>
    <TranslationEntry name="59A220639B494F615C3921AECC2A7D61" translateForJs="false">Naciśnij OK, aby zapisać zmiany</TranslationEntry>
    <TranslationEntry name="20DFC4F904BA3C650A578C41F87E7053" translateForJs="false">Zlokalizuj</TranslationEntry>
    <TranslationEntry name="50B12AE4EC4B3843CB3D054D855CEFEE" translateForJs="false">Włącz/Wyłącz moduł</TranslationEntry>
    <TranslationEntry name="7BCB7A17693ADE79DEBE1EA6FACE4A99" fullContext="7BCB7A17693ADE79DEBE1EA6FACE4A99" translateForJs="false" rules="unique=SystemWarningType" notes="Must be unique amongst all &quot;SystemWarningType&quot; entries">Tryb serwisowy</TranslationEntry>
    <TranslationEntry name="F4F70727DC34561DFDE1A3C529B6205C" translateForJs="false">Ustawienia</TranslationEntry>
    <TranslationEntry name="A940A548BA41BC988F99D51FD02F21DE" translateForJs="false" rules="unique=FirmwareFileType" notes="Must be unique amongst all &quot;FirmwareFileType&quot; entries">Firmware</TranslationEntry>
    <TranslationEntry name="BC69210E7FE3AC592AE75D8B94A2EE04" translateForJs="false">LAN Secure</TranslationEntry>
    <TranslationEntry name="A47C8E587CB98FD1795F6D4C09F6AC79" translateForJs="false">Menu instalatora</TranslationEntry>
    <TranslationEntry name="7EA9D497CE998BA6AC36477D1EC3D48E" translateForJs="false">Włącz lub wyłącz tryb serwisowy, umożliwiając konserwację bez alarmów i sygnalizatorów</TranslationEntry>
    <TranslationEntry name="C4E75ECB5127E21EEBF5E8507B775B79" translateForJs="false">Zmień ustawienia EOL linii wejściowej</TranslationEntry>
    <TranslationEntry name="413585257FD2A697EF1D38006CFD4EA5" translateForJs="false">Utwórz kopię zapasową bazy danych na USB lub przywróć bazę danych z USB</TranslationEntry>
    <TranslationEntry name="6B57C8193BF71B9818408E839220A139" translateForJs="false">Przywróć kopię zapasową</TranslationEntry>
    <TranslationEntry name="15456C748E99EF98AADC06CB6A78D94F" translateForJs="false">Nie znaleziono plików na podłączonych dyskach USB</TranslationEntry>
    <TranslationEntry name="DD28D4F8746C03672A1A82BB3AD77A84" translateForJs="false">Pliki kopii zapasowej</TranslationEntry>
    <TranslationEntry name="79C4DB4790AD48DFA0CB0C653F134484" translateForJs="false">Potwierdź przywracanie</TranslationEntry>
    <TranslationEntry name="6A90CF50083234555EC7024C117724A5" translateForJs="false">Plik kopii zapasowej jest prawidłowy — kontynuować przywracanie bazy danych? Naciśnij OK, aby potwierdzić.</TranslationEntry>
    <TranslationEntry name="33136FF5FD86737C97C9BE1477CCC604" translateForJs="false">Kopiowanie nie powiodło się</TranslationEntry>
    <TranslationEntry name="E265EB2D15730F436D75A558C3F390A8" translateForJs="false">Nie można skopiować pliku kopii zapasowej bazy danych z dysku USB.</TranslationEntry>
    <TranslationEntry name="4ED8CBE49EE2E0C44D3CD73D10C70C65" translateForJs="false">Kopia zapasowa przywrócona</TranslationEntry>
    <TranslationEntry name="18E2A7E13852EE69D60D4EA19774DBD4" translateForJs="false">Pomyślnie przywrócono kopię zapasową bazy danych, trwa ponowne uruchamianie...</TranslationEntry>
    <TranslationEntry name="B7E6314930B897740594AA2AC8B26CB4" translateForJs="false">Przywracanie nieudane</TranslationEntry>
    <TranslationEntry name="68C64F87ACDDBACE24DED912E0980DD1" translateForJs="false">Nie udało się przywrócić kopii zapasowej bazy danych.</TranslationEntry>
    <TranslationEntry name="AA722FB1C4D5F81E91C1604994686FA2" translateForJs="false">Nieprawidłowy plik</TranslationEntry>
    <TranslationEntry name="E71FD5074E18D795F6A139583ADC54F4" translateForJs="false">Nie można zweryfikować pliku kopii zapasowej bazy danych.</TranslationEntry>
    <TranslationEntry name="AEFE37A3055253DD2E5730B39704525E" translateForJs="false">Naciśnij GÓRA lub DÓŁ, aby wybrać plik kopii zapasowej</TranslationEntry>
    <TranslationEntry name="28AB39D14D35A02A2808D30CFC540CCE" translateForJs="false">Naciśnij OK, aby przywrócić bazę danych. Spowoduje to nadpisanie bieżącej bazy danych</TranslationEntry>
    <TranslationEntry name="FCF1A05E61D24E49FA6424A35525E969" translateForJs="false">Menu ustawień</TranslationEntry>
    <TranslationEntry name="84A8921B25F505D0D2077AEB5DB4BC16" translateForJs="false">Statyczny</TranslationEntry>
    <TranslationEntry name="54201C55D2BDC7A9E19D9E032D8C0EDE" translateForJs="false">DHCP</TranslationEntry>
    <TranslationEntry name="6AEEE6CF5622B2D225F05C0972BAC5AE" translateForJs="false">Typ adresu IP</TranslationEntry>
    <TranslationEntry name="3121F87028DEC8876ED6EB73A44F2A80" translateForJs="false">Adres MAC</TranslationEntry>
    <TranslationEntry name="9E90ACA73A60F2C41EA33B45CC0D70CB" translateForJs="false">Nie można zapisać:</TranslationEntry>
    <TranslationEntry name="9A05EC199C1A0F922CCB6ED3FE4DE7A4" translateForJs="false">Nieprawidłowy adres</TranslationEntry>
    <TranslationEntry name="520D0DB389F362BF79EF56CA0AF3DCAB" fullContext="520D0DB389F362BF79EF56CA0AF3DCAB" translateForJs="false">Format</TranslationEntry>
    <TranslationEntry name="5B8C99DAD1893A85076709B2D3C2D2D0" translateForJs="false">Adres IP</TranslationEntry>
    <TranslationEntry name="3026B7B5E76CC48EE8B22F6052A65E95" translateForJs="false">Maska podsieci</TranslationEntry>
    <TranslationEntry name="926DEC9494209CB088B4962509DF1A91" translateForJs="false">Brama</TranslationEntry>
    <TranslationEntry name="7F9D745C9065D9274273797BBCE68861" translateForJs="false">Serwer DNS</TranslationEntry>
    <TranslationEntry name="88183B946CC5F0E8C96B2E66E1C74A7E" fullContext="88183B946CC5F0E8C96B2E66E1C74A7E" translateForJs="true" rules="unique=IntruderInputStates" notes="Must be unique amongst all &quot;IntruderInputStates&quot; entries">Nieznany</TranslationEntry>
    <TranslationEntry name="97BA4C484A0BB9E0E45E0C7533F96CB7" fullContext="97BA4C484A0BB9E0E45E0C7533F96CB7" translateForJs="false" rules="unique=EntityChangeNotifications" notes="Must be unique amongst all &quot;EntityChangeNotifications&quot; entries">Ustawienia sieciowe</TranslationEntry>
    <TranslationEntry name="B40C7996DDEB19C2CCA57DB169486225" translateForJs="false">Naciśnij GÓRĘ lub DÓŁ, aby wyświetlić opcje sieciowe. </TranslationEntry>
    <TranslationEntry name="B6CCAFB89D88A8083654535B6B951DB5" translateForJs="false">Ustaw typ adresu na Statyczny, aby edytować ustawienia, lub DHCP dla automatycznego przydziału</TranslationEntry>
    <TranslationEntry name="6EC9D8F85B20ED89E8CD42F73A4D1394" translateForJs="false">Wybierz element</TranslationEntry>
    <TranslationEntry name="5F45CC912A524225EE271E9C454C0A67" translateForJs="false">Wyszukiwanie elementów</TranslationEntry>
    <TranslationEntry name="24BD9263CB4B8ED1A071BDF339918696" translateForJs="false">Naciśnij cyfrę, aby rozpocząć wyszukiwanie alfanumeryczne</TranslationEntry>
    <TranslationEntry name="4842E4975B52C48F8815D70C916C89F0" translateForJs="false">Naciśnij GÓRA lub DÓŁ, aby znaleźć element</TranslationEntry>
    <TranslationEntry name="7256A726A458F6919F1D7939B9C694BD" translateForJs="false">Naciśnij OK, aby wybrać bieżący element</TranslationEntry>
    <TranslationEntry name="7D5A22AC7328ECD1004AFFBB2B319CA9" translateForJs="false">[Brak elementów]</TranslationEntry>
    <TranslationEntry name="BC45FA11ABF63BF759F9BF922393691F" translateForJs="false">Szukaj...</TranslationEntry>
    <TranslationEntry name="DC770A451931E3EB28348451A1EF9896" translateForJs="false">Wyszukiwanie tekstowe</TranslationEntry>
    <TranslationEntry name="B49001CB2A9CD8E948FCBB379FE10E15" translateForJs="false">Naciśnij przyciski numeryczne, aby zmieniać litery. Naciśnij OFF, aby wyczyścić ekran.</TranslationEntry>
    <TranslationEntry name="0F04C3B5ED84822260BF23B12917C9A2" translateForJs="false">Przesuń kursor strzałkami, jeśli wymagane</TranslationEntry>
    <TranslationEntry name="4C34A1785338D981528B3B834FE913DA" translateForJs="false">Naciśnij OK, aby filtrować elementy</TranslationEntry>
    <TranslationEntry name="FE1CA7857D8AE62C2D330A30587C9411" translateForJs="false">Zabezpiecz LAN</TranslationEntry>
    <TranslationEntry name="10DBFC6C3CD7BB3CBA926969122DAEA2" translateForJs="false">Czy na pewno chcesz zabezpieczyć LAN? Naciśnij OK, aby potwierdzić.</TranslationEntry>
    <TranslationEntry name="A0CB17D5B5D6BB4DEC16CDC16886140E" translateForJs="false">Zakończono zabezpieczanie</TranslationEntry>
    <TranslationEntry name="BF66A09A8E37DDA8EC624580A959B740" translateForJs="false">LAN został zabezpieczony</TranslationEntry>
    <TranslationEntry name="E404DD0BECE5F7C53D80EDAA70513EEC" fullContext="10B11D11E2C90CA0ACA6C19345D6C80E" translateForJs="false" rules="unique=TerminalLoginPreference" notes="Must be unique amongst all &quot;TerminalLoginPreference&quot; entries">Menu główne</TranslationEntry>
    <TranslationEntry name="54524330F111A77A67402154853A5DEF" fullContext="9925D706FAAEE008FFE8C244ED84D225" translateForJs="false" rules="unique=TerminalLoginPreference" notes="Must be unique amongst all &quot;TerminalLoginPreference&quot; entries">Sterowanie strefą</TranslationEntry>
    <TranslationEntry name="29A66FEC952B288338AA69929301488E" translateForJs="false">Przeglądaj stan i steruj strefami</TranslationEntry>
    <TranslationEntry name="B59387E4D62A4E3FE4285A1311DCD272" translateForJs="false">Dziennik zdarzeń</TranslationEntry>
    <TranslationEntry name="8EF5F4944D31BBC7AD289006D574F314" translateForJs="false">Wyświetl historię zdarzeń systemu</TranslationEntry>
    <TranslationEntry name="F9AAE5FDA8D810A29F12D1E61B4AB25F" fullContext="F9AAE5FDA8D810A29F12D1E61B4AB25F" translateForJs="false" rules="unique=EntityChangeNotifications" notes="Must be unique amongst all &quot;EntityChangeNotifications&quot; entries">Użytkownicy</TranslationEntry>
    <TranslationEntry name="220CEF4F20BA8849F710019D20E0CF73" translateForJs="false">Edytuj numer PIN użytkownika</TranslationEntry>
    <TranslationEntry name="3C50FA1057747CF15E5CEDA8F56901CA" translateForJs="false">Steruj strefami, przejściami, liniami wyjściowymi i wejściowymi</TranslationEntry>
    <TranslationEntry name="E0D956BFACBC6536CEB2E8FEF1356B19" translateForJs="false">Wyświetl informacje o systemie, ustawienia sieci, ustawienia Wi-Fi i zresetuj tryb hotspot Wi-Fi</TranslationEntry>
    <TranslationEntry name="9E0E9E9C03222260A34BF7D63ACCB056" translateForJs="false">Uzyskaj dostęp do opcji instalatora, takich jak tryb serwisowy, opcje bazy danych i oprogramowania firmowego</TranslationEntry>
    <TranslationEntry name="AA85F1840E282D8A8304DBC2C0D7C9B2" translateForJs="false">EN</TranslationEntry>
    <TranslationEntry name="F390F638FBADB2A0EC02DBC268B93001" translateForJs="false">Menu główne:</TranslationEntry>
    <TranslationEntry name="8D88A2CADAEDC203A46299F737FD663F" translateForJs="false">Brak linii wyjściowych</TranslationEntry>
    <TranslationEntry name="FD04A4CF1DAC561E174AECAA2BF6A5C5" translateForJs="false">Brak skonfigurowanych linii wyjściowych dla sterowania przez użytkownika</TranslationEntry>
    <TranslationEntry name="CAF6616C8BEA1C9DBA7AB7C494445945" translateForJs="false">Nie masz uprawnień do wyświetlania żadnych linii wyjściowych w systemie.</TranslationEntry>
    <TranslationEntry name="BCB1BEE74A8014CB7618209EB21CA86C" translateForJs="false" rules="paramCheck=true" notes="This string contains special formatting parameters (e.g. &quot;{0}&quot;) that must be preserved in the translation">Dla: {0} {1}</TranslationEntry>
    <TranslationEntry name="D0B47037244E11E4F2B0168A1F962920" translateForJs="false">Bieżąca linia wyjściowa:</TranslationEntry>
    <TranslationEntry name="6375C88DADDEE50AF4401A442FD40298" translateForJs="false" rules="unique=WebPageType" notes="Must be unique amongst all &quot;WebPageType&quot; entries">Sterowanie liniami wyjściowymi</TranslationEntry>
    <TranslationEntry name="6E064F3ECF4733E718CFBA5C2257A4FF" translateForJs="false">Naciśnij GÓRA lub DÓŁ, aby wybrać linię wyjściową do sterowania</TranslationEntry>
    <TranslationEntry name="F797B0804C7AB79CBCF46F018DA79524" translateForJs="false">Naciśnij LEWO lub PRAWO, aby wybrać sterowanie czasowe linią wyjściową</TranslationEntry>
    <TranslationEntry name="3D5F3C1EE4828BDB19B11DAD822F759D" translateForJs="false">Naciśnij ON, aby włączyć, i OFF, aby wyłączyć linię wyjściową</TranslationEntry>
    <TranslationEntry name="5CFE8FA40C9234D02FC1C9A18AF24F9D" translateForJs="false">Naciśnij klawisze numeryczne, aby wyszukać linię wyjściową tekstowo</TranslationEntry>
    <TranslationEntry name="92D9E3B58A94E6FC241BDADC1D447482" translateForJs="false">Resetuj hotspot</TranslationEntry>
    <TranslationEntry name="8EEE8A87DBFAA8FD8F0C5D604B728C78" translateForJs="false">Czy na pewno chcesz zresetować ustawienia Wi-Fi do domyślnych? Naciśnij OK, aby potwierdzić.</TranslationEntry>
    <TranslationEntry name="77C4747847B182CC01CFBD2842E29F23" translateForJs="false">Resetowanie zakończone</TranslationEntry>
    <TranslationEntry name="D8BFF6B2B03254A16AF27A0565C9C1A4" translateForJs="false">Punkt dostępowy Wi-Fi został zresetowany</TranslationEntry>
    <TranslationEntry name="8A21AB7EF8DF2D22206E960680E94808" translateForJs="false">Resetuj WiFi</TranslationEntry>
    <TranslationEntry name="30FCFBB8B6913D5CFA2E82D93EEF6522" translateForJs="false">Naciśnij OK, aby zresetować ustawienia WiFi do trybu hotspotu.</TranslationEntry>
    <TranslationEntry name="7A3E81B15BF6A5F36D3CD4C2C25CBAAF" translateForJs="false">Hasło to 'inception', SSID to</TranslationEntry>
    <TranslationEntry name="EBCD6554A52FD8D106685F6D8E8D0AAE" translateForJs="false">Tryb serwisowy:</TranslationEntry>
    <TranslationEntry name="441F2B7ACBEF258A5019061874A17FDE" translateForJs="false">Naciśnij WŁ., aby włączyć, i WYŁ., aby wyłączyć tryb serwisowy</TranslationEntry>
    <TranslationEntry name="E52E386CDDDF245AC45F6634956B2A3C" translateForJs="false">Tryb serwisowy trwa 8 godzin i wyłącza sygnalizatory oraz raportowanie alarmów</TranslationEntry>
    <TranslationEntry name="8F8BB20031F4E802D79980B675B8EFEE" fullContext="8F8BB20031F4E802D79980B675B8EFEE" translateForJs="false" rules="unique=LinuxResetReason" notes="Must be unique amongst all &quot;LinuxResetReason&quot; entries">Aktualizacja firmware</TranslationEntry>
    <TranslationEntry name="C21663248C456ADD5B4601C205C5BDCF" translateForJs="false">Nie znaleziono plików firmware Inception na podłączonych nośnikach USB.</TranslationEntry>
    <TranslationEntry name="38CB30607AEADF3F4C7D4F422EE2DE9A" translateForJs="false">Potwierdź aktualizację</TranslationEntry>
    <TranslationEntry name="0BE068B96D0B3868EF972F7CA52C7933" translateForJs="false">Czy na pewno chcesz zaktualizować firmware? Naciśnij OK, aby potwierdzić.</TranslationEntry>
    <TranslationEntry name="3331C1377D2AE458BB8C491A8D021197" translateForJs="false">Aktualizowanie firmware</TranslationEntry>
    <TranslationEntry name="254373EBF57799FF674ED77A933960A6" translateForJs="false">Aktualizacja firmware w toku, proszę czekać...</TranslationEntry>
    <TranslationEntry name="328FBAFC2D6DABE23F742A1D62EBB498" translateForJs="false">OSTRZEŻENIE: Aktualizacja do tej wersji firmware wymaga przywrócenia ustawień fabrycznych. Czy na pewno chcesz kontynuować? Naciśnij OK, aby potwierdzić.</TranslationEntry>
    <TranslationEntry name="ED6C3A745745D702833C9C6D6A052BCD" translateForJs="false">Aktualizacja nie powiodła się</TranslationEntry>
    <TranslationEntry name="8BB3E4E8F87174C762EB2D8F6EE66A77" translateForJs="false">Aktualizacja zakończona pomyślnie</TranslationEntry>
    <TranslationEntry name="B1FDF4344B3A8A997C9BDF08F1E2D4B1" translateForJs="false">activityResponse.Text</TranslationEntry>
    <TranslationEntry name="B140558D965668ADF351641ADEC6AC93" translateForJs="false">Aktualizacja F/W</TranslationEntry>
    <TranslationEntry name="FEFD47E4C4D5C8A0E0B1E9287F59A44F" translateForJs="false">Naciśnij GÓRA lub DÓŁ, aby wybrać plik firmware</TranslationEntry>
    <TranslationEntry name="DD6B1D5DCA2C28A6ECA527175F527817" translateForJs="false">Naciśnij OK, aby wybrać plik, i OK ponownie, aby potwierdzić aktualizację firmware</TranslationEntry>
    <TranslationEntry name="7C20F7277ACC30C8A5E4B4487E56FEB7" translateForJs="false">Wer. FW aplikacji:</TranslationEntry>
    <TranslationEntry name="6914432FFE6D6BFC189A167CE0A51120" translateForJs="false">Wersja firmware podstawowa:</TranslationEntry>
    <TranslationEntry name="3A49B35DE2DFBA1132FAF90A50D6D6B2" translateForJs="false">Wersja PCB:</TranslationEntry>
    <TranslationEntry name="DE2655A2DF3064BCCDC23FF64CFD15AC" translateForJs="false">Wariant produktu:</TranslationEntry>
    <TranslationEntry name="47D8EE65BA107916B5A5D0C1697DFAB3" translateForJs="false">Informacje o systemie</TranslationEntry>
    <TranslationEntry name="CC87F651C564CD2F3FD10499FB762EEE" translateForJs="false">Naciśnij GÓRĘ lub DÓŁ, aby wyświetlić informacje o systemie.</TranslationEntry>
    <TranslationEntry name="00019A80A771C3A36BEF326520E489B0" translateForJs="false">Ustawienia Wi-Fi</TranslationEntry>
    <TranslationEntry name="E56118E5CF366B3DAC06B2C7937FEE27" translateForJs="false">Resetuj hotspot Wi-Fi</TranslationEntry>
    <TranslationEntry name="6EA37CCFA67E5F6FEDE19E90CEF494C4" translateForJs="false">Menu systemu</TranslationEntry>
    <TranslationEntry name="4099110B7F1C826E3BB3A5CB521149E8" translateForJs="false">Wyświetl numer seryjny i informacje o firmware</TranslationEntry>
    <TranslationEntry name="EEC89088EE408B80387155272B113256" translateForJs="false" rules="unique=WebPageType" notes="Must be unique amongst all &quot;WebPageType&quot; entries">Sieć</TranslationEntry>
    <TranslationEntry name="8B4F87EB3DB3C314CAE458F3B628411F" translateForJs="false">Wyświetl i zmień ustawienia sieci Ethernet</TranslationEntry>
    <TranslationEntry name="62278F1F66C302E03838F97E8FCD23F1" translateForJs="false">Ustawienia WiFi</TranslationEntry>
    <TranslationEntry name="4F051E85267E76882A4E667B1D0A7443" translateForJs="false">Wyświetl ustawienia WiFi</TranslationEntry>
    <TranslationEntry name="83E164FE61406B38CED183E15C36AB7E" translateForJs="false">Włącz ponownie tryb punktu dostępowego Wi-Fi i przywróć domyślną konfigurację</TranslationEntry>
    <TranslationEntry name="C523417B0B88EE941A1AC4316ACCB792" translateForJs="false">Komunikaty </TranslationEntry>
    <TranslationEntry name="E25D5B2BBC8909B709B9EC74E3745E48" translateForJs="false">Ostrzeżenia </TranslationEntry>
    <TranslationEntry name="34372DA62F702B21CE458BB0FE1CD0F9" translateForJs="false">Zdarzenia sys.:</TranslationEntry>
    <TranslationEntry name="43CA341A1075847665CE0CFDE6E335B4" translateForJs="false">Naciśnij OK, aby</TranslationEntry>
    <TranslationEntry name="8D23D3D3E635960F43CABD19079AFE15" translateForJs="false">potwierdź wszystkie komunikaty</TranslationEntry>
    <TranslationEntry name="527B5DD477ABF95E8FE19AAC201DF396" translateForJs="false">Potwierdzenie</TranslationEntry>
    <TranslationEntry name="830BD0B89A0F8A75D755634F1EFEEA1D" translateForJs="false" rules="paramCheck=true" notes="This string contains special formatting parameters (e.g. &quot;{0}&quot;) that must be preserved in the translation">nie powiodło się — komunikat wymaga użytkownika poziomu {0} do skasowania</TranslationEntry>
    <TranslationEntry name="9ABCC61041095D164C3F3419E5A29F4A" translateForJs="false">Potwierdzony</TranslationEntry>
    <TranslationEntry name="991A54A9510953D2B67984737146E1E7" translateForJs="false" rules="paramCheck=true" notes="This string contains special formatting parameters (e.g. &quot;{0}&quot;) that must be preserved in the translation">{0} z {1} komunikatów. Pozostałe komunikaty wymagają użytkownika poziomu {2} do skasowania</TranslationEntry>
    <TranslationEntry name="E5C14212D4BAA2A4FDDE658FF06EE842" translateForJs="false">Zdarzenia systemowe</TranslationEntry>
    <TranslationEntry name="5AB7332D3F7B678F45AA552CDBDF99D8" translateForJs="false">Naciśnij PRAWO, aby przełączyć na ostrzeżenia systemowe</TranslationEntry>
    <TranslationEntry name="A7A08765FAC721C19938545485977661" translateForJs="false">Naciśnij GÓRA lub DÓŁ, aby wyświetlić komunikaty</TranslationEntry>
    <TranslationEntry name="0F417097F3D6DFBD698CFAB105F44832" translateForJs="false">Naciśnij OK, aby potwierdzić i usunąć komunikat</TranslationEntry>
    <TranslationEntry name="25418C7308FD9F97E809A4FC62BA7629" translateForJs="false">Aby potwierdzić wszystkie komunikaty, naciśnij GÓRA, aż wyświetlony zostanie ekran górny, a następnie naciśnij OK</TranslationEntry>
    <TranslationEntry name="F388CAA0742445B45771CC08590D3F7B" translateForJs="false">Naciśnij LEWO, aby przełączyć na komunikaty systemowe</TranslationEntry>
    <TranslationEntry name="3F34DDBA39D6EAFAEAD6D2748A329903" translateForJs="false">Naciśnij GÓRA lub DÓŁ, aby wyświetlić ostrzeżenia</TranslationEntry>
    <TranslationEntry name="8B070E820371941BA66A428A74244659" translateForJs="false">Nie można użyć</TranslationEntry>
    <TranslationEntry name="0FD36A32B8E4249C838201EDF04F5084" translateForJs="false">skrót sterowania strefą, sprawdź profil terminala</TranslationEntry>
    <TranslationEntry name="2A3525F0B5A59D834802BF785C29DB97" fullContext="11228401AB59FA63A344DB2A532A031D" translateForJs="false" rules="unique=OSDPPresetControl" notes="Must be unique amongst all &quot;OSDPPresetControl&quot; entries">Drzwi przytrzymane otwarte</TranslationEntry>
    <TranslationEntry name="9E9B71914A5C8301F06EAD73E6BF4C78" translateForJs="false">Naciśnij OK, aby wyciszyć</TranslationEntry>
    <TranslationEntry name="18819BFCAD5F6EF4D34A70C20E2DB2C3" translateForJs="false">Powitania</TranslationEntry>
    <TranslationEntry name="8F9BFE9D1345237CB3B2B205864DA075" fullContext="8F9BFE9D1345237CB3B2B205864DA075" translateForJs="false">Użytkownik</TranslationEntry>
    <TranslationEntry name="909B1162D8894C0A872A5A84B3C19E0B" translateForJs="false">Strona pod</TranslationEntry>
    <TranslationEntry name="A9D670CBD3DE5E269D1651902F6EF31E" translateForJs="false">Programistyczny!</TranslationEntry>
    <TranslationEntry name="739B65A6698FF53AB0F6D0705A9AAF8B" translateForJs="false">Ustaw nowy PIN:</TranslationEntry>
    <TranslationEntry name="D12E69290D015B063262CB702A526C0C" translateForJs="false">Potwierdź nowy PIN:</TranslationEntry>
    <TranslationEntry name="B7583B3167559646D91A11BC75EA68B5" translateForJs="false">PIN użytkownika</TranslationEntry>
    <TranslationEntry name="820DBD2B8F606AFF866C0BBFB6B737C1" translateForJs="false">Zmieniono</TranslationEntry>
    <TranslationEntry name="3E3214BA81355C348BDB653AFDEFB006" translateForJs="false">Potwierdzenie nie powiodło się — kody PIN nie są zgodne</TranslationEntry>
    <TranslationEntry name="80350C1422E106BAD99CDC1B2CBF2172" translateForJs="false">Nieprawidłowy PIN:</TranslationEntry>
    <TranslationEntry name="2F3BFFF30E4D5AAF85A6F0A694F67B6D" translateForJs="false">Zmiana PIN</TranslationEntry>
    <TranslationEntry name="EDFA843C9A2F57B9FFBF8062A01890E1" translateForJs="false">Wpisz nowy PIN i naciśnij OK, aby potwierdzić. Strzałki można używać do przesuwania kursora, a OFF czyści ekran</TranslationEntry>
    <TranslationEntry name="D6049E410E52B24CDDF07B0B9FCBB123" translateForJs="false">Zmień PIN</TranslationEntry>
    <TranslationEntry name="367B4D428567E981F4CEF715419CDCB0" translateForJs="false">Konserwacja użytkowników</TranslationEntry>
    <TranslationEntry name="7FA3FCC6D772FB8F49A7C8B4A9C94B56" translateForJs="false">Menu użytkowników</TranslationEntry>
    <TranslationEntry name="BBF5861C9442A9D9DB7F69F94E8B063A" translateForJs="false">Zmień swój numer PIN</TranslationEntry>
    <TranslationEntry name="7330CE3ED9D7073BCC25D8E23DA6DB9C" translateForJs="false">Prawidłowy kod antypowrotny:</TranslationEntry>
    <TranslationEntry name="8CCC77FC72C17A09D0C6C43CBFA9AFCF" translateForJs="false">Przyznano uprawnienia anti-code.</TranslationEntry>
    <TranslationEntry name="883F533DF04D2DD8BE37E5A16A02116E" translateForJs="false">Nieprawidłowy anti-kod</TranslationEntry>
    <TranslationEntry name="E16175135FD9C89D546B8C16F051C861" translateForJs="false">Sprawdź, czy kod jest prawidłowy, i spróbuj ponownie.</TranslationEntry>
    <TranslationEntry name="9DBBA86B9CC93E6601F7E4A5946D0EF9" fullContext="9DBBA86B9CC93E6601F7E4A5946D0EF9" translateForJs="false">Status Wi-Fi</TranslationEntry>
    <TranslationEntry name="82A69D389BD0D345C7EB084C9B4324E3" translateForJs="false">Klient (Enterprise)</TranslationEntry>
    <TranslationEntry name="E5E44BA6FBFAA134BA542DF232748D74" translateForJs="false">Klient (osobisty)</TranslationEntry>
    <TranslationEntry name="F5CA5DD25881530EC3A465ED7DED8D24" translateForJs="false">Hotspot</TranslationEntry>
    <TranslationEntry name="D8194E06B28BE2CA7A8EA8EF53E1275F" translateForJs="false">Tryb Wi-Fi</TranslationEntry>
    <TranslationEntry name="B2E6DE83DEF6532B9431F86C50E4E360" translateForJs="false">Nazwa SSID</TranslationEntry>
    <TranslationEntry name="E4F3D9BAAA824CE9B4D4BF9150DB9E93" translateForJs="false">Adres MAC WiFi</TranslationEntry>
    <TranslationEntry name="3ACA704015AC34E43180CD1A3AEA7CCB" translateForJs="false">Włącz lub wyłącz WiFi jeśli to konieczne. Edytowanie innych ustawień musi być wykonane z interfejsu WWW</TranslationEntry>
    <TranslationEntry name="0DB8D5A2CCF3B51238461D6182037CBA" translateForJs="false" rules="unique=LinuxResetReason" notes="Must be unique amongst all &quot;LinuxResetReason&quot; entries">Włączenie zasilania (brak AC)</TranslationEntry>
    <TranslationEntry name="5364ECBAAD2EF6905754DA1BE27D204F" translateForJs="false" rules="unique=LinuxResetReason" notes="Must be unique amongst all &quot;LinuxResetReason&quot; entries">Przywracanie bazy danych</TranslationEntry>
    <TranslationEntry name="14B8D826F6E4334918D4265CD8E3B2F7" translateForJs="false" rules="unique=LinuxResetReason" notes="Must be unique amongst all &quot;LinuxResetReason&quot; entries">Restart watchdog</TranslationEntry>
    <TranslationEntry name="ACBC492548FF610FDBD07E9D14FFF4EA" translateForJs="false" rules="unique=LinuxResetReason" notes="Must be unique amongst all &quot;LinuxResetReason&quot; entries">Przycisk resetowania</TranslationEntry>
    <TranslationEntry name="14704CDB447DE2686E77AC519A37BBAA" translateForJs="false" rules="unique=LinuxResetReason" notes="Must be unique amongst all &quot;LinuxResetReason&quot; entries">Przycisk resetowania (resetowanie hasła instalatora)</TranslationEntry>
    <TranslationEntry name="FB83A625E5852C1BA47FE358F2D50FFC" fullContext="FB83A625E5852C1BA47FE358F2D50FFC" translateForJs="false" rules="unique=LinuxResetReason" notes="Must be unique amongst all &quot;LinuxResetReason&quot; entries">Ustawienia fabryczne</TranslationEntry>
