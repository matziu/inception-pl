    <TranslationEntry name="168909C0B6F1DFBD48F679D47059C1D6" translateForJs="false" rules="unique=CalculatedWeek" notes="Must be unique amongst all &quot;CalculatedWeek&quot; entries">Trzeci</TranslationEntry>
