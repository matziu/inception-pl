    <TranslationEntry name="14C3AD941726EA2F8A9E984EE6B4B456" translateForJs="false" rules="unique=WebPageType" notes="Must be unique amongst all &quot;WebPageType&quot; entries">Sterowanie licznikami</TranslationEntry>
    <TranslationEntry name="8E72DA3DA6587F1EC5A8166F29568EE9" translateForJs="false" rules="unique=WebPageType" notes="Must be unique amongst all &quot;WebPageType&quot; entries">Szukaj użytkowników</TranslationEntry>
    <TranslationEntry name="8EC274D22F143CD02DB2CBADF23E12D0" translateForJs="false" rules="unique=WebPageType" notes="Must be unique amongst all &quot;WebPageType&quot; entries">Rejestracja uwierzytelniania dwuskładnikowego (2FA)</TranslationEntry>
    <TranslationEntry name="31A12D4C37D8CA48CB66251670EB0E94" translateForJs="false" rules="unique=WebPageType" notes="Must be unique amongst all &quot;WebPageType&quot; entries">Dokumentacja API kontrolera</TranslationEntry>
    <TranslationEntry name="254F642527B45BC260048E30704EDB39" fullContext="254F642527B45BC260048E30704EDB39" translateForJs="false" rules="unique=WebPageType" notes="Must be unique amongst all &quot;WebPageType&quot; entries">Konfiguracja</TranslationEntry>
    <TranslationEntry name="9B9AF2E951F8EA63B057FA97C0B4EC3C" translateForJs="false" rules="unique=WebPageType" notes="Must be unique amongst all &quot;WebPageType&quot; entries">Modele danych</TranslationEntry>
    <TranslationEntry name="9D5EE35570EBEBEF4E554C146F535EA4" translateForJs="false" rules="unique=WebPageType" notes="Must be unique amongst all &quot;WebPageType&quot; entries">Dokumentacja modelu API</TranslationEntry>
    <TranslationEntry name="D95867DEADFE690E40F42068D6B59DF8" translateForJs="false" rules="unique=WebPageType" notes="Must be unique amongst all &quot;WebPageType&quot; entries">Odwołania</TranslationEntry>
    <TranslationEntry name="846E11181E0D82CD970C52D1A157C40F" translateForJs="false" rules="unique=WebPageType" notes="Must be unique amongst all &quot;WebPageType&quot; entries">Umowa licencyjna użytkownika końcowego (EULA)</TranslationEntry>
    <TranslationEntry name="8F1E77E0D2BE21DA93CD4D9A939148F7" fullContext="8F1E77E0D2BE21DA93CD4D9A939148F7" translateForJs="false" rules="unique=WebPageType" notes="Must be unique amongst all &quot;WebPageType&quot; entries">Zmień hasło</TranslationEntry>
    <TranslationEntry name="999FD2DB319B4339BF75FF30A5ED3628" translateForJs="false" rules="unique=WebPageType" notes="Must be unique amongst all &quot;WebPageType&quot; entries">Konfiguruj dane instalatora</TranslationEntry>
    <TranslationEntry name="40AB05D464F828E05C3A4C0DB9476ABE" translateForJs="false" rules="unique=WebPageType" notes="Must be unique amongst all &quot;WebPageType&quot; entries">Szczegóły API</TranslationEntry>
    <TranslationEntry name="C00CE527D17F6857CB94BA6FDFE2C04F" fullContext="C00CE527D17F6857CB94BA6FDFE2C04F" translateForJs="false" rules="unique=WebPageType" notes="Must be unique amongst all &quot;WebPageType&quot; entries">Jednostki (boksy)</TranslationEntry>
    <TranslationEntry name="44A1FBD662D106B5D2D483A67A45215E" fullContext="44A1FBD662D106B5D2D483A67A45215E" translateForJs="false" rules="unique=WebPageType" notes="Must be unique amongst all &quot;WebPageType&quot; entries">Bloki pamięci masowej</TranslationEntry>
    <TranslationEntry name="339AEAE135DD029C145819A314A2B269" translateForJs="false" rules="unique=WebPageType" notes="Must be unique amongst all &quot;WebPageType&quot; entries">Steruj jednostkami (boksami)</TranslationEntry>
    <TranslationEntry name="9337AD7DF029D6386C17EA026C7E12FE" fullContext="9337AD7DF029D6386C17EA026C7E12FE" translateForJs="false" rules="unique=WebPageType" notes="Must be unique amongst all &quot;WebPageType&quot; entries">Konfiguracja wstępna</TranslationEntry>
    <TranslationEntry name="E8958C71A506BF5D226FD213685CAE6E" fullContext="E8958C71A506BF5D226FD213685CAE6E" translateForJs="false" rules="unique=WebPageType" notes="Must be unique amongst all &quot;WebPageType&quot; entries">Ustawienia połączenia Mobile Access</TranslationEntry>
    <TranslationEntry name="A9F7323ECABEAAEB3DA98DE6E283DACE" fullContext="2174E64D0428A91044C43BBA50EC3970" translateForJs="false" rules="unique=WebPageType" notes="Must be unique amongst all &quot;WebPageType&quot; entries">Mobilne identyfikatory</TranslationEntry>
    <TranslationEntry name="0B9C6EEF4E3D3A222EB04E910D252339" fullContext="0B9C6EEF4E3D3A222EB04E910D252339" translateForJs="false" rules="unique=WebPageType" notes="Must be unique amongst all &quot;WebPageType&quot; entries">Licencjonowanie</TranslationEntry>
    <TranslationEntry name="5BED4154C416F69E29AF1439B88E79BC" translateForJs="false" rules="unique=WebPageType" notes="Must be unique amongst all &quot;WebPageType&quot; entries">Narzędzia testowe</TranslationEntry>
    <TranslationEntry name="2D571F39A4FB0F1A18BA6D69B74B4D7D" translateForJs="false" rules="unique=WebPageType" notes="Must be unique amongst all &quot;WebPageType&quot; entries">Zarządzanie integracją</TranslationEntry>
    <TranslationEntry name="E2463CB9309D2EB80790D05EF2A624E0" fullContext="D7F4947903481A6EED59F509C51A2019" translateForJs="false" rules="unique=WebPageType" notes="Must be unique amongst all &quot;WebPageType&quot; entries">Kamery</TranslationEntry>
    <TranslationEntry name="1C44BC9B2E185AFEB2B00F9355801BCD" translateForJs="true" rules="unique=WebPageType" notes="Must be unique amongst all &quot;WebPageType&quot; entries">NVR</TranslationEntry>
    <TranslationEntry name="B02B5D47D1092651A92B057363798101" translateForJs="false" rules="unique=WebPageType" notes="Must be unique amongst all &quot;WebPageType&quot; entries">Sterowanie kamerami</TranslationEntry>
    <TranslationEntry name="969879B610FC3089269153B17607BE86" translateForJs="false" rules="unique=WebPageType" notes="Must be unique amongst all &quot;WebPageType&quot; entries">Wyświetl urządzenia bezprzewodowe</TranslationEntry>
    <TranslationEntry name="AB375A0CC56DD9B52AA483F1ED171FB7" fullContext="AB375A0CC56DD9B52AA483F1ED171FB7" translateForJs="false" rules="unique=EntityChangeNotifications" notes="Must be unique amongst all &quot;EntityChangeNotifications&quot; entries">Ustawienia raportowania alarmów</TranslationEntry>
    <TranslationEntry name="4F3970EFD67F9933C18EFB02D862A2C2" translateForJs="false">Numer konta raportowania</TranslationEntry>
    <TranslationEntry name="EFFCAAD783905BAE5C0529107D9BC312" translateForJs="false">Konfiguracja formatu raportowania</TranslationEntry>
    <TranslationEntry name="4B1192132F5A6D7B80FB276CA5DDA731" translateForJs="false">4-cyfrowy (szesnastkowy) kod klienta przypisany do tego obiektu.</TranslationEntry>
    <TranslationEntry name="8C875EBFF9F2A69543539EF32F2A181C" translateForJs="false">ID raportowania strefy stanu systemu</TranslationEntry>
    <TranslationEntry name="4BDEDA76074DF5A644052CCEA91F189B" translateForJs="false">Konfiguracja raportowania</TranslationEntry>
    <TranslationEntry name="20E622B2C240ACEFA25BE30BF873556E" fullContext="088F19474F50E6D5A63C276575872498" translateForJs="false">Identyfikator raportowania strefy (partycji) używany przy raportowaniu zdarzeń zdrowotnych systemu, takich jak resetowanie systemu, sabotaż obudowy, moduł offline, awaria zasilania sieciowego itp. Powinien być unikalny wśród wszystkich identyfikatorów raportowania stref w systemie. Pełni tę samą funkcję co „strefa systemowa" w systemach Concept 4000 i Integriti.</TranslationEntry>
    <TranslationEntry name="E57E568DA84C61515B60FFA88B412668" translateForJs="false">Limit powtarzających się zdarzeń alarmowych (blokada po wielokrotnym wyzwoleniu)</TranslationEntry>
    <TranslationEntry name="103577AB27BF0A787AEA8CCF5EC72D78" fullContext="2B0E7B833165E61E57AF75460699C766" translateForJs="false">Limit powtarzających się zdarzeń alarmowych lub </TranslationEntry>
    <TranslationEntry name="385041109D12A08EDB0F50398704842D" fullContext="2B0E7B833165E61E57AF75460699C766" translateForJs="false" rules="unique=ReportingPacketType" notes="Must be unique amongst all &quot;ReportingPacketType&quot; entries">Wyłączenie po przekroczeniu limitu alarmów</TranslationEntry>
    <TranslationEntry name="B80B9EE8D87D6F2613DE32B955CACA9B" fullContext="2B0E7B833165E61E57AF75460699C766" translateForJs="false"> to funkcja zaprojektowana w celu ograniczenia liczby powtarzających się aktywacji linii wejściowych lub problemów stanu modułów wysyłanych do stacji monitorowania. Opcja ta jest często stosowana w przypadku, gdy urządzenie czujki staje się wadliwe i zaczyna wielokrotnie się aktywować, zapobiegając wielokrotnemu wysyłaniu fałszywych sygnałów. Może być również używana do zapobiegania sytuacji, w której intruz celowo wielokrotnie aktywuje linię wejściową, maskując swoje ruchy w potoku zdarzeń z tej jednej linii.</TranslationEntry>
    <TranslationEntry name="C08981CF5E45236D16F7CBCD414C2C79" fullContext="2B0E7B833165E61E57AF75460699C766" translateForJs="false">Jeśli limit jest ustawiony na zero, funkcja jest wyłączona i żaden limit nie jest stosowany.</TranslationEntry>
    <TranslationEntry name="437E0A7F6F6D4B36B6EE67B568B1738F" fullContext="2B0E7B833165E61E57AF75460699C766" translateForJs="false">Oprócz zdarzeń linii wejściowych, problemy stanu modułów są również śledzone i podlegają limitowi powtarzanych zdarzeń. Dla zdarzeń modułowych może to zapobiec wielokrotnemu wysyłaniu zdarzeń takich jak Niski poziom baterii, gdy pojemność baterii oscyluje na granicy wykrywalności.</TranslationEntry>
    <TranslationEntry name="C89778D55B4D3C9F5F7503C05C67E17A" fullContext="2B0E7B833165E61E57AF75460699C766" translateForJs="false">System śledzi indywidualne zdarzenia linii wejściowych i zdarzenia kondycji modułów względem limitu powtarzających się zdarzeń, identyfikując każde zdarzenie oddzielnie. W tym przypadku powtarzające się zdarzenia alarmowe z linii wejściowej mogą wyzwolić funkcję swinger shutdown i zablokować dalsze wysyłanie zdarzeń alarmowych z tej linii, jednak wykrycie sabotażu tej linii nadal zostanie zgłoszone. Podobnie, zdarzenie niskiego stanu baterii modułu może zostać ograniczone, ale zdarzenie sabotażu obudowy lub awarii zasilania AC z tego modułu jest odrębne — śledzone i ograniczane oddzielnie — i nadal będzie wysyłane.</TranslationEntry>
    <TranslationEntry name="BA085BE04C373A229D80E0EA1CA2F966" fullContext="2B0E7B833165E61E57AF75460699C766" translateForJs="false">Po osiągnięciu limitu zdarzeń dla linii wejściowej lub zdarzenia kondycji modułu, do stacji monitorowania wysyłane jest odrębne zdarzenie identyfikujące tę linię lub moduł. Wszystkie nowe aktywacje dla tej linii lub problemu kondycji modułu będą następnie odrzucane aż do rozbrojenia strefy. Dla linii wejściowych limit jest resetowany po rozbrójeniu strefy zawierającej daną linię. Dla zdarzeń kondycji modułów, ponieważ nie należą do żadnej strefy, rozbrojenie dowolnej strefy spowoduje zresetowanie limitów.</TranslationEntry>
    <TranslationEntry name="797FF71497324FB424D6559C1B706A6D" translateForJs="false">Wyłącz zdarzenie obecności technika na obiekcie</TranslationEntry>
    <TranslationEntry name="02088A8351C2913B9A43556C75D63F8A" fullContext="BF844D987CE23B4153FFA0C7E5CFB987" translateForJs="false">Zapobiega raportowaniu zdarzenia Technik na obiekcie. Niektóre stacje monitorowania nie obsługują poprawnie tego zdarzenia, więc można je wyłączyć, jeśli powoduje problemy.</TranslationEntry>
    <TranslationEntry name="3D302853D603EF43BFAB3313A75E5B33" translateForJs="false">Zaawansowane raportowanie zdarzeń strefy</TranslationEntry>
    <TranslationEntry name="1E0AB176E59E0978D40E18CF4F19BECD" fullContext="7BB105E49431241AE3D669FF81F041DA" translateForJs="false">Jeśli włączone, do stacji monitorowania będą raportowane bardziej szczegółowe lub dodatkowe zdarzenia dotyczące stanu uzbrojenia/rozbrojenia strefy. Te dodatkowe informacje są potrzebne do zgodności z normami w niektórych regionach, takich jak normy włamaniowe UL i ULC.</TranslationEntry>
    <TranslationEntry name="5493F6B8676CA2A6E215096CA2138256" fullContext="7BB105E49431241AE3D669FF81F041DA" translateForJs="false">Częściowe uzbrojenie</TranslationEntry>
    <TranslationEntry name="8D66496F083534A6FFED2E3478A1D277" fullContext="7BB105E49431241AE3D669FF81F041DA" translateForJs="false"> - Jeśli strefa zostanie uzbrojona z zaizolowanymi liniami wejściowymi, zostanie zgłoszone zdarzenie częściowego uzbrojenia zamiast standardowego zamknięcia.</TranslationEntry>
    <TranslationEntry name="DF7FCC3B5B18D5ADE26A04A22956BCD6" fullContext="7BB105E49431241AE3D669FF81F041DA" translateForJs="false">Rozbrój podczas ostrzeżenia przed uzbrojeniem</TranslationEntry>
    <TranslationEntry name="399F0BC31366EA3B42F1FE9D4AB71EB1" fullContext="7BB105E49431241AE3D669FF81F041DA" translateForJs="false"> — rozbrojenie strefy podczas fazy ostrzegania o uzbrojeniu (anulowanie oczekującego uzbrojenia) spowoduje zgłoszenie zdarzenia Użytkownik na obiekcie.</TranslationEntry>
    <TranslationEntry name="89DD0FEE85FF4618824026141D02DB3A" fullContext="7BB105E49431241AE3D669FF81F041DA" translateForJs="false">Nieudana próba uzbrojenia</TranslationEntry>
    <TranslationEntry name="1774DEE69BB4F87ACCA6CD2178517F6C" fullContext="7BB105E49431241AE3D669FF81F041DA" translateForJs="false"> — nieudana próba uzbrojenia strefy przez użytkownika z powodu niedomkniętych linii wejściowych spowoduje zgłoszenie zdarzenia nieudanego zamknięcia.</TranslationEntry>
    <TranslationEntry name="0FEA8B4A83C5FDBCFBABA73FFB75D898" fullContext="7BB105E49431241AE3D669FF81F041DA" translateForJs="false">Należy pamiętać, że ta opcja jest dostępna wyłącznie w przypadku raportowania ContactID i nie powinna być stosowana z innymi formatami raportowania.</TranslationEntry>
    <TranslationEntry name="EF044A60ED641E1CD1BC4EBE075F5793" translateForJs="false">Własne monitorowanie przez powiadomienia</TranslationEntry>
    <TranslationEntry name="104906946B0D825F8AE80DE7846CCB2C" fullContext="AA369DD48E96A54799AC8094E1F05ECB" translateForJs="false">Jeśli włączone, zdarzenie w rejestrze zdarzeń wyzwalane przy alarmie, gdy nie skonfigurowano ścieżki raportowania, zostanie pominięte. Ta opcja jest przeznaczona dla sytuacji, gdy używane są powiadamiacze (konfigurowalne pod adresem </TranslationEntry>
    <TranslationEntry name="B7C4E6156E3AAA84FC79D87579EF50A6" fullContext="AA369DD48E96A54799AC8094E1F05ECB" translateForJs="false">[Konfiguracja &gt; Ogólne &gt; Powiadamiacze]</TranslationEntry>
    <TranslationEntry name="07B85EAA9E074A287B83F2284BE69F55" fullContext="AA369DD48E96A54799AC8094E1F05ECB" translateForJs="false">) służą do wysyłania zdarzeń raportowania alarmów za pośrednictwem poczty e-mail lub powiadomień push do celów samodzielnego monitorowania, gdy nie jest używana stacja monitorowania.</TranslationEntry>
    <TranslationEntry name="81982BBE6FAE577E23E4BE237C2DA823" translateForJs="false">Włącz raportowanie Skytunnel</TranslationEntry>
    <TranslationEntry name="9E24AD8937F859D3A3FCCCD094945BFB" translateForJs="false">Konfiguracja Skytunnel</TranslationEntry>
    <TranslationEntry name="9E349823BC3EED2C8F46C0D9AA7C1CE9" fullContext="8ACF8536D5970CC8790DDABD25461255" translateForJs="false">Włącza raportowanie zdarzeń i alarmów przez Skytunnel. Skytunnel to pierwsza w branży usługa chmurowa, która zapewnia bezproblemowe połączenie i raportowanie przez internet. Wybranie tej opcji włączy </TranslationEntry>
    <TranslationEntry name="2134DD513F580F5E085F68C38E7972CD" fullContext="8ACF8536D5970CC8790DDABD25461255" translateForJs="false">Format raportowania</TranslationEntry>
    <TranslationEntry name="0060636B449D1DA5A8581BFEE180F0C2" fullContext="6B84C55F05D9A4499AEF73D8C79DD875" translateForJs="false"> i </TranslationEntry>
    <TranslationEntry name="2FE8DED98141AFC4FA3FF2D838E35843" fullContext="D562F767318680822EF57130B1DB33C4" translateForJs="false">Włącz okresowe raportowanie testowe</TranslationEntry>
    <TranslationEntry name="8028A4DFE9B427A28D61016B9E3C0A2F" fullContext="D562F767318680822EF57130B1DB33C4" translateForJs="false"> pola poniżej.</TranslationEntry>
    <TranslationEntry name="9FA4FE5B4D024780725C7C3950678E16" fullContext="8ACF8536D5970CC8790DDABD25461255" translateForJs="false">Uwaga: ta opcja jedynie włącza ścieżkę raportowania. Urządzenie Inception musi zostać również zarejestrowane w systemie Multipath IP stacji monitorowania przy użyciu numeru seryjnego Inception. Skontaktuj się ze swoją stacją monitorowania w celu założenia tego konta — będziesz potrzebować typu urządzenia (Inception), numeru seryjnego oraz wybranego formatu raportowania.  </TranslationEntry>
    <TranslationEntry name="306AD686BFDA8CC2CFE36D4DA12CBECD" fullContext="7C1D8283D1AD352E36D21759E08DBD32" translateForJs="false">Ta opcja służy do określenia formatu, w którym będą raportowane komunikaty alarmowe Skytunnel. </TranslationEntry>
    <TranslationEntry name="0AC51BF499B04CBD309ADE859E9E68C4" fullContext="7C1D8283D1AD352E36D21759E08DBD32" translateForJs="false">Contact ID: Format raportowania używany do zgłaszania otwarć/zamknięć stref oraz izolacji, sabotaży, alarmów i przywróceń linii wejściowych/stref w formacie Ademco Contact ID. Z paska narzędzi powyżej można wygenerować raport Contact ID. Raport ten zawiera wszystkie możliwe zdarzenia, które mogą być raportowane na podstawie konfiguracji systemu i może zostać przekazany stacji monitorowania lub użyty jako materiał referencyjny. </TranslationEntry>
    <TranslationEntry name="36950C17464D30D3E85B9C7FD75240AF" fullContext="7C1D8283D1AD352E36D21759E08DBD32" translateForJs="false">IR-Fast: Zastrzeżony format raportowania Inner Range, który może raportować otwarcia/zamknięcia stref oraz izolacje, sabotaże, alarmy i przywrócenia linii wejściowych/stref do stacji centralnej. W odróżnieniu od Contact ID, nie jest wymagane mapowanie linii wejściowych ani użytkowników, ponieważ wszystkie raporty alarmowe i zdarzenia mogą być raportowane w sposób unikalny.</TranslationEntry>
    <TranslationEntry name="91AFABA68911926DA16703D0FAFE1980" fullContext="7C1D8283D1AD352E36D21759E08DBD32" translateForJs="false">IR-Fast z tekstem: Zapewnia dodatkową funkcjonalność wysyłania tekstu wraz z dowolnymi zgłoszonymi zdarzeniami lub alarmami. Pełny opis tekstowy zdarzenia zostanie uwzględniony.</TranslationEntry>
    <TranslationEntry name="602D8552415D27C1287A8F4F38817B53" fullContext="409947DEA3B35FD15DC65067F788F69E" translateForJs="false">Jeśli włączone, opcja ta spowoduje okresowe wysyłanie wiadomości testowej do stacji monitorowania. Raport testowy służy do potwierdzenia zdolności systemu do wysyłania zdarzeń i alarmów do stacji monitorowania, która będzie oczekiwać wiadomości z określoną częstotliwością. Wybrana poniżej częstotliwość powinna odpowiadać temu, jak często stacja monitorowania spodziewa się otrzymywać raporty testowe</TranslationEntry>
    <TranslationEntry name="782C7F108F9F5B60E740F431A9C03648" fullContext="00F1615A642937A8C45E4605D093D7A7" translateForJs="false">Jeśli raport testowy nie zostanie odebrany przez stację monitorowania, może to oznaczać problem z kontrolerem Inception, niepożądane zmiany w programowaniu lub problemy ze ścieżkami raportowania. Wybranie tej opcji włączy </TranslationEntry>
    <TranslationEntry name="2C42CA09457ED5D7110422909E4E092C" fullContext="00F1615A642937A8C45E4605D093D7A7" translateForJs="false">Częstotliwość raportu testowego</TranslationEntry>
    <TranslationEntry name="72129AE71841587EE55B7F6B9330B4CD" fullContext="6E0E9EE32ADF90C026F9F75434458712" translateForJs="false"> i  </TranslationEntry>
    <TranslationEntry name="7BC1318FBC05FF2A12A0704F96B510E2" fullContext="00F1615A642937A8C45E4605D093D7A7" translateForJs="false">Godzina wysyłania raportu testowego</TranslationEntry>
    <TranslationEntry name="F5D170915C941FEA39F4151F511E844F" fullContext="00F1615A642937A8C45E4605D093D7A7" translateForJs="false"> opcje poniżej.</TranslationEntry>
    <TranslationEntry name="FFF8E43047CE09EC3E96BC7304DEBDAB" fullContext="1B9FE9F36AF1CCAA83B3F0EA1929C790" translateForJs="false">To ustawienie decyduje o częstotliwości wysyłania raportów testowych do stacji monitorowania. Wybierz jedną z dostępnych opcji z listy rozwijanej. Wybrana częstotliwość powinna odpowiadać temu, jak często stacja monitorowania spodziewa się otrzymywać raporty testowe</TranslationEntry>
    <TranslationEntry name="69DB53974AB1E1714DC9B8B3F942FEEE" fullContext="B17E33CDB97D544F26FF1963FE17A925" translateForJs="false">To określi, o której godzinie testowy raport zostanie wysłany do stacji monitorowania.</TranslationEntry>
    <TranslationEntry name="FC6ABAF07D9ABEFAEF19007512FD55D8" translateForJs="false">Włącz raportowanie urządzenia alarmowego</TranslationEntry>
    <TranslationEntry name="E819A2F72D60956206FBB871BC806B8C" translateForJs="false">Konfiguracja urządzenia alarmowego</TranslationEntry>
    <TranslationEntry name="DCA74104431774E5B96F32A4F7AA119B" fullContext="D562F767318680822EF57130B1DB33C4" translateForJs="false">Umożliwia raportowanie alarmów za pośrednictwem modułu T4000 lub innych obsługiwanych zewnętrznych urządzeń alarmowych. Komunikator bezpieczeństwa T4000 to wysoce zaawansowane urządzenie służące do połączenia kontrolera Inception z centralną stacją monitorowania za pośrednictwem wielu wysoce bezpiecznych ścieżek IP. Wybranie tej opcji spowoduje włączenie </TranslationEntry>
    <TranslationEntry name="24C3B545E576DED80DE4DCC2BBEE70C9" fullContext="D562F767318680822EF57130B1DB33C4" translateForJs="false">Maksymalny czas trwania alarmu</TranslationEntry>
    <TranslationEntry name="A9A0E3EC5FCAA9D50B3BE05FDEAFFF77" fullContext="D562F767318680822EF57130B1DB33C4" translateForJs="false">Uwaga: ta opcja jedynie włącza ścieżkę raportowania. Urządzenie T4000 musi zostać również zarejestrowane w systemie Multipath IP stacji monitorowania przy użyciu numeru seryjnego T4000. Skontaktuj się ze swoją stacją monitorowania w celu założenia tego konta — będziesz potrzebować typu urządzenia (T4000) i numeru seryjnego T4000. Format raportowania jest wybierany przez stację monitorowania. </TranslationEntry>
    <TranslationEntry name="34421DD09273B3F190F18E805C731532" fullContext="D562F767318680822EF57130B1DB33C4" translateForJs="false">Zapoznaj się z przewodnikiem instalacji T4000, aby uzyskać więcej informacji na temat konfiguracji tego urządzenia.</TranslationEntry>
    <TranslationEntry name="32F51F01B3B167638F30461A886D6CD1" fullContext="D562F767318680822EF57130B1DB33C4" translateForJs="false">Uwaga: jeśli używany jest format IR-Fast z tekstem, nazwy stref i linii wejściowych w systemie powinny być krótkie, ponieważ istnieje ograniczenie liczby znaków, które można przesłać. Limit wynosi 48 znaków, co musi obejmować nazwy stref i linii wejściowych wraz z nazwą zdarzenia alarmowego.</TranslationEntry>
    <TranslationEntry name="49A1186B6F1752867811FE7949C79E36" fullContext="49A1186B6F1752867811FE7949C79E36" translateForJs="false">Typ urządzenia alarmowego</TranslationEntry>
    <TranslationEntry name="E98CCACC125FC76F6884AAB14E6E5B65" fullContext="503D086493E63B02D83F049DBEDDFFD5" translateForJs="false">Wybierz typ urządzenia, za pomocą którego zgłaszasz alarmy, spośród dostępnych obsługiwanych typów. W zależności od wybranego typu urządzenia poniżej mogą pojawić się różne opcje konfiguracji.</TranslationEntry>
    <TranslationEntry name="4F2A61C20D55BA3A772256C12B713DA6" translateForJs="false">Źródło stanu ścieżki urządzenia</TranslationEntry>
    <TranslationEntry name="F345871CAD5521D1EEE1BD4998745576" translateForJs="false">Port szeregowy urządzenia alarmowego</TranslationEntry>
    <TranslationEntry name="C6A39548C34D99033F34E80F14C9E366" fullContext="4CF5E2D5D0EBC4BC69F15A90EADFE772" translateForJs="false">Określa port szeregowy, do którego urządzenie alarmowe ma próbować się połączyć. Wybór </TranslationEntry>
    <TranslationEntry name="C1DA7BA96C43C05180FBE3ECE356D446" fullContext="1DFC1FDE9852575B9203183997FB8F09" translateForJs="false">Pierwsza dostępna</TranslationEntry>
    <TranslationEntry name="E68F663FDF8198DF9BDD53A944708B22" fullContext="4CF5E2D5D0EBC4BC69F15A90EADFE772" translateForJs="false"> spowoduje, że urządzenie podejmie próbę połączenia z pierwszym podłączonym i nieprzypisanym urządzeniem szeregowym.</TranslationEntry>
    <TranslationEntry name="8D1629C98DC65739AEF9A6DA2BE1FBD5" fullContext="4CF5E2D5D0EBC4BC69F15A90EADFE772" translateForJs="false">W przypadku korzystania z wielu połączeń szeregowych zaleca się wskazanie konkretnego połączenia szeregowego</TranslationEntry>
    <TranslationEntry name="D5C7C0CFB7D42288DF9635AC41582F88" fullContext="09EEBDDA4B943E27D1295B4EBE1E09F3" translateForJs="false">Ustawia maksymalny czas, przez który urządzenie T4000 ma próbować wysłać alarm przed przekroczeniem limitu czasu. </TranslationEntry>
    <TranslationEntry name="967A96A2077A75FAA5EABAC385492EA6" fullContext="09EEBDDA4B943E27D1295B4EBE1E09F3" translateForJs="false">Uwaga: Po upływie czasu oczekiwania Inception może podjąć próbę wysłania zdarzenia przez inną ścieżkę alarmową. Jeśli wszystkie włączone ścieżki zawiodą, Inception będzie nadal ponawiać próby wysyłania przez każdą ścieżkę przez 15 minut.</TranslationEntry>
    <TranslationEntry name="9105A2AC8DBFA6B9D525AB2239554EC7" translateForJs="false">Użyj formatu IRFast zgodnego z Integriti</TranslationEntry>
    <TranslationEntry name="A9082FE9FA3D17DCEC0096DF7F78858E" fullContext="0013668B4E977F41FAC32B0E659BED1E" translateForJs="false">Jeśli T4000 jest skonfigurowany do raportowania alarmów IRFast, włączenie tej opcji spowoduje, że Inception będzie raportować alarmy IRFast w formacie zgodnym z Integriti, a nie w starszym formacie zgodnym z Concept (domyślnym). Format IRFast Integriti obsługuje raportowanie dodatkowych typów stanów linii wejściowych, które nie są obsługiwane przez protokół Concept IRFast, np. Niski poziom baterii i Błąd odpytywania.</TranslationEntry>
    <TranslationEntry name="B74410CBA8CC6489C205DC9A4B56D51A" fullContext="C824C20DABF989F4B493D51836F8909B" translateForJs="false">Ta opcja służy do określenia formatu, w jakim komunikaty alarmowe będą przesyłane przez jednostkę komunikacji alarmowej. Powinien on odpowiadać formatowi oczekiwanemu przez stację monitorowania.</TranslationEntry>
    <TranslationEntry name="1CF131364E41A555D40B560C6D08B1CE" fullContext="C824C20DABF989F4B493D51836F8909B" translateForJs="false">Zarówno formaty raportowania Contact ID, jak i SIA raportują te same typy zdarzeń w podobnych formatach, zawierając głównie informacje o koncie klienta, kodzie zdarzenia i identyfikatorze punktu wyzwolenia. SIA może zawierać dodatkowy opis tekstowy zdarzenia, podczas gdy Contact ID dostarcza bardziej kodowanych informacji o zdarzeniu, takich jak strefa, w której wystąpiło zdarzenie.</TranslationEntry>
    <TranslationEntry name="D2E755660F3BD3848823CF370AEA82E0" fullContext="C824C20DABF989F4B493D51836F8909B" translateForJs="false">Raport uruchomienia można wygenerować dla obu formatów za pomocą paska narzędziowego powyżej i wysłać do stacji monitorowania w celu zaimportowania do ich systemu. Raport zawiera szczegółowe opisy tekstowe wszystkich możliwych zdarzeń, które mogą być zgłaszane przez system na podstawie jego konfiguracji, wraz z kodami zdarzeń wyzwalających i informacjami o punktach. Dzięki tym informacjom stacja monitorowania może przekształcić zakodowane zdarzenia alarmowe w czytelne i użyteczne informacje alarmowe.</TranslationEntry>
    <TranslationEntry name="063651C9FFAA99E4B94CE14AAC2A7A45" translateForJs="false">Adres IP odbiorcy</TranslationEntry>
    <TranslationEntry name="5280EBE462D58D5BA0CD2A2E8B6D4049" fullContext="96772BCFAB7B85244479800B4C880356" translateForJs="false">Adres IP stacji centralnej obsługującej oprogramowanie odbiornika. Na ten adres będą wysyłane wszystkie alarmy i skonfigurowane jest regularne odpytywanie.</TranslationEntry>
    <TranslationEntry name="05D1C92643530D5CFD9D5E75F0F611FB" fullContext="FB6E5CE8588CA1D12CF3B918D783B250" translateForJs="false">Numer konta lub kod klienta identyfikujący to urządzenie w stacji monitorowania. W zależności od stacji monitorowania, z którą nawiązywana jest komunikacja, numer konta powinien mieć co najmniej cztery znaki.</TranslationEntry>
    <TranslationEntry name="E26B266FB5B3CBAC83823082B694A766" translateForJs="false">GPRS APN</TranslationEntry>
    <TranslationEntry name="8C71AE843CE1849D83CC6D45CC4231A0" fullContext="5BE9F3DEBAC913C09845A233EF5D4272" translateForJs="false">W razie potrzeby — APN umożliwiający urządzeniu dostęp do sieci GPRS.</TranslationEntry>
    <TranslationEntry name="E7F46E9FF0785C36D06515E04497C2A8" translateForJs="false">Nazwa użytkownika GPRS</TranslationEntry>
    <TranslationEntry name="40CE3F5730B50239BEE720C952E97B3C" fullContext="1135390572498FE48098DC4AC5BD14A9" translateForJs="false">Nazwa użytkownika — jeśli wymagana — umożliwiająca urządzeniu dostęp do sieci GPRS.</TranslationEntry>
    <TranslationEntry name="9A6E2D75C4886C6CF9CB048415EF4BF5" translateForJs="false">Hasło GPRS</TranslationEntry>
    <TranslationEntry name="3B93ACACE6D25B0422B1BAF438845215" fullContext="CBD9BB6A2B054BBDCA560C531C25C63A" translateForJs="false">Hasło — jeśli wymagane — umożliwiające urządzeniu dostęp do sieci GPRS.</TranslationEntry>
    <TranslationEntry name="A81D6D600711CABBCDE9B816C4B011DA" translateForJs="false">Kod kraju</TranslationEntry>
    <TranslationEntry name="289DD4E684BEF3B0D0224AE7C99D58FC" fullContext="AFE95D0E86EE7C6B2D5223C2D01D7CDE" translateForJs="false">Kraj, w którym zainstalowany jest dialer. Wymagane przy połączeniu ze standardową linią telefoniczną w celu prawidłowego wybierania numeru.</TranslationEntry>
    <TranslationEntry name="F8E597C933D63339B678A08A4D0BF84C" translateForJs="false">Numer telefonu odbiornika</TranslationEntry>
    <TranslationEntry name="AE8EA4B1BFA56E9926BAA7B68B065384" fullContext="5C1A9DB2F1485B0BE07C6D2CA6BFD2ED" translateForJs="false">Numer telefonu odbiornika stacji monitorowania alarmów, który ma być wybrany.</TranslationEntry>
    <TranslationEntry name="D9FB4789F65587EBD428B3235B7F3F29" fullContext="5C1A9DB2F1485B0BE07C6D2CA6BFD2ED" translateForJs="false">W przypadku podłączenia do nadajnika uniwersalnego z przechwytywaniem połączeń numer telefonu może nadal być wymagany. </TranslationEntry>
    <TranslationEntry name="6C8669C991E25A864D60C047F0D84B4A" translateForJs="false">Rozłącz po wybraniu</TranslationEntry>
    <TranslationEntry name="FFE05F1A958C7F5A9300436F210D2643" fullContext="EE2AB851F1AC6D0A80F828CA4714D7B8" translateForJs="false">Domyślnie modem stara się utrzymać połączenie otwarte po jego nawiązaniu i wysłaniu alarmu. Pozwala to na wysłanie wielu alarmów w ramach jednego połączenia, maksymalizując szybkość raportowania alarmów. Jest to szczególnie przydatne podczas połączenia z transmiterem uniwersalnym za pośrednictwem przechwytywania dialera.</TranslationEntry>
    <TranslationEntry name="F50EBE027E3F324FCED0A37E5A3F4C5D" fullContext="EE2AB851F1AC6D0A80F828CA4714D7B8" translateForJs="false">Jeśli modem jest podłączony do standardowej linii telefonicznej współdzielonej z innymi urządzeniami (np. faksem), ta opcja spowoduje rozłączenie modemu po wysłaniu alarmu. Należy pamiętać, że oznacza to konieczność nawiązywania połączenia dla każdego alarmu, co może znacznie spowolnić tempo raportowania alarmów.</TranslationEntry>
    <TranslationEntry name="0E7F9C66ED158DF29181403DC0182E3E" fullContext="00F1615A642937A8C45E4605D093D7A7" translateForJs="false">Jeśli włączone, opcja ta spowoduje okresowe wysyłanie wiadomości testowej do stacji monitorowania. Raport testowy służy do potwierdzenia zdolności systemu do wysyłania zdarzeń i alarmów do stacji monitorowania, która będzie oczekiwać wiadomości z określoną częstotliwością. Wybrana poniżej częstotliwość powinna odpowiadać temu, jak często stacja monitorowania spodziewa się otrzymywać raporty testowe.</TranslationEntry>
    <TranslationEntry name="C7462740A4BB172A18E3D47D14564B86" fullContext="2DB6308F83E82373BFF15D082BFD42F8" translateForJs="false">Określa częstotliwość wysyłania raportów testowych do stacji monitorowania. Wybierz jedną z dostępnych opcji z listy rozwijanej. Wybrana częstotliwość powinna odpowiadać temu, jak często stacja monitorowania spodziewa się otrzymywać raporty testowe</TranslationEntry>
    <TranslationEntry name="9C351612946F086E1329640B570B4131" fullContext="BD09C13CB5724DB2330C38ED9E0B6B04" translateForJs="false">Określa, o której godzinie testowy raport zostanie wysłany do stacji monitorowania.</TranslationEntry>
    <TranslationEntry name="1CBB44E7089FF80A23911F3CA904B9F8" translateForJs="false">Włącz raportowanie SIA IP</TranslationEntry>
    <TranslationEntry name="34E9D384A32F977797318AA74AEF59E3" translateForJs="false">Konfiguracja SIA IP</TranslationEntry>
    <TranslationEntry name="2FCECAF04456AE2CEAC826FD0CCAAF1C" translateForJs="false">Numer konta</TranslationEntry>
    <TranslationEntry name="E97DE37AC7BB1B9210BC97CF33E1A023" translateForJs="false">Numer linii</TranslationEntry>
    <TranslationEntry name="F75F2728ECED4B7E576AFE5557C61D71" translateForJs="false">Numer odbiornika</TranslationEntry>
    <TranslationEntry name="60AAF44D4B562252C04DB7F98497E9AA" translateForJs="false">Port</TranslationEntry>
    <TranslationEntry name="4FEE671008D870BA5D20CB7126D0D968" translateForJs="false">Włącz szyfrowanie</TranslationEntry>
    <TranslationEntry name="75EAF6C647C111824FF39F22504CE11D" translateForJs="false">Klucz szyfrujący</TranslationEntry>
    <TranslationEntry name="2859EFAE75CC409669C54745A342B681" translateForJs="false">Włącz nadzór połączenia</TranslationEntry>
    <TranslationEntry name="A6EEA9C64744CC0CF4C285B4A45DDBB2" translateForJs="false">Częstotliwość nadzoru połączenia</TranslationEntry>
    <TranslationEntry name="CF51C953F09D12594173620E426CC3B0" fullContext="CF51C953F09D12594173620E426CC3B0" translateForJs="false">Priorytet ścieżki Skytunnel</TranslationEntry>
    <TranslationEntry name="F6896AD8F7B84E9962363939906BF976" translateForJs="false">Priorytety ścieżek raportowania</TranslationEntry>
    <TranslationEntry name="056F42652BD77EC4B1EA54600A356D51" fullContext="452FA4BC074859E8ED613401E2B74B03" translateForJs="false">Określa, czy ścieżka raportowania Skytunnel powinna być używana jako ścieżka główna czy jako ścieżka zapasowa w przypadku korzystania z wielu ścieżek. </TranslationEntry>
    <TranslationEntry name="86C9EA5CCEF4083F596CA7A1CA68859B" fullContext="24BDADB156BC8F4887AD381F1E67F5DC" translateForJs="false">Zdarzenia alarmowe zawsze będą próbowały być wysłane przez ścieżkę podstawową i przełączą się na ścieżkę zapasową tylko w przypadku niepowodzenia wysyłania.</TranslationEntry>
    <TranslationEntry name="575EC8184E812CE13D2225FF6DC14C75" fullContext="575EC8184E812CE13D2225FF6DC14C75" translateForJs="false">Priorytet ścieżki urządzenia alarmowego</TranslationEntry>
    <TranslationEntry name="5C3CEB7755D136A416634DCF691A60FF" fullContext="39642D66E8402631058D05AD357A56DC" translateForJs="false">Określa, czy ścieżka raportowania urządzenia alarmowego ma być używana jako ścieżka podstawowa czy jako ścieżka zapasowa w przypadku korzystania z wielu ścieżek. </TranslationEntry>
    <TranslationEntry name="C0B00EE9A64FE16CFD46E0FAE61FA915" fullContext="C0B00EE9A64FE16CFD46E0FAE61FA915" translateForJs="false">Priorytet ścieżki SIA IP</TranslationEntry>
    <TranslationEntry name="80A2020EB14848D99F91FD71FD856EAC" fullContext="24BDADB156BC8F4887AD381F1E67F5DC" translateForJs="false">Określa, czy ścieżka raportowania SIA IP powinna być używana jako ścieżka podstawowa czy jako ścieżka zapasowa w przypadku stosowania wielu ścieżek. </TranslationEntry>
    <TranslationEntry name="CA7CB5CD37B5126BB837D64048B67A63" translateForJs="false" rules="unique=SupportedGSMDeviceTypes" notes="Must be unique amongst all &quot;SupportedGSMDeviceTypes&quot; entries">T4000</TranslationEntry>
    <TranslationEntry name="26440A2CABEBCC463BA3F3DBAE8BA847" translateForJs="false" rules="unique=SupportedGSMDeviceTypes" notes="Must be unique amongst all &quot;SupportedGSMDeviceTypes&quot; entries">CSL DualCom</TranslationEntry>
    <TranslationEntry name="49D5773780245750F5470476BC205CCB" translateForJs="false" rules="unique=SupportedGSMDeviceTypes" notes="Must be unique amongst all &quot;SupportedGSMDeviceTypes&quot; entries">Trikdis</TranslationEntry>
    <TranslationEntry name="5999DE4580994F9FF4F41CA2E9ED8418" translateForJs="false" rules="unique=SupportedGSMDeviceTypes" notes="Must be unique amongst all &quot;SupportedGSMDeviceTypes&quot; entries">IRIS</TranslationEntry>
    <TranslationEntry name="F10D63AFB3517F7F322AF659E17424D4" translateForJs="false" rules="unique=SupportedGSMDeviceTypes" notes="Must be unique amongst all &quot;SupportedGSMDeviceTypes&quot; entries">Dialer USB</TranslationEntry>
    <TranslationEntry name="81C65D61D0BD24AB88A98BC70770921C" translateForJs="false" rules="unique=SupportedGSMDeviceTypes" notes="Must be unique amongst all &quot;SupportedGSMDeviceTypes&quot; entries">Łącze wychodzące</TranslationEntry>
    <TranslationEntry name="94D0729AF111A067D80B706BC8CF8ECD" translateForJs="false" rules="unique=_OLD_SupportedGSMDeviceTypes" notes="Must be unique amongst all &quot;_OLD_SupportedGSMDeviceTypes&quot; entries">WebWayOne / Emizon TCD</TranslationEntry>
    <TranslationEntry name="7A285EFFB4AF4B4392846BBCA8448C49" translateForJs="false" rules="unique=ReportingFormatType" notes="Must be unique amongst all &quot;ReportingFormatType&quot; entries">IRFast z tekstem</TranslationEntry>
    <TranslationEntry name="41C97F8FBF4F53C7077CBB0E278C75A8" translateForJs="false" rules="unique=ReportingFormatType" notes="Must be unique amongst all &quot;ReportingFormatType&quot; entries">Integriti IRFast z tekstem</TranslationEntry>
    <TranslationEntry name="25A87E4F4A8158EA71D62329789B822E" translateForJs="false" rules="unique=SecurePendingWithActiveInputBehaviour" notes="Must be unique amongst all &quot;SecurePendingWithActiveInputBehaviour&quot; entries">Oczekujące zabezpieczenie</TranslationEntry>
    <TranslationEntry name="60C37E9F7134365E8ABDF4A68B26E118" translateForJs="false" rules="unique=AutoResecureTimerTriggerBehaviour" notes="Must be unique amongst all &quot;AutoResecureTimerTriggerBehaviour&quot; entries">Zamknięcie przejścia</TranslationEntry>
    <TranslationEntry name="81ED4BBAA8B0DB52294D2035C9C8BCDB" translateForJs="false" rules="unique=AutoResecureTimerTriggerBehaviour" notes="Must be unique amongst all &quot;AutoResecureTimerTriggerBehaviour&quot; entries">Odblokowanie i zamknięcie drzwi</TranslationEntry>
