    <TranslationEntry name="317764D60729C005F281071AB0C80623" fullContext="5BD9D67E3DDB745487AC8397508471BD" translateForJs="false"> - Pokazuj tylko zdarzenia rozbrojenia.</TranslationEntry>
    <TranslationEntry name="7B6C5E3AD41A4B343CE9DE9AF32FC664" translateForJs="false">Pokaż zdarzenia sterowania użytkownika/systemu</TranslationEntry>
    <TranslationEntry name="B5422FBA19FC4E488D71A139CFA32378" fullContext="32EC7ACB91A066143A250FAE65414959" translateForJs="false">Opcjonalnie ogranicz raport do wyświetlania tylko zdarzeń sterowania przez użytkownika lub przez system.</TranslationEntry>
    <TranslationEntry name="776F4B4D4D20A874DADFFD0E2BB435F7" fullContext="32EC7ACB91A066143A250FAE65414959" translateForJs="false"> - Pokaż wszystkie zdarzenia użytkownika/systemu.</TranslationEntry>
    <TranslationEntry name="64F53C3FEFFED4D34CE1BDF2F1405620" fullContext="32EC7ACB91A066143A250FAE65414959" translateForJs="false"> - Pokaż tylko zdarzenia sterowania użytkownika.</TranslationEntry>
    <TranslationEntry name="2620B71D5E3A462DB68E0E9B5B78351E" fullContext="32EC7ACB91A066143A250FAE65414959" translateForJs="false"> - Pokaż tylko zdarzenia sterowania systemem.</TranslationEntry>
    <TranslationEntry name="1097E5C07CD7891F09DD183C2C67D219" translateForJs="false">Pokaż zdarzenia pomyślnego/nieudanego sterowania</TranslationEntry>
    <TranslationEntry name="44B55065049EF6754558EE552510BE1E" fullContext="D4DB8891EECBE1FFEA99117C0C432C82" translateForJs="false">Opcjonalnie ogranicz raport tylko do zdarzeń zakończonych sukcesem lub niepowodzeniem. </TranslationEntry>
    <TranslationEntry name="1291E0F4003B4AAFAE7B8B45F8C5D44F" fullContext="D4DB8891EECBE1FFEA99117C0C432C82" translateForJs="false"> - Pokaż wszystkie zdarzenia zakończone sukcesem/niepowodzeniem.</TranslationEntry>
