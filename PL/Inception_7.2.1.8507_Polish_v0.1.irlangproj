    <TranslationEntry name="88A392B5A8D8F73986D83A2DEEFB0472" translateForJs="false" rules="unique=DiallerCountryCodes" notes="Must be unique amongst all &quot;DiallerCountryCodes&quot; entries">Słowacja</TranslationEntry>
