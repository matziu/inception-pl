    <TranslationEntry name="7463BB45CA04CD694DF4E2F8D94CA1D4" fullContext="198CC579BD5B1F3065032BC7093FFCA2" translateForJs="false"> - Pokazuj tylko nieudane zdarzenia uzbrojenia/rozbrojenia.</TranslationEntry>
    <TranslationEntry name="9A68C65AC5137F9EC1DA43D89AF13AAB" translateForJs="false">Pokaż zdarzenia bezpieczeństwa</TranslationEntry>
    <TranslationEntry name="0CFB929A5CC3821F0F08D28D46D119DA" fullContext="AF7718AB3AA78E0CD5C42CCBE36C57A8" translateForJs="false">Wybierz, czy zdarzenia z kategorii komunikatów zabezpieczeń mają być uwzględnione w raporcie.</TranslationEntry>
    <TranslationEntry name="9686A458BE7A6B603DCBB6EA0156A44B" translateForJs="false">Pokaż zdarzenia dostępu</TranslationEntry>
    <TranslationEntry name="969261D59839C8E1FEDCDD8433248E98" fullContext="31E4839E1892E057DB3A808A7C20D600" translateForJs="false">Wybierz, czy zdarzenia z kategorii komunikatów Dostęp mają być uwzględniane w raporcie.</TranslationEntry>
    <TranslationEntry name="64D68CA6B75D4D60F34ECD6F6E902C9F" translateForJs="false">Pokaż zdarzenia sprzętowe</TranslationEntry>
    <TranslationEntry name="6A219B62348039E192DF0C07889A3335" fullContext="C4F82D02F491DEE9C41287C24DE19CD7" translateForJs="false">Wybierz, czy zdarzenia w kategorii komunikatów sprzętowych powinny być uwzględnione w raporcie.</TranslationEntry>
    <TranslationEntry name="A529E3EE5F7FCE9A85F566DA00A2AE9A" translateForJs="false">Pokaż zdarzenia systemowe</TranslationEntry>
    <TranslationEntry name="10D4D1C65E3269B62A1C58BAC35B4D63" fullContext="327331D14575B0A25230746A6D79A169" translateForJs="false">Wybierz, czy zdarzenia z kategorii komunikatów systemowych mają być uwzględnione w raporcie.</TranslationEntry>
    <TranslationEntry name="DFCD0D1AD91D2EC031CA36E2B66D2FE0" translateForJs="false">Pokaż zdarzenia audytu</TranslationEntry>
    <TranslationEntry name="680FFBA8C42CAAA6B73702A3B384C65E" fullContext="1BF3CBFB339B3E09938F27DE80C3B05F" translateForJs="false">Wybierz, czy zdarzenia w kategorii komunikatów audytu powinny być uwzględnione w raporcie.</TranslationEntry>
    <TranslationEntry name="C48B5DFCF6E1D7045F8F684C7ED1FDB4" fullContext="7B06F7E86E53DC0F47EFB4F1789E762E" translateForJs="false" rules="unique=StorageUnitControlSecureUnlockFilter" notes="Must be unique amongst all &quot;StorageUnitControlSecureUnlockFilter&quot; entries">Tylko zdarzenia bezpieczne</TranslationEntry>
    <TranslationEntry name="FE9C85BAD94A8EF0EC3D4C5FBDFD34FB" fullContext="7B06F7E86E53DC0F47EFB4F1789E762E" translateForJs="false" rules="unique=StorageUnitControlSecureUnlockFilter" notes="Must be unique amongst all &quot;StorageUnitControlSecureUnlockFilter&quot; entries">Tylko zdarzenia odblokowania</TranslationEntry>
