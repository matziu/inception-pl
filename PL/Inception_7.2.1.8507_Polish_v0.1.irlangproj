    <TranslationEntry name="A18BA677358604109193ABB256018652" fullContext="A18BA677358604109193ABB256018652" translateForJs="false">Czytnik 7 VAL</TranslationEntry>
    <TranslationEntry name="F4F4B086C0110A381C2F1D28FE992CD9" fullContext="F4F4B086C0110A381C2F1D28FE992CD9" translateForJs="false">Czytnik 8 VAL</TranslationEntry>
    <TranslationEntry name="D934D2E9EFE7ACEE80DA09B929763845" fullContext="D934D2E9EFE7ACEE80DA09B929763845" translateForJs="false">Czytnik 3 INV</TranslationEntry>
    <TranslationEntry name="1ED850CC50E002E4AD8DC4EBC7706AAF" fullContext="1ED850CC50E002E4AD8DC4EBC7706AAF" translateForJs="false">Czytnik 4 INV</TranslationEntry>
    <TranslationEntry name="9DEA7AD0BB7BF8E57A30C8765EE4BCBD" fullContext="9DEA7AD0BB7BF8E57A30C8765EE4BCBD" translateForJs="false">Czytnik 5 INV</TranslationEntry>
    <TranslationEntry name="E0CC26413F3FB085CF7198BFEBF39CA6" fullContext="E0CC26413F3FB085CF7198BFEBF39CA6" translateForJs="false">Czytnik 6 INV</TranslationEntry>
    <TranslationEntry name="7BCDDFE27ECE1B51940CC5CC0CDAB1F1" fullContext="7BCDDFE27ECE1B51940CC5CC0CDAB1F1" translateForJs="false">Czytnik 7 INV</TranslationEntry>
    <TranslationEntry name="B87D8808939C11538C5ADE398E49D4E2" fullContext="B87D8808939C11538C5ADE398E49D4E2" translateForJs="false">Czytnik 8 INV</TranslationEntry>
    <TranslationEntry name="EC6582DADE11D290A8166BCE6422675F" fullContext="EC6582DADE11D290A8166BCE6422675F" translateForJs="false">Brak przejścia</TranslationEntry>
    <TranslationEntry name="BDDAE3A44C11982378744BA8DF8EA943" fullContext="BDDAE3A44C11982378744BA8DF8EA943" translateForJs="false">Czas odblokowania</TranslationEntry>
    <TranslationEntry name="61E064C7E8576FAA46BE907B7EFC599D" fullContext="61E064C7E8576FAA46BE907B7EFC599D" translateForJs="false">Ustawienia strony przejścia</TranslationEntry>
    <TranslationEntry name="CC86E7990F13BDCC22A072613EC0291D" fullContext="CC86E7990F13BDCC22A072613EC0291D" translateForJs="false">Ustawienia zewnętrzne</TranslationEntry>
    <TranslationEntry name="73FD61485ECC6B3993A62B291C9581AD" fullContext="73FD61485ECC6B3993A62B291C9581AD" translateForJs="false">Czytnik zewnętrzny</TranslationEntry>
    <TranslationEntry name="C0421A19A73FE1552780DABA20836DAF" fullContext="C0421A19A73FE1552780DABA20836DAF" translateForJs="false">Ustawienia wewnętrzne</TranslationEntry>
    <TranslationEntry name="56FE603C56710E2796455FF0D70A8F0F" fullContext="56FE603C56710E2796455FF0D70A8F0F" translateForJs="false">Czytnik wewnętrzny</TranslationEntry>
    <TranslationEntry name="B95D3D403307EFA40962DF363734E941" fullContext="B95D3D403307EFA40962DF363734E941" translateForJs="false">Ustawienia modułu</TranslationEntry>
    <TranslationEntry name="716AEAEBE771AFEC9DFEADD937072E55" fullContext="716AEAEBE771AFEC9DFEADD937072E55" translateForJs="false">Zbiorcza aktualizacja elementów:</TranslationEntry>
    <TranslationEntry name="6D9160DC4176D784DF94F92A091A9A59" fullContext="6D9160DC4176D784DF94F92A091A9A59" translateForJs="false">Aktualizuj wszystko</TranslationEntry>
    <TranslationEntry name="DE7F0327204217D20E8E4B6137B6AD45" fullContext="DE7F0327204217D20E8E4B6137B6AD45" translateForJs="false">Pokaż zaawansowane opcje przejścia</TranslationEntry>
    <TranslationEntry name="6D6B1DD152906B2CC826C006B4919529" fullContext="6D6B1DD152906B2CC826C006B4919529" translateForJs="false">Zaawansowane opcje przejścia</TranslationEntry>
    <TranslationEntry name="100D48494B9C8874E23F554D1B479A3C" fullContext="100D48494B9C8874E23F554D1B479A3C" translateForJs="false">Dodatkowy czytnik zewnętrzny</TranslationEntry>
    <TranslationEntry name="B526EA90857F7505EBDB2CE552BDAC4F" fullContext="B526EA90857F7505EBDB2CE552BDAC4F" translateForJs="false">Dodatkowy czytnik wewnętrzny</TranslationEntry>
    <TranslationEntry name="38E4601CFE55E505F0E8367A4B55158C" fullContext="38E4601CFE55E505F0E8367A4B55158C" translateForJs="false">Wydłużony czas odblokowania przejścia</TranslationEntry>
    <TranslationEntry name="72C2C6EF34847FE00AD4DCC32DAF8C30" fullContext="72C2C6EF34847FE00AD4DCC32DAF8C30" translateForJs="false">Poniższa tabela służy do konfiguracji linii wejściowych kontrolera Inception</TranslationEntry>
    <TranslationEntry name="8C1BC02D7974E64ABF24C741D1504E64" fullContext="6859082C4456019FF98F269B1F928278" translateForJs="false"> - Punkt sprzętowy odnosi się do fizycznych złączy na kontrolerze Inception. Złącza te są oznaczone na module, dlatego każdy punkt sprzętowy na liście ma odpowiadające złącze na kontrolerze Inception.</TranslationEntry>
    <TranslationEntry name="356C772625426F4F7C76AE753A58EFD3" fullContext="542BB8100E07F3C6AB2AD44EBAC035D8" translateForJs="false"> - Każdy punkt sprzętowy linii wejściowej w kontrolerze Inception może mieć ustawioną funkcjonalność jako jedną z trzech poniższych opcji.</TranslationEntry>
    <TranslationEntry name="B71A1EFE50E13DBC24EE47A2F352BB69" fullContext="9C6982303FED5A7A78CF9219659A8880" translateForJs="false"> - Jest to domyślne zachowanie linii wejściowej; pozostawienie go bez zmian spowoduje, że linia wejściowa nie będzie widoczna na innych stronach konfiguracji ani stanu.</TranslationEntry>
    <TranslationEntry name="31F211424A9A6691524EFAF082B315E6" fullContext="542BB8100E07F3C6AB2AD44EBAC035D8" translateForJs="false"> - Po wybraniu tej opcji linia wejściowa będzie działać jako standardowa czujka wykrywania wtargnięcia, np. PIR. Ta linia wejściowa wymaga podłączenia urządzenia detekcji z rezystorami End of Line, aby system mógł identyfikować stany alarmowy, uszczelniony i sabotażu. Po skonfigurowaniu, ta linia wejściowa musi być zaprogramowana do strefy w celu monitorowania zmian jej stanu lub użyta jako wyzwolenie dla automatyki.</TranslationEntry>
    <TranslationEntry name="7953438613159D406AB95411E1725EDC" fullContext="542BB8100E07F3C6AB2AD44EBAC035D8" translateForJs="false">Przełącznik/przycisk ogólny * Po wybraniu tej opcji linia wejściowa będzie działać jako standardowa linia wejściowa dla przycisków lub przełączników, np. punkt napadowy. Ta linia wejściowa nie wymaga rezystorów End of Line i jest zwykłą dwustanową linią przełącznika lub przycisku. Po skonfigurowaniu, ta linia wejściowa musi być zaprogramowana do strefy w celu monitorowania zmian jej stanu lub użyta jako wyzwolenie dla automatyki.</TranslationEntry>
    <TranslationEntry name="CAAAFA35FEAD89D5B94785396CE975F7" fullContext="542BB8100E07F3C6AB2AD44EBAC035D8" translateForJs="false"> - Linia wejściowa zostanie automatycznie nazwana na podstawie nazwy kontrolera Inception i zachowania linii wejściowej. Przy wprowadzaniu nazwy zaleca się stosowanie konwencji nazewnictwa, która identyfikuje punkt sprzętowy i podłączone urządzenie.</TranslationEntry>
    <TranslationEntry name="064F92A744A4FF0148DA83402678AC61" fullContext="064F92A744A4FF0148DA83402678AC61" translateForJs="false">Poniższa tabela służy do konfiguracji linii wejściowych dla 8-wejściowego Ekspandera</TranslationEntry>
    <TranslationEntry name="8967DFE9EF9A9D9645B920495FF85B66" fullContext="5D45CDBAB6978DD944E9EBC4B5D7E8EE" translateForJs="false"> - Punkt sprzętowy odnosi się do fizycznych złączy na Module 8-wejściowego Ekspandera. Złącza te są oznaczone na module, dlatego każdy punkt sprzętowy na liście ma odpowiadające złącze na 8-wejściowym Ekspanderze.</TranslationEntry>
    <TranslationEntry name="C67228B8EC0500FB42C093D1AAFE2027" fullContext="1677E796B5937B0343A6A645DB68B9DB" translateForJs="false"> - Każdy punkt sprzętowy na Ekspanderze 8 wejść może mieć funkcjonalność ustawioną na jedną z trzech opcji poniżej.</TranslationEntry>
    <TranslationEntry name="E7CF9D117923460DFBC851E4CF5E2644" fullContext="9C6982303FED5A7A78CF9219659A8880" translateForJs="false"> — Po wybraniu linia wejściowa będzie działać jako standardowa czujka bezpieczeństwa, np. czujka PIR. Ta linia wejściowa będzie wymagać podłączenia urządzenia detekcji z rezystorami EOL, aby system mógł identyfikować stany alarmu, uszczelnienia i sabotażu. Po skonfigurowaniu linia wejściowa musi zostać przypisana do strefy w celu monitorowania zmian jej stanu lub użyta jako wyzwolenie dla automatyki.</TranslationEntry>
    <TranslationEntry name="97C0D51624CD51D0516C6FB1EAC439A9" fullContext="9C6982303FED5A7A78CF9219659A8880" translateForJs="false"> - Jeśli wybrano tę opcję, linia wejściowa będzie działać jako standardowa linia wejściowa dla przycisków lub przełączników, takich jak punkt napadowy. Ta linia wejściowa nie wymaga rezystorów EOL i jest zwykłym dwustanowym przełącznikiem lub przyciskiem. Po skonfigurowaniu linia wejściowa musi zostać dodana do strefy w celu monitorowania zmian jej stanu lub użyta jako wyzwolenie dla automatyki.</TranslationEntry>
    <TranslationEntry name="6516F799349B53C45AFADB263B0418CD" fullContext="9C6982303FED5A7A78CF9219659A8880" translateForJs="false"> - Linia wejściowa zostanie automatycznie nazwana na podstawie nazwy modułu sprzętowego i zachowania linii wejściowej. W przypadku ręcznego wprowadzania nazwy zaleca się stosowanie konwencji nazewnictwa identyfikującej punkt sprzętowy i podłączone urządzenie.</TranslationEntry>
    <TranslationEntry name="D4920C844F348D9E5082D42B5E126502" fullContext="D4920C844F348D9E5082D42B5E126502" translateForJs="false">Wbudowane linie wejściowe</TranslationEntry>
    <TranslationEntry name="95890477A3098CEDD75641D7334CD7B4" fullContext="95890477A3098CEDD75641D7334CD7B4" translateForJs="false">Ekspander Unibus 9 - 16</TranslationEntry>
    <TranslationEntry name="974AF8F2B0D862ADD0CDC9EBA6C0F26A" fullContext="974AF8F2B0D862ADD0CDC9EBA6C0F26A" translateForJs="false">Ekspander Unibus 17 - 24</TranslationEntry>
    <TranslationEntry name="0A560AEC4C0BBBC15F1855F5B9E11BF3" fullContext="0A560AEC4C0BBBC15F1855F5B9E11BF3" translateForJs="false">Ekspander Unibus 25 - 32</TranslationEntry>
    <TranslationEntry name="AEC49F7A17457BACE21D17131450D6ED" fullContext="AEC49F7A17457BACE21D17131450D6ED" translateForJs="false">Lista przejść</TranslationEntry>
    <TranslationEntry name="706A2BEACBC876826C977898905B487D" fullContext="706A2BEACBC876826C977898905B487D" translateForJs="false">Odśwież przejście</TranslationEntry>
    <TranslationEntry name="B718ADEC73E04CE3EC720DD11A06A308" fullContext="B718ADEC73E04CE3EC720DD11A06A308" translateForJs="false">ID</TranslationEntry>
    <TranslationEntry name="F4EC5F57BD4D31B803312D873BE40DA9" translateForJs="true">Zmień</TranslationEntry>
    <TranslationEntry name="F4D72A64ACD8929C0CC9ED96A7A336CC" translateForJs="true">Uwzględnij</TranslationEntry>
    <TranslationEntry name="0063394F0497BFD610EBAC0AEE7CFC34" fullContext="0063394F0497BFD610EBAC0AEE7CFC34" translateForJs="false">Powiązania</TranslationEntry>
    <TranslationEntry name="BB7330938F57A1368D922C1D8D6BB5E5" fullContext="9E4688213E5ED5662BB1992FCFE099F2" translateForJs="false">To ustawienie kojarzy pojedynczą strefę z tym terminalem LCD w celu wskazania stanu i wygody użytkowania. </TranslationEntry>
    <TranslationEntry name="44B77AA9BDD72D3114DD307F508E6906" fullContext="9E4688213E5ED5662BB1992FCFE099F2" translateForJs="false">Podczas nawigacji do menu Sterowanie strefą ta strefa będzie domyślnie zaznaczona, jeśli w systemie skonfigurowano wiele stref</TranslationEntry>
    <TranslationEntry name="51FE54977E8FF69F71B2B810719B453C" fullContext="9E4688213E5ED5662BB1992FCFE099F2" translateForJs="false">Po wylogowaniu terminal będzie emitował dźwięki sygnalizacji zwrotnej informujące o aktywnym alarmie w strefie, aktywnym opóźnieniu na wejście lub wyjście, lub o zbliżającym się automatycznym uzbrojeniu strefy. Jeśli użytkownik zaloguje się, gdy jeden z tych komunikatów sygnalizacji zwrotnej jest aktywny, terminal automatycznie przeniesie go do menu Steruj strefą w celu szybkiego sterowania.</TranslationEntry>
    <TranslationEntry name="5886C1EF1B3082C2ED7DB10B3D70C934" fullContext="9E4688213E5ED5662BB1992FCFE099F2" translateForJs="false">Ponadto powiązanie strefy z terminalem umożliwia uzbrajanie i rozbrajanie tej strefy bez konieczności przechodzenia do menu Steruj strefą. Podczas logowania do terminalu, zamiast naciskania </TranslationEntry>
    <TranslationEntry name="86276E0EFE4A2B64D7B3CBDD226ADC9A" fullContext="5424FB0F400B58E9C95059406FEA40B4" translateForJs="false">[OK]</TranslationEntry>
    <TranslationEntry name="50421F562D4008690125BA2171F68A62" fullContext="9E4688213E5ED5662BB1992FCFE099F2" translateForJs="false"> przycisk po wprowadzeniu PIN-u użytkownika, </TranslationEntry>
    <TranslationEntry name="C664785135D4027CAB6C62F604DEA751" fullContext="9E4688213E5ED5662BB1992FCFE099F2" translateForJs="false"> przycisk może być wciśnięty zamiast tego, aby bezpośrednio uzbroić lub rozbroić strefę. Na przykład, aby rozbroić skojarzoną strefę, użytkownik może nacisnąć </TranslationEntry>
    <TranslationEntry name="63BDE87C684DF141F47ABF0463F48826" fullContext="2CC306E97C3E4A8ED8A671C717B9BDEF" translateForJs="false">[Numer PIN]</TranslationEntry>
    <TranslationEntry name="C84DA3EECDC39E6D2B6A5405A90B290E" fullContext="9E4688213E5ED5662BB1992FCFE099F2" translateForJs="false"> jako skrót, minimalizując liczbę wymaganych naciśnięć klawiszy. </TranslationEntry>
    <TranslationEntry name="780462C15F9A3C4F03418791714A9D69" fullContext="BCF820E0F5FB7CBA84BA02EE0A392019" translateForJs="false">To ustawienie określa, które strefy będą wyświetlane w menu Sterowanie strefą terminala LCD.</TranslationEntry>
    <TranslationEntry name="9AB65E399EB3EF1B35B9862E2A64FC4E" fullContext="BCF820E0F5FB7CBA84BA02EE0A392019" translateForJs="false">Jeśli do listy przypisano strefy, menu Sterowanie strefą zostanie przefiltrowane tak, aby wyświetlać tylko te strefy; jeśli lista jest pusta, żaden filtr nie zostanie zastosowany do listy stref.</TranslationEntry>
    <TranslationEntry name="206D62DB1920EF285913F049296D7A63" fullContext="BCF820E0F5FB7CBA84BA02EE0A392019" translateForJs="false">Ta funkcja może być przydatna w systemach z wieloma strefami, na przykład poprzez filtrowanie do stref w pobliżu danego terminalu LCD. Gdy użytkownik korzysta z terminalu w celu sterowania strefą, widzi tylko najbardziej odpowiednie strefy dla danego terminalu, zamiast przewijać przez wszystkie strefy w systemie.</TranslationEntry>
    <TranslationEntry name="FA725B38C256C2B8ACA3D555EC54E851" fullContext="BCF820E0F5FB7CBA84BA02EE0A392019" translateForJs="false">Uwaga: To ustawienie wpływa również na </TranslationEntry>
    <TranslationEntry name="338D7BEE655D2D641F675BC948F18F12" fullContext="BCF820E0F5FB7CBA84BA02EE0A392019" translateForJs="false"> ustawienie. Jeśli na tej liście są jakieś strefy, </TranslationEntry>
    <TranslationEntry name="B21C635877AC8A38F6B4CD3371E147CF" fullContext="BCF820E0F5FB7CBA84BA02EE0A392019" translateForJs="false"> musi być również uwzględniony na liście.</TranslationEntry>
    <TranslationEntry name="BB6C59233C7913BFF6AF448BE46CA104" fullContext="A17D0D35FE5CAFC4F167ED272E406818" translateForJs="false">Powiązane przejście</TranslationEntry>
    <TranslationEntry name="0BAE91E79F0679AEC5103E4E58BB8C49" fullContext="2CC306E97C3E4A8ED8A671C717B9BDEF" translateForJs="false">To ustawienie przypisuje przejście do terminala LCD. Gdy użytkownik zaloguje się do tego terminala LCD i naciśnie </TranslationEntry>
    <TranslationEntry name="49D0420458803EA474A9E82B39462393" fullContext="2CC306E97C3E4A8ED8A671C717B9BDEF" translateForJs="false"> przycisk (np. </TranslationEntry>
    <TranslationEntry name="624876D24154737343F953714FF45F28" fullContext="2CC306E97C3E4A8ED8A671C717B9BDEF" translateForJs="false">) uzyskają dostęp do powiązanego przejścia, jeśli posiadają odpowiednie uprawnienia użytkownika.</TranslationEntry>
    <TranslationEntry name="F7E6008C917FCBBB2CC6210D8ED7D254" fullContext="2CC306E97C3E4A8ED8A671C717B9BDEF" translateForJs="false">Po powiązaniu z przejściem, </TranslationEntry>
    <TranslationEntry name="D1D744A4A96B103C7217FC03629A05D3" fullContext="D1D744A4A96B103C7217FC03629A05D3" translateForJs="false">Strona przejścia</TranslationEntry>
    <TranslationEntry name="E9A08DF5891C7E54D19C8A7184BD813C" fullContext="2CC306E97C3E4A8ED8A671C717B9BDEF" translateForJs="false"> opcja poniżej musi być ustawiona przed użyciem tego Terminalu LCD do kontroli dostępu. </TranslationEntry>
    <TranslationEntry name="2705AFB70B0537D6977ECA94C7F7D36C" fullContext="2CC306E97C3E4A8ED8A671C717B9BDEF" translateForJs="false">Ten terminal LCD będzie również sygnalizować dźwiękiem, gdy drzwi są przytrzymane otwarte (kontaktron lub styk językowy jest utrzymywany w stanie otwartym przy zablokowanym przejściu przez czas przekraczający </TranslationEntry>
    <TranslationEntry name="3315BE8D36D8DD78E077A81BC95D5B39" fullContext="2CC306E97C3E4A8ED8A671C717B9BDEF" translateForJs="false"> ).</TranslationEntry>
    <TranslationEntry name="3D24FCFE3A30887987956547CF9A0F96" fullContext="C47BFB9A3CE51CE681B427DEFC959360" translateForJs="false">Określa położenie Terminala LCD względem </TranslationEntry>
    <TranslationEntry name="4D20B928665A7A7B41DE1D7955677B06" fullContext="C47BFB9A3CE51CE681B427DEFC959360" translateForJs="false">. Jest to wymagane, jeśli zamierzasz używać tego terminala do dostępu PIN lub </TranslationEntry>
    <TranslationEntry name="957A4BD040A40C48F340145579C3A85C" fullContext="C47BFB9A3CE51CE681B427DEFC959360" translateForJs="false"> przycisk jako przycisk wyjścia po wylogowaniu. Umożliwia to również aktualizację lokalizacji użytkownika podczas dostępu za pomocą PIN, gdy po drugiej stronie przejścia znajduje się strefa. </TranslationEntry>
    <TranslationEntry name="E9A6090BDD42B77DD173179D35D06FB3" fullContext="C47BFB9A3CE51CE681B427DEFC959360" translateForJs="false">Uwaga: aby zezwolić na dostęp przez PIN, upewnij się, że przejście jest skonfigurowane do zezwalania na dostęp przez PIN od strony przejścia, po której znajduje się terminal</TranslationEntry>
    <TranslationEntry name="3082265617918F321E1CF28427912064" fullContext="3082265617918F321E1CF28427912064" translateForJs="false">Zachowanie po wylogowaniu bez autoryzacji</TranslationEntry>
    <TranslationEntry name="F23ED8E08007E73DA9712BB72B8DE163" fullContext="A17D0D35FE5CAFC4F167ED272E406818" translateForJs="false">Umożliwia terminala </TranslationEntry>
    <TranslationEntry name="F1D0A6B203C260CB071BEFBBDBFC4C0A" fullContext="A17D0D35FE5CAFC4F167ED272E406818" translateForJs="false"> przycisk, który ma być używany jako przycisk żądania dostępu dla </TranslationEntry>
    <TranslationEntry name="EE827E2B9EE19D1FB170BD0E9C48A555" fullContext="A17D0D35FE5CAFC4F167ED272E406818" translateForJs="false"> gdy terminal jest wylogowany. Ta opcja jest przydatna w sytuacjach, gdy terminale mogą znajdować się już w pobliżu przejścia i wymagany jest przycisk wyjścia/wejścia. Ta funkcja eliminuje potrzebę instalowania osobnego przycisku dostępu.</TranslationEntry>
    <TranslationEntry name="5D2E21151BF1F2B96CC99EAD4413263F" fullContext="5D2E21151BF1F2B96CC99EAD4413263F" translateForJs="false">Klawiatura tylko dla dostępu</TranslationEntry>
    <TranslationEntry name="E4868DED06348994921EC96B49419A3D" fullContext="5424FB0F400B58E9C95059406FEA40B4" translateForJs="false">Jeśli włączone, terminal LCD będzie ograniczony wyłącznie do funkcji kontroli dostępu, takich jak dostęp przez PIN dla wejścia/wyjścia lub wylogowany </TranslationEntry>
    <TranslationEntry name="8B91D70035DE721B955000CEDCA1D015" fullContext="5424FB0F400B58E9C95059406FEA40B4" translateForJs="false"> przycisk dla REN/REX.</TranslationEntry>
    <TranslationEntry name="AA66A9D9981192FAB1AE9F863BCCD341" fullContext="5424FB0F400B58E9C95059406FEA40B4" translateForJs="false">Ta opcja uniemożliwia wszystkim użytkownikom logowanie się do Terminala LCD w celu wykonywania innych zadań, takich jak wprowadzanie zmian w programowaniu, uzbrajanie stref lub sterowanie liniami wyjściowymi. </TranslationEntry>
    <TranslationEntry name="D9FCDC4A3F477055B9385FCB56BF32BA" fullContext="5424FB0F400B58E9C95059406FEA40B4" translateForJs="false">Uwaga: Ta opcja powinna być włączona tylko wtedy, gdy terminal LCD jest używany wyłącznie do kontroli dostępu lub istnieje potencjalne zagrożenie bezpieczeństwa z powodu umieszczenia terminala LCD w miejscu publicznym. </TranslationEntry>
    <TranslationEntry name="48F16F8E8224473AA120BFA0F5DB596F" fullContext="48F16F8E8224473AA120BFA0F5DB596F" translateForJs="false">Zapewnij sygnalizację zwrotną alertu</TranslationEntry>
    <TranslationEntry name="13A3EDBE8A5320FBFFE17326BF9CC11D" fullContext="7EFB8F6BAF553165017C6DCE258C449B" translateForJs="false">Jeśli włączone, terminal LCD będzie mógł informować użytkowników o obecności komunikatów systemowych i ostrzeżeń systemowych. Umożliwia to systemowi Inception przyciągnięcie uwagi użytkowników, gdy ma nowe informacje do wyświetlenia, lub jako przypomnienie o problemach do rozwiązania.</TranslationEntry>
    <TranslationEntry name="718A05856EBC3510B0F74DF4E8FD3F49" fullContext="7EFB8F6BAF553165017C6DCE258C449B" translateForJs="false">Sygnalizacja zwrotna alertu będzie zapewniana przez głośnik i diody LED terminala LCD. Jeśli Inception musi powiadomić użytkowników, wewnętrzny głośnik terminala LCD będzie sygnalizować dźwiękowo, a diody LED, które nie wyświetlają stanu elementu (skonfigurowane w </TranslationEntry>
    <TranslationEntry name="004EAB6F736E7BA7461FAE253E58D082" fullContext="004EAB6F736E7BA7461FAE253E58D082" translateForJs="false">Wyświetlacz stanu LED</TranslationEntry>
    <TranslationEntry name="09D13B1EFE8DFC67F6F43CA559BD29BA" fullContext="7EFB8F6BAF553165017C6DCE258C449B" translateForJs="false"> sekcja) będzie migać.</TranslationEntry>
    <TranslationEntry name="6DEC6449FFCF82E1844DC02712B690B9" fullContext="7EFB8F6BAF553165017C6DCE258C449B" translateForJs="false">Sygnalizacja zwrotna alertu będzie dozwolona tylko wtedy, gdy system jest rozbrojony. Jeśli z terminalem jest skojarzona strefa (sugerująca lokalizację terminalu), sygnalizacja zwrotna alertu będzie dozwolona, gdy ta strefa jest rozbrojona. W przeciwnym razie wszystkie strefy w systemie muszą być rozbrojone.</TranslationEntry>
    <TranslationEntry name="DF83087495FFD80874E7202A4A4282A6" fullContext="7EFB8F6BAF553165017C6DCE258C449B" translateForJs="false">Mogą wystąpić dwa różne typy sygnalizacji zwrotnej alertu. Gdy zostanie utworzone nowe ostrzeżenie lub komunikat, terminal będzie sygnalizować dźwiękowo ciągłym sygnałem z szybko migającymi diodami LED. Gdy użytkownik wyświetli komunikaty i ostrzeżenia (np. przeglądając menu Zdarzenia systemowe terminala LCD lub przeglądając stronę </TranslationEntry>
    <TranslationEntry name="EDED163390BADCFED854CD0608585FD8" fullContext="D031838F00CEB572817EC270348400AA" translateForJs="false">[System &gt; Przegląd systemu]</TranslationEntry>
    <TranslationEntry name="B9289036F5E9CA5B8DA8E89C5B0CA06C" fullContext="7EFB8F6BAF553165017C6DCE258C449B" translateForJs="false"> strona internetowa), terminal będzie sygnalizować dźwiękiem przez 1 sekundę co dwie minuty, aby przypomnieć użytkownikowi, że nadal są ostrzeżenia lub komunikaty do przetworzenia. Użytkownik może wyświetlić menu Zdarzenia systemowe terminala LCD tylko wtedy, gdy jego </TranslationEntry>
    <TranslationEntry name="5F230EDFE0E31AF9EA839275F87999AC" fullContext="7EFB8F6BAF553165017C6DCE258C449B" translateForJs="false"> nadaje im uprawnienie.</TranslationEntry>
    <TranslationEntry name="136282CD7074AF7DB8B17843B1C670B9" fullContext="7EFB8F6BAF553165017C6DCE258C449B" translateForJs="false">Ponadto, jeśli Komunikat lub Ostrzeżenie będzie się utrzymywać przez jakiś czas, sygnalizacja zwrotna alertów dla aktualnie obecnych zdarzeń może zostać wyciszona poprzez naciśnięcie WYŁ. w menu Zdarzenia systemowe terminala LCD (i WŁ., aby cofnąć wyciszenie) lub za pomocą </TranslationEntry>
    <TranslationEntry name="FBB71DCB7ABC4D8F092B47C1EC3AEF55" fullContext="FBB71DCB7ABC4D8F092B47C1EC3AEF55" translateForJs="false">Wycisz/Wyłącz wyciszenie sygnalizacji zwrotnej alertu</TranslationEntry>
    <TranslationEntry name="90F6B5F04E6F532A203F67C096BC0558" fullContext="7EFB8F6BAF553165017C6DCE258C449B" translateForJs="false"> strona. Jeśli nowy Komunikat lub Ostrzeżenie zostanie wygenerowane podczas gdy inne są wyciszone, standardowa sygnalizacja zwrotna alertów nadal będzie działać.</TranslationEntry>
    <TranslationEntry name="E7DED1413C889E886CADAC766502166F" fullContext="7EFB8F6BAF553165017C6DCE258C449B" translateForJs="false">Nie wszystkie ostrzeżenia ani komunikaty wyzwalają sygnalizację zwrotną alertu. Ogólnie rzecz biorąc, sygnalizację zwrotną alertu wyzwalają ostrzeżenia i komunikaty związane z problemami z kondycją sprzętu, problemami ze ścieżką raportowania i uszkodzeniami linii wejściowych. Ponadto tymczasowo zaizolowane linie wejściowe i nieautoryzowane logowania użytkowników poziomu 3 będą wyzwalać sygnalizację zwrotną alertu.</TranslationEntry>
    <TranslationEntry name="53E0DBC06E48E3D381AC224FA8BAE3DF" fullContext="53E0DBC06E48E3D381AC224FA8BAE3DF" translateForJs="false">LED</TranslationEntry>
    <TranslationEntry name="689B82D633F38B6C98A01E8A1C82BF4D" fullContext="689B82D633F38B6C98A01E8A1C82BF4D" translateForJs="false">Element do wyświetlenia</TranslationEntry>
    <TranslationEntry name="DACC8AA21C91B132EC342238DB8615C8" fullContext="FDF5DEA3C326ABA0726E86A6B61B65D5" translateForJs="false">Odwróć stan</TranslationEntry>
    <TranslationEntry name="D6AD850EE4872A2C175BC8EA8C55EF1C" fullContext="FDF5DEA3C326ABA0726E86A6B61B65D5" translateForJs="false">Te opcje umożliwiają mapowanie stanu stref, przejść lub linii wyjściowych na diody LED terminala LCD.</TranslationEntry>
    <TranslationEntry name="E11E01F84721DCA3D8C4593695B4CB6A" fullContext="FDF5DEA3C326ABA0726E86A6B61B65D5" translateForJs="false"> - Dioda LED świeci przy uzbrojonej strefie, nie świeci przy rozbrojonej. Dioda LED miga szybko przy strefie w alarmie, miga wolno przy opóżnieniu na wejście, wyjście i stanach ostrzeżenia o uzbrajaniu</TranslationEntry>
    <TranslationEntry name="35C4DA26B99A08BC52C3710560BEE2D5" fullContext="FDF5DEA3C326ABA0726E86A6B61B65D5" translateForJs="false"> - Dioda LED świeci przy zablokowanym przejściu, nie świeci przy odblokowaniu. Dioda LED miga szybko przy siłowym otwarciu, miga wolno przy zbyt długim otwarciu (DOTL)</TranslationEntry>
    <TranslationEntry name="85741B27B671FDDE92907C2DD271B056" fullContext="FDF5DEA3C326ABA0726E86A6B61B65D5" translateForJs="false"> — dioda LED świeci, gdy linia wyjściowa jest włączona; nie świeci, gdy jest wyłączona.</TranslationEntry>
    <TranslationEntry name="AA5AA92D6AA235EA23BA5999D1B7A673" fullContext="6B84C55F05D9A4499AEF73D8C79DD875" translateForJs="false">Uwaga: </TranslationEntry>
    <TranslationEntry name="917EC3EE0711EDE26681E0E956FE6F0D" fullContext="FDF5DEA3C326ABA0726E86A6B61B65D5" translateForJs="false"> opcja służy do odwrócenia stanów, które włączają i wyłączają diody LED. </TranslationEntry>
    <TranslationEntry name="D036E2F7CC5EA585D65D53DCB5901CC9" fullContext="D036E2F7CC5EA585D65D53DCB5901CC9" translateForJs="false">Linie wejściowe/wyjściowe terminala</TranslationEntry>
    <TranslationEntry name="F95D018D36DA389A63BB86E7A01303C2" fullContext="F95D018D36DA389A63BB86E7A01303C2" translateForJs="false">Włącz wykrywanie sabotażu</TranslationEntry>
    <TranslationEntry name="F0B9EC351970D279D47DD78A1F773E10" fullContext="B5449786C966F58932DF739FACC97246" translateForJs="false">Jeśli skonfigurowano, linia wejściowa sabotażu obudowy na terminalu będzie monitorowana przez system i uwzględniana w ogólnym monitorowaniu stanu systemu. System przekaże to zdarzenie sprzętowe do stacji monitorowania, jeśli raportowanie alarmów jest włączone i prawidłowo skonfigurowane. Ponadto wszystkie strefy przejdą w stan alarmu po wykryciu sabotażu, niezależnie od tego, czy strefa jest uzbrojona, i będą musiały zostać rozbrojone, aby wyłączyć sygnalizatory i lampy stroboskopowe.</TranslationEntry>
    <TranslationEntry name="3FA21610D9859A9F62FD0D8B7BD3BF02" fullContext="3FA21610D9859A9F62FD0D8B7BD3BF02" translateForJs="false">Poniższa tabela służy do konfiguracji linii wejściowych dla Terminala dotykowego</TranslationEntry>
    <TranslationEntry name="1B5F688B48BF4E8B24AAD65F4B88DD9D" fullContext="F4C34BF1DC118A1C04FD272376296F0D" translateForJs="false"> - Punkt sprzętowy odnosi się do fizycznych złączy na Module dotykowym. Złącza te są oznaczone na module, dlatego każdy punkt sprzętowy na liście ma odpowiadające złącze na Ekranie dotykowym.</TranslationEntry>
    <TranslationEntry name="448FE8DB5091D7AC391DD32516FE965A" fullContext="9C6982303FED5A7A78CF9219659A8880" translateForJs="false"> - Każdy punkt sprzętowy na Terminalu dotykowym może mieć funkcjonalność ustawioną na jedną z trzech opcji poniżej.</TranslationEntry>
    <TranslationEntry name="F436C3C6CC4AD12C0F5EE58BC9FCE88F" fullContext="F436C3C6CC4AD12C0F5EE58BC9FCE88F" translateForJs="false">Poniższa tabela służy do konfigurowania linii wyjściowych dla terminala ekranowego.</TranslationEntry>
    <TranslationEntry name="79531DF6CC3B7B704F7E47553EB84CB9" fullContext="5D45CDBAB6978DD944E9EBC4B5D7E8EE" translateForJs="false">Typ linii wyjściowej</TranslationEntry>
    <TranslationEntry name="090ED925E64CA66F1501FD3837D30D5B" fullContext="F4C34BF1DC118A1C04FD272376296F0D" translateForJs="false"> — Każdy punkt sprzętowy linii wyjściowej na ekranie dotykowym może mieć ustawioną funkcjonalność zgodnie z jedną z poniższych opcji.</TranslationEntry>
    <TranslationEntry name="9EEA85B4979F1140DBE628F2C5228BA0" fullContext="5D45CDBAB6978DD944E9EBC4B5D7E8EE" translateForJs="false"> — jest to domyślne zachowanie linii wyjściowej i jeśli nie zostanie zmienione, linia wyjściowa nie pojawi się na innych stronach konfiguracji ani stanu.</TranslationEntry>
    <TranslationEntry name="5A2E7D2B23E5D842CDD50E8523A048FF" fullContext="5D45CDBAB6978DD944E9EBC4B5D7E8EE" translateForJs="false"> - Jeśli zaznaczono, linią wyjściową może sterować system lub użytkownik w celu aktywacji urządzeń takich jak stroboskopy, sygnalizatory i sterowanie oświetleniem. Linia wyjściowa będzie widoczna na stronach konfiguracji lub stanu, jednak aby użytkownik mógł nią sterować, musi być skonfigurowana jako </TranslationEntry>
    <TranslationEntry name="FB8777EAF9B2B65CAACDFE8BF676EAFA" fullContext="5D45CDBAB6978DD944E9EBC4B5D7E8EE" translateForJs="false">Sterowany przez użytkownika</TranslationEntry>
    <TranslationEntry name="3343CE9009FC679113EBD938785CE4A1" fullContext="5D45CDBAB6978DD944E9EBC4B5D7E8EE" translateForJs="false"> i być przypisane do uprawnień użytkownika</TranslationEntry>
    <TranslationEntry name="895DECA7A669B2D41A1C9E9331D03C53" fullContext="5D45CDBAB6978DD944E9EBC4B5D7E8EE" translateForJs="false"> - Linia wyjściowa zostanie automatycznie nazwana na podstawie nazwy modułu sprzętowego i punktu sprzętowego. Jeśli wprowadzasz nazwę, zaleca się stosowanie konwencji nazewnictwa identyfikującej punkt sprzętowy i podłączone urządzenie.</TranslationEntry>
    <TranslationEntry name="F2963B048CC69AC95769E7FF360F61D8" fullContext="F2963B048CC69AC95769E7FF360F61D8" translateForJs="false">Wbudowane linie wyjściowe</TranslationEntry>
    <TranslationEntry name="0A91AF2E8ED7C0027E29FA3423BED960" fullContext="0A91AF2E8ED7C0027E29FA3423BED960" translateForJs="false">Włącz linię wejściową 1</TranslationEntry>
    <TranslationEntry name="721CD04D2E09DF4C1F67EBAE1DEFF21F" fullContext="4A2CBFB52DDCFAD380D635A7E1CC5C12" translateForJs="false">Jeśli wybrano, do terminalu LCD można podłączyć normalnie zamknięte urządzenie detekcji lub przycisk/przełącznik. Wejście terminalu LCD nie obsługuje rezystorów End of Line i dlatego nie może identyfikować stanu sabotażu czujki; nie zaleca się stosowania tego wejścia do celów bezpieczeństwa. To wejście jest powszechnie używane do automatyki, np. jako przycisk wykonujący zautomatyzowaną akcję. </TranslationEntry>
    <TranslationEntry name="3098B83735CD64006D9045A749C4F219" fullContext="E9F7A6ED463BC1F6AF0214370050EB9E" translateForJs="false">Linia wejściowa jest podłączona do złącza GND i X3/Z01 na tylnym panelu Terminala LCD.</TranslationEntry>
    <TranslationEntry name="F2B15B7FD51C031F5BD33E1C5563FBBF" fullContext="F2B15B7FD51C031F5BD33E1C5563FBBF" translateForJs="false">Nazwa linii wejściowej 1</TranslationEntry>
    <TranslationEntry name="1E6DBA589C141310279F6B3B295271B7" fullContext="5B0A0576B1E59A05B94F1B0DEA14591A" translateForJs="false">Nazwa tej linii wejściowej, która będzie używana w całym systemie</TranslationEntry>
    <TranslationEntry name="1977B71A379EFE00B9EA0F2294ABB1BD" fullContext="1977B71A379EFE00B9EA0F2294ABB1BD" translateForJs="false">Typ linii wejściowej 1</TranslationEntry>
    <TranslationEntry name="B8B091933310E41E813046E80CD68EB5" fullContext="171F0E834BE84BE3A2260BE472233452" translateForJs="false">Określa sposób działania tej linii wejściowej oraz sposób interpretowania informacji o stanie.</TranslationEntry>
    <TranslationEntry name="94BC8D500B0C8E7784B6DB26A431F27B" fullContext="171F0E834BE84BE3A2260BE472233452" translateForJs="false">Przełącznik/Przycisk</TranslationEntry>
    <TranslationEntry name="3EEEEF3F8AD49D15554D650848E87B60" fullContext="171F0E834BE84BE3A2260BE472233452" translateForJs="false"> - Po wybraniu tej opcji linia wejściowa będzie działać jako standardowa linia wejściowa dla przycisków lub przełączników, np. punkt napadowy. Ta linia wejściowa nie wymaga rezystorów End of Line i jest zwykłą dwustanową linią przełącznika lub przycisku. Po skonfigurowaniu, ta linia wejściowa musi być zaprogramowana do strefy w celu monitorowania zmian jej stanu lub użyta jako wyzwolenie dla automatyki.</TranslationEntry>
    <TranslationEntry name="CFEDF3E4C105CBF6008EC79BBE826233" fullContext="171F0E834BE84BE3A2260BE472233452" translateForJs="false"> - Po wybraniu linia wejściowa będzie funkcjonować jako standardowa linia wejściowa czujki bezpieczeństwa, np. PIR. Linia wejściowa wymaga podłączenia urządzenia detekcyjnego z rezystorami EOL, umożliwiając systemowi identyfikację stanów alarmu, normalnego i sabotażu. Po skonfigurowaniu linia wejściowa musi zostać przypisana do strefy w celu monitorowania zmian stanu lub użyta jako wyzwalacz automatyki.</TranslationEntry>
    <TranslationEntry name="21C752AD64407D117FE0584B1E47DE02" fullContext="21C752AD64407D117FE0584B1E47DE02" translateForJs="false">Włącz linię wejściową 2</TranslationEntry>
    <TranslationEntry name="AA1EC524ED908F6878133D8DB932504A" fullContext="4A2CBFB52DDCFAD380D635A7E1CC5C12" translateForJs="false">Linia wejściowa jest podłączona do złącza GND i X3/Z02 na tylnym panelu Terminala LCD.</TranslationEntry>
    <TranslationEntry name="BD9538D7866723288E5EBBE0A7959174" fullContext="BD9538D7866723288E5EBBE0A7959174" translateForJs="false">Nazwa linii wejściowej 2</TranslationEntry>
    <TranslationEntry name="E588375D4AE8C12D9B53C9C5BDF9947E" fullContext="E588375D4AE8C12D9B53C9C5BDF9947E" translateForJs="false">Typ linii wejściowej 2</TranslationEntry>
    <TranslationEntry name="B4999973889E5DB2EDEC40268E588A18" fullContext="B4999973889E5DB2EDEC40268E588A18" translateForJs="false">Włącz linię wyjściową 1</TranslationEntry>
    <TranslationEntry name="FBC63C0B30AF117D012CD2C9BB980070" fullContext="8360F7668088380F7CBADDB62317C916" translateForJs="false">Jeśli zaznaczono, do terminala LCD można podłączyć wyjście z otwartym kolektorem. To wyjście jest linią wyjściową ogólnego przeznaczenia i może być używane do funkcji automatyki i zabezpieczeń. Linia wyjściowa może przełączać maksymalnie 100 mA; jeśli konieczne jest przełączenie większego prądu, zaleca się użycie tej linii wyjściowej do sterowania przekaźnikiem.</TranslationEntry>
    <TranslationEntry name="1CD7912D7FA4C3A85A946306A282FECF" fullContext="82C23E3896E067EFE0988B5192C02861" translateForJs="false">Linia wyjściowa jest podłączona do złącza +VE i X1 z tyłu Terminalu LCD.</TranslationEntry>
    <TranslationEntry name="983E6B12D58BD125691E0E705B519E17" fullContext="983E6B12D58BD125691E0E705B519E17" translateForJs="false">Nazwa linii wyjściowej 1</TranslationEntry>
    <TranslationEntry name="8D48D8A5EB03DAFC00CC910B94AEFDD5" fullContext="355B2F822AB843ACE9A84EDD3C3D9FA3" translateForJs="false">Nazwa tej linii wyjściowej, która będzie używana w całym systemie</TranslationEntry>
    <TranslationEntry name="D3EB2729984DA2BE460670AF16368D1C" fullContext="D3EB2729984DA2BE460670AF16368D1C" translateForJs="false">Włącz linię wyjściową 2</TranslationEntry>
    <TranslationEntry name="4C00BAF3A7B4CE22DECEB35678128D6E" fullContext="8360F7668088380F7CBADDB62317C916" translateForJs="false">Linia wyjściowa jest podłączona do złącza +VE i AX2 z tyłu Terminala LCD.</TranslationEntry>
    <TranslationEntry name="524445F0DE7587CADF30BF1271A82A25" fullContext="524445F0DE7587CADF30BF1271A82A25" translateForJs="false">Nazwa linii wyjściowej 2</TranslationEntry>
    <TranslationEntry name="1B2D11B3B34999BAAC848153BC6552A8" fullContext="1B2D11B3B34999BAAC848153BC6552A8" translateForJs="false">Linia wyjściowa przewodowa</TranslationEntry>
    <TranslationEntry name="297BC4968B749A2BBE8F4F9CA3D0DA5F" fullContext="297BC4968B749A2BBE8F4F9CA3D0DA5F" translateForJs="false">Interfejsy windy</TranslationEntry>
    <TranslationEntry name="DCBA1267707F9AEE679C46489821B3DB" fullContext="DCBA1267707F9AEE679C46489821B3DB" translateForJs="false">Poniższa tabela służy do konfiguracji kart interfejsu windy dla 8-wejściowego Ekspandera.</TranslationEntry>
    <TranslationEntry name="DF050D82D8D7D0C9ACE509471C8375CC" fullContext="A5A925FCA7697E7E1E131DAD7940E722" translateForJs="false">Każdy punkt sprzętowy piętra na karcie interfejsu windy ma styk przekaźnikowy do sterowania przyciskiem windy, a także wejście wykrywające naciśnięcie przycisku. Więcej informacji o podłączaniu tych elementów znajdziesz w instrukcji instalacji dla Ekspandera interfejsu windy Unibus 16-Floor. </TranslationEntry>
    <TranslationEntry name="52814C48641F5BAD68E48C93609046F4" fullContext="A5A925FCA7697E7E1E131DAD7940E722" translateForJs="false">Poniższe tabele umożliwiają konfigurację linii wejściowych i wyjściowych pięter dla kart interfejsu windy, które zostały podłączone. Do interfejsu unibus można podłączyć do 6 kart interfejsu windy, umożliwiając konfigurację do 96 punktów piętrowych.</TranslationEntry>
    <TranslationEntry name="157B99299BB412AC59E81FFC55638077" fullContext="A5A925FCA7697E7E1E131DAD7940E722" translateForJs="false"> - Punkt sprzętowy odnosi się do fizycznych złączy na 16-piętrowym Ekspanderze interfejsu windy. Złącza te są oznaczone na module, dlatego każdy punkt sprzętowy na liście ma odpowiadające złącze na kartach interfejsu windy.</TranslationEntry>
    <TranslationEntry name="AB1CD2A06DBE01207EF90B353EC53DD7" fullContext="AB1CD2A06DBE01207EF90B353EC53DD7" translateForJs="false">Piętro podłączone</TranslationEntry>
    <TranslationEntry name="4B1633E058155BAF23DD69654EE3CB41" fullContext="A5A925FCA7697E7E1E131DAD7940E722" translateForJs="false"> - Każdy punkt sprzętowy może być skonfigurowany jako </TranslationEntry>
    <TranslationEntry name="637D1CFAC18A109A5A514F46D8947D5F" fullContext="A5A925FCA7697E7E1E131DAD7940E722" translateForJs="false">. Jeśli jest okablowane, linia wejściowa i linia wyjściowa zostaną automatycznie utworzone dla tego punktu sprzętowego. Dla pięter, które nie są okablowane, nic nie zostanie wygenerowane.</TranslationEntry>
    <TranslationEntry name="FF430CB85BA292344B1FEF5AC105AC71" fullContext="A5A925FCA7697E7E1E131DAD7940E722" translateForJs="false"> - Linia wejściowa i wyjściowa zostaną automatycznie nazwane na podstawie nazwy modułu sprzętowego i punktu sprzętowego. Jeśli wprowadzasz nazwę, zaleca się stosowanie konwencji nazewnictwa identyfikującej punkt sprzętowy i podłączone urządzenie. Wygenerowana linia wejściowa będzie miała </TranslationEntry>
    <TranslationEntry name="FC1FD2DBFA916D93186FEC10D2F31E86" fullContext="A5A925FCA7697E7E1E131DAD7940E722" translateForJs="false"> - Wykrywanie</TranslationEntry>
    <TranslationEntry name="6C8F561F4BCE0A30B3ED42BF9708D651" fullContext="A5A925FCA7697E7E1E131DAD7940E722" translateForJs="false"> dołączone do nazwy, a linia wyjściowa będzie miała </TranslationEntry>
    <TranslationEntry name="4126B1174C83F28FCD89BAC8C6669DE3" fullContext="A5A925FCA7697E7E1E131DAD7940E722" translateForJs="false"> - Kontakt</TranslationEntry>
    <TranslationEntry name="7D71C44415EC41FE6753474BAA2403D0" fullContext="A5A925FCA7697E7E1E131DAD7940E722" translateForJs="false"> dołączono.</TranslationEntry>
    <TranslationEntry name="0E01F97B7E0B9818E21CDE022C19A83A" fullContext="0E01F97B7E0B9818E21CDE022C19A83A" translateForJs="false">Ekspander Unibus 1 - 16</TranslationEntry>
    <TranslationEntry name="668289409F6E691A6FC6000F1BCF90C2" fullContext="668289409F6E691A6FC6000F1BCF90C2" translateForJs="false">Ekspander Unibus 17 - 32</TranslationEntry>
    <TranslationEntry name="8981D2966324BF4024914CD7F51F2534" fullContext="8981D2966324BF4024914CD7F51F2534" translateForJs="false">Ekspander Unibus 33 - 48</TranslationEntry>
    <TranslationEntry name="6C37B73A5014D48E99C7CE60535456CA" fullContext="6C37B73A5014D48E99C7CE60535456CA" translateForJs="false">Ekspander Unibus 49 - 64</TranslationEntry>
    <TranslationEntry name="9E0CDDB3ADBD42268B8ABE84F970F697" fullContext="9E0CDDB3ADBD42268B8ABE84F970F697" translateForJs="false">Ekspander Unibus 65 - 80</TranslationEntry>
    <TranslationEntry name="1A06F8DAEFFB095C4FAF98AF279F6DE8" fullContext="1A06F8DAEFFB095C4FAF98AF279F6DE8" translateForJs="false">Ekspander Unibus 81 - 96</TranslationEntry>
    <TranslationEntry name="99A5C66A5A0893843BD102F7BC0AC890" fullContext="99A5C66A5A0893843BD102F7BC0AC890" translateForJs="false">Monitoruj sabotaż SIFER/OSDP</TranslationEntry>
    <TranslationEntry name="C7DE90B92547936C501EB0A1FE456034" fullContext="D5D97E2D1A2E959F9852FB4E65220442" translateForJs="false">Jeśli włączone, czytniki SIFER lub OSDP podłączone do modułu będą monitorowane przez system pod kątem sabotaży. Czytnik SIFER wykrywa na przykład fizyczny sabotaż za pomocą wiązki optycznej względem powierzchni, na której jest zamontowany.</TranslationEntry>
    <TranslationEntry name="70046CFBAF7F1FBAA91E3EE348F2F69E" fullContext="D5D97E2D1A2E959F9852FB4E65220442" translateForJs="false">Jeśli wystąpi sabotaż czytnika, system przekaże to zdarzenie sprzętowe do stacji monitorowania, jeśli raportowanie alarmów jest włączone i prawidłowo skonfigurowane. Podczas raportowania zdarzenia system uwzględni nazwę przejścia, do którego podłączony jest czytnik, aby ułatwić identyfikację miejsca zdarzenia. Ponadto wszystkie strefy przejdą w stan alarmu, niezależnie od tego, czy strefa jest uzbrojona, i będą musiały zostać rozbrojone, aby zatrzymać stroboskopy i sygnalizatory. </TranslationEntry>
    <TranslationEntry name="530D615598A6351C11837FE6F42E2E13" fullContext="7A9F41F6EDADAD363BF071BDC09184FA" translateForJs="false">Jeśli skonfigurowano, sabotaż obudowy modułu będzie monitorowany przez system i uwzględniony w ogólnym monitorowaniu zdrowia systemu. System przekaże to zdarzenie sprzętowe do stacji monitorowania, jeśli raportowanie alarmów jest włączone i prawidłowo skonfigurowane. Ponadto wszystkie strefy przejdą w stan alarmu po wykryciu sabotażu, niezależnie od tego, czy strefa jest uzbrojona, i będą musiały zostać rozbrojone, aby zatrzymać stroboskopy i sygnalizatory.</TranslationEntry>
    <TranslationEntry name="7661F942AD8E8A497CC75128D5273442" fullContext="7661F942AD8E8A497CC75128D5273442" translateForJs="false">Typ przełącznika sabotażu obudowy</TranslationEntry>
    <TranslationEntry name="50C3D254CF3F5EDCB8D388B6B3606978" fullContext="37516EF7C4FF9B1779562360F87F272E" translateForJs="false">Jeśli skonfigurowano, linia wejściowa sabotażu obudowy modułu będzie monitorowana przez system i uwzględniona w ogólnym monitorowaniu zdrowia systemu. Ta opcja określa rodzaj przełącznika sabotażu obudowy podłączonego do modułu sprzętowego.</TranslationEntry>
    <TranslationEntry name="3401D182C03CD00C5EF5AE133539466C" fullContext="37516EF7C4FF9B1779562360F87F272E" translateForJs="false"> - Brak podłączonego przełącznika. </TranslationEntry>
    <TranslationEntry name="B23C7F1B6241ECBB4EC0BAF7DF0E573E" fullContext="37516EF7C4FF9B1779562360F87F272E" translateForJs="false"> - Styk sabotażowy jest w obwodzie otwartym, gdy jest zaplombowany/zamknięty. </TranslationEntry>
    <TranslationEntry name="19CDB402E83BD4E96875FE6F0E552DFA" fullContext="37516EF7C4FF9B1779562360F87F272E" translateForJs="false"> — styk sabotażu jest obwodowo zamknięty, gdy jest zapieczętowany/zamknięty.</TranslationEntry>
    <TranslationEntry name="B29DFA7A4827702B71B0872B9155B965" fullContext="37516EF7C4FF9B1779562360F87F272E" translateForJs="false">Uwaga: Obudowy Inner Range są dostarczane z </TranslationEntry>
    <TranslationEntry name="1EC68B45113F12366ADBA7EB264866C2" fullContext="37516EF7C4FF9B1779562360F87F272E" translateForJs="false"> styki sabotażowe.</TranslationEntry>
    <TranslationEntry name="778486B7108CB82900909A5810951700" fullContext="37516EF7C4FF9B1779562360F87F272E" translateForJs="false">Jeśli skonfigurowano, system przekaże to zdarzenie sprzętowe do stacji monitorowania, jeśli raportowanie alarmów jest włączone i prawidłowo skonfigurowane. Ponadto wszystkie strefy przejdą w stan alarmu po wykryciu sabotażu, niezależnie od tego, czy strefa jest uzbrojona, i będą musiały zostać rozbrojone, aby zatrzymać stroboskopy i sygnalizatory.</TranslationEntry>
    <TranslationEntry name="27330338409C4FC71B60A664610A9890" fullContext="27330338409C4FC71B60A664610A9890" translateForJs="false">Monitoruj zakłócenia RF</TranslationEntry>
    <TranslationEntry name="C5EB1938151E70F1314892B531EB9F07" fullContext="2DE68494BBC4818FEA982837420561E6" translateForJs="false">Jeśli włączone, moduł będzie monitorowany przez system pod kątem zdarzeń zakłóceń RF, a zdarzenie to zostanie uwzględnione w ogólnym monitorowaniu kondycji systemu. System przekaże to zdarzenie sprzętowe do stacji monitorowania, jeśli zgłaszanie alarmów jest włączone i poprawnie skonfigurowane.</TranslationEntry>
    <TranslationEntry name="836149813CF95BE1CDD7962AF010B609" fullContext="836149813CF95BE1CDD7962AF010B609" translateForJs="false">Włącz pamięć podręczną kart</TranslationEntry>
    <TranslationEntry name="8D79B4B41901165E1C487AB3B543C251" fullContext="FF46785EBC5F025109ACA7B4DBADB1EC" translateForJs="false">Włączenie pamięci podręcznej kart zapewni, że przechowywane identyfikatory kart użytkownika w module kontroli dostępu będą ważne po przejściu modułu w tryb offline. Wyłączenie pamięci podręcznej kart zablokuje ważne identyfikatory użytkownika, gdy moduł kontroli dostępu pozostaje offline. Domyślnie pamięć podręczna kart jest włączona.</TranslationEntry>
    <TranslationEntry name="8948D723ABD2944591297AF687930609" fullContext="8948D723ABD2944591297AF687930609" translateForJs="false">Sygnalizator wewnętrzny (przewodowy)</TranslationEntry>
    <TranslationEntry name="9FB4744093293CE67C235F1ED4D5627E" fullContext="81E1FF72155D41A4F6CEE277F82678D9" translateForJs="false">Jeśli opcja jest włączona, sterownik Wewnętrznego sygnalizatora (S1INT) w module będzie monitorowany pod kątem sabotażu i zostanie uwzględniony w ogólnym monitorze kondycji systemu. Aby wykryć sabotaż sygnalizatora, urządzenia sygnalizatorowe muszą być podłączone za pomocą normalnie zamkniętego styku sabotażowego. </TranslationEntry>
    <TranslationEntry name="1E1A918024F8E81D827424AC337CD5E4" fullContext="31A50A596C485A92DE0AA9806098C04C" translateForJs="false">Uwaga: jeśli ta opcja jest włączona, system przekaże to zdarzenie sprzętowe do stacji monitorowania, jeśli raportowanie alarmów jest włączone i prawidłowo skonfigurowane. Ponadto wszystkie strefy przejdą w stan alarmu po wykryciu sabotażu, niezależnie od tego, czy strefa jest uzbrojona, i będą musiały zostać rozbrojone, aby zatrzymać sygnalizatory i stroboskopy.</TranslationEntry>
    <TranslationEntry name="CB97D6E7C9029B330AD8DFD802A89165" fullContext="CB97D6E7C9029B330AD8DFD802A89165" translateForJs="false">Wewnętrzny sygnalizator zasilany prądem stałym</TranslationEntry>
    <TranslationEntry name="85E2E28F1CAD22E7D2DB57CBC34FEE58" fullContext="A0FFF32F62CABFE52B086B890500C7C8" translateForJs="false">Jeśli włączone, wewnętrzny sterownik sygnalizatora będzie działać w trybie sterowania DC, zamiast sterować sygnalizatorem do wydawania określonych tonów. Ta opcja umożliwia bezpośrednie podłączenie piezosyreniki do punktu sterownika sygnalizatora, zamiast okablowania do rzeczywistego przekaźnika.</TranslationEntry>
    <TranslationEntry name="52FEB340A5CC6868DBD736365D0ACB6A" fullContext="52FEB340A5CC6868DBD736365D0ACB6A" translateForJs="false">Sygnalizator zewnętrzny (przewodowy)</TranslationEntry>
    <TranslationEntry name="52D38C84933D4559B3496D05843D26F2" fullContext="31A50A596C485A92DE0AA9806098C04C" translateForJs="false">Jeśli włączone, zewnętrzny sterownik sygnalizatora (S2EXT) modułu będzie monitorowany pod kątem sabotaży i uwzględniony w ogólnym monitorze zdrowia systemu. Aby wykrywać sabotaże sygnalizatorów, urządzenia sygnalizatora muszą być okablowane z normalnie zamkniętym przełącznikiem sabotażu. </TranslationEntry>
    <TranslationEntry name="59DC4D3F516FFEE01238B23B5DAEA3A2" fullContext="59DC4D3F516FFEE01238B23B5DAEA3A2" translateForJs="false">Zewnętrzny sygnalizator zasilany prądem stałym</TranslationEntry>
    <TranslationEntry name="85CFDC6594CE2BBE3BFBA0987E8CF000" fullContext="A2E58BA90E37F95C26637ACC9131D045" translateForJs="false">Jeśli włączone, zewnętrzny sterownik sygnalizatora będzie działać w trybie sterowania DC, zamiast sterować sygnalizatorem do wydawania określonych tonów. Ta opcja umożliwia bezpośrednie podłączenie piezosyreniki do punktu sterownika sygnalizatora, zamiast okablowania do rzeczywistego przekaźnika.</TranslationEntry>
    <TranslationEntry name="DDC41CF1135191CC060D829857E5A30A" fullContext="DDC41CF1135191CC060D829857E5A30A" translateForJs="false">Zasilacz podłączony do DC IN</TranslationEntry>
    <TranslationEntry name="034ACE3053AB46A55294551C6E4DA642" fullContext="36A952CAB6EF6F42123B7596E0745691" translateForJs="false">Po włączeniu, zasilacz 24V Inception będzie monitorowany pod kątem braku zasilania AC w ogólnym monitorze stanu systemu. Włącz tę opcję tylko wtedy, gdy kontroler Inception jest zasilany poprzez wejście DC IN.</TranslationEntry>
    <TranslationEntry name="A568F77BCDCD29E4419F896AABC2D269" fullContext="36A952CAB6EF6F42123B7596E0745691" translateForJs="false">Kontroler Inception zgłosi zdarzenia awarii zasilania AC do stacji monitorowania, jeśli raportowanie alarmów jest włączone i prawidłowo skonfigurowane, gdy ta opcja jest włączona i zasilacz DC ulegnie awarii.</TranslationEntry>
    <TranslationEntry name="BCA7A7470720D5B711CF59C1478D9DF8" fullContext="BCA7A7470720D5B711CF59C1478D9DF8" translateForJs="false">Podłączono baterię zapasową do BATT</TranslationEntry>
    <TranslationEntry name="3E5DC74AE2EE8C2E0FA9DDFA4F36C3DC" fullContext="8D4AB79540F277C8E53CF238A6BA584D" translateForJs="false">Gdy włączone, podłączona bateria będzie monitorowana pod kątem niskiego poziomu naładowania i braku baterii w ogólnym monitorze zdrowia systemu. Ta opcja umożliwia również konfigurację opcji testowania baterii poniżej. Kontroler Inception będzie raportować te zdarzenia sprzętowe do stacji monitorowania, jeśli raportowanie alarmów jest włączone i prawidłowo skonfigurowane, w przypadku niskiego poziomu naładowania baterii lub niepowodzenia testu baterii.</TranslationEntry>
    <TranslationEntry name="D2973A16BDB3C8C7BE4AE37AB4E586B2" fullContext="8D4AB79540F277C8E53CF238A6BA584D" translateForJs="false">Tej opcji należy używać tylko wtedy, gdy do złącza BATT kontrolera jest faktycznie podłączony akumulator. Jeśli kontroler jest zasilany z zewnętrznego zasilacza 12-14V podłączonego do złącza BATT, tej opcji nie należy włączać.</TranslationEntry>
    <TranslationEntry name="A7ED18D49E20B205C429542B690177E8" fullContext="A7ED18D49E20B205C429542B690177E8" translateForJs="false">Podłączono zasilacz Integriti SMART Power Supply</TranslationEntry>
    <TranslationEntry name="403A40F3095730BA8C0F196A16E1C0BA" fullContext="D6A8EAB854E0C6F18E9261C14BBE2318" translateForJs="false">Jeśli włączone, stany Awaria zasilania sieciowego, Przepalony bezpiecznik LAN i Awaria zasilacza zewnętrznego zasilacza będą uwzględniane w ogólnym monitorze stanu systemu.</TranslationEntry>
    <TranslationEntry name="C818C0F39560CA8A2F9D799D42AA3E73" fullContext="D6A8EAB854E0C6F18E9261C14BBE2318" translateForJs="false">Uwaga: Włączaj tę opcję tylko wtedy, gdy ten moduł jest podłączony do zasilacza Inner Range 3/8A Smart Power Supply za pomocą 10-pinowego przewodu PSU.</TranslationEntry>
    <TranslationEntry name="7E611A79F290F57D05E7A1B4CB0396F4" fullContext="D6A8EAB854E0C6F18E9261C14BBE2318" translateForJs="false">Kontroler Inception zgłosi te zdarzenia sprzętowe do stacji monitorowania, jeśli raportowanie alarmów jest włączone i prawidłowo skonfigurowane, w przypadku wystąpienia stanów alarmowych z tym zasilaczem.</TranslationEntry>
    <TranslationEntry name="46AB004AA8000781263AD6FB60C2E912" fullContext="46AB004AA8000781263AD6FB60C2E912" translateForJs="false">Bateria podłączona do zasilacza Integriti SMART</TranslationEntry>
    <TranslationEntry name="A8A671BE1026BD38BE0EBC6187CB2E7C" fullContext="F99CF32E47FB943B0C0658305BD1990D" translateForJs="false">Jeśli włączone, akumulator podłączony do zewnętrznego zasilacza będzie monitorowany pod kątem stanu niskiego naładowania przez ogólny monitor stanu systemu. Można również przeprowadzać regularne testy akumulatora w celu weryfikacji jego stanu.</TranslationEntry>
    <TranslationEntry name="3881D8609D21E840C4586ABEC7F2B873" fullContext="F99CF32E47FB943B0C0658305BD1990D" translateForJs="false">Uwaga: Włączaj tę opcję tylko wtedy, gdy ten moduł jest podłączony do zasilacza Inner Range 3/8A Smart Power Supply za pomocą 10-pinowego przewodu PSU i do tego zasilacza jest podłączona bateria.</TranslationEntry>
    <TranslationEntry name="CE9CE48F355A77AE5AB43C0DE06A6183" fullContext="F99CF32E47FB943B0C0658305BD1990D" translateForJs="false">Kontroler Inception zgłosi te zdarzenia sprzętowe do stacji monitorowania, jeśli raportowanie alarmów jest włączone i prawidłowo skonfigurowane, w przypadku niskiego poziomu baterii lub nieudanego testu baterii.</TranslationEntry>
    <TranslationEntry name="4F73C355AF88A6BD4D1563EC0592E4C2" fullContext="4F73C355AF88A6BD4D1563EC0592E4C2" translateForJs="false">Włącz testowanie baterii</TranslationEntry>
    <TranslationEntry name="2E87E29E88C7D90EA02FCBE5C9C9E1CB" fullContext="6C879861CD81951790530BF11EF36556" translateForJs="false">Jeśli włączone, wraz z opcjami zasilania i baterii powyżej, moduł zostanie uwzględniony w zaplanowanym testowaniu baterii systemu. </TranslationEntry>
    <TranslationEntry name="9133C9D6D1C5D906CDD003762A2C1970" fullContext="6C879861CD81951790530BF11EF36556" translateForJs="false">Testowanie baterii jest wymagane w celu zapewnienia, że w przypadku awarii zasilania sieciowego każdy moduł może być zasilany z podłączonej baterii. Regularne testowanie baterii gwarantuje wykrycie i możliwość wymiany baterii, która ulegnie degradacji z czasem.</TranslationEntry>
    <TranslationEntry name="C07F896D5F0222CE789677DFBD25A00D" fullContext="6C879861CD81951790530BF11EF36556" translateForJs="false">Ta opcja, wraz z </TranslationEntry>
    <TranslationEntry name="4F42FDBA303772CEE9ECBAF837FA194F" fullContext="4F42FDBA303772CEE9ECBAF837FA194F" translateForJs="false">Czas trwania testu baterii</TranslationEntry>
    <TranslationEntry name="7155AB7EDA2E2E425621D1D09D252F4D" fullContext="6C879861CD81951790530BF11EF36556" translateForJs="false"> poniżej — umożliwia jedynie dodanie tego modułu do listy modułów do testowania. Czas i częstotliwość przeprowadzania testów są konfigurowane na </TranslationEntry>
    <TranslationEntry name="534B3AB00D5BE90714E9842FEEEAB9FE" fullContext="6C879861CD81951790530BF11EF36556" translateForJs="false"> strona. Gdy nadejdzie zaplanowany czas, wszystkie moduły skonfigurowane do testowania baterii zostaną dodane do kolejki. Moduły są testowane jeden po drugim, tak aby w przypadku awarii zasilania sieciowego w trakcie testu tylko część systemu była narażona, a nie cały system. Testowanie rozpocznie się tylko wtedy, gdy moduł jest online, zasilanie sieciowe jest dostępne, stan baterii nie jest niski ani brakujący i nie wykryto zwarcia.</TranslationEntry>
    <TranslationEntry name="CACCDE9224E4142DA0C48D172633FA3E" fullContext="6C879861CD81951790530BF11EF36556" translateForJs="false">Test baterii zostaje zaliczony, jeśli przez cały czas jego trwania nie zostaną wykryte żadne problemy. Jeśli w trakcie testu baterii wykryty zostanie problem z baterią, stacja monitorowania zostanie o tym powiadomiona, a na interfejsie WWW pojawi się ostrzeżenie. Moduł z nieudanym testem baterii musi zaliczyć test, aby wyczyścić ten stan. Może to nastąpić podczas następnego zaplanowanego testu lub test można uruchomić ręcznie na stronie </TranslationEntry>
    <TranslationEntry name="E9ADDB7FDE6303D287428D8862E1CC67" fullContext="33F21C764C1167D1342B7954C70B18AA" translateForJs="false">[Stan / Sterowanie &gt; Test sprzętu]</TranslationEntry>
    <TranslationEntry name="E5FFF9CD53FF26204A159BF946EA4E57" fullContext="6C879861CD81951790530BF11EF36556" translateForJs="false">Testy baterii mogą zostać przerwane z wielu powodów: użytkownik może anulować test, doszło do zaniku zasilania AC na zasilaczu, zwarcia przewodów, utraty komunikacji z modułem lub konieczności uruchomienia sygnalizatorów przez moduł. Przerwany test nie jest ani wynikiem pozytywnym, ani negatywnym i nic nie jest zgłaszane do stacji monitorowania.</TranslationEntry>
    <TranslationEntry name="CD1FA7C24706A2FE4B5ADAE410D57ABB" fullContext="698A5002363F63C7A59E01A85919C1F9" translateForJs="false">Określa czas trwania testu baterii modułu.</TranslationEntry>
    <TranslationEntry name="80C01D481D193F7AD491F7C6C8777DD8" fullContext="698A5002363F63C7A59E01A85919C1F9" translateForJs="false">Czas trwania testu baterii powinien być określony na podstawie średniego poboru prądu modułu i pojemności podłączonej baterii, a także minimalnego czasu, przez który system ma pozostawać zasilany w przypadku awarii zasilania sieciowego.</TranslationEntry>
    <TranslationEntry name="C4638FB1E8FF34BE909EF8B6EC896365" fullContext="C4638FB1E8FF34BE909EF8B6EC896365" translateForJs="false">Poniższa tabela służy do konfigurowania linii wyjściowych dla kontrolera Inception.</TranslationEntry>
    <TranslationEntry name="6F7D3ADD88803B5B2DB11361C49773C4" fullContext="6859082C4456019FF98F269B1F928278" translateForJs="false"> — każdy sprzętowy punkt linii wyjściowej w Kontrolerze Inception może mieć ustawioną funkcję zgodnie z jedną z poniższych opcji.</TranslationEntry>
    <TranslationEntry name="BBC1A4D8E86AA6A4CEAAB39C5DDFB94C" fullContext="BBC1A4D8E86AA6A4CEAAB39C5DDFB94C" translateForJs="false">Poniższa tabela służy do konfigurowania linii wyjściowych dla ekspandera 8 linii wyjściowych.</TranslationEntry>
    <TranslationEntry name="281A94F372F78B7CAE8A922D0DB6F67D" fullContext="672F2A250FBDE844CD25C1BC8E23DF1A" translateForJs="false"> - Punkt sprzętowy odnosi się do fizycznych złączy na ekspanderze 8-Aux. Te złącza są oznaczone na module, dlatego każdy punkt sprzętowy na liście ma odpowiadające złącze na ekspanderze 8-Aux.</TranslationEntry>
    <TranslationEntry name="DAD72B865A818C0F3D176A6FA56A7B55" fullContext="672F2A250FBDE844CD25C1BC8E23DF1A" translateForJs="false"> — każdy sprzętowy punkt linii wyjściowej w 8-Aux Ekspanderze może mieć ustawioną funkcję zgodnie z jedną z poniższych opcji.</TranslationEntry>
    <TranslationEntry name="1580EC2E453D219DAC9024982F16D25A" fullContext="672F2A250FBDE844CD25C1BC8E23DF1A" translateForJs="false"> — Jest to domyślne zachowanie linii wyjściowej; jeśli nie zostanie zmienione, linia wyjściowa nie pojawi się na żadnych innych stronach konfiguracji ani stanu.</TranslationEntry>
    <TranslationEntry name="1ABADCF7E75B3C536368AC7C614947B1" fullContext="672F2A250FBDE844CD25C1BC8E23DF1A" translateForJs="false"> i być przypisana do uprawnień użytkownika.</TranslationEntry>
    <TranslationEntry name="C14A171DC2AF8CBCC5AF31E849309099" fullContext="C14A171DC2AF8CBCC5AF31E849309099" translateForJs="false">Poniższa tabela służy do konfigurowania linii wyjściowych dla ekspandera 8 linii wejściowych.</TranslationEntry>
    <TranslationEntry name="749135F4F0579EE432C0A25E43566875" fullContext="5D45CDBAB6978DD944E9EBC4B5D7E8EE" translateForJs="false"> — każdy sprzętowy punkt linii wyjściowej w 8-wejściowym Ekspanderze może mieć ustawioną funkcję zgodnie z jedną z poniższych opcji.</TranslationEntry>
    <TranslationEntry name="DF43D9B5EFC5321D2BAAD05835A4F65D" fullContext="DF43D9B5EFC5321D2BAAD05835A4F65D" translateForJs="false">Unibus Expander 3 - 8</TranslationEntry>
    <TranslationEntry name="5F0EBDC9746FBEB51BA1AB3B981789D6" fullContext="457E5A60C214991F076C2016945E6D64" translateForJs="false">Ustawia typ czytnika podłączonego do modułu. Pozostałe opcje na tej stronie zależą od wybranego typu czytnika.</TranslationEntry>
    <TranslationEntry name="1672926712489F24A21C3A953509BB1E" fullContext="457E5A60C214991F076C2016945E6D64" translateForJs="false">Uwaga: w przypadku czytników Wiegand czytnik skonfigurowany w każdym gnieździe (np. </TranslationEntry>
    <TranslationEntry name="E46FA9247259681465CB023547241B5A" fullContext="457E5A60C214991F076C2016945E6D64" translateForJs="false">Czytnik 1</TranslationEntry>
    <TranslationEntry name="944ED2A669215B1A46FD4306D7CBAC30" fullContext="457E5A60C214991F076C2016945E6D64" translateForJs="false">Czytnik 2</TranslationEntry>
    <TranslationEntry name="3684EE5AA36649BD7E0AAC7491BA1017" fullContext="457E5A60C214991F076C2016945E6D64" translateForJs="false"> ) powinny odpowiadać czytnikom na portach Wiegand modułu. Natomiast czytniki SIFER/OSDP mogą być w dowolnej kolejności.</TranslationEntry>
    <TranslationEntry name="EF0147FA684B4783DBDD1D9C9DF0F45F" fullContext="EF0147FA684B4783DBDD1D9C9DF0F45F" translateForJs="false">Numer seryjny czytnika</TranslationEntry>
    <TranslationEntry name="A001F98F180AFDA3E77B5AA9142A21A1" fullContext="9462CAA0DAF769D03AFD9172FF88BEBC" translateForJs="false">Jest to unikalny numer identyfikacyjny trwale zakodowany w czytniku SIFER/IR. W większości przypadków numer seryjny pojawi się automatycznie po wykryciu czytnika SIFER/IR i w przypadku dostępnego wolnego miejsca dla czytnika. W przeciwnym razie numer seryjny można znaleźć na tylnej stronie czytnika, w opakowaniu SIFER lub na </TranslationEntry>
    <TranslationEntry name="953E6EE73ED65F8172D9BBAB96AF603D" fullContext="9462CAA0DAF769D03AFD9172FF88BEBC" translateForJs="false"> strony podczas podłączania czytnika SIFER.</TranslationEntry>
    <TranslationEntry name="6696B14BCC5CEF3B2935DA88CF207083" fullContext="6696B14BCC5CEF3B2935DA88CF207083" translateForJs="false">Adres OSDP</TranslationEntry>
    <TranslationEntry name="04764BE5EDE65D33C19B0FA17B941CF1" fullContext="AB5736ECE311487460CAF5AEE18A6936" translateForJs="false">Jest to adres OSDP, którego czytnik aktualnie używa do komunikacji z modułem hosta. Musi być unikalny spośród czytników podłączonych do tego samego modułu. W większości przypadków adres OSDP pojawi się automatycznie po wykryciu czytnika OSDP i znalezieniu wolnego miejsca dla czytnika. W przeciwnym razie można go wprowadzić ręcznie, jeśli jest znany, lub na </TranslationEntry>
    <TranslationEntry name="D32B4DCE95B79D0F9B4B74257C186F55" fullContext="AB5736ECE311487460CAF5AEE18A6936" translateForJs="false"> strony podczas podłączania czytnika OSDP.</TranslationEntry>
    <TranslationEntry name="8EA3D75A79AA464B9CF267CEDFBC4CC6" fullContext="482B8865469C8C97DECAA1B74F083B13" translateForJs="false">Czytniki można skonfigurować do uzbrajania jednej lub więcej stref, gdy użytkownik trzy razy z rzędu w krótkich odstępach czasu odczyta swoją kartę przy czytniku. Użytkownik może uzbroić tylko te strefy, do których ma uprawnienia, a uzbrojenie może się nie powieść, jeśli strefa zawiera niespokojone linie wejściowe. W takim przypadku użytkownik powinien skorzystać z bardziej zaawansowanego interfejsu, aby spróbować uzbroić strefę, np. Terminala LCD lub interfejsu internetowego.  </TranslationEntry>
    <TranslationEntry name="4DF03DA9CFBFD79AFCE5E5CE84AAA5B4" fullContext="482B8865469C8C97DECAA1B74F083B13" translateForJs="false"> — żadna akcja nie zostanie wykonana.</TranslationEntry>
    <TranslationEntry name="15F92BDB40C3BF12E5EF1AA3759270D6" fullContext="482B8865469C8C97DECAA1B74F083B13" translateForJs="false">Uzbrój strefę po drugiej stronie przejścia</TranslationEntry>
    <TranslationEntry name="E47AF842A17F1EA0A7578320683EA23C" fullContext="482B8865469C8C97DECAA1B74F083B13" translateForJs="false"> - Strefa skonfigurowana po drugiej stronie przejścia od tego czytnika zostanie uzbrojona. Opóźnienie na wyjście nie zostanie wyzwolone.</TranslationEntry>
    <TranslationEntry name="BD71AB9AA86B1934688462D3F703551C" fullContext="482B8865469C8C97DECAA1B74F083B13" translateForJs="false"> - Uzbroi wszystkie strefy aktualnie skonfigurowane w systemie, do których uzbrojenia użytkownik ma uprawnienia. Strefy, do których użytkownik nie ma uprawnień, nie zostaną uzbrojone. Opóźnienie na wyjście nie zostanie wyzwolone.</TranslationEntry>
    <TranslationEntry name="01F61DA3F96165FCC9E49F611F6C5FC9" fullContext="482B8865469C8C97DECAA1B74F083B13" translateForJs="false">Uzbrój strefę po tej samej stronie przejścia</TranslationEntry>
    <TranslationEntry name="B7AC595A05686D5157E5AA83288DCC57" fullContext="482B8865469C8C97DECAA1B74F083B13" translateForJs="false"> - Strefa skonfigurowana po tej samej stronie przejścia co ten czytnik zostanie uzbrojona. Spowoduje to również rozpoczęcie opóźnienia na wyjście dla strefy.</TranslationEntry>
    <TranslationEntry name="D4A472A5E8219C3E66CE71875D58436B" fullContext="4220D4DA842A7B19BCBBA3394E5C8B11" translateForJs="false">Czytnik SIFER/OSDP może zapewniać wizualną i akustyczną sygnalizację zwrotną dotyczącą stanu strefy lub przejścia. Ta opcja określa, dla którego elementu — jeśli w ogóle — ma być wyświetlana sygnalizacja zwrotna. Ponadto dioda LED czytnika może być używana do wyświetlania stanu tego elementu zamiast statycznego koloru. W przypadku czytników SIFER jest to mała dioda LED. W przypadku czytników OSDP jest to jedyna dioda LED. Po skonfigurowaniu kolor diody LED stanu jest określany przez monitorowany element i nie może być ustawiany ręcznie — zastępuje to pole diody LED stanu poniżej (</TranslationEntry>
    <TranslationEntry name="0F114F8BCC75339BE873AF571F2C7A4D" fullContext="4220D4DA842A7B19BCBBA3394E5C8B11" translateForJs="false"> dla czytników SIFER lub </TranslationEntry>
    <TranslationEntry name="68E838D796D975CBAD694118D7A47477" fullContext="4220D4DA842A7B19BCBBA3394E5C8B11" translateForJs="false"> dla czytników OSDP).</TranslationEntry>
    <TranslationEntry name="EB5003B02F776F438CC4C1D53025946E" fullContext="4220D4DA842A7B19BCBBA3394E5C8B11" translateForJs="false"> - Dioda LED stanu będzie domyślnie przyjmować kolor wybrany w polu poniżej (</TranslationEntry>
    <TranslationEntry name="354529C7D2ED3E3FF9086441D81C9B6C" fullContext="4220D4DA842A7B19BCBBA3394E5C8B11" translateForJs="false"> dla czytników OSDP). Gdy użytkownik przyłoży kartę, dioda LED stanu zaświeci się na zielono, jeśli dostęp zostanie przyznany, i na czerwono, jeśli zostanie odmówiony.</TranslationEntry>
    <TranslationEntry name="E8D57BD9167357353696AB3C1E6027A3" fullContext="4220D4DA842A7B19BCBBA3394E5C8B11" translateForJs="false"> — Dioda statusu zaświeci się na czerwono, gdy przejście powiązane z tym czytnikiem jest zablokowane, i na zielono gdy jest odblokowane.</TranslationEntry>
    <TranslationEntry name="569506039AA258EF8AAC219E5E6E401C" fullContext="4220D4DA842A7B19BCBBA3394E5C8B11" translateForJs="false"> - Czytnik SIFER będzie wyświetlał sygnalizację zwrotną stanu strefy znajdującej się po tej samej stronie przejścia co czytnik. Czytnik wyemituje różne tony sygnalizacji, wskazując alarm w strefie, opóźnienie na wejście, opóźnienie na wyjście i ostrzeżenie o automatycznym uzbrojeniu. Mała dioda LED zapali się na czerwono, gdy strefa jest uzbrojona, i na zielono, gdy strefa jest rozbrojona.</TranslationEntry>
    <TranslationEntry name="F28E1FF362A6FAEB1F0B270BCBDC30D6" fullContext="4220D4DA842A7B19BCBBA3394E5C8B11" translateForJs="false"> - Takie samo działanie jak </TranslationEntry>
    <TranslationEntry name="668A02EC0D2A95C9513FF4D63B77A7BB" fullContext="4220D4DA842A7B19BCBBA3394E5C8B11" translateForJs="false"> opcja powyżej, ale dla strefy znajdującej się po drugiej stronie przejścia od czytnika. </TranslationEntry>
    <TranslationEntry name="985907C860DB7F43C204FD7136F6C990" fullContext="4220D4DA842A7B19BCBBA3394E5C8B11" translateForJs="false">Uwaga: jasność diody LED i głośność sygnalizacji zwrotnej czytników SIFER można regulować na stronie </TranslationEntry>
    <TranslationEntry name="C6D7399226FFD40376486ED4D6321FC2" fullContext="9A3BC7DFD56CD21C7096CC2FC9229CFB" translateForJs="false">[Konfiguracja &gt; Kontrola dostępu &gt; Czytniki]</TranslationEntry>
    <TranslationEntry name="DB6C5EBF5CD1C768345D1F382BA2E07F" fullContext="D5B26C67E117E5B78A0F829345A64C3E" translateForJs="false">Ustawia kolor dużej diody LED na czytniku SIFER.</TranslationEntry>
    <TranslationEntry name="D2C3972041C3E86E73836FD5A6CBB762" fullContext="9A3BC7DFD56CD21C7096CC2FC9229CFB" translateForJs="false">Uwaga: jasność diody LED można regulować na </TranslationEntry>
    <TranslationEntry name="A3110DE849EAF8138874A788897F5DF3" fullContext="A3110DE849EAF8138874A788897F5DF3" translateForJs="false">Kolor małej diody LED (Status)</TranslationEntry>
    <TranslationEntry name="8B909B8498AAA26157CF580563DF3A59" fullContext="9A3BC7DFD56CD21C7096CC2FC9229CFB" translateForJs="false">Ustawia kolor małej diody LED na czytniku SIFER. Dotyczy tylko sytuacji, gdy powyższe </TranslationEntry>
    <TranslationEntry name="983E45D9F14C8E4B92B207877E7CABB0" fullContext="7E078F6AF1291FFD6804BDC52A7E6600" translateForJs="false">Brak.</TranslationEntry>
    <TranslationEntry name="B64D09D664776C4B7B885CC45FEBE5D2" fullContext="7E078F6AF1291FFD6804BDC52A7E6600" translateForJs="false">Ustawia kolor diody LED na czytniku. Dotyczy tylko sytuacji, gdy powyższe </TranslationEntry>
    <TranslationEntry name="DC197223D78BCA5246443B7B26D85804" fullContext="4502B9AAD29739AD90AA60383B6B843F" translateForJs="false">Czytniki klawiatur Wiegand umożliwiają wprowadzenie numeru PIN użytkownika w celu żądania dostępu przez przejście. Różne klawiatury wysyłają numery PIN w różny sposób — ta opcja określa sposób przetwarzania naciśnięć klawiszy. Jeśli typ podłączonej klawiatury nie jest wymieniony na liście, należy kolejno wypróbować każdą z dostępnych opcji, ponieważ może ona odpowiadać jednemu ze znanych typów.</TranslationEntry>
    <TranslationEntry name="9222D2B776917E1B365A3254CBE3A470" fullContext="4502B9AAD29739AD90AA60383B6B843F" translateForJs="false">Użytkownik może zgłosić żądanie dostępu przez przejście tylko wtedy, gdy </TranslationEntry>
    <TranslationEntry name="9291F5F90E5151CDD57FC23344146B06" fullContext="4502B9AAD29739AD90AA60383B6B843F" translateForJs="false">Tryb dostępu przez przejście</TranslationEntry>
    <TranslationEntry name="0728FFE9F93C3B85381B3C56DD9CDC70" fullContext="4502B9AAD29739AD90AA60383B6B843F" translateForJs="false"> jest ustawiony w trybie korzystającym z PIN.</TranslationEntry>
    <TranslationEntry name="ECF59DB1C82D1A1E90FB7C0FCB900C3F" fullContext="ECF59DB1C82D1A1E90FB7C0FCB900C3F" translateForJs="false">Linie wejściowe RF</TranslationEntry>
    <TranslationEntry name="30BF7604AA1452EBAD944F0A69938FA3" fullContext="30BF7604AA1452EBAD944F0A69938FA3" translateForJs="false">Poniższa tabela służy do konfiguracji linii wejściowych dla Modułu Ekspandera RF</TranslationEntry>
    <TranslationEntry name="455C00CEB7B96E6DA81E965813C6BCE5" fullContext="EFCA3B1012EC3BDC1F0E303B29D1D795" translateForJs="false">Moduł RF IR-Paradox obsługuje do 32 urządzeń czujek z wejściem RF. </TranslationEntry>
    <TranslationEntry name="6FD3923BCCDD68CEFDCDAD21CC680283" fullContext="EFCA3B1012EC3BDC1F0E303B29D1D795" translateForJs="false"> - Punkt sprzętowy odnosi się do 32 wejść RF, które mogą być używane na Module RF IR-Paradox.</TranslationEntry>
    <TranslationEntry name="9F7D4A8D112CD661BC11ACB98136F9AE" fullContext="8A5FFA7911C9A3201038BEC48A15161D" translateForJs="false"> - Każdy punkt sprzętowy wejścia RF na Module RF IR-Paradox może mieć funkcjonalność ustawioną na jedną z czterech opcji poniżej.</TranslationEntry>
    <TranslationEntry name="F7FCBA38DF2268625B3B9D2D8291F946" fullContext="8A5FFA7911C9A3201038BEC48A15161D" translateForJs="false"> - Jest to domyślne zachowanie dla linii wejściowej RF; jeśli pozostanie niezmienione, linia wejściowa RF nie będzie wyświetlana na innych stronach konfiguracji ani stanu.</TranslationEntry>
    <TranslationEntry name="823937D16AD7F6E30BBCE6648E80E876" fullContext="EFCA3B1012EC3BDC1F0E303B29D1D795" translateForJs="false"> - Jeśli zaznaczono, linia wejściowa będzie działać jako czujka ruchu; opcja ta jest używana w przypadku podłączenia bezprzewodowego czujnika PIR.</TranslationEntry>
    <TranslationEntry name="5CBE652402453ADD41E4675D16A5285B" fullContext="EFCA3B1012EC3BDC1F0E303B29D1D795" translateForJs="false"> - Jeśli wybrano, linia wejściowa będzie działać jako kontakt drzwi/okna, czujka rozbicia szyby lub ochrona mienia. Jest to używane, gdy podłączane urządzenie to bezprzewodowy kontaktron drzwi, bezprzewodowa czujka rozbicia szyby lub bezprzewodowa czujka ochrony mienia.</TranslationEntry>
    <TranslationEntry name="232A833CFC585BEC130023C532379C5F" fullContext="EFCA3B1012EC3BDC1F0E303B29D1D795" translateForJs="false"> - Jeśli zaznaczone, linia wejściowa będzie działać jako czujka dymu; opcja ta jest używana, gdy podłączane urządzenie jest bezprzewodową czujką dymu.</TranslationEntry>
    <TranslationEntry name="73546DB42DD71A420616885E02B3F20B" fullContext="EFCA3B1012EC3BDC1F0E303B29D1D795" translateForJs="false"> - Jest to sześciocyfrowy numer seryjny linii wejściowej RF, często umieszczony na tylnej stronie lub wewnątrz czujki. Jeśli na czujce nie ma numeru, można go zidentyfikować, otwierając czujkę, czekając, aż dioda LED nadawcza przestanie migać, a następnie naciskając i zwalniając przełącznik wykrywania sabotażu. Następnie można przejść do strony </TranslationEntry>
    <TranslationEntry name="7FDC84BE2F053CA6A2792568FD1D2141" fullContext="8A5FFA7911C9A3201038BEC48A15161D" translateForJs="false"> strona i znajdź najnowszy </TranslationEntry>
    <TranslationEntry name="9B56561D3B9660C88067C620D8C96859" fullContext="8A5FFA7911C9A3201038BEC48A15161D" translateForJs="false">Naciśnięto przycisk nauki urządzenia RF</TranslationEntry>
    <TranslationEntry name="B5DDF62E6D3D09DDE6F58FE5BA41D09D" fullContext="8A5FFA7911C9A3201038BEC48A15161D" translateForJs="false"> zdarzenie, to zdarzenie będzie zawierać numer seryjny. Zapoznaj się z instrukcją czujki, aby uzyskać więcej informacji o trybie nauki.</TranslationEntry>
    <TranslationEntry name="60EA4F62D17639E94D9C2112A67BB3BD" fullContext="8A5FFA7911C9A3201038BEC48A15161D" translateForJs="false"> - Linia wejściowa zostanie automatycznie nazwana na podstawie nazwy modułu RF i punktu sprzętowego. W przypadku ręcznego wprowadzania nazwy zaleca się stosowanie konwencji nazewnictwa identyfikującej punkt sprzętowy i podłączone urządzenie.</TranslationEntry>
    <TranslationEntry name="A47A49DA79F2D8E8E92A121EEC9AEC41" fullContext="8A5FFA7911C9A3201038BEC48A15161D" translateForJs="false">Moduł RF Inovonics obsługuje do 32 urządzeń czujek z wejściem RF.</TranslationEntry>
    <TranslationEntry name="31F25927874D227260ED3F5C45941CB6" fullContext="8A5FFA7911C9A3201038BEC48A15161D" translateForJs="false"> - Punkt sprzętowy odnosi się do 32 wejść RF, które mogą być używane na Module RF Inovonics.</TranslationEntry>
    <TranslationEntry name="73E49EEB6C67E22986F704CF45ECD995" fullContext="8A5FFA7911C9A3201038BEC48A15161D" translateForJs="false"> - Po wybraniu tej opcji linia wejściowa będzie działać jako standardowa czujka alarmowa. Alarm urządzenia i sabotaż będą monitorowane. Może być stosowana z większością urządzeń nadawczych, takich jak czujki ruchu, dymu i stłuczenia szkła. Ponadto piloty RF mogą być również używane jako wejścia przyciskowe dla bezprzewodowych przycisków lub napadowych.</TranslationEntry>
    <TranslationEntry name="93DBF444003EAA5F1835AB42E07FF52F" fullContext="8A5FFA7911C9A3201038BEC48A15161D" translateForJs="false"> - Niektóre czujki Inovonics są zdolne do raportowania wielu alarmów — ta opcja służy do uzyskiwania dostępu do alarmu pomocniczego czujki. Byłoby to stosowane na przykład w przypadku czujek z dwoma wejściami, które umożliwiają podłączenie osobnego urządzenia do nadajnika.</TranslationEntry>
    <TranslationEntry name="560EEF3621F173BC076A5E63307BA969" fullContext="8A5FFA7911C9A3201038BEC48A15161D" translateForJs="false"> - Po wybraniu tej opcji linia wejściowa będzie reprezentować stan repeatera. Linia wejściowa nie przejdzie w stan alarmu, jednak wejdzie w stan sabotażu, jeśli repeater zostanie naruszony, a także będzie monitorować nieudane ankiety i informacje o niskim stanie baterii.</TranslationEntry>
    <TranslationEntry name="DF7FCD3A972C188156E5F898C8C994DC" fullContext="8A5FFA7911C9A3201038BEC48A15161D" translateForJs="false"> - Jest to ośmiocyfrowy numer seryjny linii wejściowej RF, często umieszczony z tyłu lub wewnątrz czujki. Jeśli na czujce nie ma numeru, numer seryjny można zidentyfikować, otwierając czujkę i naciskając przycisk uczenia. Następnie można przejść do </TranslationEntry>
    <TranslationEntry name="06839274A58AB58E3B188023DCFA6C04" fullContext="06839274A58AB58E3B188023DCFA6C04" translateForJs="false">Siła sygnału</TranslationEntry>
    <TranslationEntry name="B0709DC6AC03418FB4F857E42DA41642" fullContext="B0709DC6AC03418FB4F857E42DA41642" translateForJs="false">Konfiguracja interfejsu dotykowego</TranslationEntry>
    <TranslationEntry name="F650BC018BAD1F29278D49345C06B89E" fullContext="F650BC018BAD1F29278D49345C06B89E" translateForJs="false">Strefa główna</TranslationEntry>
    <TranslationEntry name="CFC5CA94EFA3D24D71E9B8E21E2E8875" fullContext="CFC5CA94EFA3D24D71E9B8E21E2E8875" translateForJs="false">Przejście główne</TranslationEntry>
    <TranslationEntry name="4BEA441C63D56E1C6CCC6FC5B2CA216C" fullContext="4BEA441C63D56E1C6CCC6FC5B2CA216C" translateForJs="false">Przyciski alarmowe</TranslationEntry>
    <TranslationEntry name="7FAF5BB6FC5BA42F3DE50613895BA029" fullContext="7FAF5BB6FC5BA42F3DE50613895BA029" translateForJs="false">Następujące opcje umożliwią włączenie obliczanych linii wejściowych, które mogą być ręcznie wyzwalane z ekranu dotykowego za pomocą przycisku awaryjnego.</TranslationEntry>
    <TranslationEntry name="56AD5CC14EB526233F5DA15E99627BED" fullContext="A98D290EA4C1E1A282458B28F509E9A1" translateForJs="false">Włączenie dowolnego z przycisków alarmowych spowoduje wyświetlenie przycisku alarmowego na ekranie głównym terminala ekranowego, który po naciśnięciu otworzy menu z włączonymi opcjami. Automatycznie zostanie również utworzona wyliczona linia wejściowa dla tego terminala ekranowego powiązana z danym przyciskiem alarmowym. Wyliczona linia wejściowa zostanie pobudzona impulsem po aktywowaniu przez użytkownika przycisku w menu alarmowym terminala ekranowego.</TranslationEntry>
    <TranslationEntry name="1EA3EE54C843131DCE3B6FCDD8A3588E" fullContext="A98D290EA4C1E1A282458B28F509E9A1" translateForJs="false">Aby skonfigurować monitorowanie i raportowanie tych zdarzeń, obliczone linie wejściowe powinny być dodane do strefy za pomocą stron Edytuj strefy lub Mapa linii wejściowych strefy, używając odpowiedniej grupy procesów linii wejściowej.</TranslationEntry>
    <TranslationEntry name="89806F06E7C074CB8DE508851871F8AA" fullContext="89806F06E7C074CB8DE508851871F8AA" translateForJs="false">Włącz przycisk pożarowy</TranslationEntry>
    <TranslationEntry name="7FAA7554A475E684686D6C5E2E2A830F" fullContext="7C034F3E2C17CDB3C1A46078A772E92E" translateForJs="false">Jeśli skonfigurowano, na interfejsie ekranu dotykowego zostanie włączony przycisk umożliwiający użytkownikom wywołanie alarmu pożarowego. Po aktywacji wyzwoli obliczoną linię wejściową w systemie Inception.</TranslationEntry>
    <TranslationEntry name="A960487D9A4D84F41B7F325B8235C07A" fullContext="A960487D9A4D84F41B7F325B8235C07A" translateForJs="false">Włącz przycisk pogotowia</TranslationEntry>
    <TranslationEntry name="6395BF9ECA6D29C43CA5FE8FE498B8AB" fullContext="C9570225605DCB1D2C9E04AD5E4118A4" translateForJs="false">Jeśli skonfigurowano, na interfejsie ekranu dotykowego zostanie włączony przycisk umożliwiający użytkownikom wywołanie alarmu pogotowia. Po aktywacji wyzwoli obliczoną linię wejściową w systemie Inception.</TranslationEntry>
    <TranslationEntry name="3F06449AE1F0728511F3F6BE3C8CF1E8" fullContext="3F06449AE1F0728511F3F6BE3C8CF1E8" translateForJs="false">Włącz przycisk policyjny</TranslationEntry>
    <TranslationEntry name="71679AD27E2A33CB03D8B6B9351D4DEF" fullContext="E2E40A9E0D5E71C098A1AF0D470A0B4E" translateForJs="false">Jeśli skonfigurowano, na interfejsie ekranu dotykowego zostanie włączony przycisk umożliwiający użytkownikom wywołanie alarmu policyjnego. Po aktywacji wyzwoli obliczoną linię wejściową w systemie Inception.</TranslationEntry>
    <TranslationEntry name="4CB1B994E3DDAAD3E9A532F859F50BBD" fullContext="4CB1B994E3DDAAD3E9A532F859F50BBD" translateForJs="false">Filtry elementów</TranslationEntry>
    <TranslationEntry name="BCB4811E21F885195F8EB1DEC1ECB2C3" fullContext="E0E3D9FB1CB842DEDB3624A225B5B9BF" translateForJs="false">To ustawienie określa, które strefy będą wyświetlane na terminalu dotykowym.</TranslationEntry>
    <TranslationEntry name="547ACC0C63640B0C0F50C75453FE2AE9" fullContext="E0E3D9FB1CB842DEDB3624A225B5B9BF" translateForJs="false">Jeśli do listy przypisano strefy, panel dotykowy zostanie przefiltrowany tak, aby wyświetlać tylko te strefy; jeśli lista jest pusta, żaden filtr nie zostanie zastosowany do listy stref.</TranslationEntry>
    <TranslationEntry name="453025350C38DA45F96333577718DCB1" fullContext="E0E3D9FB1CB842DEDB3624A225B5B9BF" translateForJs="false">Ta funkcja może być przydatna w systemach z wieloma strefami, na przykład poprzez filtrowanie do stref w pobliżu danego terminalu z ekranem dotykowym. Gdy użytkownik korzysta z terminalu w celu sterowania strefą, widzi tylko najbardziej odpowiednie strefy dla danego terminalu, zamiast przewijać przez wszystkie strefy w systemie.</TranslationEntry>
    <TranslationEntry name="458A88C500A0F5549A13FD75B7777B24" fullContext="458A88C500A0F5549A13FD75B7777B24" translateForJs="false">Filtruj dostępne przejścia</TranslationEntry>
    <TranslationEntry name="9626D48862F2386C4B7B43DE7B55080E" fullContext="FF7D71BF573F83BA841D4671B56EB1F0" translateForJs="false">To ustawienie określa, które przejścia będą wyświetlane na terminalu z ekranem dotykowym.</TranslationEntry>
    <TranslationEntry name="D2EB3A9DDA8F997D42101C1AB4EED2BF" fullContext="FF7D71BF573F83BA841D4671B56EB1F0" translateForJs="false">Jeśli na liście są przypisane przejścia, terminal z ekranem dotykowym będzie filtrowany, aby wyświetlać tylko te przejścia; jeśli lista jest pusta, do listy przejść nie zostanie zastosowany żaden filtr.</TranslationEntry>
    <TranslationEntry name="370770BD9DBC89B8CEF14FF01EF25553" fullContext="FF7D71BF573F83BA841D4671B56EB1F0" translateForJs="false">Ta funkcja może być przydatna w systemach z wieloma przejściami — na przykład przez filtrowanie tylko pobliskich przejść dla danego terminala z ekranem dotykowym. Gdy użytkownik uzyskuje dostęp do terminala w celu sterowania przejściami, widzi tylko najbardziej odpowiednie przejścia dla danego terminala, zamiast przewijać listę wszystkich przejść w systemie.</TranslationEntry>
    <TranslationEntry name="19B24D7B7AC517860144245AB54F7141" fullContext="19B24D7B7AC517860144245AB54F7141" translateForJs="false">Filtruj sterowalne linie wejściowe</TranslationEntry>
    <TranslationEntry name="291FC6D43F3BBCB0FE2864093E17C88B" fullContext="34779FDCEDECACAD9E15408A659381E9" translateForJs="false">To ustawienie określa, które linie wejściowe będą wyświetlane na terminalu Ekran dotykowy.</TranslationEntry>
    <TranslationEntry name="839070639475AF57A82DB5D3C690D13A" fullContext="34779FDCEDECACAD9E15408A659381E9" translateForJs="false">Jeśli do listy przypisano linie wejściowe, ekran dotykowy zostanie przefiltrowany tak, aby wyświetlać tylko te linie; jeśli lista jest pusta, filtr nie będzie stosowany.</TranslationEntry>
    <TranslationEntry name="EA1780C33C36500A735BD06948FAA389" fullContext="34779FDCEDECACAD9E15408A659381E9" translateForJs="false">Ta funkcja może być przydatna w systemach z wieloma liniami wejściowymi, na przykład przez filtrowanie do linii wejściowych w pobliżu danego terminala ekranowego. Gdy użytkownik korzysta z terminala, aby sterować linią wejściową, widzi tylko najbardziej odpowiednie linie wejściowe dla danego terminala, zamiast przewijać wszystkie linie wejściowe w systemie.</TranslationEntry>
    <TranslationEntry name="3D2D567770063AF6E9FF381B32BC7D09" fullContext="3D2D567770063AF6E9FF381B32BC7D09" translateForJs="false">Filtruj sterowalne linie wyjściowe</TranslationEntry>
    <TranslationEntry name="12A826A7BE280952D1AE746178C02F2C" fullContext="8B7C30666C4F3980A5D4EA89E037973F" translateForJs="false">To ustawienie określa, które linie wyjściowe będą wyświetlane na terminalu z ekranem dotykowym.</TranslationEntry>
    <TranslationEntry name="6CA0371DFF997CF91AC838266D712E50" fullContext="8B7C30666C4F3980A5D4EA89E037973F" translateForJs="false">Jeśli do listy przypisano linie wyjściowe, ekran dotykowy zostanie przefiltrowany tak, aby wyświetlać tylko te; jeśli lista jest pusta, do listy linii wyjściowych nie zostanie zastosowany żaden filtr.</TranslationEntry>
    <TranslationEntry name="DB84A84D6D07309E25A40DD4CAFA3ACE" fullContext="8B7C30666C4F3980A5D4EA89E037973F" translateForJs="false">Ta funkcja może być przydatna w systemach z wieloma liniami wyjściowymi, na przykład przez filtrowanie do linii wyjściowych w pobliżu danego terminala ekranowego. Gdy użytkownik korzysta z terminala, aby sterować linią wyjściową, widzi tylko najbardziej odpowiednie linie wyjściowe dla danego terminala, zamiast przewijać wszystkie linie wyjściowe w systemie.</TranslationEntry>
    <TranslationEntry name="6C582778E4F9F631CBF3686388731A88" fullContext="6C582778E4F9F631CBF3686388731A88" translateForJs="false">Filtruj moduły sprzętowe</TranslationEntry>
    <TranslationEntry name="B7553F77D63B0C8A9378ED7D78847513" fullContext="15F367BA2EEE343CD20AD9B8D47210F9" translateForJs="false">To ustawienie określa, które moduły sprzętowe będą wyświetlane na Terminalu dotykowym.</TranslationEntry>
    <TranslationEntry name="100A66C50E601E92A207065AE246B9C7" fullContext="15F367BA2EEE343CD20AD9B8D47210F9" translateForJs="false">Jeśli do listy przypisane są moduły, Ekran dotykowy będzie filtrowany, aby wyświetlać tylko te moduły; jeśli lista jest pusta, do listy modułów nie będzie stosowany żaden filtr.</TranslationEntry>
    <TranslationEntry name="24D8202513492ECD822372BCEFAD9C67" fullContext="15F367BA2EEE343CD20AD9B8D47210F9" translateForJs="false">Ta funkcja może być przydatna w systemach z wieloma modułami, na przykład przez filtrowanie do modułów w pobliżu danego terminala ekranowego. Gdy użytkownik korzysta z terminala, aby wyświetlić stan modułu, widzi tylko najbardziej odpowiednie moduły dla danego terminala, zamiast przewijać wszystkie moduły w systemie.</TranslationEntry>
    <TranslationEntry name="CA5F1A9179A231818C23654AF0A6BC31" fullContext="CA5F1A9179A231818C23654AF0A6BC31" translateForJs="false">Zdarzenia analizy wideo</TranslationEntry>
    <TranslationEntry name="060F6EC29ED8B0475CC8ABB19B409F7E" fullContext="060F6EC29ED8B0475CC8ABB19B409F7E" translateForJs="false">Poniższa lista opcji służy do konfiguracji linii wejściowych obliczeniowych, które będą automatycznie tworzone dla zdarzeń analizy wideo dla kamer bezpośrednich.</TranslationEntry>
    <TranslationEntry name="3A0BB67E3E17B61106241034A1993A6A" translateForJs="false">Resetuj zdarzenia kondycji systemu</TranslationEntry>
    <TranslationEntry name="618E2EB90783631850D22BC4557CE2B0" fullContext="7A1EB348E6ABB6AFF7E07A2E036486D9" translateForJs="false">Poniższa lista opcji służy do konfiguracji linii wejściowych obliczeniowych, które będą automatycznie tworzone dla zdarzeń analizy wideo kamer. Kategorie na tej stronie są dynamicznie wypełniane na podstawie konfiguracji kamer i konfigurowanej bramy IR Video Gateway. Jeśli brakuje kategorii zdarzeń lub strona jest pusta, należy sprawdzić konfigurację urządzeń IR Video, a następnie użyć </TranslationEntry>
    <TranslationEntry name="D11B31486B94C9C07F1D29A1885372E1" fullContext="7A1EB348E6ABB6AFF7E07A2E036486D9" translateForJs="false">Lista urządzeń -&gt; Pobierz skonfigurowane urządzenia</TranslationEntry>
    <TranslationEntry name="FDB93D2D7B3A0924FFAFB7CB2CA91FB3" fullContext="7A1EB348E6ABB6AFF7E07A2E036486D9" translateForJs="false"> aby pobrać zdarzenia z bramki</TranslationEntry>
    <TranslationEntry name="72A3C1D1B6DEF53D28580EAFEFAB09C3" translateForJs="false">Zdarzenia resetu obliczonych linii wejściowych</TranslationEntry>
    <TranslationEntry name="5EB0DCCA498852C3E320CFBD0FE514F4" fullContext="5EB0DCCA498852C3E320CFBD0FE514F4" translateForJs="false">Kondycja kamer</TranslationEntry>
    <TranslationEntry name="BD4D4683D1E499D250FA397EFF781F67" fullContext="BD4D4683D1E499D250FA397EFF781F67" translateForJs="false">Poniższa lista opcji służy do konfiguracji zdarzeń, które powinny być monitorowane dla zdarzeń stanu kamer.</TranslationEntry>
    <TranslationEntry name="EB4D54102A6B68C9C149032AFF55F551" fullContext="EB4D54102A6B68C9C149032AFF55F551" translateForJs="false">Lista urządzeń</TranslationEntry>
    <TranslationEntry name="2C8008A8E5A21E535271578B0C674239" fullContext="2C8008A8E5A21E535271578B0C674239" translateForJs="false">Pobierz skonfigurowane urządzenia</TranslationEntry>
    <TranslationEntry name="AE7463B9A5F7EE7A5BAA07C3CC96D498" fullContext="AE7463B9A5F7EE7A5BAA07C3CC96D498" translateForJs="false">Załaduj urządzenia zintegrowane</TranslationEntry>
    <TranslationEntry name="A42B1AD1452D0A173B4D36DD2FFA47A1" fullContext="1D4C038899F387DA695F5E8F1A4E33AD" translateForJs="false">Z poniższej tabeli wybierz wykryte urządzenia podrzędne, które powinny zostać dodane do systemu Inception, a następnie kliknij </TranslationEntry>
    <TranslationEntry name="2F7FAE4F9CF271D6BD77C5E1CEAF70D7" translateForJs="true">Pobieranie urządzeń z integracji...</TranslationEntry>
    <TranslationEntry name="490AA6E856CCF208A054389E47CE0D06" translateForJs="true">Id</TranslationEntry>
    <TranslationEntry name="5BBDB0BECE216A3D72DDADF154DF63B5" fullContext="5BBDB0BECE216A3D72DDADF154DF63B5" translateForJs="false">Stan systemu</TranslationEntry>
    <TranslationEntry name="0469E16897373E8722212100EC3922C7" fullContext="0469E16897373E8722212100EC3922C7" translateForJs="false">Poniższa lista opcji służy do konfiguracji zdarzeń, które powinny być monitorowane w ramach Zdarzeń stanu systemu.</TranslationEntry>
    <TranslationEntry name="4B4AFBBF0BCD71657BCA99510C5B502C" fullContext="4B4AFBBF0BCD71657BCA99510C5B502C" translateForJs="false">Zdarzenia czujników</TranslationEntry>
    <TranslationEntry name="A8CC35D3EBB7516177E2E0B0374A0133" fullContext="A8CC35D3EBB7516177E2E0B0374A0133" translateForJs="false">Poniższa lista opcji służy do konfiguracji linii wejściowych obliczeniowych, które powinny być generowane dla zdarzeń czujników kamer bezpośrednich.</TranslationEntry>
    <TranslationEntry name="0391B5C18562C294AFD4F47885682051" fullContext="0391B5C18562C294AFD4F47885682051" translateForJs="false">Poniższa lista opcji służy do konfiguracji linii wejściowych obliczeniowych, które powinny być generowane dla zdarzeń czujników kamer.</TranslationEntry>
    <TranslationEntry name="439CB5DE3F4A76AE47334F336BF53F59" translateForJs="false">Resetuj wyliczone zdarzenia linii wejściowej</TranslationEntry>
    <TranslationEntry name="15509D17DCA75E9A7594C57E0B35D0CF" translateForJs="false">Czy drzwi RF Allegion są skonfigurowane?</TranslationEntry>
    <TranslationEntry name="7C683FA614FD6F1FA46F8BD262DF71BE" translateForJs="false">Ustawienia drzwi RF Allegion</TranslationEntry>
    <TranslationEntry name="211213B4ECF1E2DB81C603887C546EB3" fullContext="211213B4ECF1E2DB81C603887C546EB3" translateForJs="false">Reed włączony</TranslationEntry>
    <TranslationEntry name="AFAD2642F9DC3C004DD6482BCBCDC4D2" translateForJs="false">Ustawienia przejścia RF Aperio</TranslationEntry>
    <TranslationEntry name="29F03695CE4A9667D2564443EFE3033C" fullContext="29F03695CE4A9667D2564443EFE3033C" translateForJs="false">Numer EAC zamka Aperio</TranslationEntry>
    <TranslationEntry name="E022358727BD3C103D157C6B643995CD" translateForJs="false">Ustawienia przejścia RF</TranslationEntry>
    <TranslationEntry name="11913A62F5BB8BDB35B246F54A01D595" translateForJs="false">Czy drzwi RF Salto są skonfigurowane?</TranslationEntry>
    <TranslationEntry name="ED234728BC4EC988DF4B5DD3ED6F7842" translateForJs="false">Ustawienia przejścia RF Salto</TranslationEntry>
    <TranslationEntry name="A60FFF41A7BC5FE7EFD682C13542C468" fullContext="A60FFF41A7BC5FE7EFD682C13542C468" translateForJs="true">Wyślij raport testowy</TranslationEntry>
    <TranslationEntry name="0D57C8CF15470FB86F793A7A86A7820B" fullContext="0D57C8CF15470FB86F793A7A86A7820B" translateForJs="false">Wyślij wszystkie możliwe alarmy</TranslationEntry>
    <TranslationEntry name="819C566346F6B8A0C699045F3E84B97B" fullContext="819C566346F6B8A0C699045F3E84B97B" translateForJs="false">Wyczyść kolejkę alarmów</TranslationEntry>
    <TranslationEntry name="2744B42B4DA1B1084305FA3F5568EC81" fullContext="2744B42B4DA1B1084305FA3F5568EC81" translateForJs="false">Raport uruchomieniowy</TranslationEntry>
    <TranslationEntry name="0B03ECCCC3FFF2D1B54FF189DC71A155" fullContext="0B03ECCCC3FFF2D1B54FF189DC71A155" translateForJs="false">Utwórz raport uruchomieniowy</TranslationEntry>
    <TranslationEntry name="D843CE34F5042BFCFD251FFDC859FD2D" fullContext="D843CE34F5042BFCFD251FFDC859FD2D" translateForJs="false">To okno dialogowe umożliwia pobranie raportu uruchomieniowego Contact ID zawierającego wszystkie identyfikatory raportowania użytkowników i stref, a także stany wszystkich linii wejściowych i modułów, które mogą zostać przesłane do stacji monitorowania.</TranslationEntry>
    <TranslationEntry name="6743B9FCC57CF1B169FB4EF6C7A955D2" fullContext="B9AF8D11F3755A3D68C007C50EB1986F" translateForJs="false">A </TranslationEntry>
    <TranslationEntry name="632A99AF4088168902587AB730615980" fullContext="B9AF8D11F3755A3D68C007C50EB1986F" translateForJs="false">Pełny raport</TranslationEntry>
    <TranslationEntry name="C3BE6D6CC987BCE463FE66AD3F9AC4F3" fullContext="B9AF8D11F3755A3D68C007C50EB1986F" translateForJs="false"> zawiera listę wszystkich elementów, które mogą być raportowane. </TranslationEntry>
    <TranslationEntry name="160597CB824286A40E39A3B40BF5DD5A" fullContext="160597CB824286A40E39A3B40BF5DD5A" translateForJs="false">Zmiany + pełny raport</TranslationEntry>
    <TranslationEntry name="E3DD07F6035AE3C96BAF464293739426" fullContext="B9AF8D11F3755A3D68C007C50EB1986F" translateForJs="false"> wyświetli listę wszystkich aktualizacji i usunięć od czasu poprzedniego uruchomienia raportu, a następnie pełny raport.</TranslationEntry>
    <TranslationEntry name="4AC6A0414F086775DA2B4A239782F168" fullContext="B9AF8D11F3755A3D68C007C50EB1986F" translateForJs="false">Może to być przydatne dla stacji monitorowania w celu aktualizacji ich mapowań dla tego obiektu.</TranslationEntry>
    <TranslationEntry name="BBD47109890259C0127154DB1AF26C75" fullContext="BBD47109890259C0127154DB1AF26C75" translateForJs="false">Pełne</TranslationEntry>
    <TranslationEntry name="901AA4A5FB563F3BC0EB13B717C73C50" fullContext="901AA4A5FB563F3BC0EB13B717C73C50" translateForJs="false">Pokaż zmiany od: </TranslationEntry>
    <TranslationEntry name="279EB98D8F21E46979A14A89C31B133E" fullContext="279EB98D8F21E46979A14A89C31B133E" translateForJs="false">Resetuj dane Contact ID</TranslationEntry>
    <TranslationEntry name="50934C2619BC3E4982BD99404D4A7A77" fullContext="50934C2619BC3E4982BD99404D4A7A77" translateForJs="false">Szczegóły strefy</TranslationEntry>
    <TranslationEntry name="151369D78CD8FAAF07E3FAF11AF7D61C" fullContext="151369D78CD8FAAF07E3FAF11AF7D61C" translateForJs="false">Szczegóły przejścia</TranslationEntry>
    <TranslationEntry name="20231E63160B9A2364600EC87C2C3DE3" fullContext="20231E63160B9A2364600EC87C2C3DE3" translateForJs="false">ID czytnika</TranslationEntry>
    <TranslationEntry name="2448E68C2152A3B5B0C88C7495ED34A8" fullContext="2448E68C2152A3B5B0C88C7495ED34A8" translateForJs="false">ID przejścia</TranslationEntry>
    <TranslationEntry name="BE2D90361EE372475475767665703F51" fullContext="BE2D90361EE372475475767665703F51" translateForJs="false">Czytniki przejścia</TranslationEntry>
    <TranslationEntry name="43CE134D4BE8888DB92CD30DA9E8C130" fullContext="43CE134D4BE8888DB92CD30DA9E8C130" translateForJs="false">Szczegóły linii wejściowej</TranslationEntry>
    <TranslationEntry name="EADE96F27782118494A720C4E409AB16" fullContext="EADE96F27782118494A720C4E409AB16" translateForJs="false">Szczegóły linii wyjściowej</TranslationEntry>
    <TranslationEntry name="07697885C8902A21635688AC9AA8F607" fullContext="07697885C8902A21635688AC9AA8F607" translateForJs="false">Szczegóły piętra windy</TranslationEntry>
    <TranslationEntry name="740FB9D43B4D158D5EDD3E0826562B62" fullContext="740FB9D43B4D158D5EDD3E0826562B62" translateForJs="false">Szczegóły jednostki (boksu)</TranslationEntry>
    <TranslationEntry name="0AC5BB292EC68D19B9C48FF858EC1A1E" fullContext="0AC5BB292EC68D19B9C48FF858EC1A1E" translateForJs="false">Szczegóły konfiguracji użytkownika</TranslationEntry>
    <TranslationEntry name="97FED01ECB26B615484BFAC6E89C89D4" fullContext="97FED01ECB26B615484BFAC6E89C89D4" translateForJs="false">Profile terminali LCD</TranslationEntry>
    <TranslationEntry name="94D195167534075E1D21420794820DB4" fullContext="94D195167534075E1D21420794820DB4" translateForJs="false">Profile uprawnień WWW</TranslationEntry>
    <TranslationEntry name="8696BCA6F5BD902B69828000EFD1EF52" fullContext="8696BCA6F5BD902B69828000EFD1EF52" translateForJs="false">Utwórz wszystkie strefy w swoim obiekcie i nadaj im nazwy. Pamiętaj, aby dodać strefę „Na zewnątrz”, jeśli masz kontrolę dostępu w obiekcie i chcesz śledzić lokalizacje użytkowników.</TranslationEntry>
    <TranslationEntry name="45EAA1A116546BA079FE050058A6E9C7" fullContext="45EAA1A116546BA079FE050058A6E9C7" translateForJs="false">Nazwa strefy</TranslationEntry>
    <TranslationEntry name="B9DDED78148243E316F6F643E92DF337" fullContext="B9DDED78148243E316F6F643E92DF337" translateForJs="false">Dodaj nową strefę</TranslationEntry>
    <TranslationEntry name="D6DC680FF4D9607184AF78214F172B3D" fullContext="D6DC680FF4D9607184AF78214F172B3D" translateForJs="false">Usuń wybrane strefy</TranslationEntry>
    <TranslationEntry name="1FC2FE8C69CF49A97913909F0ABCF57C" fullContext="1FC2FE8C69CF49A97913909F0ABCF57C" translateForJs="false">Linie wejściowe ścieżki wejścia/wyjścia</TranslationEntry>
    <TranslationEntry name="379D604C717A2CD3C36788F916797D2B" fullContext="379D604C717A2CD3C36788F916797D2B" translateForJs="false">Wybierz linie wejściowe zlokalizowane na ścieżce wejścia/wyjścia. </TranslationEntry>
    <TranslationEntry name="D330FF97A4EEFF5C8935DE2CDB7952C5" fullContext="99AFD22C93A0BCD959BF60BFACBC1428" translateForJs="false">Ścieżka wejścia/wyjścia jest wymagana, gdy Terminal LCD umożliwiający sterowanie strefą znajduje się wewnątrz uzbrojonej strefy. Pozwala to na ochronę terminala, a jednocześnie użytkownik musi mieć możliwość dotarcia do niego w celu uzbrojenia i rozbrojenia strefy. Można wyznaczyć główny punkt wejścia, który po wyzwoleniu jako pierwszy umożliwia użytkownikowi przejście przez uzbrojoną strefę do Terminala LCD, tworząc ścieżkę wejścia/wyjścia. Ścieżkę tworzą linie wejściowe bezpieczeństwa, w których linie chroniące trasę przez strefę są programowane inaczej. Umożliwia to użytkownikowi wejście przez określone drzwi i przejście wyznaczoną trasą do terminala w celu rozbrojenia, lub uzbrojenia strefy z terminala i wyjście trasą przez strefę. Wszelkie odejście od tej ścieżki spowoduje wyzwolenie alarmu. </TranslationEntry>
    <TranslationEntry name="8CADF8438CC5A5F564C60A517CCBF852" fullContext="99AFD22C93A0BCD959BF60BFACBC1428" translateForJs="false">Przypisz linie wejściowe, które powinny być wyzwalane jako pierwsze w głównym punkcie wejścia jako </TranslationEntry>
    <TranslationEntry name="B493C4B033592E5644D3C16035BC086C" fullContext="99AFD22C93A0BCD959BF60BFACBC1428" translateForJs="false">Główne linie wejściowe</TranslationEntry>
    <TranslationEntry name="43503E07C03EA484BECD3F8AC2A92DEA" fullContext="99AFD22C93A0BCD959BF60BFACBC1428" translateForJs="false">. Uruchamiają one timer wejścia i wprowadzają strefę w tryb wejścia, umożliwiając użytkownikowi przejście ścieżką bez wyzwolenia alarmu. Zazwyczaj będzie to kontaktron drzwi lub PIR w pobliżu drzwi wejściowych. </TranslationEntry>
    <TranslationEntry name="FD35CD24218E099CEF06A4F14518A444" fullContext="99AFD22C93A0BCD959BF60BFACBC1428" translateForJs="false">Wszystkie inne linie wejściowe obejmujące ścieżkę wejścia/wyjścia powinny być przypisane jako </TranslationEntry>
    <TranslationEntry name="0B51B1406C1C2B963C11A01D15F31739" fullContext="99AFD22C93A0BCD959BF60BFACBC1428" translateForJs="false">Linie wejściowe przekazywania</TranslationEntry>
    <TranslationEntry name="53E44ABF85EDE5E6BC1AE2B26D646480" fullContext="99AFD22C93A0BCD959BF60BFACBC1428" translateForJs="false">. W czasie gdy aktywny jest timer opóźnienia wyjścia lub wejścia, linie wejściowe podstawowe i przekazujące są ignorowane, umożliwiając użytkownikowi przejście ścieżką. Jeśli linia wejściowa przekazująca zostanie wyzwolona przed linią podstawową na ścieżce wejścia (tzn. użytkownik ominął główny punkt wejścia), czas wejścia strefy zostanie zignorowany i strefa natychmiast przejdzie w stan alarmu.</TranslationEntry>
    <TranslationEntry name="D356114F9A19556D8083DFE88D980BDB" fullContext="99AFD22C93A0BCD959BF60BFACBC1428" translateForJs="false">W trybie wejścia alarm zostanie wyzwolony, jeśli strefa nie zostanie rozbrojona przed upływem czasu opóźnienia na wejście lub jeśli użytkownik opuści ścieżkę i wyzwoli linię wejściową z natychmiastowym alarmem. Podobnie w trybie wyjścia alarm zostanie wyzwolony, jeśli użytkownik opuści ścieżkę i wyzwoli linię wejściową z natychmiastowym alarmem.</TranslationEntry>
    <TranslationEntry name="2BA8E149CD57A1AD6710C3092AE04E9C" fullContext="A54B0DA3F3D75326B3A7F7211C0FE2D9" translateForJs="false">Zazwyczaj pierwsza linia wejściowa, która zostanie wyzwolona, gdy użytkownik wejdzie do budynku przez główne wejście. Te linie wejściowe uruchamiają opóźnienie na wejście, umożliwiając użytkownikowi rozbrojenie systemu z klawiatury lub czytnika bez generowania alarmu strefy. Bez wcześniejszego wyzwolenia podstawowej linii wejściowej, linie wejściowe przekazujące byłyby traktowane tak samo jak linie wejściowe czujek włamaniowych, powodując przejście strefy w stan alarmu. </TranslationEntry>
    <TranslationEntry name="FF39E29FE69ED80E9A15ECA4A72B6EBA" fullContext="A54B0DA3F3D75326B3A7F7211C0FE2D9" translateForJs="false">Aby przypisać linię wejściową do tej strefy jako linię wejściową główną, kliknij </TranslationEntry>
    <TranslationEntry name="47369BECFCFA3057B35B3C53D9DB96F7" fullContext="D136AF69D4115C70D83C7F9A0DE400BF" translateForJs="false"> przycisk spowoduje otwarcie okna zawierającego wszystkie dostępne linie wejściowe. Po dodaniu linii wejściowej zostanie jej automatycznie przypisana </TranslationEntry>
    <TranslationEntry name="AC057B4D8FC5EA6193980DA31FF2D8C0" fullContext="D136AF69D4115C70D83C7F9A0DE400BF" translateForJs="false"> typ wejścia (grupa procesów).</TranslationEntry>
    <TranslationEntry name="772161AADF68220963B8E972601D9416" fullContext="D136AF69D4115C70D83C7F9A0DE400BF" translateForJs="false">Są to pomocnicze linie wejściowe wyzwalane podczas przemieszczania się użytkownika ścieżką wejścia/wyjścia w celu rozbrojenia strefy z klawiatury lub czytnika. Jeśli najpierw zostanie wyzwolona linia podstawowa i uruchomi opóźnienie na wejście, aktywacje tych linii wejściowych będą ignorowane przez czas trwania opóźnienia na wejście. Jeśli opóźnienie na wejście strefy nie zostanie wyzwolone, linie wejściowe przekazujące natychmiast wygenerują alarm strefy. Te linie wejściowe powinny obejmować większość linii wejściowych na ścieżce wejścia/wyjścia, aby w przypadku ominięcia przez intruza głównego punktu wejścia alarm zadziałał jak najszybciej.</TranslationEntry>
    <TranslationEntry name="2B1187E522193CB08A97C3D57F40545B" fullContext="D136AF69D4115C70D83C7F9A0DE400BF" translateForJs="false">Aby przypisać linię wejściową do tej strefy jako linię wejściową przekazania, kliknij </TranslationEntry>
    <TranslationEntry name="BE2EEE5933E9052FB34560193FB44564" fullContext="BE2EEE5933E9052FB34560193FB44564" translateForJs="false">Linie wejściowe włamania i inne</TranslationEntry>
    <TranslationEntry name="BE68942FCB68C7CDF3B9CBDFB6E619C6" fullContext="BE68942FCB68C7CDF3B9CBDFB6E619C6" translateForJs="false">Wybierz wszystkie inne linie wejściowe monitorowane przez tę strefę, które nie są częścią ścieżki wejścia/wyjścia. </TranslationEntry>
    <TranslationEntry name="46A4D79DEADF9A461369AD803C4A5962" fullContext="F6C165E4B1655F5AA80603CF72A41A23" translateForJs="false">Gdy strefa jest uzbrojona, linie wejściowe włamaniowe po wyzwoleniu spowodują natychmiastowe przejście strefy w stan alarmu; linie wejściowe włamaniowe są zazwyczaj zlokalizowane poza główną ścieżką wejścia/wyjścia.</TranslationEntry>
    <TranslationEntry name="F47C5D99255F9434C20F0B51D7CC8133" fullContext="F6C165E4B1655F5AA80603CF72A41A23" translateForJs="false">Jeśli strefa monitoruje dodatkowe linie wejściowe nieuzywane do wykrywania włamań, takie jak przycisk napadowy lub przełącznik automatyki, należy dodać linię wejściową do </TranslationEntry>
    <TranslationEntry name="B2E539C25AAAF1C3781E2F3A24857A86" fullContext="F6C165E4B1655F5AA80603CF72A41A23" translateForJs="false"> sekcji. Po przypisaniu można wybrać grupę procesów, która określi sposób reagowania strefy na zmiany stanu linii wejściowej — będzie to decydować o aktywacji sygnalizatorów i zgłaszaniu alarmów. Poszczególne linie wejściowe mogą wyzwalać alarmy lub sygnalizatory nawet jeśli strefa jest rozbrojona.</TranslationEntry>
    <TranslationEntry name="3583E78DB7C4384AD9A1A8180A5FB516" fullContext="6B0996849C35774816D9B9E0C0139401" translateForJs="false">Są to linie wejściowe, które natychmiastowo generują alarm strefy. Linie wejściowe czujek włamaniowych nie powinny obejmować linii wejściowych znajdujących się na głównej ścieżce wejścia/wyjścia z budynku. Linie te zazwyczaj będą się znajdować przy drzwiach i w obszarach budynku, do których dostęp uzyskuje się po rozbronieniu strefy. </TranslationEntry>
    <TranslationEntry name="F0FAAD41C48B75F562167AC82B58A1AE" fullContext="6B0996849C35774816D9B9E0C0139401" translateForJs="false">Aby przypisać linię wejściową do tej strefy jako linię wejściową czujki włamaniowej, kliknij </TranslationEntry>
    <TranslationEntry name="93490C9403BB3275843DDE6FF2EEE774" fullContext="6B0996849C35774816D9B9E0C0139401" translateForJs="false"> przycisk — otworzy się okno zawierające wszystkie dostępne linie wejściowe. Po dodaniu linii wejściowej zostanie jej automatycznie przypisany typ linii wejściowej Natychmiastowy alarm (grupa procesów).</TranslationEntry>
    <TranslationEntry name="459349D07AC40D50E8915D2864F2618A" fullContext="11228401AB59FA63A344DB2A532A031D" translateForJs="false">Inne linie wejściowe i urządzenia niezwiązane z wykrywaniem włamań, ale wymagające przetwarzania lub monitorowania przez strefę. Aby przypisać linię wejściową do tej strefy jako </TranslationEntry>
    <TranslationEntry name="05358EB5F0B8A34E9DBDFC3EB9B8AB3E" fullContext="11228401AB59FA63A344DB2A532A031D" translateForJs="false"> linia wejściowa, kliknij przycisk </TranslationEntry>
    <TranslationEntry name="686BC74FD2A40E9DC4D5029366B8C2E0" fullContext="11228401AB59FA63A344DB2A532A031D" translateForJs="false"> przycisk — otworzy się okno zawierające wszystkie dostępne linie wejściowe. Po wybraniu linii wejściowej będzie można ręcznie wybrać typ linii wejściowej; zaleca się niewybranie podstawowych, przekazujących lub natychmiastowych grup przetwarzania alarmów.</TranslationEntry>
    <TranslationEntry name="AE5515235FA3D29E8360C36B7D2F2C1F" fullContext="11228401AB59FA63A344DB2A532A031D" translateForJs="false">Można wybrać następujące typy linii wejściowych (grupy procesów):</TranslationEntry>
    <TranslationEntry name="8CC43DD7361FE90276A33E8A831CED7B" fullContext="384EBC274C42A75FDE45D2A6FF7FCBCD" translateForJs="false">Sprawdź, czy stroboskop jest prawidłowo zaprogramowany dla wybranej strefy, klikając </TranslationEntry>
    <TranslationEntry name="31560976987847EEFDE087B4E0E93478" fullContext="D9639666E00D34AB54136B2482E7B8C3" translateForJs="false">Jeśli stroboskop nie działa zgodnie z oczekiwaniami, ręcznie włącz linię wyjściową, do której jest podłączony stroboskop, na stronie </TranslationEntry>
    <TranslationEntry name="45018BB74327108381815DC84680D87C" fullContext="D9639666E00D34AB54136B2482E7B8C3" translateForJs="false"> strona. Jeśli stroboskop działa po sterowaniu linią wyjściową, sprawdź programowanie strefy na stronie </TranslationEntry>
    <TranslationEntry name="5DCD57359B6A2A64F9066B625A01B1D2" fullContext="5DCD57359B6A2A64F9066B625A01B1D2" translateForJs="false">Wewnętrzne sygnalizatory</TranslationEntry>
    <TranslationEntry name="C8F9DFE27B9525B201AF0CEF68BC56F4" fullContext="D743D0836E85B4C99E00B1901654E873" translateForJs="false">Sprawdź, czy wewnętrzny sygnalizator i wszelkie wewnętrzne linie wyjściowe sygnalizatora są prawidłowo zaprogramowane dla wybranej strefy, klikając </TranslationEntry>
    <TranslationEntry name="750110F93087407988B4A2348B8BCDDB" fullContext="DEE11D5843CBD78B0A8BD295606CD33C" translateForJs="false">Jeśli sygnalizator wewnętrzny nie działa prawidłowo, przejdź do </TranslationEntry>
    <TranslationEntry name="BE1A51BE47CA79D091468BE2C4D389E8" fullContext="33F21C764C1167D1342B7954C70B18AA" translateForJs="false"> strona i potwierdź, że strefie przypisano </TranslationEntry>
    <TranslationEntry name="7F882D742DA62F0EDBABBF9D5FDDC99F" fullContext="DEE11D5843CBD78B0A8BD295606CD33C" translateForJs="false">Urządzenie wewnętrznego sygnalizatora</TranslationEntry>
    <TranslationEntry name="2CFE1F42429ED64863E7F8B743790456" fullContext="DEE11D5843CBD78B0A8BD295606CD33C" translateForJs="false">Linie wyjściowe wewnętrznego sygnalizatora</TranslationEntry>
    <TranslationEntry name="BCFC2A79CC56BB05850915D7E90F21F5" fullContext="33F21C764C1167D1342B7954C70B18AA" translateForJs="false">. Jeśli używane są linie wyjściowe sygnalizatora, można nimi ręcznie sterować przez </TranslationEntry>
    <TranslationEntry name="B06CEEE897BA5C6F01357A4C2937347F" fullContext="33F21C764C1167D1342B7954C70B18AA" translateForJs="false"> strona, aby upewnić się, że okablowanie jest prawidłowe.</TranslationEntry>
    <TranslationEntry name="DEAA06044EA0343A8267BC77972122D6" fullContext="33F21C764C1167D1342B7954C70B18AA" translateForJs="false">Przydatne do ręcznego testowania sygnalizatorów bez konieczności wyzwalania alarmu. Ta opcja omija również </TranslationEntry>
    <TranslationEntry name="9DA6B22E6BFC64344EDEC7360E9F364A" fullContext="9DA6B22E6BFC64344EDEC7360E9F364A" translateForJs="false">Zewnętrzne sygnalizatory</TranslationEntry>
    <TranslationEntry name="95E59E539CD69C94026493117498FBEC" fullContext="06B8B724E56047FE2AA5EBF577AF3D6A" translateForJs="false">Sprawdź, czy zewnętrzny sygnalizator i wszelkie zewnętrzne linie wyjściowe sygnalizatora są prawidłowo zaprogramowane dla wybranej strefy, klikając </TranslationEntry>
    <TranslationEntry name="97A6882C66F4BCC68893E0C0C27043A6" fullContext="33F21C764C1167D1342B7954C70B18AA" translateForJs="false">Jeśli zewnętrzny sygnalizator nie działa prawidłowo, przejdź do </TranslationEntry>
    <TranslationEntry name="887CBFE3DEAC2F67283F31695996EFDA" fullContext="33F21C764C1167D1342B7954C70B18AA" translateForJs="false">Zewnętrzne urządzenie sygnalizacyjne</TranslationEntry>
    <TranslationEntry name="C39DE332167678FAFA85E0C96098D342" fullContext="33F21C764C1167D1342B7954C70B18AA" translateForJs="false">Linie wyjściowe zewnętrznego sygnalizatora</TranslationEntry>
    <TranslationEntry name="A15A00C6CA1D51A402699E9425FB79FF" fullContext="587F063D5DA9D77170CB9166EC0659A6" translateForJs="false">Test obchodowy można uruchomić i zatrzymać dla wybranej strefy za pomocą poniższych przycisków. Po uruchomieniu linie wejściowe będą automatycznie przemieszczać się z </TranslationEntry>
    <TranslationEntry name="A16A6B06609898D0DD1BD1A0454E2F2C" fullContext="587F063D5DA9D77170CB9166EC0659A6" translateForJs="true">Linie wejściowe do przetestowania</TranslationEntry>
    <TranslationEntry name="FEB71BE077BA2B61CC854704280F6120" fullContext="587F063D5DA9D77170CB9166EC0659A6" translateForJs="false"> listę podczas testowania.</TranslationEntry>
    <TranslationEntry name="D981E534C42A8FCAEAE41979D626B707" fullContext="39C57F846BD8FD9AB4F7EF3D00ACF6EA" translateForJs="false">Gdy test obchodowy jest aktywny, przetwarzanie stanu linii wejściowych jest wyłączone, co umożliwia testowanie linii wejściowych reagowania kryzysowego, takich jak przyciski pod przymusem, przyciski alarmowe i czujki dymu, bez uruchamiania alarmów.</TranslationEntry>
    <TranslationEntry name="2F635790E27325AAF601D562AB61FA86" fullContext="39C57F846BD8FD9AB4F7EF3D00ACF6EA" translateForJs="false">Jednak przetwarzanie linii wejściowych jest wyłączone tylko dla strefy/stref przeprowadzających test obchodowy, więc jeśli linie wejściowe są uwzględnione w wielu strefach, reakcja alarmowa może nadal wystąpić. W takim przypadku może być warto przeprowadzać testy wielu stref jednocześnie.</TranslationEntry>
    <TranslationEntry name="48C9898EE9AD95D52EFE6BA1034C9519" fullContext="39C57F846BD8FD9AB4F7EF3D00ACF6EA" translateForJs="false">Test zostanie automatycznie zakończony po pomyślnym przetestowaniu wszystkich linii wejściowych w danej strefie. Jeśli niektóre linie wejściowe nie mogą być przetestowane, test można anulować przed czasem za pomocą przycisku </TranslationEntry>
    <TranslationEntry name="70D772284149EDE15FC682EE4E6799F9" fullContext="70D772284149EDE15FC682EE4E6799F9" translateForJs="false">Anuluj test obchodowy</TranslationEntry>
    <TranslationEntry name="FA418A8E794138F571BAA2A006AC5B45" fullContext="39C57F846BD8FD9AB4F7EF3D00ACF6EA" translateForJs="false"> przycisk poniżej. Postęp uruchomionego testu może być jednocześnie widoczny na wielu urządzeniach.</TranslationEntry>
    <TranslationEntry name="D8EB609ED149BB1A0625DAA541070034" fullContext="D8EB609ED149BB1A0625DAA541070034" translateForJs="false">Uruchom test obchodowy</TranslationEntry>
    <TranslationEntry name="875FFCD58C167334A31D3DE2FF42776A" fullContext="875FFCD58C167334A31D3DE2FF42776A" translateForJs="false">Aktywuj każdą z linii wejściowych na poniższej liście, aby je przetestować. Po przetestowaniu zostaną automatycznie przeniesione do listy 'Zaliczone'.</TranslationEntry>
    <TranslationEntry name="FE0269AAAC39DDD1A262ED86AE84425F" fullContext="FE0269AAAC39DDD1A262ED86AE84425F" translateForJs="false">Pobiera plik na komputer lokalny zawierający kopię zapasową bazy danych. Alternatywnie kopia zapasowa może zostać pobrana bezpośrednio na dysk USB podłączony do Kontrolera Inception.</TranslationEntry>
    <TranslationEntry name="51E19A3685FF39AA5F11838A3BC17A5C" fullContext="51E19A3685FF39AA5F11838A3BC17A5C" translateForJs="false">Pobierz kopię zapasową na dysk USB</TranslationEntry>
    <TranslationEntry name="F35B2F25B676982CFF4FEB4B1EBEEFB5" fullContext="F35B2F25B676982CFF4FEB4B1EBEEFB5" translateForJs="false">Przesyła wcześniej pobrany plik kopii zapasowej w celu przywrócenia bazy danych. Bieżące ustawienia bazy danych zostaną utracone.</TranslationEntry>
    <TranslationEntry name="2C3B45BAD8BD3969F1B6F76F8D53DEA2" fullContext="2C3B45BAD8BD3969F1B6F76F8D53DEA2" translateForJs="false">Wgraj i przywróć plik kopii zapasowej</TranslationEntry>
    <TranslationEntry name="A7EA05BCA2924214C7101C705EF0A2BD" fullContext="A7EA05BCA2924214C7101C705EF0A2BD" translateForJs="false">Przywróć kopię zapasową z dysku USB</TranslationEntry>
    <TranslationEntry name="A03EFB62079EABF9FFB2596C9FEC467E" fullContext="A03EFB62079EABF9FFB2596C9FEC467E" translateForJs="false">Czyści bazę danych i resetuje kontroler, przywracając jego ustawienia fabryczne.</TranslationEntry>
    <TranslationEntry name="DE7D275CECA85716D63385297471003D" fullContext="DE7D275CECA85716D63385297471003D" translateForJs="false">Resetuj do ustawień fabrycznych</TranslationEntry>
    <TranslationEntry name="C12057DCF36B417ED7DCABE2CF95A96A" fullContext="C12057DCF36B417ED7DCABE2CF95A96A" translateForJs="false">Utwórz raport konfiguracji</TranslationEntry>
    <TranslationEntry name="7B60770A3AB6C87E859C0F73A337A9DC" fullContext="7B60770A3AB6C87E859C0F73A337A9DC" translateForJs="false">Ustawienia daty/godziny</TranslationEntry>
    <TranslationEntry name="45E96C0A422CE8A1A6EC1BD5EB9625C6" fullContext="45E96C0A422CE8A1A6EC1BD5EB9625C6" translateForJs="false">Wybierz wszystkie</TranslationEntry>
    <TranslationEntry name="82081BFD43B049D598423CF4B42CACEC" fullContext="82081BFD43B049D598423CF4B42CACEC" translateForJs="false">Przywróć kopię zapasową bazy danych z dysku USB</TranslationEntry>
    <TranslationEntry name="D487AE2E331D13F769AE328C2DE8A0CE" fullContext="D487AE2E331D13F769AE328C2DE8A0CE" translateForJs="false">To okno dialogowe umożliwia przywrócenie kopii zapasowej bazy danych z podłączonego dysku USB.</TranslationEntry>
    <TranslationEntry name="2BD339D85EE3B33E513359CE781B60CC" fullContext="2BD339D85EE3B33E513359CE781B60CC" translateForJs="false">Przywróć</TranslationEntry>
    <TranslationEntry name="4183D493D40E5C77EC962E4BAF3D2437" fullContext="4183D493D40E5C77EC962E4BAF3D2437" translateForJs="false">Podgląd kalendarza poniżej służy do sprawdzenia, czy zdarzenia kalendarza zostały poprawnie zaprogramowane.</TranslationEntry>
    <TranslationEntry name="9717143C9936D271E965A0C5379BE81A" fullContext="86DB9E5CE7844E934A73FCD510EBA283" translateForJs="false">Podgląd kalendarza może być używany do przeglądania dowolnej daty w przyszłości i potwierdzania, czy zdarzenia kalendarza w przyszłości zostały prawidłowo zaprogramowane. </TranslationEntry>
    <TranslationEntry name="E78BC8FED690E7D16CFF151FFBEEF7BF" fullContext="86DB9E5CE7844E934A73FCD510EBA283" translateForJs="false">Gdy wprowadzane są zmiany w zdarzeniach kalendarzy, zaleca się najpierw zaktualizować podgląd kalendarza, klikając </TranslationEntry>
    <TranslationEntry name="3555DE41441A9AAFB6DFA16337C6FB5C" fullContext="86DB9E5CE7844E934A73FCD510EBA283" translateForJs="false"> przycisk. Kalendarz jest zawsze wyświetlany w miesiącach; możesz wyświetlić podgląd kalendarza, naciskając klawisze strzałek, aby przechodzić do przodu i wstecz. Aby powrócić do bieżącego dnia, kliknij </TranslationEntry>
    <TranslationEntry name="C5E7DFAF771D423ECF59B008369021E8" fullContext="C5E7DFAF771D423ECF59B008369021E8" translateForJs="false">dzisiaj</TranslationEntry>
    <TranslationEntry name="092E74DEBCA9F6B64FDB6DC6E335BEA9" fullContext="86DB9E5CE7844E934A73FCD510EBA283" translateForJs="false">Kolor niebieski wskazuje zdarzenia kalendarza, które będą obowiązywać w danym dniu.</TranslationEntry>
    <TranslationEntry name="61B0374A2C270F5041F3346B8DE50F31" fullContext="61B0374A2C270F5041F3346B8DE50F31" translateForJs="false">Dodaj z rejestru</TranslationEntry>
    <TranslationEntry name="C1B1A103D13E5860392F4A148E32FE87" fullContext="C1B1A103D13E5860392F4A148E32FE87" translateForJs="false">Dodaj szablon identyfikatora ze zdarzenia rejestru</TranslationEntry>
    <TranslationEntry name="B176A84111107828BC6EB6F931EECBB3" fullContext="B176A84111107828BC6EB6F931EECBB3" translateForJs="false">To okno dialogowe umożliwia tworzenie szablonu identyfikatora na podstawie niedawnego (tj. w ciągu ostatnich 24 godzin) zdarzenia odczytu nierozpoznanego identyfikatora.</TranslationEntry>
    <TranslationEntry name="7B601B33D4E09B3401B3DC4EB229B96B" fullContext="7B601B33D4E09B3401B3DC4EB229B96B" translateForJs="false">Domyślna konfiguracja instalatora</TranslationEntry>
    <TranslationEntry name="9785BE52A77A31067805F7BB3B0BE2FB" fullContext="9785BE52A77A31067805F7BB3B0BE2FB" translateForJs="false">Twoje urządzenie wymaga, aby użytkownik Instalator miał skonfigurowane domyślne dane do logowania przez internet — jest to spowodowane pierwszym użyciem lub zresetowaniem użytkownika Instalator do ustawień domyślnych.</TranslationEntry>
    <TranslationEntry name="97B83770A2057542F568C338E8BC1F86" fullContext="97B83770A2057542F568C338E8BC1F86" translateForJs="false">Musisz upewnić się, że hasło instalatora spełnia aktualnie ustawioną politykę haseł:</TranslationEntry>
    <TranslationEntry name="F5D6040ED78CA86DDC73296A49B18510" fullContext="F5D6040ED78CA86DDC73296A49B18510" translateForJs="true">Zapisz zmiany</TranslationEntry>
    <TranslationEntry name="379029140A1BC931036EA8A6B1018B23" fullContext="379029140A1BC931036EA8A6B1018B23" translateForJs="false">Twoje bieżące hasło nie spełnia aktualnie ustawionej polityki haseł.</TranslationEntry>
    <TranslationEntry name="C0348D3564175D475F968F5A033430CA" fullContext="C0348D3564175D475F968F5A033430CA" translateForJs="false">Aby chronić Twoje konto i zapewnić, że Twoje hasło spełnia aktualnie ustawioną politykę haseł, musisz utworzyć nowe hasło spełniające następujące kryteria:</TranslationEntry>
    <TranslationEntry name="62A1EA310617CCF34C77FB5217128B1B" translateForJs="false" rules="paramCheck=true" notes="This string contains special formatting parameters (e.g. &quot;{0}&quot;) that must be preserved in the translation">Musi mieć co najmniej {0} znaków.</TranslationEntry>
    <TranslationEntry name="6A77D7339F76624915B0DA5B5F36F257" fullContext="D2482EF4ADF3A14D01688126069E2882" translateForJs="false">Co najmniej jedna litera.</TranslationEntry>
    <TranslationEntry name="C5F8568FFB3D35418C90B0D853822CB4" fullContext="B31A01F2FE52F7C513BA38566A711EA6" translateForJs="false">Co najmniej jedna cyfra.</TranslationEntry>
    <TranslationEntry name="D61FDFD9E72AF3EF035A98CB2F1AD35C" fullContext="63E853048F3910550EA9527905A018C3" translateForJs="false">Co najmniej jeden znak specjalny (np. @, !, &amp;, ?).</TranslationEntry>
    <TranslationEntry name="887F7DB126221FE60D18C895D41DC8F6" fullContext="887F7DB126221FE60D18C895D41DC8F6" translateForJs="false">Potwierdź hasło</TranslationEntry>
    <TranslationEntry name="1A5BBAFC127F6BA22EC0D652F0838915" translateForJs="false" rules="paramCheck=true" notes="This string contains special formatting parameters (e.g. &quot;{0}&quot;) that must be preserved in the translation">Wymagany jest nowy domyślny PIN i musi mieć co najmniej {0} cyfr.</TranslationEntry>
    <TranslationEntry name="48FEE610DDFECFBD1C9A0879D21826C5" translateForJs="false" rules="paramCheck=true" notes="This string contains special formatting parameters (e.g. &quot;{0}&quot;) that must be preserved in the translation">Wymagany jest nowy domyślny PIN i musi mieć od {0} do {1} cyfr.</TranslationEntry>
    <TranslationEntry name="2EB83A84472C2AD5EA370E14532781CA" translateForJs="false" rules="paramCheck=true" notes="This string contains special formatting parameters (e.g. &quot;{0}&quot;) that must be preserved in the translation">Twój aktualny PIN nie spełnia bieżącej polityki i musi mieć dokładnie {0} cyfr.</TranslationEntry>
    <TranslationEntry name="C2A7415F63E5E8A76CF0E8098DAF5AB2" translateForJs="false" rules="paramCheck=true" notes="This string contains special formatting parameters (e.g. &quot;{0}&quot;) that must be preserved in the translation">Twój bieżący PIN nie spełnia obowiązujących zasad i musi mieć od {0} do {1} cyfr.</TranslationEntry>
    <TranslationEntry name="47B2C5987F37F0BC39CE32E878D35B77" fullContext="47B2C5987F37F0BC39CE32E878D35B77" translateForJs="false">Resetuj listę kontrolną</TranslationEntry>
    <TranslationEntry name="F560A837B226BB8DC63C2F9FFD94B749" fullContext="F560A837B226BB8DC63C2F9FFD94B749" translateForJs="false">Strefy, sprzęt, wykrywanie włamań i windy</TranslationEntry>
    <TranslationEntry name="C1F6AF9CD570DF25F33AFBE20B1B9DE7" fullContext="C1F6AF9CD570DF25F33AFBE20B1B9DE7" translateForJs="false">Strefy, sprzęt i wykrywanie włamania</TranslationEntry>
    <TranslationEntry name="0C64BD487DEB23701EFE7DA9D8EC2900" fullContext="0C64BD487DEB23701EFE7DA9D8EC2900" translateForJs="false">Przedziały czasowe i harmonogramy</TranslationEntry>
    <TranslationEntry name="E5F6222DB567607B9F3E6AEA15794076" fullContext="E5F6222DB567607B9F3E6AEA15794076" translateForJs="false">Uprawnienia, identyfikatory i użytkownicy</TranslationEntry>
    <TranslationEntry name="423E555C5EC3885F2BB5D9D2D6627F63" fullContext="423E555C5EC3885F2BB5D9D2D6627F63" translateForJs="false">Monitorowanie</TranslationEntry>
    <TranslationEntry name="8896298178019B16ABCC8C2F5E61F79E" fullContext="8896298178019B16ABCC8C2F5E61F79E" translateForJs="false">Ostatnie kroki</TranslationEntry>
    <TranslationEntry name="2B19016679479844026EC7E29E08006E" fullContext="9F98B868674F0CE66D668281691DE169" translateForJs="false">Ten krok służy do konfiguracji ustawień sieciowych i metody połączenia z interfejsem WWW Inception. Domyślne ustawienia sieciowe to Ethernet z użyciem DHCP; w razie potrzeby można skonfigurować połączenie Ethernet ze statycznym adresem IP. </TranslationEntry>
    <TranslationEntry name="CC3504AD4276A7687B1065BA6A1A249F" fullContext="9F98B868674F0CE66D668281691DE169" translateForJs="false">Jeśli zakupiono Adapter Wi-Fi Inception, można podłączyć kontroler do sieci bezprzewodowej obiektu lub połączyć się bezpośrednio za pomocą Bezprzewodowego hotspotu. Zaleca się pozostawienie tej opcji włączonej i ustawionej na Bezprzewodowy hotspot, jeśli nie zostawiasz adaptera Wi-Fi na obiekcie, ale będziesz z niego korzystać w przyszłości przy serwisowaniu tego kontrolera Inception.</TranslationEntry>
    <TranslationEntry name="E3AAF08C0D70547E84EC53D63BB32E58" fullContext="9F98B868674F0CE66D668281691DE169" translateForJs="false">Możesz włączyć Skytunnel, jeśli wymagane jest zdalne połączenie z urządzenia spoza sieci lokalnej z kontrolerem Inception. Skytunnel zapewnia bezproblemowe połączenie, które nie wymaga przekierowania portów. Skytunnel jest usługą w chmurze i wymaga dostępu do internetu zarówno dla kontrolera Inception, jak i urządzenia łączącego się.</TranslationEntry>
    <TranslationEntry name="066E6BF8EE344AE94483204E21F87C97" fullContext="066E6BF8EE344AE94483204E21F87C97" translateForJs="false">Stan Ethernet</TranslationEntry>
    <TranslationEntry name="DB00F6339EE22D36B6CEEE7D82183A6C" fullContext="DB00F6339EE22D36B6CEEE7D82183A6C" translateForJs="false">Tryb WiFi</TranslationEntry>
    <TranslationEntry name="7CFEBBE855856FC258D09EEA1CA47BEB" fullContext="7CFEBBE855856FC258D09EEA1CA47BEB" translateForJs="false">Stan WiFi</TranslationEntry>
    <TranslationEntry name="CB48CBF342305A9AE53E02E21FCB644C" fullContext="CB48CBF342305A9AE53E02E21FCB644C" translateForJs="false">Nie włączono</TranslationEntry>
    <TranslationEntry name="34DB62695E2D8EE5E97899AF0292D934" fullContext="34DB62695E2D8EE5E97899AF0292D934" translateForJs="false">Nie można nawiązać połączenia</TranslationEntry>
    <TranslationEntry name="37783A45AB7B3A41E46EC1E3E8D6E21E" fullContext="37783A45AB7B3A41E46EC1E3E8D6E21E" translateForJs="false">Dostęp WWW przez SkyTunnel</TranslationEntry>
    <TranslationEntry name="A707F801C5BEE44E691B2D25C8C3614A" fullContext="A707F801C5BEE44E691B2D25C8C3614A" translateForJs="false">Konfiguruj ustawienia sieciowe</TranslationEntry>
    <TranslationEntry name="5662D472A7F97A3DC96BE336E08A47B1" fullContext="D444EBCEE97E23721262D676FFA10687" translateForJs="false">Konfiguruj ustawienia sieci Ethernet dla DHCP lub statycznego IP. </TranslationEntry>
    <TranslationEntry name="D63CFD8988D12D786DE6C55DB70964E5" fullContext="D444EBCEE97E23721262D676FFA10687" translateForJs="false">Skonfiguruj ustawienia Wi-Fi, jeśli na obiekcie instalowany jest adapter Wi-Fi.</TranslationEntry>
    <TranslationEntry name="3ADE9C1749F5AC0FAF5231F856DA824A" fullContext="F60576844AD1964B963A516F29B95082" translateForJs="false">Ten krok służy do konfiguracji ustawień daty i czasu. Po jego zakończeniu czas wyświetlany przez kontroler powinien odpowiadać czasowi w lokalizacji panelu. Ważne jest dokładne ustawienie daty i czasu, aby przedziały czasowe i zdarzenia kalendarzowe występowały o właściwej porze. Przedziały czasowe mogą służyć do wyzwalania wielu zaplanowanych akcji w systemie, na przykład: </TranslationEntry>
    <TranslationEntry name="3BD7A79EFEB7AF1B2CF5BDFC6A41DA7D" fullContext="3BD7A79EFEB7AF1B2CF5BDFC6A41DA7D" translateForJs="false">Wolny dostęp do przejścia</TranslationEntry>
    <TranslationEntry name="96479B4E65C1AA940898E95F9E1F1AD5" fullContext="74169C68ECBBAD50FBFF35EBE6B3D727" translateForJs="false">Automatyczne uzbrajanie strefy</TranslationEntry>
    <TranslationEntry name="9FA7599F9F86000888CD48894CA71976" fullContext="F60576844AD1964B963A516F29B95082" translateForJs="false">Zaleca się skonfigurowanie kontrolera do synchronizacji z serwerem NTP, co zapewni zawsze prawidłową datę i godzinę. Serwer NTP może znajdować się w sieci lokalnej lub w internecie.</TranslationEntry>
    <TranslationEntry name="147EAEDCEBDD52DD01D2F1E42523B898" fullContext="F60576844AD1964B963A516F29B95082" translateForJs="false">Jeśli sieć, do której podłączony jest kontroler, nie ma dostępu do serwera NTP, należy ręcznie ustawić datę i godzinę. Uwaga: jeśli ręcznie ustawisz datę i godzinę, będziesz również musiał ręcznie korygować zmiany czasu letniego dla swojej lokalizacji.</TranslationEntry>
    <TranslationEntry name="08C602565C8FFB9F4A3D0F9589710F0B" fullContext="08C602565C8FFB9F4A3D0F9589710F0B" translateForJs="false">Bieżąca data i czas</TranslationEntry>
    <TranslationEntry name="225F0204CD2CA87530C681AEAE9B7F3E" fullContext="225F0204CD2CA87530C681AEAE9B7F3E" translateForJs="false">Serwer NTP</TranslationEntry>
    <TranslationEntry name="F33C05693163353F1E4D340E87431E27" fullContext="F33C05693163353F1E4D340E87431E27" translateForJs="false">Konfiguruj ustawienia daty i czasu</TranslationEntry>
    <TranslationEntry name="CF5E7F88FAA5B962070BD095E207360A" fullContext="CF5E7F88FAA5B962070BD095E207360A" translateForJs="false">Skonfiguruj serwer NTP i ustawienia strefy czasowej lub ręcznie ustaw datę i godzinę, jeśli serwer NTP nie jest dostępny.</TranslationEntry>
    <TranslationEntry name="6354DCE662702F1F34D5EE84C1EA1AAA" fullContext="6BB8B50B14C10DCCA852833BBD1660C5" translateForJs="false">Ten krok służy do konfiguracji ustawień, takich jak długość PIN użytkownika, konfiguracja końca linii i </TranslationEntry>
    <TranslationEntry name="4B42D9359BE1501BA824F93E8A2421B8" fullContext="6BB8B50B14C10DCCA852833BBD1660C5" translateForJs="false">. Możesz wybrać minimalną i maksymalną długość PIN-ów użytkownika. Domyślna długość PIN-u wynosi od dwóch do czterech cyfr, jednak obiekt może wymagać dłuższych PIN-ów, ponieważ są one bezpieczniejsze.</TranslationEntry>
    <TranslationEntry name="12F8CA23248BCF158AB5DC8C66B39CD8" fullContext="6BB8B50B14C10DCCA852833BBD1660C5" translateForJs="false">Jeśli istnieje ryzyko, że użytkownicy na miejscu mogą znaleźć się w sytuacji przymusu, możesz włączyć </TranslationEntry>
    <TranslationEntry name="1D4C2346DC1327A8B4C5E2578A3D95C7" fullContext="6BB8B50B14C10DCCA852833BBD1660C5" translateForJs="false"> funkcja. Polega to na utworzeniu PIN-u, który wszyscy użytkownicy mogą wprowadzić w terminalu lub na klawiaturze pod przymusem, aby cicho powiadomić stację monitorowania o sytuacji przymusu. </TranslationEntry>
    <TranslationEntry name="97BAEA6DEECB1D8498DECC5969F1F5EC" fullContext="6BB8B50B14C10DCCA852833BBD1660C5" translateForJs="false"> musi mieć również przypisane uprawnienia — powinny one umożliwiać użytkownikowi pod przymusem dostęp do elementów, do których zwykle ma dostęp, bez wzbudzania podejrzeń, ale nie zezwalać na zbyt szeroki dostęp, ponieważ ten PIN jest znany wielu użytkownikom.</TranslationEntry>
    <TranslationEntry name="4453875742A940E689A0CA91A84F0D9B" fullContext="6BB8B50B14C10DCCA852833BBD1660C5" translateForJs="false">Jeśli zastępujesz istniejący system alarmowy, możesz uniknąć zmiany rezystorów końca linii dla każdego urządzenia detekcyjnego, wybierając odpowiadającą konfigurację końca linii. W przypadku instalacji nowego systemu zaleca się użycie domyślnych wartości 2k2 + 2k2 lub 2k2 + 6k8, ponieważ odpowiadają one rezystorom dostarczanym z produktami Inner Range.</TranslationEntry>
    <TranslationEntry name="852F7D11FB5C43E6F974C9B003DD002B" fullContext="6BB8B50B14C10DCCA852833BBD1660C5" translateForJs="false">W przypadku Europy, </TranslationEntry>
    <TranslationEntry name="8A3AB8B3912E17A43A6DC22F30C19FF4" fullContext="6BB8B50B14C10DCCA852833BBD1660C5" translateForJs="false"> można wybrać w celu spełnienia lokalnych standardów bezpieczeństwa. EN50131 i BS8243 to dwa standardy, które można aktualnie wybrać, co pozwala systemowi wyświetlać dodatkowe opcje lub funkcje charakterystyczne dla tych standardów.</TranslationEntry>
    <TranslationEntry name="A1D0EC6D56F8833A078B5A7AC4CAF2D4" fullContext="A1D0EC6D56F8833A078B5A7AC4CAF2D4" translateForJs="false">Minimum</TranslationEntry>
    <TranslationEntry name="8321E79C278EC510F63675C040594892" fullContext="8321E79C278EC510F63675C040594892" translateForJs="false">Maksimum</TranslationEntry>
    <TranslationEntry name="A8C075E5B6BFCFEB56DAA18F0D60BB99" fullContext="A8C075E5B6BFCFEB56DAA18F0D60BB99" translateForJs="false">Długość PIN</TranslationEntry>
    <TranslationEntry name="8A6E143CFB4EBA49625A219A9784A287" fullContext="8A6E143CFB4EBA49625A219A9784A287" translateForJs="false">Konfiguracja końca linii</TranslationEntry>
    <TranslationEntry name="5FC158C012748479925441762EAD1DA6" fullContext="5FC158C012748479925441762EAD1DA6" translateForJs="false">Konfiguruj ustawienia systemu</TranslationEntry>
    <TranslationEntry name="648F02B81F88C3834FE9EF9FBAA6CC3F" fullContext="2E7CE34EAF83A1B74AE41551D6CE6BFA" translateForJs="false">Skonfiguruj długość PIN użytkownika, ustawienia użytkownika alarmowego oraz ustawienia końca linii.</TranslationEntry>
    <TranslationEntry name="7D2DA24E7BEFD8C59FAD4B67916CCF80" fullContext="2E7CE34EAF83A1B74AE41551D6CE6BFA" translateForJs="false">W przypadku Europy, wybierz tryb zgodności jeśli jest wymagany (np. EN50131 dla instalacji europejskich).</TranslationEntry>
    <TranslationEntry name="064402F01DE173CB6FAE35E309AED0D1" fullContext="064402F01DE173CB6FAE35E309AED0D1" translateForJs="false">Konfiguruj ustawienia systemu i zgodność</TranslationEntry>
    <TranslationEntry name="0EEAFA5CE01245B8724F971353123F97" fullContext="CE954D7EA1A1F5B28C231BE002B839C0" translateForJs="false">Ten krok służy do tworzenia i nadawania nazw wszystkim strefom, które będą monitorować linie wejściowe w systemie. Polega to jedynie na tworzeniu stref, aby mogły być używane w następnym </TranslationEntry>
    <TranslationEntry name="432886B2F5933B3F6C9A957A9440342D" fullContext="CE954D7EA1A1F5B28C231BE002B839C0" translateForJs="false">Rejestracja sprzętu</TranslationEntry>
    <TranslationEntry name="0772CD31D1C2CE397A67EC71946035A9" fullContext="CE954D7EA1A1F5B28C231BE002B839C0" translateForJs="false"> kroku, rzeczywista konfiguracja stref jest wykonywana później w </TranslationEntry>
    <TranslationEntry name="576EB1BDD77D22DA5ADBCC04D2F934AC" fullContext="576EB1BDD77D22DA5ADBCC04D2F934AC" translateForJs="false">Konfiguruj wykrywanie intruzów</TranslationEntry>
    <TranslationEntry name="352734C61441CF259C5685C1789E1554" fullContext="CE954D7EA1A1F5B28C231BE002B839C0" translateForJs="false"> krok </TranslationEntry>
    <TranslationEntry name="6BCFACDA539B0B01471331C0CEEE8C6D" fullContext="CE954D7EA1A1F5B28C231BE002B839C0" translateForJs="false">System można zaprogramować z jedną strefą lub z wieloma strefami. Korzyścią z jednej strefy jest łatwość uzbrajania i rozbrajania całego systemu. Jednak tworzenie wielu stref umożliwia podział obiektu i ograniczenie dostępu użytkowników do określonych stref — nie każdy użytkownik będzie potrzebował dostępu do strefy, takiej jak serwerownia. </TranslationEntry>
    <TranslationEntry name="A4996E5B48B92E9A34E4C135343716CF" fullContext="CE954D7EA1A1F5B28C231BE002B839C0" translateForJs="false">Jeśli używasz systemu Inception do kontroli dostępu, zaleca się posiadanie oddzielnych stref wewnątrz i na zewnątrz przejść, aby korzystać z takich funkcji jak </TranslationEntry>
    <TranslationEntry name="5A15EF543703FCE0E11A1E296835CA08" fullContext="CE954D7EA1A1F5B28C231BE002B839C0" translateForJs="false">Uzbrojenie 3-krotnym odczytem karty</TranslationEntry>
    <TranslationEntry name="CAFEBAD7307BBEACB912EC723F64004B" fullContext="CE954D7EA1A1F5B28C231BE002B839C0" translateForJs="false">Lokalizacja użytkownika</TranslationEntry>
    <TranslationEntry name="8DC6AC38BE8FC79DCB5A6D7395D35DAD" fullContext="CE954D7EA1A1F5B28C231BE002B839C0" translateForJs="false">Należy tworzyć dodatkowe strefy, jeśli chcesz grupować linie wejściowe o wspólnym przeznaczeniu, np. wszystkie czujki dymu w budynku.</TranslationEntry>
    <TranslationEntry name="3104A3CF25E05C70E6AB37E7050D8C1D" fullContext="3104A3CF25E05C70E6AB37E7050D8C1D" translateForJs="false">Zaprogramowane strefy</TranslationEntry>
    <TranslationEntry name="61B3EEAC2F78EC22E16FD5FD81D25F96" fullContext="61B3EEAC2F78EC22E16FD5FD81D25F96" translateForJs="false">Utwórz strefy</TranslationEntry>
    <TranslationEntry name="AAE3EA350452D63934D186BEA5C2E69F" fullContext="AAE3EA350452D63934D186BEA5C2E69F" translateForJs="false">Utwórz i nazwij wszystkie strefy dla obiektu.</TranslationEntry>
    <TranslationEntry name="C4DF7A1F716B41E083C29A68B89BC995" fullContext="C4DF7A1F716B41E083C29A68B89BC995" translateForJs="false">Konfiguracja stref obiektu</TranslationEntry>
    <TranslationEntry name="A7F5B75C397154FB802E4FF9CA0B4973" fullContext="2125E8F4FC2EE9C007B622C301759DB9" translateForJs="false">Ten krok służy do konfiguracji Kontrolera Inception i modułów LAN. Obejmuje to programowanie linii wejściowych, linii wyjściowych, przejść i czytników w zależności od typu modułu, a także konfigurację zachowania modułu i składników monitorowania kondycji modułu (na przykład sabotaże obudowy, sabotaże sygnalizatora, inteligentne zasilacze, zewnętrzna bateria).</TranslationEntry>
    <TranslationEntry name="29E9427EB0EA5EC83C658E82B17027FE" fullContext="2125E8F4FC2EE9C007B622C301759DB9" translateForJs="false">Linie wejściowe, wyjściowe i czytniki są tworzone w systemie dopiero po skonfigurowaniu modułu. Podczas konfigurowania modułu zostaniesz przeprowadzony przez kolejne sekcje programowania. Kroki te będą zależeć od typu konfigurowanego modułu. Ten krok jest zakończony, gdy wszystkie moduły pojawią się w </TranslationEntry>
    <TranslationEntry name="9850984FA18974D28BB52C3A794133FC" fullContext="9850984FA18974D28BB52C3A794133FC" translateForJs="false">Skonfigurowane moduły</TranslationEntry>
    <TranslationEntry name="E89F8688220E5E5884C0EAA6690DCE61" fullContext="2125E8F4FC2EE9C007B622C301759DB9" translateForJs="false"> listy. </TranslationEntry>
    <TranslationEntry name="44F8E5EE0317DCED5FEF94FDB9164248" fullContext="2125E8F4FC2EE9C007B622C301759DB9" translateForJs="false">Jeśli chcesz skonfigurować moduł, którego jeszcze nie zakupiłeś lub nie podłączyłeś do systemu, możesz go utworzyć, klikając </TranslationEntry>
    <TranslationEntry name="CA06360D52CDAC148FEF8992C9B4839C" fullContext="CA06360D52CDAC148FEF8992C9B4839C" translateForJs="false">Nieskonfigurowane moduły sprzętowe</TranslationEntry>
    <TranslationEntry name="7CD1DB4C109BBE167EE9BE1028B28243" fullContext="7CD1DB4C109BBE167EE9BE1028B28243" translateForJs="false">Skonfigurowane moduły sprzętowe</TranslationEntry>
    <TranslationEntry name="FD1F12E65E76BC7612F9D78D4A9DAA33" fullContext="FD1F12E65E76BC7612F9D78D4A9DAA33" translateForJs="false">Uruchom kreator sprzętu</TranslationEntry>
    <TranslationEntry name="4C7A388FD6C84796EEA52B46ADD37DC8" fullContext="4C7A388FD6C84796EEA52B46ADD37DC8" translateForJs="false">Konfiguruj Kontroler Inception i podłączone moduły LAN.</TranslationEntry>
    <TranslationEntry name="A18BDE5D5FF07E3C5FFC8C065964EA90" fullContext="A18BDE5D5FF07E3C5FFC8C065964EA90" translateForJs="false">Testuj komponenty sprzętowe (linie wejściowe, linie wyjściowe, akumulator)</TranslationEntry>
    <TranslationEntry name="375DD33DB82B01F1F96DA56646647AFE" fullContext="375DD33DB82B01F1F96DA56646647AFE" translateForJs="false">Testuj linie wejściowe i wyjściowe Kontrolera Inception oraz wszystkich innych modułów LAN. Upewnij się, że wszystkie linie wejściowe i wyjściowe są prawidłowo okablowane i nazwane</TranslationEntry>
    <TranslationEntry name="7D5B51B31A42B90891F6B2D287CDB096" fullContext="7D5B51B31A42B90891F6B2D287CDB096" translateForJs="false">Wykonaj rejestrację sprzętową</TranslationEntry>
    <TranslationEntry name="749536C47003FAF44AE5306FC8DF7041" fullContext="9284B2779C432D538FA8C1D5E4817534" translateForJs="false">Jeśli system jest używany do wykrywania włamań, ten trzyczęściowy krok mapuje linie wejściowe do stref dla celów monitorowania, konfiguruje strefy, a następnie testuje stroboskopy i sygnalizatory, aby upewnić się, że ich konfiguracja jest prawidłowa.</TranslationEntry>
    <TranslationEntry name="14319C42F315BB8C40BEF9515AA732C2" fullContext="9284B2779C432D538FA8C1D5E4817534" translateForJs="false">Pierwsza część polega na mapowaniu linii wejściowych do utworzonych stref. </TranslationEntry>
    <TranslationEntry name="9F0FBFAD321527D0ACDDD9F972E32944" fullContext="9284B2779C432D538FA8C1D5E4817534" translateForJs="false">[Mapowanie wejść strefy]</TranslationEntry>
    <TranslationEntry name="A57D75070E20148C500977ADCE7D141B" fullContext="9284B2779C432D538FA8C1D5E4817534" translateForJs="false"> strona umożliwia dodanie linii wejściowych do jednej z czterech kategorii. Trzy z tych kategorii dotyczą wykrywania intruzów i automatycznie przypisują właściwe </TranslationEntry>
    <TranslationEntry name="5D190890B21D41A45827679B28C6E021" fullContext="9284B2779C432D538FA8C1D5E4817534" translateForJs="false">. Czwarta kategoria to </TranslationEntry>
    <TranslationEntry name="AA180F7C49D0023FDE8EF098C4D66417" fullContext="9284B2779C432D538FA8C1D5E4817534" translateForJs="false">, są to urządzenia niezwiązane z wykrywaniem włamań, ale nadal wymagające przetwarzania lub monitorowania przez strefę. </TranslationEntry>
    <TranslationEntry name="14B286AF80D6FD7B55EB8A034C112957" fullContext="9284B2779C432D538FA8C1D5E4817534" translateForJs="false">Druga część to konfiguracja strefy, w której można ustawić </TranslationEntry>
    <TranslationEntry name="2C1E69B9919A90AA42A4A526195F128D" fullContext="9284B2779C432D538FA8C1D5E4817534" translateForJs="false">Opóźnienia na wejście/wyjście, sygnalizator, stroboskop</TranslationEntry>
    <TranslationEntry name="1F67372A566E6A228FA6DF96E13A6197" fullContext="9284B2779C432D538FA8C1D5E4817534" translateForJs="false"> funkcjonalność. Opcje ustawione dla każdej strefy będą się różnić w zależności od przeznaczenia strefy.</TranslationEntry>
    <TranslationEntry name="1E066EC34A984B55135935947F877EA0" fullContext="9284B2779C432D538FA8C1D5E4817534" translateForJs="false">Trzecia część umożliwia testowanie stroboskopów i sygnalizatorów stref, co potwierdza, że fizyczne sygnalizatory i stroboskopy są prawidłowo okablowane i że opcje strefy określające, które sygnalizatory dźwięczą, są poprawnie skonfigurowane.</TranslationEntry>
    <TranslationEntry name="4FF48EC604EF6B4EFB227A82FEDBA2FD" fullContext="4FF48EC604EF6B4EFB227A82FEDBA2FD" translateForJs="false">Tak, konfiguruj wykrywanie intruzów</TranslationEntry>
    <TranslationEntry name="D6B693CCF4983A3CD80C2F98921AAA1C" fullContext="D6B693CCF4983A3CD80C2F98921AAA1C" translateForJs="false">Nie, wykrywanie intruzów nie jest potrzebne</TranslationEntry>
    <TranslationEntry name="F8C78C1BD7315D82E29BFA6E0232F143" fullContext="F8C78C1BD7315D82E29BFA6E0232F143" translateForJs="false">Czy na tym obiekcie stosowane jest wykrywanie włamań?</TranslationEntry>
    <TranslationEntry name="2AD3DE876049CEE03B072F08145C3E2B" fullContext="2AD3DE876049CEE03B072F08145C3E2B" translateForJs="false">Powiąż linie wejściowe ze strefami</TranslationEntry>
    <TranslationEntry name="9EE4F7B90BF589DDD121508BE364D645" fullContext="9EE4F7B90BF589DDD121508BE364D645" translateForJs="false">Przypisz linie wejściowe do odpowiednich stref</TranslationEntry>
    <TranslationEntry name="4D9B14EE5F114C93D780C851B4FA6201" fullContext="4D9B14EE5F114C93D780C851B4FA6201" translateForJs="false">Edytuj ustawienia strefy</TranslationEntry>
    <TranslationEntry name="06711C65E61FDF8F372E3802E729EA01" fullContext="06711C65E61FDF8F372E3802E729EA01" translateForJs="false">Konfiguruj opcje dla wszystkich stref.</TranslationEntry>
    <TranslationEntry name="C961C56ACD906703554D77A8108B7B2E" fullContext="C961C56ACD906703554D77A8108B7B2E" translateForJs="false">Testuj stroboskopy i sygnalizatory strefy</TranslationEntry>
    <TranslationEntry name="91861F48245CB718631CCC6043375237" fullContext="91861F48245CB718631CCC6043375237" translateForJs="false">Potwierdź, że sygnalizatory i stroboskopy są prawidłowo aktywowane dla każdej strefy.</TranslationEntry>
    <TranslationEntry name="3DD2C318C2B6AC54DA0B76FA43FF5DC3" fullContext="3DD2C318C2B6AC54DA0B76FA43FF5DC3" translateForJs="false">Zadeklarowałeś, że dla tego obiektu nie jest potrzebna detekcja włamania. Jeśli tak nie jest, zresetuj krok i odpowiedz Tak</TranslationEntry>
    <TranslationEntry name="7F1307426C8EA34E792EC42EF592173B" fullContext="6D616A7CCDC41FFDC9E2DDE634F21914" translateForJs="false">Jeśli system jest używany do integracji z windami, obejmuje to tworzenie Pięter windy i Kabin windy — dwóch głównych składników integracji.</TranslationEntry>
    <TranslationEntry name="73B16CD25029C5074D1AFCF47F155D40" fullContext="6D616A7CCDC41FFDC9E2DDE634F21914" translateForJs="false">Zasadniczo, niskopoziomowa integracja windy polega na podłączeniu linii wyjściowych systemu Inception do przycisków windy w kabinie windy, umożliwiając włączanie lub wyłączanie poszczególnych przycisków przez system Inception. Następnie użytkownik może zaprezentować kartę przy czytniku znajdującym się w kabinie windy, a w oparciu o jego uprawnienia, określone przyciski wyboru piętra mogą być włączone. Ponadto przyciski windy mogą być również podłączone do linii wejściowych systemu Inception, co pozwala systemowi Inception wiedzieć, który przycisk nacisnął użytkownik.</TranslationEntry>
    <TranslationEntry name="42CCD64A0A8A3ED594509DBFC0803038" fullContext="6D616A7CCDC41FFDC9E2DDE634F21914" translateForJs="false">Pierwszym krokiem jest utworzenie Pięter windy. Piętra windy reprezentują cel, do którego przycisk w kabinie windy zabiera użytkownika, a wiele kabin windy może mieć przycisk, który może zabrać użytkownika na to samo piętro. W niektórych przypadkach może istnieć wiele pięter windy utworzonych dla tego samego fizycznego piętra w budynku — na przykład jeśli kabina windy ma dwoje drzwi i istnieją różne przyciski dla 7A i 7B. W takim przypadku można utworzyć różne piętra z różnymi uprawnieniami dla każdej strony kabiny. Alternatywnie, jeśli określona kabina windy wymaga ograniczenia dostępu tylko do wybranych użytkowników, na przykład winda serwisowa, można utworzyć normalne piętra dla innych kabin, a także osobny zestaw pięter serwisowych dla serwisowej kabiny windy, z uprawnieniami wyłącznie dla pracowników technicznych.</TranslationEntry>
    <TranslationEntry name="1AFBA6A592F1D457DE943D2C785D0E89" fullContext="6D616A7CCDC41FFDC9E2DDE634F21914" translateForJs="false">Drugi krok polega na utworzeniu kabin windy. Reprezentują one fizyczną kabinę windy lub panel przycisków, z którym interaguje użytkownik. Zawierają one jeden lub więcej czytników, przy których użytkownik przykłada kartę lub wprowadza PIN, a także przyciski windy włączane lub wyłączane przez system Inception. Każdy przycisk windy wymaga zarówno piętra windy dla miejsca docelowego przycisku, jak i linii wyjściowej umożliwiającej jego aktywację na panelu. Opcjonalnie można również określić linię wejściową wskazującą, kiedy przycisk został naciśnięty.</TranslationEntry>
    <TranslationEntry name="FE1C52B60B205FAB83A0A462E3FFAB38" fullContext="FE1C52B60B205FAB83A0A462E3FFAB38" translateForJs="false">Tak, konfiguruj integrację windy</TranslationEntry>
    <TranslationEntry name="65E5FE53D628D8387C326C29B64C53BD" fullContext="65E5FE53D628D8387C326C29B64C53BD" translateForJs="false">Nie, integracja windy nie jest potrzebna</TranslationEntry>
    <TranslationEntry name="901AE32CFD66EC1AC57EF8788474BCAD" fullContext="901AE32CFD66EC1AC57EF8788474BCAD" translateForJs="false">Czy integracja z windami jest używana w tym obiekcie?</TranslationEntry>
    <TranslationEntry name="D03FC0EAB4BC8D988AB2E98B05B8F6C3" fullContext="D03FC0EAB4BC8D988AB2E98B05B8F6C3" translateForJs="false">Utwórz piętra windy</TranslationEntry>
    <TranslationEntry name="C1C698F098F0E91438C75397B12240D5" fullContext="C1C698F098F0E91438C75397B12240D5" translateForJs="false">Utwórz Piętra windy dla obiektu. Piętra mogą być współdzielone między wieloma Kabinami windy.</TranslationEntry>
    <TranslationEntry name="2C2D41ED0E5EE93F9EBAA1201AB6F204" fullContext="2C2D41ED0E5EE93F9EBAA1201AB6F204" translateForJs="false">Utwórz kabiny windy</TranslationEntry>
    <TranslationEntry name="261B03602B80C47E81A246FB168DD077" fullContext="261B03602B80C47E81A246FB168DD077" translateForJs="false">Utwórz kabiny windy dla obiektu.</TranslationEntry>
    <TranslationEntry name="602213C8CAEE974AB5CEE21D3C41C247" fullContext="602213C8CAEE974AB5CEE21D3C41C247" translateForJs="false">Stwierdziłeś, że integracja z windą nie jest konieczna dla tego obiektu. Jeśli tak nie jest, zresetuj krok i odpowiedz Tak</TranslationEntry>
    <TranslationEntry name="2748D7C2A7A21F175E5B71A9DB4421CB" fullContext="2748D7C2A7A21F175E5B71A9DB4421CB" translateForJs="false">Konfiguruj integrację windy</TranslationEntry>
    <TranslationEntry name="34659F28D5F70E6C3CBB0BB276E4D6FE" fullContext="74169C68ECBBAD50FBFF35EBE6B3D727" translateForJs="false">Ten krok służy do tworzenia i konfigurowania przedziałów czasowych używanych w późniejszych krokach, takich jak </TranslationEntry>
    <TranslationEntry name="067A54BFD35902965FF9D64C3DE21C65" fullContext="74169C68ECBBAD50FBFF35EBE6B3D727" translateForJs="false">, wyzwalając automatykę i kwalifikując </TranslationEntry>
    <TranslationEntry name="795341DE32FAEC18616B60B81B2BC2DD" fullContext="74169C68ECBBAD50FBFF35EBE6B3D727" translateForJs="false">Uprawnienia użytkownika</TranslationEntry>
    <TranslationEntry name="2598B751EE500E980A6D2015417A59EE" fullContext="74169C68ECBBAD50FBFF35EBE6B3D727" translateForJs="false">Przedziały czasowe bazują na cotygodniowych godzinach cyklicznych, gdzie przedziały czasowe są zazwyczaj aktywne w tych samych godzinach każdego tygodnia. Wyjątki od tych reguł można dodawać, aby umożliwić tymczasowe zmiany harmonogramu bez konieczności znacznej rekonfiguracji. </TranslationEntry>
    <TranslationEntry name="C520492F8B87AB63EA26E75791342D85" fullContext="74169C68ECBBAD50FBFF35EBE6B3D727" translateForJs="false">Domyślny przedział czasowy nosi nazwę Godziny pracy; ten przedział czasowy jest powszechnie używany do wyzwalania zdarzeń podczas typowego dnia roboczego, takich jak odblokowywanie wewnętrznych przejść na początku dnia pracy lub włączanie linii wyjściowej sterującej oświetleniem. Jest to tylko przykład i można go edytować, aby dostosować do godzin pracy danego obiektu, lub usunąć.  </TranslationEntry>
    <TranslationEntry name="9B21A25A3645497B80A1B5FB2AB86EA8" fullContext="74169C68ECBBAD50FBFF35EBE6B3D727" translateForJs="false">Rozważ, które elementy systemu powinny być objęte harmonogramem i jak można je pogrupować. Konieczne może być utworzenie wielu Przedziałów czasowych, aby obsłużyć te przypadki, takich jak: kiedy należy umożliwić swobodny dostęp przez przejście, kiedy strefy powinny automatycznie uzbroić się wieczorami, wszelka wymagana automatyzacja zaplanowana oraz kiedy uprawnienia użytkownika powinny być aktywne lub ograniczone. </TranslationEntry>
    <TranslationEntry name="667580065ADD92537C65EA0B750CA7C4" fullContext="667580065ADD92537C65EA0B750CA7C4" translateForJs="false">Zaprogramowane przedziały czasowe</TranslationEntry>
    <TranslationEntry name="B21DBAF42F73FA2F93767FC1FF8CF4F0" fullContext="B21DBAF42F73FA2F93767FC1FF8CF4F0" translateForJs="false">Konfiguruj przedziały czasowe</TranslationEntry>
    <TranslationEntry name="A7C9FF4B9A7D28CA865FCFB8645F6DB5" fullContext="A7C9FF4B9A7D28CA865FCFB8645F6DB5" translateForJs="false">Utwórz i skonfiguruj wszystkie przedziały czasowe dla obiektu.</TranslationEntry>
    <TranslationEntry name="D31505E2C74537AD0B530892AB5B8169" fullContext="8DA9E0B812C0D872EE439DDAEBB545D2" translateForJs="false">Ten krok służy do konfiguracji </TranslationEntry>
    <TranslationEntry name="5D9964370EAA30B7CE12E2CEED9C5C24" fullContext="5D9964370EAA30B7CE12E2CEED9C5C24" translateForJs="false">Automatyczne uzbrojenie strefy</TranslationEntry>
    <TranslationEntry name="5F570B610287E45335E800F70C2161C9" fullContext="5F570B610287E45335E800F70C2161C9" translateForJs="false">Wolny dostęp do piętra windy</TranslationEntry>
    <TranslationEntry name="616D5633F6AA3ADF3DA556E762491F31" fullContext="8DA9E0B812C0D872EE439DDAEBB545D2" translateForJs="false"> harmonogramów. </TranslationEntry>
    <TranslationEntry name="207F8FDED149C6B522B28A65D5A2D80F" fullContext="8DA9E0B812C0D872EE439DDAEBB545D2" translateForJs="false"> używa przedziałów czasowych i stanów stref do odblokowania przejścia i zapewnia użytkownikowi dostęp do przejścia bez konieczności przedstawiania identyfikatora. Można to wykorzystać do odblokowania wewnętrznych przejść, gdy wewnętrzna strefa przejścia jest rozbrojona w godzinach pracy. Przejście zostanie ponownie zablokowane, gdy użytkownik uzbroi wewnętrzną strefę lub na koniec dnia, gdy przedział czasowy stanie się nieważny. </TranslationEntry>
    <TranslationEntry name="85ABE9B861ED543B0D7680AACAEE77A7" fullContext="8DA9E0B812C0D872EE439DDAEBB545D2" translateForJs="false">Możesz użyć </TranslationEntry>
    <TranslationEntry name="2AD448E942A8C22558B96B32D76596C1" fullContext="8DA9E0B812C0D872EE439DDAEBB545D2" translateForJs="false"> funkcję z przedziałem czasowym, aby zapewnić uzbrojenie strefy o określonej godzinie każdej nocy, zapobiegając przypadkowemu pozostawieniu strefy rozbrojonej przez noc. </TranslationEntry>
    <TranslationEntry name="48720EDBB4D45D1F24C106F790830601" fullContext="8DA9E0B812C0D872EE439DDAEBB545D2" translateForJs="false"> nie rozbroi strefy, gdy przedział czasowy stanie się nieaktywny.</TranslationEntry>
    <TranslationEntry name="579749A74554BF13811983D1A82A8036" fullContext="040E0F024ED06B53F4C757718D4A35BC" translateForJs="false"> opcja używa przedziałów czasowych i stanów stref do automatycznego ustawiania piętra w tryb wolnego dostępu, umożliwiając użytkownikowi dostęp do piętra w kabinie windy bez konieczności przedstawiania identyfikatora. Można to wykorzystać do umożliwienia dostępu do piętra w określonych porach dnia, ale tylko wtedy, gdy strefa na tym piętrze jest rozbrojona. Piętro powróci do stanu zabezpieczonego, gdy użytkownik uzbroi strefę na tym piętrze lub gdy przedział czasowy stanie się nieważny.</TranslationEntry>
    <TranslationEntry name="170CEE154FE03159FBF21962D865DF1B" fullContext="170CEE154FE03159FBF21962D865DF1B" translateForJs="false">Przejdź do strony harmonogramu</TranslationEntry>
    <TranslationEntry name="241521F70FC9B08AA4AFABE4832C7ACE" fullContext="109D8121357FE35AA3984624ACE4B61A" translateForJs="false">Przypisz przedziały czasowe do przejść wymagających </TranslationEntry>
    <TranslationEntry name="9BA9FC4CC9A0B529F465441FB7B1EB15" fullContext="109D8121357FE35AA3984624ACE4B61A" translateForJs="false"> i oznacz strefę do śledzenia, jeśli jest to wymagane. </TranslationEntry>
    <TranslationEntry name="37C079530F6052EE49C4216274211C3F" fullContext="109D8121357FE35AA3984624ACE4B61A" translateForJs="false">Przypisz przedziały czasowe do stref wymagających </TranslationEntry>
    <TranslationEntry name="A32C6BCBACE82BE104BC234D1E6B2093" fullContext="109D8121357FE35AA3984624ACE4B61A" translateForJs="false"> funkcjonalność.</TranslationEntry>
    <TranslationEntry name="32FDB3278C3C0790EF82137A2791053C" fullContext="0C6580ABAA2470F00B4D5F1F37360B64" translateForJs="false">Przypisz przedziały czasowe do pięter windy, które wymagają </TranslationEntry>
    <TranslationEntry name="EFF51C70EFB3B00F32341F338F28B325" fullContext="0C6580ABAA2470F00B4D5F1F37360B64" translateForJs="false"> i zaznacz, czy stan strefy ma być śledzony.</TranslationEntry>
    <TranslationEntry name="D85982B1262A45804C345F520986EFA6" fullContext="D85982B1262A45804C345F520986EFA6" translateForJs="false">Ustaw harmonogramy przejść, stref i wind</TranslationEntry>
    <TranslationEntry name="7927CFE8142740702AC2039B88D79CFE" fullContext="7927CFE8142740702AC2039B88D79CFE" translateForJs="false">Ustaw harmonogramy przejść i stref</TranslationEntry>
    <TranslationEntry name="C41E3C2DDCE8082AC8F8649BDC099C95" fullContext="BEBD8FA919A1CB37637D52DA85F36522" translateForJs="false">Ten krok służy do wyboru, którymi liniami wyjściowymi mogą sterować użytkownicy przez interfejs internetowy lub terminal LCD. </TranslationEntry>
    <TranslationEntry name="D630CC50CFFD879CBCA475E688235467" fullContext="BEBD8FA919A1CB37637D52DA85F36522" translateForJs="false">Linie wyjściowe skonfigurowane jako </TranslationEntry>
    <TranslationEntry name="64A2D7DFA2187FB6407F48144C9DEDC6" fullContext="BEBD8FA919A1CB37637D52DA85F36522" translateForJs="false"> umożliwia ręczne sterowanie przez użytkownika, jednak nadal musi on mieć przyznane uprawnienie do sterowania tą linią wyjściową. Po przypisaniu do uprawnień użytkownika będzie on mógł sterować linią wyjściową z interfejsu internetowego Inception lub z terminala LCD, a także wyświetlać jej stan. Można również skonfigurować linię wyjściową tak, aby zezwalać na </TranslationEntry>
    <TranslationEntry name="A43BCB1DE75EA09C639399E747B9E55A" fullContext="BEBD8FA919A1CB37637D52DA85F36522" translateForJs="false">, co umożliwia każdej osobie sterowanie linią wyjściową z dowolnego terminala LCD na obiekcie bez konieczności wprowadzania PIN. Uwaga: terminal LCD musi być skonfigurowany dla </TranslationEntry>
    <TranslationEntry name="8695E5960956A43024F0B5AB88FB637B" fullContext="BEBD8FA919A1CB37637D52DA85F36522" translateForJs="false">Zaleca się, aby jako sterowane przez użytkownika oznaczać tylko linie wyjściowe, którymi użytkownicy powinni sterować ręcznie </TranslationEntry>
    <TranslationEntry name="5CF3311D8D4138CC48A324021F66779D" fullContext="BEBD8FA919A1CB37637D52DA85F36522" translateForJs="false">. Są to zazwyczaj elementy związane z automatyką, np. oświetlenie, zraszacze wodne lub klimatyzacja. </TranslationEntry>
    <TranslationEntry name="FFBA7BF4A9C3C3AE25229737C41DED71" fullContext="FFBA7BF4A9C3C3AE25229737C41DED71" translateForJs="false">Liczba sterowalnych linii wyjściowych</TranslationEntry>
    <TranslationEntry name="06116C9BB41909E665EB8EDFDB1F1794" fullContext="06116C9BB41909E665EB8EDFDB1F1794" translateForJs="false">Przejdź do strony linii wyjściowych sterowanych przez użytkownika</TranslationEntry>
    <TranslationEntry name="E86E47F9B551594AD15F517AB15591A2" fullContext="E86E47F9B551594AD15F517AB15591A2" translateForJs="false">Wybierz linie wyjściowe, którymi użytkownicy mogą sterować.</TranslationEntry>
    <TranslationEntry name="F42A36A84BD52EB30E7A81AA34BE0721" fullContext="F42A36A84BD52EB30E7A81AA34BE0721" translateForJs="false">Wybierz linie wyjściowe sterowane przez użytkownika</TranslationEntry>
    <TranslationEntry name="7AF82E265B469F18E1101E468F85E56F" fullContext="8A07A2CFC22AD0AD5630D8DC96F1566D" translateForJs="false">Ten krok służy do tworzenia grup uprawnień, które będą przypisywane jednemu lub więcej użytkownikom w celu określenia przejść, stref i linii wyjściowych, do których użytkownicy będą mogli uzyskać dostęp lub które będą mogli sterować. </TranslationEntry>
    <TranslationEntry name="288D9B9F63911D4AD761B27B6522DA76" fullContext="8A07A2CFC22AD0AD5630D8DC96F1566D" translateForJs="false">Grupy uprawnień są przydatne, ponieważ mogą zawierać wspólny zestaw uprawnień, który można następnie przypisać wielu użytkownikom. Po przypisaniu uprawnienia dla wszystkich tych użytkowników można aktualizować, zmieniając bezpośrednio grupę uprawnień, co ułatwia zarządzanie uprawnieniami. Tworząc grupy uprawnień, zaleca się najpierw zidentyfikowanie tego, co jest wspólne między grupą użytkowników. Zazwyczaj będzie to rola, np. pracownicy IT, pracownicy administracyjni itp. Jednak w niektórych obiektach może to być po prostu różny poziom dostępu, np. dostęp podstawowy lub dostęp kierowniczy. Grupy uprawnień zawierałyby wtedy wszystkie uprawnienia wymagane do tego, aby pracownik mógł uzyskać dostęp do przejść i sterować strefami i liniami wyjściowymi w ramach swojej pracy. </TranslationEntry>
    <TranslationEntry name="FDE5392F3AC27C3FDECB166B2FB4436F" fullContext="8A07A2CFC22AD0AD5630D8DC96F1566D" translateForJs="false">Zaleca się, aby wyraźnie nazywać grupy uprawnień na podstawie roli użytkownika, aby inna osoba mogła przypisywać je do użytkowników bez konieczności przeglądania ich zawartości.</TranslationEntry>
    <TranslationEntry name="E2B19F751557DDB1986E789F41B9C236" fullContext="E2B19F751557DDB1986E789F41B9C236" translateForJs="false">Zaprogramowane role/grupy uprawnień</TranslationEntry>
    <TranslationEntry name="32D2C60ED8B1A15BDD36DC88C6EF1E83" fullContext="32D2C60ED8B1A15BDD36DC88C6EF1E83" translateForJs="false">Konfiguruj grupy uprawnień</TranslationEntry>
    <TranslationEntry name="4BC960CBE71F7B52DEF2417A64DD2012" fullContext="4BC960CBE71F7B52DEF2417A64DD2012" translateForJs="false">Twórz grupy uprawnień zawierające przejścia, strefy i linie wyjściowe dla różnych ról użytkowników.</TranslationEntry>
    <TranslationEntry name="AC6F0A4366E95E50A49E6A6B1D2F44C8" fullContext="AC6F0A4366E95E50A49E6A6B1D2F44C8" translateForJs="false">Konfiguruj grupę uprawnień i role</TranslationEntry>
    <TranslationEntry name="A108A78B1AD6C6DB83B15F44895B3618" fullContext="90A221FC5AE0DDB1DB63922FE7FD8EA1" translateForJs="false">Jeśli system jest używany do kontroli dostępu, ten krok służy do konfigurowania typów identyfikatorów używanych na obiekcie. </TranslationEntry>
    <TranslationEntry name="DA3C864E0A7B1B4921DC2205BD944CED" fullContext="90A221FC5AE0DDB1DB63922FE7FD8EA1" translateForJs="false">Szablony identyfikatorów zawierają informacje o tym, jak identyfikatory prezentowane przy czytnikach powinny być interpretowane (np. jako karty, odciski palców, dane skanu twarzy) oraz używany format karty (jeśli dotyczy). Identyfikatory są następnie przypisywane do użytkowników poprzez określenie szablonu identyfikatora i numeru identyfikatora. Szablony identyfikatorów można konfigurować z określonym formatem karty i zawierać kod obiektu do dopasowania kart, lub można je konfigurować do używania surowych danych karty (bezpośrednie wpisanie), które używają pełnych danych karty jako numeru identyfikatora. </TranslationEntry>
    <TranslationEntry name="43F7C7D9F19771718AD8C2F1E187316A" fullContext="90A221FC5AE0DDB1DB63922FE7FD8EA1" translateForJs="false">Jeśli zamierzasz używać kart z kodem obiektu, musisz określić format karty i kod obiektu. Aby zidentyfikować format karty i kod obiektu kart, otwórz </TranslationEntry>
    <TranslationEntry name="713ED758021CB5FC51BF207A0DB41740" fullContext="90A221FC5AE0DDB1DB63922FE7FD8EA1" translateForJs="false">[Stan/Sterowanie &gt; Rejestr zdarzeń]</TranslationEntry>
    <TranslationEntry name="CAE4122DCDBC5E0F44A68525A05C976E" fullContext="90A221FC5AE0DDB1DB63922FE7FD8EA1" translateForJs="false"> strony i wykonaj odczyt karty na czytniku.</TranslationEntry>
    <TranslationEntry name="763A88E731D0499B2F63CFCE2CA874AE" fullContext="90A221FC5AE0DDB1DB63922FE7FD8EA1" translateForJs="false">Jeśli na obiekcie używanych jest wiele typów identyfikatorów, można utworzyć wiele szablonów lub użyć trybu surowego (bezpośredniego wpisu).</TranslationEntry>
    <TranslationEntry name="D702D1524A5887692846F7BDC2E7893F" fullContext="D702D1524A5887692846F7BDC2E7893F" translateForJs="false">Tak, identyfikatory są używane w obiekcie</TranslationEntry>
    <TranslationEntry name="0AE5218FF5CDCE7162B55DAA48AFE347" fullContext="0AE5218FF5CDCE7162B55DAA48AFE347" translateForJs="false">Nie, identyfikatory nie są używane w obiekcie</TranslationEntry>
    <TranslationEntry name="6FA29ACBE3638261683274E82E5F92C0" fullContext="6FA29ACBE3638261683274E82E5F92C0" translateForJs="false">Czy ten system jest używany do kontroli dostępu z kartami lub innymi identyfikatorami?</TranslationEntry>
    <TranslationEntry name="62E52DB958F81745F93BE5D1072B8F67" fullContext="62E52DB958F81745F93BE5D1072B8F67" translateForJs="false">Konfiguruj szablon karty dostępu</TranslationEntry>
    <TranslationEntry name="93A7A09BA27F50BAE1002D386E4904AB" fullContext="93A7A09BA27F50BAE1002D386E4904AB" translateForJs="false">Utwórz szablon identyfikatora pasujący do formatu i kodu obiektu identyfikatorów używanych na obiekcie.</TranslationEntry>
    <TranslationEntry name="5BBEC22E7BF4FDF495A2FD2F43291372" fullContext="5BBEC22E7BF4FDF495A2FD2F43291372" translateForJs="false">Wskazałeś, że w tym obiekcie nie jest używana kontrola dostępu. Jeśli tak nie jest, zresetuj ten krok i odpowiedz Tak.</TranslationEntry>
    <TranslationEntry name="AB6CAB8EE40350759D31F5D93D002EFA" fullContext="AB6CAB8EE40350759D31F5D93D002EFA" translateForJs="false">Konfiguruj szablon identyfikatora dostępu</TranslationEntry>
    <TranslationEntry name="7B4DF2C13633C36E3039F175BF01A0BE" fullContext="6CE9C32BCD06D241B0B5B58F6940E08C" translateForJs="false">Ten krok służy do przeglądania i konfigurowania profili stron internetowych. Profile stron internetowych określają, które strony użytkownik może przeglądać za pośrednictwem interfejsu internetowego Inception, a także co może na nich robić. Profil strony internetowej obejmuje uprawnienia do </TranslationEntry>
    <TranslationEntry name="7348A3D64CB429A9BD502F1BE8600058" fullContext="6CE9C32BCD06D241B0B5B58F6940E08C" translateForJs="false">Edycja elementu</TranslationEntry>
    <TranslationEntry name="B5EA6703564BCE1C46184D6E45485384" fullContext="6CE9C32BCD06D241B0B5B58F6940E08C" translateForJs="false">Monitorowanie elementu</TranslationEntry>
    <TranslationEntry name="09DB63C6764433686A9B89FDBBDF3D19" fullContext="6CE9C32BCD06D241B0B5B58F6940E08C" translateForJs="false">Wykonanie zadania</TranslationEntry>
    <TranslationEntry name="806F4EF6DB0D9AABE7284259B34ECC3D" fullContext="6CE9C32BCD06D241B0B5B58F6940E08C" translateForJs="false">. </TranslationEntry>
    <TranslationEntry name="05FFEC6F34FECC80FCEFD57DE1E5490B" fullContext="6CE9C32BCD06D241B0B5B58F6940E08C" translateForJs="false"> określa, które strefy, przejścia, linie wyjściowe i grupy skrótów pojawiają się na pulpicie nawigacyjnym użytkownika. </TranslationEntry>
    <TranslationEntry name="DD488ECA94D643D602B5286A0F8A3A97" fullContext="6CE9C32BCD06D241B0B5B58F6940E08C" translateForJs="false">Domyślnie zostało utworzonych kilka profili obejmujących typowe rodzaje użytkowników. Jeśli domyślne profile nie są odpowiednie dla danego obiektu, konieczne będzie utworzenie nowych lub ich modyfikacja. </TranslationEntry>
    <TranslationEntry name="1938A048B3BC6969AB856B54C098D538" fullContext="1938A048B3BC6969AB856B54C098D538" translateForJs="false">Skonfigurowane profile WWW</TranslationEntry>
    <TranslationEntry name="633CF5E82713573913A232E9C75F0AC0" fullContext="633CF5E82713573913A232E9C75F0AC0" translateForJs="false">Przeglądaj i konfiguruj profile internetowe</TranslationEntry>
    <TranslationEntry name="1A8BE8D4B6543BBA4E75B0B9291244E8" fullContext="8640618FD4359A507A1547EBD5D5D621" translateForJs="false">Przejrzyj istniejące profile i zmodyfikuj je w razie potrzeby lub utwórz nowe, jeśli jest to wymagane. </TranslationEntry>
    <TranslationEntry name="5574B9311DE0C401B425F519EB1ABA83" fullContext="8640618FD4359A507A1547EBD5D5D621" translateForJs="false">Przypisz strefy, przejścia lub linie wyjściowe, które mają pojawiać się na stronach pulpitu nawigacyjnego użytkowników</TranslationEntry>
    <TranslationEntry name="455EE69AE7D9F0815AF61BE4AF165BA0" fullContext="9FAD4D3E098C5EFD1EEEDEE07F203078" translateForJs="false">Ten krok służy do tworzenia i konfigurowania użytkowników. Użytkownik to każda osoba, która wchodzi w interakcję z systemem Inception poprzez odczyt karty, wprowadzenie numeru PIN lub zalogowanie się do interfejsu internetowego. </TranslationEntry>
    <TranslationEntry name="B3406A1AECF29825C32C903741BF923A" fullContext="9FAD4D3E098C5EFD1EEEDEE07F203078" translateForJs="false">Identyfikatory służą do identyfikacji użytkownika i muszą być unikalne wśród wszystkich użytkowników. Identyfikatory obejmują numer PIN używany do dostępu przy czytnikach z klawiaturą lub logowania się do terminala LCD, karty do kontroli dostępu oraz piloty RF do zdalnego sterowania. Możesz również przyznać użytkownikowi nazwę użytkownika i hasło, aby umożliwić mu dostęp do interfejsu internetowego Inception; użytkownik będzie również potrzebował profilu strony internetowej, który określa, które strony może przeglądać i jak może z nimi wchodzić w interakcję.</TranslationEntry>
    <TranslationEntry name="75FA8BDBF82E11CA7E54140ACDB3E88F" fullContext="9FAD4D3E098C5EFD1EEEDEE07F203078" translateForJs="false">Musisz przypisać użytkownikowi indywidualne uprawnienia lub grupy uprawnień utworzone we wcześniejszym kroku; określi to, do których stref, przejść i linii wyjściowych użytkownik może uzyskać dostęp lub sterować nimi w systemie oraz kiedy ma do tego prawo. </TranslationEntry>
    <TranslationEntry name="A1C419AEF94052F25D5682760E883E60" fullContext="9FAD4D3E098C5EFD1EEEDEE07F203078" translateForJs="false">Użytkownicy mogą być również importowani zbiorczo z pliku CSV, jeśli konieczne jest dodanie wielu użytkowników</TranslationEntry>
    <TranslationEntry name="7AFB003CEE221B3176350A0E07D90C3A" fullContext="7AFB003CEE221B3176350A0E07D90C3A" translateForJs="false">Twórz i konfiguruj użytkowników</TranslationEntry>
    <TranslationEntry name="49C6BB87EE856FD20D172E2FEF57FD72" fullContext="49C6BB87EE856FD20D172E2FEF57FD72" translateForJs="false">Utwórz nowego użytkownika dla każdej osoby, która będzie korzystać z systemu Inception, i przypisz jej odpowiednie identyfikatory oraz uprawnienia.</TranslationEntry>
    <TranslationEntry name="E28F406DB5871BDAE2E4950BBD01C695" fullContext="8CB97F26BDF2B8A02710FC6CBDA37D2D" translateForJs="false">Ten krok służy do konfiguracji raportowania alarmów i zdarzeń do stacji monitorowania. Kontroler Inception obsługuje raportowanie przez Skytunnel lub za pomocą zewnętrznego urządzenia T4000. </TranslationEntry>
    <TranslationEntry name="13A2E891020EECBFDBBF10E30C64F678" fullContext="8CB97F26BDF2B8A02710FC6CBDA37D2D" translateForJs="false"> - Korzysta z połączenia sieciowego kontrolera Inception z dostępem do internetu w celu komunikacji z serwerem SkyTunnel. Po odebraniu zdarzenia przez serwer SkyTunnel jest ono przekazywane do stacji monitorowania. Funkcja ta działa od razu po konfiguracji i nie wymaga żadnego dodatkowego specjalistycznego sprzętu.</TranslationEntry>
    <TranslationEntry name="A1029AC0F8FFDEF65B4359FDE4958DFA" fullContext="8CB97F26BDF2B8A02710FC6CBDA37D2D" translateForJs="false"> - T4000 to urządzenie Inner Range, które łączy się z Kontrolerem Inception przez USB. Zapewnia wiele redundantnych ścieżek raportowania przy użyciu wielu sieci 3G oprócz raportowania przez Internet Ethernet. Częste odpytywanie wszystkich ścieżek zapewnia niezawodne monitorowanie alarmów.</TranslationEntry>
    <TranslationEntry name="9EEC51DDBB382CFD9AD6AA799CDA7F7E" fullContext="8CB97F26BDF2B8A02710FC6CBDA37D2D" translateForJs="false">Uwaga: Te opcje jedynie włączają ścieżki raportowania. Kontroler Inception (dla SkyTunnel) lub T4000 musi zostać również zarejestrowany w systemie Multipath IP stacji monitorowania. Skontaktuj się ze swoją stacją monitorowania w celu założenia tego konta.</TranslationEntry>
    <TranslationEntry name="05BD3411488E48DDD0FFC4BE8A14C86E" fullContext="8CB97F26BDF2B8A02710FC6CBDA37D2D" translateForJs="false">Można używać wielu ścieżek, oznaczając je jako ścieżkę podstawową lub zapasową. </TranslationEntry>
    <TranslationEntry name="DAFF73764A5EF0E9CF5951E3C2950A08" fullContext="DAFF73764A5EF0E9CF5951E3C2950A08" translateForJs="false">Tak, alarmy będą monitorowane</TranslationEntry>
    <TranslationEntry name="FD46E583AB4595B5D74595EFCEC8CD52" fullContext="FD46E583AB4595B5D74595EFCEC8CD52" translateForJs="false">Nie, ten system nie będzie monitorowany</TranslationEntry>
    <TranslationEntry name="9EFF18FAFBA2163214AD5BFC1F69BFB5" fullContext="9EFF18FAFBA2163214AD5BFC1F69BFB5" translateForJs="false">Czy ten system jest monitorowany przez stację monitorowania?</TranslationEntry>
    <TranslationEntry name="BBD4C041508866BDA8C49BE2082E1B3F" fullContext="BBD4C041508866BDA8C49BE2082E1B3F" translateForJs="false">Konfiguruj monitorowanie alarmów</TranslationEntry>
    <TranslationEntry name="A4A448751D8B2326F3C7809610BE2B42" fullContext="F3F3E2AA35F0E6525E2FB59317B444E5" translateForJs="false">Skonfiguruj podstawową ścieżkę komunikacyjną do raportowania do stacji monitorowania.</TranslationEntry>
    <TranslationEntry name="740ADAEEF146CFF56F07E97CA62D152C" fullContext="F3F3E2AA35F0E6525E2FB59317B444E5" translateForJs="false">W przypadku stosowania formatu Contact ID pobierz i wyślij raport Contact ID do stacji monitorowania.</TranslationEntry>
    <TranslationEntry name="B7A4244278881670AE5F1F7F57EA79EE" fullContext="F3F3E2AA35F0E6525E2FB59317B444E5" translateForJs="false">Pomyślnie wysłano raport testowy.</TranslationEntry>
    <TranslationEntry name="5880E106F16237FFE675CE4CEFF4B560" fullContext="5880E106F16237FFE675CE4CEFF4B560" translateForJs="false">Wskazano, że monitorowanie alarmów nie jest konieczne dla tego obiektu. Jeśli to nieprawda, zresetuj ten krok i odpowiedz Tak</TranslationEntry>
    <TranslationEntry name="29A55625964832ACF7C3AA2B49B6C060" fullContext="3608199638D5B5A3AA3249C9D8827792" translateForJs="false">Ten krok służy do konfigurowania systemu w celu wysyłania komunikatów powiadomień do użytkowników w przypadku wystąpienia zdarzeń w systemie. Powiadamiacze można skonfigurować tak, aby wysyłały powiadomienia na przykład przy każdym alarmie w określonej strefie lub przy przyznaniu lub odmowie dostępu do określonego przejścia. Powiadomienia mogą być również wysyłane w przypadku wielokrotnych nieudanych prób logowania do interfejsu internetowego lub terminalu LCD, lub gdy wprowadzane są zmiany programistyczne do określonych elementów. Można również komunikować zdarzenia konserwacyjne, takie jak problemy z zasilaniem i baterią modułów lub urządzeń RF.</TranslationEntry>
    <TranslationEntry name="2D542EF7A89267FE2BDB03DAE8AD1520" fullContext="3608199638D5B5A3AA3249C9D8827792" translateForJs="false">Inception obsługuje wysyłanie wiadomości do użytkowników pocztą e-mail. Aby korzystać ze ścieżki powiadomień e-mail, Inception musi być skonfigurowany z serwerem e-mail oraz użytkownicy odbiorcy muszą mieć przypisany adres e-mail.</TranslationEntry>
    <TranslationEntry name="FE78401CB6CDD2C37679A2723679AE0A" fullContext="3608199638D5B5A3AA3249C9D8827792" translateForJs="false">Można tworzyć wiele powiadamiaczy w celu powiadamiania różnych użytkowników o różnych zdarzeniach w różnym czasie. Utwórz tyle powiadamiaczy, ile wymaga system, aby wysyłać pożądane zdarzenia do użytkowników.</TranslationEntry>
    <TranslationEntry name="D575E100249B3E680D16509DDEEC5530" fullContext="D575E100249B3E680D16509DDEEC5530" translateForJs="false">Tak, powiadomienia dla użytkownika są wymagane</TranslationEntry>
    <TranslationEntry name="18DA20BB06D52EEC4FD1550CD381E573" fullContext="18DA20BB06D52EEC4FD1550CD381E573" translateForJs="false">Nie, ten system nie będzie używał powiadomień użytkownika</TranslationEntry>
    <TranslationEntry name="629A2DF363A0E6A46DD459A8CC97E21F" fullContext="629A2DF363A0E6A46DD459A8CC97E21F" translateForJs="false">Czy ten system wysyła powiadomienia o zdarzeniach do użytkowników za pośrednictwem poczty e-mail?</TranslationEntry>
    <TranslationEntry name="010AF1DB366E1B92559A184050156A70" fullContext="010AF1DB366E1B92559A184050156A70" translateForJs="false">Konfiguruj ustawienia serwera e-mail</TranslationEntry>
    <TranslationEntry name="C60C1916458650ABD0B7119938A95694" fullContext="2DDD6185630B01C9F558F73A12B10B9B" translateForJs="false">Konfiguruj ustawienia serwera pocztowego, aby umożliwić systemowi Inception wysyłanie wiadomości e-mail.</TranslationEntry>
    <TranslationEntry name="FF9382369A5B7EA44F7FBD2451F0B614" fullContext="2DDD6185630B01C9F558F73A12B10B9B" translateForJs="false">Pomyślnie wysłano wiadomość e-mail testową (przy użyciu </TranslationEntry>
    <TranslationEntry name="335B6AC925B339D7EB2D74A5E660550E" fullContext="2DDD6185630B01C9F558F73A12B10B9B" translateForJs="false"> przycisk w przyborniku), aby upewnić się, że ścieżka działa.</TranslationEntry>
    <TranslationEntry name="43AE8F729F2CE64434A3729F8AA379B0" fullContext="43AE8F729F2CE64434A3729F8AA379B0" translateForJs="false">Konfiguruj powiadamiacze zdarzeń</TranslationEntry>
    <TranslationEntry name="822D8B97DBDEDB76AFF25D5DDD64FC12" fullContext="822D8B97DBDEDB76AFF25D5DDD64FC12" translateForJs="false">Utwórz i skonfiguruj wymagane powiadamiacze dla systemu.</TranslationEntry>
    <TranslationEntry name="81C1BD8EC1209E5834195C8B2BD711D7" fullContext="81C1BD8EC1209E5834195C8B2BD711D7" translateForJs="false">Wskazano, że żadne powiadomienia dla użytkowników nie są wymagane dla tego obiektu. Jeśli tak nie jest, zresetuj krok i odpowiedz Tak</TranslationEntry>
    <TranslationEntry name="F8D85461D45FEEE187FDB167CD554661" fullContext="F8D85461D45FEEE187FDB167CD554661" translateForJs="false">Konfiguruj ustawienia powiadomień użytkownika</TranslationEntry>
    <TranslationEntry name="6A6F29AE8BEAE7BD20BD93CB98EAB008" fullContext="903F806917407F7BCDDE420AB8D31C11" translateForJs="false">Ten krok służy do konfigurowania logiki automatyki wykraczającej poza podstawowy system detekcji włamań i kontroli dostępu. Automatyczne akcje zapewniają możliwość rozwiązywania scenariuszy automatyki dla obiektu. Najczęściej będą to proste przypadki automatyki, takie jak włączanie świateł po rozbronieniu strefy, ale mają elastyczność do obsługi bardzo skomplikowanych scenariuszy.</TranslationEntry>
    <TranslationEntry name="590779FD7DC3709D248C2117DFBF0CA5" fullContext="903F806917407F7BCDDE420AB8D31C11" translateForJs="false">Zidentyfikuj wszelkie automatyczne reakcje, które system ma wykonywać i kiedy powinny one nastąpić. Mogą to być takie czynności jak włączanie oświetlenia lub klimatyzacji po rozbronieniu strefy lub wykryciu aktywności. Mogą one również być powiązane z bezpieczeństwem obiektu, np. uzbrajanie niektórych stref, gdy inna strefa jest uzbrojona. Wyzwolenia mogą obejmować stan wielu elementów systemu, w tym przedziały czasowe, więc automatykę można skonfigurować tak, aby była aktywna tylko w określonych godzinach. W zależności od wymaganej automatyki, dla jednego zadania może być konieczne skonfigurowanie wielu akcji.</TranslationEntry>
    <TranslationEntry name="2352A5ADD221A5CDE2E3FE3FB5EE69E0" fullContext="903F806917407F7BCDDE420AB8D31C11" translateForJs="false">Zobacz opis strony na </TranslationEntry>
    <TranslationEntry name="143F4376112FDCD128E8C54C0F50D114" fullContext="903F806917407F7BCDDE420AB8D31C11" translateForJs="false"> strona zawierająca więcej informacji o konfiguracji akcji.</TranslationEntry>
    <TranslationEntry name="A7E6913A5657927018B5C90D9573B933" fullContext="A7E6913A5657927018B5C90D9573B933" translateForJs="false">Konfiguruj akcje automatyczne</TranslationEntry>
    <TranslationEntry name="DB012242431BDBC8C9D3584AF09E1D24" fullContext="DB012242431BDBC8C9D3584AF09E1D24" translateForJs="false">Skonfiguruj dodatkową automatykę dla obiektu</TranslationEntry>
    <TranslationEntry name="C90955CD1950BDC2F1B96485DC83EEE6" fullContext="C90955CD1950BDC2F1B96485DC83EEE6" translateForJs="false">Konfiguruj wskaźniki alertów</TranslationEntry>
    <TranslationEntry name="4DBAA6A2B6A1725E05061AFD6397C30F" fullContext="4DBAA6A2B6A1725E05061AFD6397C30F" translateForJs="false">Wybierz linie wyjściowe używane do sygnalizowania oczekujących alertów użytkownikom poziomu 1.</TranslationEntry>
    <TranslationEntry name="F074CF65B062DB4B669F0FE90AA4602F" fullContext="F074CF65B062DB4B669F0FE90AA4602F" translateForJs="false">Zgodność z EN50131</TranslationEntry>
    <TranslationEntry name="0B983A88676CD70A45D78D9C34111192" fullContext="E70FDFECA39849C64D06FD04468AF4F3" translateForJs="false">Ten krok służy do zmiany PIN i hasła do interfejsu internetowego dla użytkownika Instalator. Zmiana ta jest wymagana, ponieważ domyślne dane logowania instalatora nie są bezpieczne i gdyby zostały użyte przez inną osobę, zapewniłyby najwyższy poziom uprawnień. </TranslationEntry>
    <TranslationEntry name="02A2CDE1FDE301730F6401431B3CEF24" fullContext="E70FDFECA39849C64D06FD04468AF4F3" translateForJs="false">Niezwykle ważne jest, aby zmienić hasło i PIN interfejsu internetowego po włączeniu </TranslationEntry>
    <TranslationEntry name="81CAE2BCE8F5A91F0DB8D40DD2989353" fullContext="E70FDFECA39849C64D06FD04468AF4F3" translateForJs="false"> opcja, ponieważ panel będzie dostępny przez Internet. W takim przypadku zaleca się również zmianę nazwy użytkownika.</TranslationEntry>
    <TranslationEntry name="3DE40F1189F2F95DE25A454CABFC4292" fullContext="3DE40F1189F2F95DE25A454CABFC4292" translateForJs="false">Zmień domyślne dane logowania instalatora</TranslationEntry>
    <TranslationEntry name="0B66A9DCE88154375839855B24E409A4" fullContext="0B66A9DCE88154375839855B24E409A4" translateForJs="false">Zmień domyślny PIN instalatora, hasło i nazwę użytkownika.</TranslationEntry>
    <TranslationEntry name="8D11358AAC93094EF565E3CDF0BADD09" fullContext="8D11358AAC93094EF565E3CDF0BADD09" translateForJs="false">Wykonaj systemowy test obchodowy</TranslationEntry>
    <TranslationEntry name="61684B96C8228E6EFCBE2B4EE12E34DE" fullContext="F4CB18F9099D785508C7A77040EE7A09" translateForJs="false">Ten krok wyłącza tryb serwisowy, który jest domyślnie włączony przy pierwszej konfiguracji systemu. Tryb serwisowy umożliwia instalowanie i konfigurowanie kontrolera Inception bez generowania alarmów sygnalizatorów i raportowania alarmów. Po wyłączeniu trybu serwisowego sygnalizatory systemowe i raportowanie alarmów zostaną włączone.</TranslationEntry>
    <TranslationEntry name="F8D1C88A416977E5E3150CCA7BEB7C2D" fullContext="F4CB18F9099D785508C7A77040EE7A09" translateForJs="false">Możesz włączyć tryb serwisowy w późniejszym terminie, aby przeprowadzić konserwację bez generowania sygnałów sygnalizatora i raportowania alarmów.</TranslationEntry>
    <TranslationEntry name="FB026059BCD77B2A5EC6D8EDE8979850" fullContext="F4CB18F9099D785508C7A77040EE7A09" translateForJs="false">Uwaga: Po wyłączeniu trybu serwisowego wszystkie bieżące alarmy zostaną przetworzone, co może spowodować włączenie sygnalizatorów. Podobnie, jeśli jakiekolwiek moduły zgłaszają problemy z sabotażem (np. sabotaż obudowy lub sabotaż sygnalizatora), może to również spowodować włączenie sygnalizatorów.</TranslationEntry>
    <TranslationEntry name="1E69098029D4BB3EF92726A482BEA9E0" fullContext="1E69098029D4BB3EF92726A482BEA9E0" translateForJs="false">Przejdź do strony serwisowej</TranslationEntry>
    <TranslationEntry name="81032C955CF41C7FA39318C2FB5D8305" fullContext="81032C955CF41C7FA39318C2FB5D8305" translateForJs="false">Wyłącz tryb serwisowy, aby włączyć sygnalizatory i raportowanie alarmów. </TranslationEntry>
    <TranslationEntry name="FAEA209167B418C9C317C2CE76FAABDB" fullContext="FAEA209167B418C9C317C2CE76FAABDB" translateForJs="false">Wyłącz tryb serwisowy</TranslationEntry>
    <TranslationEntry name="75895097D1122BB37E403783DD219990" fullContext="7EF9C534F6DBB4E8AFADA80B4BB81A92" translateForJs="false">Ten krok służy do utworzenia kopii zapasowej, aby zapewnić łatwe odtworzenie konfiguracji i programowania ze wszystkich poprzednich kroków w przypadku ich utraty.</TranslationEntry>
    <TranslationEntry name="4E5F2073FBC3C03A0BA5EBB9BEBA0CEC" fullContext="7EF9C534F6DBB4E8AFADA80B4BB81A92" translateForJs="false">Ponadto ten krok obejmuje tworzenie raportu programowania systemu zawierającego podsumowanie wszystkich ustawień programowania w systemie w czytelnej dla człowieka postaci. Ponieważ kopie zapasowe bazy danych są zaszyfrowane, raport ten ma stanowić podsumowanie całego programowania systemu na koniec uruchomienia, co może ułatwić przyszłą konserwację, służyć jako materiał referencyjny lub pomóc w weryfikacji problemów z programowaniem w przyszłości.</TranslationEntry>
    <TranslationEntry name="EC6641C61D25A0D07AE0B5F178DCE586" fullContext="EC6641C61D25A0D07AE0B5F178DCE586" translateForJs="false">Wyświetl stronę kopii zapasowej/przywracania</TranslationEntry>
    <TranslationEntry name="EC7CAAA7344A613C699C324A3F3E0EFF" fullContext="AFCEC690538E2492EAB6D827507829BC" translateForJs="false">Pobierz kopię zapasową bazy danych i przechowuj ją w bezpiecznym miejscu.</TranslationEntry>
    <TranslationEntry name="027402CDFA8B4CA77B75834250D8070C" fullContext="AFCEC690538E2492EAB6D827507829BC" translateForJs="false">Pobierz raport programowania (przez </TranslationEntry>
    <TranslationEntry name="99769BD32C2F4D4D18A65F63244067F8" fullContext="AFCEC690538E2492EAB6D827507829BC" translateForJs="false"> przycisk na pasku narzędzi)</TranslationEntry>
    <TranslationEntry name="79339AF4C48008E9F8DF331ABB7CB4CF" fullContext="79339AF4C48008E9F8DF331ABB7CB4CF" translateForJs="false">Utwórz kopię zapasową bazy danych i pobierz raport programowania</TranslationEntry>
    <TranslationEntry name="0F209D0B4DB0008343346F8ABDC8CB71" fullContext="8C88D3744C32A6E3B91466493746A348" translateForJs="false">Ten krok służy do usunięcia pozostałych ostrzeżeń w systemie. Ostrzeżenia systemowe mają na celu wskazanie problemów w systemie, które uniemożliwiają jego optymalne działanie i powinny zostać usunięte jak najszybciej.</TranslationEntry>
    <TranslationEntry name="7E27C439BEB6E5AD088BAD403A9FD91C" fullContext="7E27C439BEB6E5AD088BAD403A9FD91C" translateForJs="false">Wyświetl stronę przeglądu systemu</TranslationEntry>
    <TranslationEntry name="71B83794C96CE58C72B4755B6044852E" fullContext="E03CE0D4F254E9B181D5E51DA886462E" translateForJs="false">Odwiedź </TranslationEntry>
    <TranslationEntry name="B5B2DF782342BF244DD08419CE7143CD" fullContext="E03CE0D4F254E9B181D5E51DA886462E" translateForJs="false"> strona i napraw wszelkie wymienione tam ostrzeżenia.</TranslationEntry>
    <TranslationEntry name="ACC57D458C77F7A24133E282A45607E5" fullContext="ACC57D458C77F7A24133E282A45607E5" translateForJs="false">Napraw ostrzeżenia</TranslationEntry>
    <TranslationEntry name="88DF6523ACD6EC698A0F37C8E8B4BC74" fullContext="8D942D1BBD0323CBBC375DF1EECDB636" translateForJs="false">Uruchomienie systemu zostało zakończone. Przetestuj system, aby potwierdzić, że działa zgodnie z wymaganiami klienta. </TranslationEntry>
    <TranslationEntry name="274B23363140B08B9A158C29FE36023B" fullContext="8D942D1BBD0323CBBC375DF1EECDB636" translateForJs="false">Upewnij się, że na górnym pasku nie ma Ostrzeżeń, a jeśli są, przejdź do </TranslationEntry>
    <TranslationEntry name="5F638F793F84443E4CCCE5DC1DAB29C4" fullContext="8D942D1BBD0323CBBC375DF1EECDB636" translateForJs="false"> i przetworzyć je.</TranslationEntry>
    <TranslationEntry name="98BB1BECEB8873CFB0975B8F8CD4EEDF" fullContext="8D942D1BBD0323CBBC375DF1EECDB636" translateForJs="false">Lista kontrolna uruchomienia systemu może być nadal używana po początkowym uruchomieniu w celu ułatwienia nawigacji po interfejsie WWW, jeśli jest to wymagane.</TranslationEntry>
    <TranslationEntry name="D5191F74443271FDF0891962695CDB72" fullContext="D5191F74443271FDF0891962695CDB72" translateForJs="false">Ustaw uruchomienie jako zakończone</TranslationEntry>
    <TranslationEntry name="112874C832267AACFB66DC17F4B2A5F1" fullContext="8D942D1BBD0323CBBC375DF1EECDB636" translateForJs="false"> przycisk poniżej oznaczy listę kontrolną uruchomienia jako zakończoną i usunie skrót do listy kontrolnej z paska tytułu.</TranslationEntry>
    <TranslationEntry name="04D350E89548D8F591E9D6445F6EE128" fullContext="D031838F00CEB572817EC270348400AA" translateForJs="false">UWAGA EN50131: Ukończenie uruchomienia spowoduje „przekazanie” obiektu, uniemożliwiając użytkownikom poziomu 3 swobodne logowanie. Tymczasowo zezwól na dostęp poziomu 3 przez </TranslationEntry>
    <TranslationEntry name="01B0A09FC3EFAD4BDC3C287F6CC5AECC" fullContext="D031838F00CEB572817EC270348400AA" translateForJs="false"> strona lub MENU - 8 - 1 na terminalu LCD.</TranslationEntry>
    <TranslationEntry name="602969EA11173136C7B37F9925EF926C" fullContext="602969EA11173136C7B37F9925EF926C" translateForJs="false">Kliknij przycisk poniżej, aby ukończyć listę kontrolną uruchomienia.</TranslationEntry>
    <TranslationEntry name="5A6BF52BEF48EB92B76F3FBDD5290BD7" fullContext="5A6BF52BEF48EB92B76F3FBDD5290BD7" translateForJs="false">Uruchomienie zakończone</TranslationEntry>
    <TranslationEntry name="A8856C9DEFFCD415746250A993B82479" fullContext="A8856C9DEFFCD415746250A993B82479" translateForJs="false">Aby wykonać ten krok:</TranslationEntry>
    <TranslationEntry name="29DEDA21D8606663213ED1B61CAB2AB5" fullContext="29DEDA21D8606663213ED1B61CAB2AB5" translateForJs="false">Resetuj element</TranslationEntry>
    <TranslationEntry name="0C578FC7879740FC1782C197C0FAD57F" fullContext="0C578FC7879740FC1782C197C0FAD57F" translateForJs="false">Wyślij niestandardowy komunikat</TranslationEntry>
    <TranslationEntry name="594BA6A072695C3539CB2A570B875EF4" fullContext="594BA6A072695C3539CB2A570B875EF4" translateForJs="false">Wpisz tutaj komunikat i kliknij przycisk Wyślij, aby przesłać tekst przez aktualnie wybrane połączenie.</TranslationEntry>
    <TranslationEntry name="94966D90747B97D1F0F206C98A8B1AC3" fullContext="94966D90747B97D1F0F206C98A8B1AC3" translateForJs="false">Wyślij</TranslationEntry>
    <TranslationEntry name="FD31EC086307A3537311B6DEB52B845F" fullContext="FD31EC086307A3537311B6DEB52B845F" translateForJs="false">Włącz przesyłanie firmware</TranslationEntry>
    <TranslationEntry name="D3057FD00825A2A24E0716C77C7E4937" fullContext="3DDAA063E6FE7DBEED77AAFA4C2A302C" translateForJs="false">Zdalne przesyłanie firmware jest aktualnie wyłączone w celu oszczędzania transmisji danych 3G. Aby włączyć przesyłanie firmware, skontaktuj się z pomocą techniczną Inner Range Multipath pod numerem </TranslationEntry>
    <TranslationEntry name="BDB3EF16629E3215E6E3C85C36ECBF38" fullContext="3DDAA063E6FE7DBEED77AAFA4C2A302C" translateForJs="false">+61 3 9780 4300</TranslationEntry>
    <TranslationEntry name="915C93D63C3369C16A0D8F8B82682EE2" fullContext="3DDAA063E6FE7DBEED77AAFA4C2A302C" translateForJs="false"> lub o </TranslationEntry>
    <TranslationEntry name="C13F1627DB96C8522B7C4F1DBDECF519" fullContext="3DDAA063E6FE7DBEED77AAFA4C2A302C" translateForJs="false">multipath.support@innerrange.com</TranslationEntry>
    <TranslationEntry name="2A47C60A410F0A1A1E1886E41F2316BA" fullContext="3DDAA063E6FE7DBEED77AAFA4C2A302C" translateForJs="false"> i podaj numer seryjny tego kontrolera Inception </TranslationEntry>
    <TranslationEntry name="0EA8CA7FD31A162240CF23B399D401C2" fullContext="3DDAA063E6FE7DBEED77AAFA4C2A302C" translateForJs="false">({0})</TranslationEntry>
    <TranslationEntry name="89BDEA6F8925F672B1C226E48B016577" fullContext="3DDAA063E6FE7DBEED77AAFA4C2A302C" translateForJs="false"> aby otrzymać kod tymczasowo umożliwiający przesyłanie plików aktualizacji firmware.</TranslationEntry>
    <TranslationEntry name="906366A870272D09DC10D44559985A8A" fullContext="468AB34362A33EFEB815F8322EDEF203" translateForJs="false">Firmware można nadal załadować lokalnie, umieszczając plik firmware na nośniku USB i podłączając go do kontrolera Inception.</TranslationEntry>
    <TranslationEntry name="CA0DBAD92A874B2F69B549293387925E" fullContext="CA0DBAD92A874B2F69B549293387925E" translateForJs="false">Kod</TranslationEntry>
    <TranslationEntry name="D38419C89CDF48AC090EEF5655614666" fullContext="D38419C89CDF48AC090EEF5655614666" translateForJs="false">Aktualizuj firmware kontrolera</TranslationEntry>
    <TranslationEntry name="79545A7118039FC3A564A42A13A0C0B8" fullContext="79545A7118039FC3A564A42A13A0C0B8" translateForJs="false">Wybierz plik aktualizacji firmware</TranslationEntry>
    <TranslationEntry name="1351017AC6423911223BC19A8CB7C653" fullContext="1351017AC6423911223BC19A8CB7C653" translateForJs="false">Nazwa pliku</TranslationEntry>
    <TranslationEntry name="D28691C15F1F4E42C30C474EA17A2B81" fullContext="D28691C15F1F4E42C30C474EA17A2B81" translateForJs="false">Rozmiar (bajty)</TranslationEntry>
    <TranslationEntry name="77B380A576E7435BB413C26FF30B7ADE" fullContext="77B380A576E7435BB413C26FF30B7ADE" translateForJs="false">Lokalizacja pliku</TranslationEntry>
    <TranslationEntry name="40A77754436FAC7D2221B76B4F508517" fullContext="40A77754436FAC7D2221B76B4F508517" translateForJs="false">Weryfikowanie pliku firmware...</TranslationEntry>
    <TranslationEntry name="B46B082932B8B5D1EA6819DC04A909B1" fullContext="B46B082932B8B5D1EA6819DC04A909B1" translateForJs="false">Prześlij plik...</TranslationEntry>
    <TranslationEntry name="0F97AF2C9E0A39CD8548D03477B7DDE3" fullContext="0F97AF2C9E0A39CD8548D03477B7DDE3" translateForJs="false">Usuń wybrane pliki</TranslationEntry>
    <TranslationEntry name="59AF3165C0A8FB51F60F666AA36827E1" fullContext="59AF3165C0A8FB51F60F666AA36827E1" translateForJs="false">Anuluj przesyłanie</TranslationEntry>
    <TranslationEntry name="9639E32CAB248434A17AB32237CB3B71" fullContext="9639E32CAB248434A17AB32237CB3B71" translateForJs="false">Zastosuj</TranslationEntry>
    <TranslationEntry name="7E861518949DA89F65E5CB75562258F9" fullContext="7E861518949DA89F65E5CB75562258F9" translateForJs="false">Postęp pobierania firmware</TranslationEntry>
    <TranslationEntry name="51410B48C1FABD2B7732DB14977443EA" fullContext="D8FE1934771FFA5FA5B360F60D74AE93" translateForJs="false">Rozpocznij pobieranie za pomocą </TranslationEntry>
    <TranslationEntry name="11EEEC5FDF542D7F2ACF95BA97848F82" fullContext="11EEEC5FDF542D7F2ACF95BA97848F82" translateForJs="false">Rozpocznij pobieranie do kontrolera</TranslationEntry>
    <TranslationEntry name="84E57B281F51ADDC866F775EA17B30D5" fullContext="D8FE1934771FFA5FA5B360F60D74AE93" translateForJs="false"> przycisk poniżej. Proces pobierania może chwilę potrwać i w razie potrzeby można go anulować za pomocą </TranslationEntry>
    <TranslationEntry name="F6471E01CC01715F9814BA5589EC87CB" fullContext="F6471E01CC01715F9814BA5589EC87CB" translateForJs="false">Anuluj pobieranie</TranslationEntry>
    <TranslationEntry name="4F2A732336BD785D87419B4F20205F95" fullContext="D8FE1934771FFA5FA5B360F60D74AE93" translateForJs="false"> przycisk. Zaznacz </TranslationEntry>
    <TranslationEntry name="FC0313351FCF8F70475F1D27508AFF22" fullContext="FC0313351FCF8F70475F1D27508AFF22" translateForJs="false">Automatycznie zastosuj nowy firmware</TranslationEntry>
    <TranslationEntry name="AFDA7377F92B56B6E9FE40BBE19B78A9" fullContext="D8FE1934771FFA5FA5B360F60D74AE93" translateForJs="false"> pole wyboru, jeśli chcesz, aby nowy firmware był zastosowany do kontrolera natychmiast po zakończeniu pobierania.</TranslationEntry>
    <TranslationEntry name="E97113617A8E0912774EB23ACD317A0B" fullContext="E97113617A8E0912774EB23ACD317A0B" translateForJs="false">mniej niż tydzień temu</TranslationEntry>
    <TranslationEntry name="E0F80D474B67FB160BA3D99B406F614E" fullContext="E0F80D474B67FB160BA3D99B406F614E" translateForJs="false">ponad tydzień temu</TranslationEntry>
    <TranslationEntry name="E127DE5A80CA06DD82D32788EEF5E81A" fullContext="E127DE5A80CA06DD82D32788EEF5E81A" translateForJs="false">Informacje o systemie Inception</TranslationEntry>
    <TranslationEntry name="55364C36588FCE7DC1FD52C84884D8A1" fullContext="55364C36588FCE7DC1FD52C84884D8A1" translateForJs="false">Najnowsza kopia zapasowa bazy danych</TranslationEntry>
    <TranslationEntry name="6745895079518009901080E1DE7949F5" fullContext="6745895079518009901080E1DE7949F5" translateForJs="false">Aktualizuj oprogramowanie aplikacji</TranslationEntry>
    <TranslationEntry name="D1CBDB22D439455266A5BA70E37A55AE" fullContext="D1CBDB22D439455266A5BA70E37A55AE" translateForJs="false">Informacje o najnowszym firmware</TranslationEntry>
    <TranslationEntry name="1500A425671A1EB96F99C3EAA53645C2" fullContext="1500A425671A1EB96F99C3EAA53645C2" translateForJs="false">Połączenie SkyTunnel jest wymagane do wykrywania nowych wersji firmware. Upewnij się, że raportowanie alarmów SkyTunnel lub dostęp internetowy SkyTunnel jest włączony i że kontroler Inception ma aktywne połączenie z Internetem.</TranslationEntry>
    <TranslationEntry name="C3492796B5C57DE05D00D8D45717B6F3" fullContext="C3492796B5C57DE05D00D8D45717B6F3" translateForJs="false">Dostępna jest nowsza wersja firmware dla tego kontrolera.</TranslationEntry>
    <TranslationEntry name="E239C869E9ABD18A534B95E9372B0E76" fullContext="E239C869E9ABD18A534B95E9372B0E76" translateForJs="false">Nowa wersja firmware</TranslationEntry>
    <TranslationEntry name="B8A9F8E83E1493E7E6C0703C44AC7004" fullContext="B8A9F8E83E1493E7E6C0703C44AC7004" translateForJs="false">Data wydania firmware</TranslationEntry>
    <TranslationEntry name="323A33E004007E26560988739CD53613" fullContext="323A33E004007E26560988739CD53613" translateForJs="false">Nowy plik aktualizacji firmware można pobrać do kontrolera, klikając opcję „Pobierz firmware do kontrolera" poniżej. Plik aktualizacji firmware zostanie pobrany wyłącznie na kontroler. Następnie można użyć przycisku „Zaktualizuj oprogramowanie aplikacji" powyżej, aby zastosować plik firmware w wybranym momencie.</TranslationEntry>
    <TranslationEntry name="DAA17AA608C7AF53B0F5DCBBA8C30175" fullContext="DAA17AA608C7AF53B0F5DCBBA8C30175" translateForJs="false">Aktualnie zainstalowana wersja firmware jest aktualna.</TranslationEntry>
    <TranslationEntry name="7D30008F0B835E8BED959CC22E904109" fullContext="7D30008F0B835E8BED959CC22E904109" translateForJs="false">Informacje o wydaniu nowego firmware można również pobrać na urządzenie, naciskając opcję 'Pobierz informacje o wydaniu' poniżej.</TranslationEntry>
    <TranslationEntry name="C3A4CDB44D0F4300FDB46C6BA1788F05" fullContext="C3A4CDB44D0F4300FDB46C6BA1788F05" translateForJs="false">Pobierz firmware do kontrolera</TranslationEntry>
    <TranslationEntry name="615A0C861DBCBAB6B9A5934E9DD25E01" fullContext="615A0C861DBCBAB6B9A5934E9DD25E01" translateForJs="false">Pobierz informacje o wersji</TranslationEntry>
    <TranslationEntry name="44976609C87765877B58517FBD428E48" fullContext="44976609C87765877B58517FBD428E48" translateForJs="true">Ustaw datę/godzinę ręcznie</TranslationEntry>
    <TranslationEntry name="E679304D8B93ACBD32556A987C96D1E5" fullContext="E679304D8B93ACBD32556A987C96D1E5" translateForJs="false">Bieżący czas serwera</TranslationEntry>
    <TranslationEntry name="756EF0C0B43BC119C0C02C7C83927374" fullContext="756EF0C0B43BC119C0C02C7C83927374" translateForJs="false">Wybierz datę i godzinę, aby ustawić zegar systemowy.</TranslationEntry>
    <TranslationEntry name="FAF28F7C195336AD7B20BDB70DF27129" fullContext="FAF28F7C195336AD7B20BDB70DF27129" translateForJs="false">UWAGA: Zmiany mogą zostać nadpisane, jeśli aktywna jest synchronizacja NTP</TranslationEntry>
    <TranslationEntry name="4EDD71575508BA267EF8E78BC4BECAFB" fullContext="4EDD71575508BA267EF8E78BC4BECAFB" translateForJs="false">Czas do ustawienia</TranslationEntry>
    <TranslationEntry name="7D1D7846E822C60ABAA78B7F2F46C0A0" fullContext="7D1D7846E822C60ABAA78B7F2F46C0A0" translateForJs="false">Pobierz bieżący czas z przeglądarki</TranslationEntry>
    <TranslationEntry name="C4B37F8AE2F55AAD3D7EA013826E9149" fullContext="89A06E27005E4D307646BCB06AEA448D" translateForJs="false">Uwierzytelnianie dwuskładnikowe nie jest obecnie włączone dla tego urządzenia Inception. Jeśli trafiłeś na tę stronę przez pomyłkę, kliknij </TranslationEntry>
    <TranslationEntry name="6C92285FA6D3E827B198D120EA3AC674" fullContext="C59951F75D1665052A2812FFEED68992" translateForJs="false">tutaj</TranslationEntry>
    <TranslationEntry name="5F95A7115804B964B62EEBCFFE8ECC4A" fullContext="89A06E27005E4D307646BCB06AEA448D" translateForJs="false"> aby powrócić do strony głównej.</TranslationEntry>
    <TranslationEntry name="81025C3A6996DF334543860889452A28" fullContext="69E40F0F58D2DFDBC6BA3DB8453DCD41" translateForJs="false">Polityka bezpieczeństwa dla tego konta użytkownika wymaga skonfigurowania uwierzytelniania dwuskładnikowego (2FA) przed uzyskaniem dostępu do interfejsu WWW Inception.</TranslationEntry>
    <TranslationEntry name="EC531EEB6312FE822D24BB650103858A" fullContext="A3C4F41A52232D213543166CD5EBEFDE" translateForJs="false">Pobierz aplikację Google Authenticator (lub inną zgodną aplikację 2FA) na swój smartfon lub tablet.</TranslationEntry>
    <TranslationEntry name="A88300E1A91B6A9C4550660A75C9506C" fullContext="0018683C0E1FFF4F614713E183BAF55F" translateForJs="false">Zeskanuj kod QR za pomocą aplikacji uwierzytelniającej na telefonie lub ręcznie wprowadź klucz uwierzytelniający, aby dodać nowe konto 2FA.</TranslationEntry>
    <TranslationEntry name="64E2B3B1F5C148D10F32586AC32D36B3" fullContext="64E2B3B1F5C148D10F32586AC32D36B3" translateForJs="false">Awaryjny kod zapasowy</TranslationEntry>
    <TranslationEntry name="FCFC71C90312CCF017759774CF588B42" fullContext="01586E3E4157841B8A5A2E60BCCA6098" translateForJs="false">Kliknij przycisk Generuj kod zapasowy, aby wygenerować awaryjny kod zapasowy, który może być użyty do zalogowania się do systemu Inception w przypadku utraty zarejestrowanego urządzenia osobistego.</TranslationEntry>
    <TranslationEntry name="9CA707ED33A2D7048EDC1DD90B6DA79E" fullContext="9CA707ED33A2D7048EDC1DD90B6DA79E" translateForJs="false">Generuj kod zapasowy</TranslationEntry>
    <TranslationEntry name="BD8DBDD5C10A4919F86D73EE0C265B90" fullContext="BD8DBDD5C10A4919F86D73EE0C265B90" translateForJs="false">Rejestracja</TranslationEntry>
    <TranslationEntry name="7C0C40B9DD4FDFE6415419546C6C9DCD" fullContext="B6263CEEA89B3EDF32369136DEBBD557" translateForJs="false">Wprowadź 6-cyfrowy kod z aplikacji uwierzytelniającej i kliknij przycisk Zarejestruj, aby potwierdzić rejestrację 2FA.</TranslationEntry>
    <TranslationEntry name="66B05CF9583426CDD158AD0537A08669" fullContext="66B05CF9583426CDD158AD0537A08669" translateForJs="false">Rejestruj</TranslationEntry>
    <TranslationEntry name="5688960F32FA35938EF64CDCEDDEC9EA" fullContext="5688960F32FA35938EF64CDCEDDEC9EA" translateForJs="false">Info 1</TranslationEntry>
    <TranslationEntry name="362D9C5DC974D814E8695160AD04D4FA" fullContext="362D9C5DC974D814E8695160AD04D4FA" translateForJs="false">Informacja 2</TranslationEntry>
    <TranslationEntry name="E964CA2F4E8E56B2E32AEB12663CD91B" fullContext="E964CA2F4E8E56B2E32AEB12663CD91B" translateForJs="false">Stałe informacje 1</TranslationEntry>
    <TranslationEntry name="55CAE7C98BA49AE5C9CBC7F43786CF0A" translateForJs="false" rules="paramCheck=true" notes="This string contains special formatting parameters (e.g. &quot;{0}&quot;) that must be preserved in the translation">Wyświetlanie {0} {1}</TranslationEntry>
    <TranslationEntry name="FEDB6BDC7D6D6EC048F965282F0A5016" translateForJs="false" rules="paramCheck=true" notes="This string contains special formatting parameters (e.g. &quot;{0}&quot;) that must be preserved in the translation">przefiltrowano z {0} wszystkich {1}</TranslationEntry>
    <TranslationEntry name="35DE2A61DA317B11CEABF586F10B1D86" translateForJs="false" rules="paramCheck=true" notes="This string contains special formatting parameters (e.g. &quot;{0}&quot;) that must be preserved in the translation">Brak {0} do monitorowania</TranslationEntry>
    <TranslationEntry name="3891269221901B95E5CBB5AF1764CE5D" translateForJs="false" rules="paramCheck=true" notes="This string contains special formatting parameters (e.g. &quot;{0}&quot;) that must be preserved in the translation">Wyświetlanie 0 {0}</TranslationEntry>
    <TranslationEntry name="C9E099333953967AB40E7C8C6D11ED5D" fullContext="C9E099333953967AB40E7C8C6D11ED5D" translateForJs="false">Czas utworzenia</TranslationEntry>
    <TranslationEntry name="5F3D42CB0B6EC1E0B01B2612025B6B68" fullContext="5F3D42CB0B6EC1E0B01B2612025B6B68" translateForJs="false">Czas ostatniej modyfikacji</TranslationEntry>
    <TranslationEntry name="5E9E6FFFB20FAB1BF0DBA1B7DED13E10" fullContext="5E9E6FFFB20FAB1BF0DBA1B7DED13E10" translateForJs="false">Umowa licencyjna użytkownika końcowego (EULA)</TranslationEntry>
    <TranslationEntry name="B2109839AFA864C6813DF59C9B56D531" fullContext="B2109839AFA864C6813DF59C9B56D531" translateForJs="false">Politykę prywatności Inner Range oraz cyfrową kopię niniejszej Umowy EULA można również znaleźć tutaj:</TranslationEntry>
    <TranslationEntry name="068530789AC69E89B14DE2B61F64F27C" fullContext="068530789AC69E89B14DE2B61F64F27C" translateForJs="false">Polityka prywatności i EULA</TranslationEntry>
    <TranslationEntry name="C7F5A2BDB24208E53589535F08178A18" fullContext="C7F5A2BDB24208E53589535F08178A18" translateForJs="false">Przeczytaj i zaakceptuj poniższą umowę licencyjną, aby kontynuować:</TranslationEntry>
    <TranslationEntry name="C4408D335012A56FF58937D78050EFAD" fullContext="C4408D335012A56FF58937D78050EFAD" translateForJs="false">Akceptuj</TranslationEntry>
    <TranslationEntry name="0D3627289B893D3EEA08E52589ED06AE" fullContext="0D3627289B893D3EEA08E52589ED06AE" translateForJs="false">Odrzuć</TranslationEntry>
    <TranslationEntry name="54DF9536F2BC89E18BEC27B0D34AB42E" fullContext="6B84C55F05D9A4499AEF73D8C79DD875" translateForJs="false">Pobierz CSV</TranslationEntry>
    <TranslationEntry name="2607298669ACE2FC910321AFEB9F8A84" fullContext="6B84C55F05D9A4499AEF73D8C79DD875" translateForJs="false">Pobierz PDF</TranslationEntry>
    <TranslationEntry name="CCF3FE7704767C489584E19323DB169D" fullContext="CCF3FE7704767C489584E19323DB169D" translateForJs="false">Załaduj 500 więcej</TranslationEntry>
    <TranslationEntry name="7C6A7A731D1FDE1E114F102EF55CE197" fullContext="7C6A7A731D1FDE1E114F102EF55CE197" translateForJs="false">Załaduj 10000 więcej</TranslationEntry>
    <TranslationEntry name="3F6A6CCD8CC0686F5D5332DFDD7F388A" fullContext="3F6A6CCD8CC0686F5D5332DFDD7F388A" translateForJs="false">Filtruj zdarzenia</TranslationEntry>
    <TranslationEntry name="DFD35DD2A74BAED196C617A364879977" fullContext="DFD35DD2A74BAED196C617A364879977" translateForJs="false">Zdarzenia rejestru można filtrować, aby ułatwić wyszukiwanie konkretnych zdarzeń.</TranslationEntry>
    <TranslationEntry name="BBAB53F090EB2BFFD82F1C299268DD9D" fullContext="6B84C55F05D9A4499AEF73D8C79DD875" translateForJs="false">Istnieją 3 sposoby filtrowania zdarzeń rejestru: na podstawie czasu, komunikatu lub kategorii. Tych 3 filtrów można używać osobno lub łączyć do zaawansowanego wyszukiwania. </TranslationEntry>
    <TranslationEntry name="314775181D0725CA0DCA6383F2D92997" fullContext="6B84C55F05D9A4499AEF73D8C79DD875" translateForJs="false">Filtry czasowe</TranslationEntry>
    <TranslationEntry name="1C889AAF9B93AD5F841B859E1193CF63" fullContext="6B84C55F05D9A4499AEF73D8C79DD875" translateForJs="false"> filtr służy do określenia daty i godziny w przeszłości, po której zostaną odfiltrowane zdarzenia wcześniejsze. Można go użyć do wyświetlenia ostatnich 7 dni w rejestrze zdarzeń. </TranslationEntry>
    <TranslationEntry name="D446633B3BA0F4828AC02D7B82AF5E7E" fullContext="6B84C55F05D9A4499AEF73D8C79DD875" translateForJs="false"> filtr służy do określenia daty i godziny, po której zostaną odfiltrowane późniejsze zdarzenia. Określenie </TranslationEntry>
    <TranslationEntry name="7A8D85FD7CDE98D0747CD71DC1EE0979" fullContext="6B84C55F05D9A4499AEF73D8C79DD875" translateForJs="false"> filtr w przeszłości uniemożliwi dodawanie bieżącego rejestru. Opcje te są często używane razem, aby wyświetlać tylko zdarzenia rejestru, które wystąpiły w określonym przedziale czasowym. </TranslationEntry>
    <TranslationEntry name="B0BCF10B87DA170390A03553D56EA62E" fullContext="6B84C55F05D9A4499AEF73D8C79DD875" translateForJs="false">Filtr tekstowy</TranslationEntry>
    <TranslationEntry name="A41E0A2704C727B3CEB9EC671F4B983D" fullContext="6B84C55F05D9A4499AEF73D8C79DD875" translateForJs="false"> - Pole wyszukiwania filtruje aktualnie wyświetlane zdarzenia Rejestru zdarzeń na podstawie wprowadzonego tekstu. Tekst ten jest przeszukiwany w kolumnach Komunikat, Kto, Co i Gdzie. Tekst nie musi pojawiać się w określonej kolejności — każde słowo oddzielone spacją jest wyszukiwane w wierszu. Wyniki będą zawierać wszystkie zdarzenia Rejestru, które zawierają każde wprowadzone słowo w polu wyszukiwania pomiędzy polami. Funkcja ta jest powszechnie stosowana do wyszukiwania konkretnych zdarzeń, np. użytkownika o imieniu Maria sterującego strefą Foyer. Jeśli tekst </TranslationEntry>
    <TranslationEntry name="72CBC515A0F46EA98CB651C945EB5838" fullContext="6B84C55F05D9A4499AEF73D8C79DD875" translateForJs="false">Mary Foyer</TranslationEntry>
    <TranslationEntry name="F11261EA6FFC289C425F356A148DAB48" fullContext="6B84C55F05D9A4499AEF73D8C79DD875" translateForJs="false"> zostało wpisane w pole wyszukiwania, wyświetlane będą tylko zdarzenia rejestru zawierające oba słowa.</TranslationEntry>
    <TranslationEntry name="58894ADC7253FB978EE7783A1A105A1B" fullContext="6B84C55F05D9A4499AEF73D8C79DD875" translateForJs="false">Filtr kategorii</TranslationEntry>
    <TranslationEntry name="191B6411583DBA8B521CC6AEB47040AD" fullContext="6B84C55F05D9A4499AEF73D8C79DD875" translateForJs="false"> - Każde zdarzenie w Rejestrze zdarzeń systemu Inception należy do kategorii, według której można filtrować, aby zawęzić typy wyświetlanych komunikatów. Kategorie to: Bezpieczeństwo, Dostęp, Sprzęt, System i Audyt. W filtrze można jednocześnie uwzględnić wiele kategorii. Aby ustawić, czy dana kategoria jest uwzględniona w filtrze, kliknij lub dotknij kategorię, aby przełączyć jej aktywność. Domyślnie strona Rejestr zdarzeń wyświetla tylko kategorie komunikatów: Bezpieczeństwo, Dostęp i System. </TranslationEntry>
    <TranslationEntry name="4DB6FEBCB5355039717440908A5D460A" fullContext="6B84C55F05D9A4499AEF73D8C79DD875" translateForJs="false">Powyższe filtry można łączyć, aby zapewnić elastyczny sposób filtrowania zdarzeń. Gdy stosowany jest jeden lub więcej filtrów, zdarzenia niespełniające kryteriów filtra będą ukryte, a informacje o liczbie wyświetlonych zdarzeń w stosunku do łącznej ich liczby zostaną zaktualizowane, np. </TranslationEntry>
    <TranslationEntry name="63C23C02C52B5539CFC77EDBC0A2798F" fullContext="6B84C55F05D9A4499AEF73D8C79DD875" translateForJs="false">Wyświetlanie 241 zdarzeń (przefiltrowanych z 744 wszystkich zdarzeń)</TranslationEntry>
    <TranslationEntry name="EFE8079CAEDB590F1484A608A1F36D87" fullContext="6B84C55F05D9A4499AEF73D8C79DD875" translateForJs="false"> opcje są uzależnione od filtrowania zdarzeń.</TranslationEntry>
    <TranslationEntry name="1E6D57E813355689E9C77E947D73AD8F" fullContext="1E6D57E813355689E9C77E947D73AD8F" translateForJs="false">Od:</TranslationEntry>
    <TranslationEntry name="33CAA076F23F453DD4061726F3706325" fullContext="33CAA076F23F453DD4061726F3706325" translateForJs="false">Do:</TranslationEntry>
    <TranslationEntry name="24C29702DC9C63DEDB98E92F3028E068" fullContext="24C29702DC9C63DEDB98E92F3028E068" translateForJs="false">Szukaj:</TranslationEntry>
    <TranslationEntry name="479D26404AE098FF8BA1A0596760D0FE" fullContext="479D26404AE098FF8BA1A0596760D0FE" translateForJs="false">Filtrowanie kategorii komunikatów:</TranslationEntry>
    <TranslationEntry name="C77CF5DEB127E58991053ACFDEE45DFB" fullContext="C77CF5DEB127E58991053ACFDEE45DFB" translateForJs="false">Ukryj zdjęcia użytkowników:</TranslationEntry>
    <TranslationEntry name="16F7AFCEF8F554673916ABDEBCC37664" fullContext="16F7AFCEF8F554673916ABDEBCC37664" translateForJs="false">WhenTicks</TranslationEntry>
    <TranslationEntry name="0AA2B6E935172EFE51B1988E06564747" fullContext="0AA2B6E935172EFE51B1988E06564747" translateForJs="false">GdySekwencja</TranslationEntry>
    <TranslationEntry name="D4336A6F1DD6AE76D2FD3E8411B41E9C" fullContext="D4336A6F1DD6AE76D2FD3E8411B41E9C" translateForJs="false">KategoriaPowiadomień</TranslationEntry>
    <TranslationEntry name="3CFB5A85520F02DF360D53C30735E69C" fullContext="3CFB5A85520F02DF360D53C30735E69C" translateForJs="false">KlasaKoloru</TranslationEntry>
    <TranslationEntry name="DB5200E32385F344890C6EF10CE47100" fullContext="DB5200E32385F344890C6EF10CE47100" translateForJs="false">Wczytaj więcej wpisów rejestru</TranslationEntry>
    <TranslationEntry name="C8326B4F92C6BE13ACC2B451D4A5D0EB" translateForJs="false" rules="paramCheck=true" notes="This string contains special formatting parameters (e.g. &quot;{0}&quot;) that must be preserved in the translation">Wyświetlanie {0} zdarzeń</TranslationEntry>
    <TranslationEntry name="87DEBCFBF94DAF1B2FEE879082AE1EE2" translateForJs="false" rules="paramCheck=true" notes="This string contains special formatting parameters (e.g. &quot;{0}&quot;) that must be preserved in the translation">przefiltrowano z {0} łącznych zdarzeń</TranslationEntry>
    <TranslationEntry name="110AB924BD16E6D306895DE20FC8EFAD" fullContext="110AB924BD16E6D306895DE20FC8EFAD" translateForJs="false">Nie znaleziono pasujących zdarzeń</TranslationEntry>
    <TranslationEntry name="21E67CBBE27DD174685370ED11B1D8EB" fullContext="21E67CBBE27DD174685370ED11B1D8EB" translateForJs="false">Pokazuje 0 zdarzeń</TranslationEntry>
    <TranslationEntry name="A45876C67224201CE79E35DE0124BEE7" fullContext="A45876C67224201CE79E35DE0124BEE7" translateForJs="false">Pobierz raport sprzętowy</TranslationEntry>
    <TranslationEntry name="A4C022863155EC6AA9D6DF8050EA84D4" fullContext="A4C022863155EC6AA9D6DF8050EA84D4" translateForJs="false">Ustaw adres OSDP</TranslationEntry>
    <TranslationEntry name="7DCE122004969D56AE2E0245CB754D35" fullContext="7DCE122004969D56AE2E0245CB754D35" translateForJs="false">Edytuj</TranslationEntry>
    <TranslationEntry name="1063E38CB53D94D386F21227FCD84717" fullContext="1063E38CB53D94D386F21227FCD84717" translateForJs="false">Usuń</TranslationEntry>
    <TranslationEntry name="D97712A749CAFD142C0470A4B496BA61" fullContext="D97712A749CAFD142C0470A4B496BA61" translateForJs="false">Zmień tryb IO kontrolera</TranslationEntry>
    <TranslationEntry name="80ADBA4A62FE6C77DC51393ACEBF73FF" fullContext="80ADBA4A62FE6C77DC51393ACEBF73FF" translateForJs="false">Zmień typ przejścia ILAM</TranslationEntry>
    <TranslationEntry name="4989C5CFE640DE02AB7D2179E0EDE2A8" fullContext="4989C5CFE640DE02AB7D2179E0EDE2A8" translateForJs="false">Powrót do listy sprzętu</TranslationEntry>
    <TranslationEntry name="F5D0AF8BD2E0257C708E166927AC1BA5" fullContext="F5D0AF8BD2E0257C708E166927AC1BA5" translateForJs="false">Utwórz nowy sprzęt</TranslationEntry>
    <TranslationEntry name="F784D35B936BDC546B7A3AB29BD56E13" fullContext="F784D35B936BDC546B7A3AB29BD56E13" translateForJs="false">Typ modułu</TranslationEntry>
    <TranslationEntry name="5DBC3F95E7CA95239C69D634D7FC1059" fullContext="5DBC3F95E7CA95239C69D634D7FC1059" translateForJs="false">Dodaj nową integrację / urządzenie</TranslationEntry>
    <TranslationEntry name="A4DBD95E97839226082E0538314A31EF" fullContext="A4DBD95E97839226082E0538314A31EF" translateForJs="false">Aktualizuj adres OSDP</TranslationEntry>
    <TranslationEntry name="1DACC4EB0B7BF3A1433E4B7FC085B9BF" fullContext="97040D4C7B9CB03B81755D4148B9767C" translateForJs="false">Wybierz czytnik OSDP podłączony do aktualnie wybranego modułu, którego adres ma zostać zmieniony. Na liście znajdą się tylko czytniki OSDP aktualnie online i połączone.</TranslationEntry>
    <TranslationEntry name="4848BD8FDEC4A3052D3E2BB0473CB226" fullContext="97040D4C7B9CB03B81755D4148B9767C" translateForJs="false">Czytniki SIFER nie będą uwzględnione na tej liście i nie wymagają użycia tej funkcji dzięki automatycznemu zarządzaniu adresami po podłączeniu do dowolnego systemu Inner Range.</TranslationEntry>
    <TranslationEntry name="5D7AAE7B9AC10B0320619E387048EF25" fullContext="FD6BB53C50B38B70F328E4CB33CD2250" translateForJs="false">Wprowadź nowy adres numeryczny, który ma zostać ustawiony dla czytnika OSDP. Po potwierdzeniu do wybranego czytnika zostanie wysłana komenda ustawiająca adres na podany.</TranslationEntry>
    <TranslationEntry name="0FB34408DA33B2DEE29D27021931D96C" fullContext="FD6BB53C50B38B70F328E4CB33CD2250" translateForJs="false">Po wysłaniu polecenia czytnik zostanie odłączony i niezwłocznie ponownie podłączony do modułu pod nowym adresem, o ile jest on wolny. Można to potwierdzić poprzez komunikaty w Rejestrze zdarzeń pokazujące rozłączenie i ponowne połączenie po wysłaniu polecenia, zmianę nazwy czytnika lub wyświetlenie nowego adresu w tym samym oknie po jego ponownym otwarciu.</TranslationEntry>
    <TranslationEntry name="774FEB45CC1FBBC2C23AFF2F13930CDA" fullContext="774FEB45CC1FBBC2C23AFF2F13930CDA" translateForJs="false">Nowy adres OSDP</TranslationEntry>
    <TranslationEntry name="E4E009EC8FBA4965F72AD8FF91A7D2A7" fullContext="E4E009EC8FBA4965F72AD8FF91A7D2A7" translateForJs="false">Dodaj integrację / urządzenie sieciowe</TranslationEntry>
    <TranslationEntry name="8B3A60BD8F117D6335FB3269105A1915" fullContext="8B3A60BD8F117D6335FB3269105A1915" translateForJs="false">Inception może integrować się z systemami takimi jak IR Video Gateway lub inne urządzenia sieciowe i monitorować je jak inne Moduły sprzętowe. Naciśnij poniższy przycisk, aby zobaczyć dostępne integracje lub typy urządzeń i dodać je.</TranslationEntry>
    <TranslationEntry name="FA0D5E2993EFC6998CAF5580193D5C6B" fullContext="FA0D5E2993EFC6998CAF5580193D5C6B" translateForJs="false">Nieskonfigurowane moduły</TranslationEntry>
    <TranslationEntry name="D8B26CC297845A3433BE359F2FC5873B" fullContext="D8B26CC297845A3433BE359F2FC5873B" translateForJs="false">Opis modułu</TranslationEntry>
    <TranslationEntry name="2B77DAA5983F1FFED90B1FE6E5167275" fullContext="2B77DAA5983F1FFED90B1FE6E5167275" translateForJs="false">Rodzina sprzętu</TranslationEntry>
    <TranslationEntry name="1B5AD587739E32535302D2F36B16DF4E" fullContext="1B5AD587739E32535302D2F36B16DF4E" translateForJs="false">Przeznaczenia wejść/wyjść kontrolera</TranslationEntry>
    <TranslationEntry name="F58E4825AB3F3FFC3EEE21943A31DED1" fullContext="ADA8FFB2EC10A774273BE9E8AE30DD27" translateForJs="false">Wybierz poniżej, do czego są używane linie wejściowe i wyjściowe wbudowane w Kontroler.</TranslationEntry>
    <TranslationEntry name="E9695A24C1B1F8C1786A133EC46A5102" fullContext="ADA8FFB2EC10A774273BE9E8AE30DD27" translateForJs="false">Wybierz </TranslationEntry>
    <TranslationEntry name="CF611DDC9FA24A15027ADBE92E9F9F47" fullContext="CF611DDC9FA24A15027ADBE92E9F9F47" translateForJs="false">Kontrola dostępu (zaawansowana)</TranslationEntry>
    <TranslationEntry name="44496017777A32E0898E582A8C8DF669" fullContext="ADA8FFB2EC10A774273BE9E8AE30DD27" translateForJs="false"> poniżej, jeśli jakiekolwiek wbudowane linie wyjściowe służą do sterowania zamkami przejść lub wbudowane czytniki są używane do integracji z windą. W przeciwnym razie wybierz </TranslationEntry>
    <TranslationEntry name="F5291D0BAD13DE5DF83A0B58579E08C2" fullContext="F5291D0BAD13DE5DF83A0B58579E08C2" translateForJs="false">Intruz (podstawowy)</TranslationEntry>
    <TranslationEntry name="218C9F6D90C65A89786CC27AD3029FD1" fullContext="ADA8FFB2EC10A774273BE9E8AE30DD27" translateForJs="false"> dla podstawowych linii wejściowych i wyjściowych.</TranslationEntry>
    <TranslationEntry name="37C74F5065189F848CB460EE6418B545" fullContext="ADA8FFB2EC10A774273BE9E8AE30DD27" translateForJs="false">Jeśli zmienisz zdanie później, możesz wybrać kontroler poniżej i nacisnąć przycisk 'Zmień tryb IO kontrolera', aby ponownie wyświetlić to okno dialogowe.</TranslationEntry>
    <TranslationEntry name="FD4C6DFA40A16843577DBA673853B25F" fullContext="3549AECF6F04503AB3E03BBC8495024A" translateForJs="false">Wybierz poniżej, jakim typem przejść będzie sterował ten moduł ILAM.</TranslationEntry>
    <TranslationEntry name="237AD79DFDD8562180CBE8D715C6AC30" fullContext="3549AECF6F04503AB3E03BBC8495024A" translateForJs="false">Jeśli zmienisz zdanie później, możesz wybrać ILAM poniżej i nacisnąć przycisk „Zmień typ przejścia ILAM”, aby ponownie wyświetlić to okno dialogowe.</TranslationEntry>
    <TranslationEntry name="B78965C0262229E051FC48A4D6CBF0A0" fullContext="B78965C0262229E051FC48A4D6CBF0A0" translateForJs="false">Przejścia RF</TranslationEntry>
    <TranslationEntry name="C43D782636A3948CC79C4A6E12A56308" fullContext="C43D782636A3948CC79C4A6E12A56308" translateForJs="false">Przejścia przewodowe</TranslationEntry>
    <TranslationEntry name="169D355C1A596E17AD98B02979B22BE1" fullContext="169D355C1A596E17AD98B02979B22BE1" translateForJs="false">Nowy ILAM</TranslationEntry>
    <TranslationEntry name="285ACF3DA30452C69CD1C4CC7A3EB1A5" fullContext="A69B9E24BC9CB01EFD27895BB1AD9F87" translateForJs="false">Wybierz poniżej, jakiego typu przejścia będzie kontrolować tworzony ILAM.</TranslationEntry>
    <TranslationEntry name="8A88A9DD889F924B9D0298D01764EEC2" fullContext="014F12EB0EB16CDDE1C53A1B76B4A0AA" translateForJs="false">Jaki typ przejść RF próbujesz skonfigurować?</TranslationEntry>
    <TranslationEntry name="B66089C53C180C395026E5FA5CDBCBFC" fullContext="B66089C53C180C395026E5FA5CDBCBFC" translateForJs="false">Aperio</TranslationEntry>
    <TranslationEntry name="EB931A5AC255A24A5E47E0944DBD4148" fullContext="EB931A5AC255A24A5E47E0944DBD4148" translateForJs="false">Nieprzypisane linie wejściowe RF z ostatniego rejestru</TranslationEntry>
    <TranslationEntry name="D679EC10DF771A767A122BE4F9E37864" fullContext="D679EC10DF771A767A122BE4F9E37864" translateForJs="false">Ostatnie numery seryjne linii wejściowej RF ze zdarzeń rejestru</TranslationEntry>
    <TranslationEntry name="8226E718B7D1E5ECFEBAB364B3CF4EB4" fullContext="8226E718B7D1E5ECFEBAB364B3CF4EB4" translateForJs="false">Paruj nową linię wejściową</TranslationEntry>
    <TranslationEntry name="D79B497C1453B0FEF1E84F97953FBA27" fullContext="D79B497C1453B0FEF1E84F97953FBA27" translateForJs="false">Wyciągnij przezroczystą zakładkę z nowego urządzenia. Spowoduje to aktywację trybu parowania.</TranslationEntry>
    <TranslationEntry name="61E00191F53F9D43C70EE30650369A9A" fullContext="61E00191F53F9D43C70EE30650369A9A" translateForJs="false">Naciśnij i przytrzymaj przycisk rejestracji na urządzeniu, aż wskaźnik świetlny zmieni kolor na zielony (5-10 sekund).</TranslationEntry>
    <TranslationEntry name="AC275CA7655BEC63208981A461686D5B" fullContext="AC275CA7655BEC63208981A461686D5B" translateForJs="false">Więcej szczegółów można znaleźć w Skróconej instrukcji uruchomienia urządzenia.</TranslationEntry>
    <TranslationEntry name="AB9481A9FA7BE0DD7B3CD44A413B850E" fullContext="AB9481A9FA7BE0DD7B3CD44A413B850E" translateForJs="false">Wskaźnik świetlny urządzenia pulsuje zielonym kolorem w trybie parowania.</TranslationEntry>
    <TranslationEntry name="49FA51365060E38D1AB4341142EC5C6B" translateForJs="false" rules="paramCheck=true" notes="This string contains special formatting parameters (e.g. &quot;{0}&quot;) that must be preserved in the translation">Wyszukiwanie urządzenia ({0})...</TranslationEntry>
    <TranslationEntry name="42D45B1AE9D8EAB4B54D85A98E9F1D69" translateForJs="false" rules="paramCheck=true" notes="This string contains special formatting parameters (e.g. &quot;{0}&quot;) that must be preserved in the translation">Urządzenie niepodłączone</TranslationEntry>
    <TranslationEntry name="F3BA2944A19FB33C4E09B43F59E14D74" fullContext="F3BA2944A19FB33C4E09B43F59E14D74" translateForJs="false">Urządzenie podłączone</TranslationEntry>
    <TranslationEntry name="6D94980E877E7AE49F06B0B597B19446" fullContext="6D94980E877E7AE49F06B0B597B19446" translateForJs="false">Typ urządzenia:</TranslationEntry>
    <TranslationEntry name="7C140E02D23DAEEA71983E4EFC439FCA" fullContext="7C140E02D23DAEEA71983E4EFC439FCA" translateForJs="false">Test linii wyjściowej</TranslationEntry>
    <TranslationEntry name="2A3CD5946CFD317EB99C3D32E35E2D4C" fullContext="2A3CD5946CFD317EB99C3D32E35E2D4C" translateForJs="false">Punkt</TranslationEntry>
    <TranslationEntry name="96D4F4CCC325F5BC17FC7BB9447AB338" fullContext="96D4F4CCC325F5BC17FC7BB9447AB338" translateForJs="false">Test linii wejściowej</TranslationEntry>
    <TranslationEntry name="C8C59626A85748CF1D7F517C25E57F01" fullContext="C8C59626A85748CF1D7F517C25E57F01" translateForJs="false">Bieżący stan</TranslationEntry>
    <TranslationEntry name="99562F9B4A8717E8854481C7578F0EA8" fullContext="99562F9B4A8717E8854481C7578F0EA8" translateForJs="false">Wejścia w stan</TranslationEntry>
    <TranslationEntry name="0CBC6611F5540BD0809A388DC95A615B" fullContext="0CBC6611F5540BD0809A388DC95A615B" translateForJs="true">Test</TranslationEntry>
    <TranslationEntry name="C5A8EA69C975E8902DCE6C56739527F2" fullContext="C5A8EA69C975E8902DCE6C56739527F2" translateForJs="false">Brak linii wejściowych/wyjściowych</TranslationEntry>
    <TranslationEntry name="07E37F4522F20944B4D98C56074D7FF6" fullContext="27F352388C6C7252DCDED2B6FE130B2B" translateForJs="false">Dla tego modułu nie skonfigurowano żadnych linii wejściowych ani wyjściowych. Przejdź do strony Kreatora sprzętu, aby je skonfigurować.</TranslationEntry>
    <TranslationEntry name="AA9BA9714BF27D5949718EF19D7C7123" fullContext="AA9BA9714BF27D5949718EF19D7C7123" translateForJs="false">Przejdź do kreatora sprzętu</TranslationEntry>
    <TranslationEntry name="CBBE4CFDC99D0965C54E74D371E2137B" fullContext="FC2808F0BDC98A24DC42E402A90C5649" translateForJs="false">Aby monitorować elementy stanu zdrowia związane z modułem, takie jak sabotaże obudowy i inteligentne zasilacze, system musi wiedzieć, które komponenty zostały podłączone. Konfiguruje się to na </TranslationEntry>
    <TranslationEntry name="754028B410E8B568BD6D557CDB997E50" fullContext="FC2808F0BDC98A24DC42E402A90C5649" translateForJs="false"> sekcję dla modułu na </TranslationEntry>
    <TranslationEntry name="561F367482C0637A10435813132685DF" fullContext="561F367482C0637A10435813132685DF" translateForJs="false">Typ problemu ze sprawnością modułu</TranslationEntry>
    <TranslationEntry name="B95F208B8A3E0954789BE6E80C4135CE" fullContext="B95F208B8A3E0954789BE6E80C4135CE" translateForJs="false">Sabotaż czytnika przejścia 1</TranslationEntry>
    <TranslationEntry name="A46B34DD763D3CEB3EDAE17D5DFBE33F" fullContext="A46B34DD763D3CEB3EDAE17D5DFBE33F" translateForJs="false">Sabotaż czytnika przejścia 2</TranslationEntry>
    <TranslationEntry name="D3E43FD285EA2EC7A9D06B323E5C83B1" fullContext="D3E43FD285EA2EC7A9D06B323E5C83B1" translateForJs="false">Sabotaż czytnika przejścia 3</TranslationEntry>
    <TranslationEntry name="EA1E6B1C8104977C2485BD9CC3340147" fullContext="EA1E6B1C8104977C2485BD9CC3340147" translateForJs="false">Sabotaż czytnika przejścia 4</TranslationEntry>
    <TranslationEntry name="DC06EEEF0563CFC0B0C654B22A07929C" fullContext="DC06EEEF0563CFC0B0C654B22A07929C" translateForJs="false">Sabotaż czytnika przejścia 5</TranslationEntry>
    <TranslationEntry name="E49FBBB197E2FD0A900E4070B63DD631" fullContext="E49FBBB197E2FD0A900E4070B63DD631" translateForJs="false">Sabotaż czytnika przejścia 6</TranslationEntry>
    <TranslationEntry name="8CDEA89CF392B6F025D0F134D26CD0D1" fullContext="8CDEA89CF392B6F025D0F134D26CD0D1" translateForJs="false">Sabotaż czytnika przejścia 7</TranslationEntry>
    <TranslationEntry name="220500DB20E11BB783F57D71476C2A41" fullContext="220500DB20E11BB783F57D71476C2A41" translateForJs="false">Sabotaż czytnika przejścia 8</TranslationEntry>
