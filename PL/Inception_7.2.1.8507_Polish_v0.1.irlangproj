    <TranslationEntry name="BCC688C04AB75FE2A2BE806315E28D5F" translateForJs="false" rules="paramCheck=true" notes="This string contains special formatting parameters (e.g. &quot;{0}&quot;) that must be preserved in the translation">Podano nieprawidłowy port SIA IP: {0}</TranslationEntry>
    <TranslationEntry name="2086AACA66CDB94AF36F1D4166ED9AE3" translateForJs="false" rules="paramCheck=true" notes="This string contains special formatting parameters (e.g. &quot;{0}&quot;) that must be preserved in the translation">Wyświetlanie zdarzeń żądań dostępu od {0}</TranslationEntry>
    <TranslationEntry name="B2E839FD6DFCDB9A6F387CECB70C45B2" translateForJs="false">Filtruj według przejść/kabin windy:</TranslationEntry>
    <TranslationEntry name="CCBF67579DFF276D7DD76B04EFD01916" translateForJs="false">Filtruj według użytkowników:</TranslationEntry>
