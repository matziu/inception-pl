    <TranslationEntry name="CC417F154A09E5C8BD807816005B840F" translateForJs="false">Żaden e-mail nie został wysłany pomyślnie.</TranslationEntry>
    <TranslationEntry name="AB65C28ACDF9550FB14250756BE33570" translateForJs="false">Kopiowanie plików do udziału sieciowego nie jest zaimplementowane w systemie Windows</TranslationEntry>
    <TranslationEntry name="066C302C30AAFD5B8477E63B2B6B2E4E" translateForJs="false" rules="paramCheck=true" notes="This string contains special formatting parameters (e.g. &quot;{0}&quot;) that must be preserved in the translation">Docelowa ścieżka sieciowego udziału plików była nieprawidłowo sformatowana lub zawierała nieprawidłowe znaki ({0})</TranslationEntry>
    <TranslationEntry name="EC26AC5594BF2F00E2EC7F704B3501C2" translateForJs="false" rules="paramCheck=true" notes="This string contains special formatting parameters (e.g. &quot;{0}&quot;) that must be preserved in the translation">Nie można skopiować pliku do zdalnego udziału sieciowego: {0}</TranslationEntry>
    <TranslationEntry name="A898E7BDDB4948813E677D65FB1B0F32" translateForJs="false">Nie można zapisać pliku na dysk USB — dysk może być odłączony lub zabezpieczony przed zapisem.</TranslationEntry>
    <TranslationEntry name="753ADCF980D5A5E163693652AD8F39ED" fullContext="753ADCF980D5A5E163693652AD8F39ED" translateForJs="false">Regularny harmonogram wyłączony</TranslationEntry>
    <TranslationEntry name="B67F99E74379EE282EE5585D1C29A424" translateForJs="false" rules="paramCheck=true" notes="This string contains special formatting parameters (e.g. &quot;{0}&quot;) that must be preserved in the translation">Nie znaleziono zaplanowanego zadania o ID {0}</TranslationEntry>
    <TranslationEntry name="B731EBB6A437946E3879D3917A9BAC04" translateForJs="false" rules="paramCheck=true" notes="This string contains special formatting parameters (e.g. &quot;{0}&quot;) that must be preserved in the translation">Nie można wygenerować pliku wyjściowego — nierozpoznany typ akcji: {0}</TranslationEntry>
    <TranslationEntry name="FB44FC3E4C89192A81D33FEC407F1F14" translateForJs="false">Nie udało się wygenerować pliku wyjściowego zadania.</TranslationEntry>
    <TranslationEntry name="F45EBB0D3F6C54646DD0DBCD04A24B8B" translateForJs="false">Podczas generowania pliku wyjściowego zadania wystąpił wyjątek</TranslationEntry>
    <TranslationEntry name="3935C24EB01443B4F7F9E820DCDEF5E1" translateForJs="false" rules="paramCheck=true" notes="This string contains special formatting parameters (e.g. &quot;{0}&quot;) that must be preserved in the translation">Wygenerowany plik wyjściowy: {0}</TranslationEntry>
    <TranslationEntry name="1DF73EB9A8EEEC7FFE2724CDD0C5412F" translateForJs="false" rules="paramCheck=true" notes="This string contains special formatting parameters (e.g. &quot;{0}&quot;) that must be preserved in the translation">Nie można wysłać pliku wyjściowego — nierozpoznany typ ścieżki wysyłania: {0}</TranslationEntry>
    <TranslationEntry name="98626B86246E2895995D4252D5F6714B" translateForJs="false">Zadanie zostało wykonane i wysłane pomyślnie.</TranslationEntry>
    <TranslationEntry name="B6381F3E6479FBCF81AC06C06D532BF0" translateForJs="false">Nie można znaleźć interfejsu sprzętowego dla tej jednostki.</TranslationEntry>
    <TranslationEntry name="DE86017B0815D74627CFF7F3A3DEA62B" translateForJs="false" rules="paramCheck=true" notes="This string contains special formatting parameters (e.g. &quot;{0}&quot;) that must be preserved in the translation">Nie można usunąć blokady dla użytkownika {0} — użytkownik ma wyższy poziom priorytetu.</TranslationEntry>
    <TranslationEntry name="96F7106CB1255A64F05DE37458801CFC" translateForJs="false">Wysłano komunikat alarmu użytkownika</TranslationEntry>
    <TranslationEntry name="D80A90589C9772F01FF79A60D7FCB191" translateForJs="false">Aktualizacje firmware wbudowanych urządzeń peryferyjnych nie mogą być wykonywane jednocześnie z aktualizacjami zewnętrznych modułów. W przypadku wykonywania aktualizacji firmware wbudowanego wybierz z listy wyłącznie wbudowany Kontroler Inception.</TranslationEntry>
    <TranslationEntry name="44C6133A0835CF359A56B4B9045F94CA" translateForJs="false">Nie można rozpocząć pobierania — trwa już inne pobieranie firmware</TranslationEntry>
    <TranslationEntry name="C50AD3478F983DAAD3F3470F52DDE1AA" translateForJs="false">Nie można rozpocząć pobierania — połączenie SkyTunnel nie jest aktualnie aktywne</TranslationEntry>
