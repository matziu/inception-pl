    <TranslationEntry name="6D9058E0BFDB145F6F74C9B77AF5CD8F" translateForJs="false" rules="unique=FobTemplateType" notes="Must be unique amongst all &quot;FobTemplateType&quot; entries">IR Wireless RF 4 Button</TranslationEntry>
    <TranslationEntry name="88215F46344BF305A8E13A0194A41573" translateForJs="false">Typ sprzętu zdalnego</TranslationEntry>
    <TranslationEntry name="B6895245CBB4C62AE4B54C84E660B213" fullContext="DEC809642217E9886FEC3865F8172E2D" translateForJs="false">Typ zdalnego sprzętu powinien odpowiadać typowi pilota, z którym ten szablon zostanie powiązany. Wybrany typ określa, jakie opcje są dostępne poniżej. W przypadku systemu Paradox RF kontroler Inception obsługuje jednoprzyciskowy REM 101 oraz czteroprzyciskowe breloki REM1, 2 i 15. W przypadku systemów Inovonics obsługiwane są wszystkie piloty, jednak wykonywane akcje zależą od modelu pilota.</TranslationEntry>
    <TranslationEntry name="1A069767003E1D189A5F3B6F62B4B778" fullContext="DEC809642217E9886FEC3865F8172E2D" translateForJs="false">Wybranie typu Jednoprzyciski pilot zmieni poniższe opcje na pojedynczy typ odpowiedzi. Ten pojedynczy przycisk może służyć do sygnalizowania przymusu użytkownika lub wykonywania wielu akcji.</TranslationEntry>
    <TranslationEntry name="37E247CD35BD9D071B14358D1E9D5067" fullContext="DEC809642217E9886FEC3865F8172E2D" translateForJs="false">Wybranie typu Paradox 4 Button (REM1, REM2, REM15) zmieni poniższe opcje, umożliwiając określenie głównego elementu sterującego dla przycisków odblokowania i blokowania oraz skonfigurowanie akcji odpowiedzi dla dodatkowych przycisków sterujących.</TranslationEntry>
    <TranslationEntry name="C29DB6838D6B0E380E0AAB528204B802" fullContext="DEC809642217E9886FEC3865F8172E2D" translateForJs="false">Wybranie typu Inovonics z 1, 2 lub 4 przyciskami spowoduje zmianę poniższych opcji, umożliwiając przypisanie niestandardowych akcji do maksymalnie 4 przycisków. Model pilota określa, jakie akcje są dostępne. Oprócz tego, że są to piloty z jednym, dwoma lub czterema przyciskami, niektóre piloty dwuprzyciskowe mogą generować naciśnięcie „Trzeciego przycisku" po naciśnięciu obu przycisków jednocześnie, podczas gdy inne wymagają naciśnięcia obu przycisków w celu wysłania jednego sygnału. Zapoznaj się z dokumentacją Inovonics, aby określić typ pilota.</TranslationEntry>
    <TranslationEntry name="BD8C7A0D0EC6C2CF58FD7F5E92E46FFD" fullContext="816626012CBA0EFDD2B3CA461734547A" translateForJs="false">Główny element sterowania</TranslationEntry>
    <TranslationEntry name="127012E91B38C52CFCD8C957DB2EBFEB" fullContext="5F24588DDBB57421408B48F3E9FF5B85" translateForJs="false">Ustawia strefę lub przejście, które będzie sterowane przez </TranslationEntry>
    <TranslationEntry name="634998A407135EAAF7DD85691E350683" fullContext="06B8B724E56047FE2AA5EBF577AF3D6A" translateForJs="false"> przyciski.</TranslationEntry>
    <TranslationEntry name="D528FFD5DEA793A69BAA84B38F872629" fullContext="5F24588DDBB57421408B48F3E9FF5B85" translateForJs="false">Dla strefy: </TranslationEntry>
    <TranslationEntry name="6837D9CF360CCFC9212226396F3FBE70" fullContext="5F24588DDBB57421408B48F3E9FF5B85" translateForJs="false"> rozbroi się, </TranslationEntry>
    <TranslationEntry name="021FF61BEF2A06697DCC98335AA182C6" fullContext="5F24588DDBB57421408B48F3E9FF5B85" translateForJs="false"> uzbroi się.</TranslationEntry>
    <TranslationEntry name="E5FCC17AA1C1FA90FA4C7288CDE0BD91" fullContext="5F24588DDBB57421408B48F3E9FF5B85" translateForJs="false">Dla przejścia: </TranslationEntry>
    <TranslationEntry name="7ABDE7F3D926D60A63BCF78BC02D1510" fullContext="5F24588DDBB57421408B48F3E9FF5B85" translateForJs="false"> zostanie odblokowane, </TranslationEntry>
    <TranslationEntry name="822F51E1B205C481A6AA9CA9E65F4468" fullContext="5F24588DDBB57421408B48F3E9FF5B85" translateForJs="false"> zostanie zablokowane.</TranslationEntry>
    <TranslationEntry name="2BFEF4AEC7E04AB737F79971C3D520D3" fullContext="5F24588DDBB57421408B48F3E9FF5B85" translateForJs="false">W przypadku używania REM2, sterowanie tym elementem lub naciśnięcie </TranslationEntry>
    <TranslationEntry name="F7D2AE968F0427CDFE0845AD096959BC" fullContext="5F24588DDBB57421408B48F3E9FF5B85" translateForJs="false"> przycisk spowoduje wyświetlenie sygnalizacji zwrotnej o stanie tego elementu.</TranslationEntry>
    <TranslationEntry name="E877A69E126574DA8B5001922E835994" fullContext="5F24588DDBB57421408B48F3E9FF5B85" translateForJs="false">Podczas sterowania przejściem/strefą:</TranslationEntry>
    <TranslationEntry name="4267A1AB1C0B404BB70457D5C6DED54A" fullContext="5F24588DDBB57421408B48F3E9FF5B85" translateForJs="false">Czerwona dioda LED włączona z sygnałami dźwiękowymi</TranslationEntry>
    <TranslationEntry name="6F04BC25FE42F19D227295D986CA30DE" fullContext="5F24588DDBB57421408B48F3E9FF5B85" translateForJs="false"> - Pomyślnie zablokowano/uzbrojono przejście/strefę</TranslationEntry>
    <TranslationEntry name="9294812D1DB812E6DAD4825ACA4E2476" fullContext="5F24588DDBB57421408B48F3E9FF5B85" translateForJs="false">Zielona dioda LED świeci z sygnałami dźwiękowymi</TranslationEntry>
    <TranslationEntry name="FC178C00FE540E58253A204E424E58B5" fullContext="5F24588DDBB57421408B48F3E9FF5B85" translateForJs="false"> - Pomyślnie odblokowano/rozbrojono przejście/strefę</TranslationEntry>
    <TranslationEntry name="925AD324868EF96D2AD7A2E1CE2CB23B" fullContext="5F24588DDBB57421408B48F3E9FF5B85" translateForJs="false">Czerwona dioda LED miga szybko z szybkimi sygnałami dźwiękowymi</TranslationEntry>
    <TranslationEntry name="AE69625621895466039F48A534BDE655" fullContext="5F24588DDBB57421408B48F3E9FF5B85" translateForJs="false"> - Nie udało się sterować przejściem/strefą</TranslationEntry>
    <TranslationEntry name="95722403FCB91BDC36C9A70543D32845" fullContext="5F24588DDBB57421408B48F3E9FF5B85" translateForJs="false">Podczas naciśnięcia </TranslationEntry>
    <TranslationEntry name="3E68D641D186874CF5820E0AE6C3C07C" fullContext="5F24588DDBB57421408B48F3E9FF5B85" translateForJs="false"> przycisk:</TranslationEntry>
    <TranslationEntry name="4A7F11DD57CBD5025084F497BB661D37" fullContext="5F24588DDBB57421408B48F3E9FF5B85" translateForJs="false">Czerwona dioda LED z sygnałem dźwiękowym</TranslationEntry>
    <TranslationEntry name="90BF8097F5B91FDA3893033B73496C24" fullContext="5F24588DDBB57421408B48F3E9FF5B85" translateForJs="false"> - Przejście/strefa jest aktualnie zablokowane/uzbrojona</TranslationEntry>
    <TranslationEntry name="4FA987A7B4DFB17754CDBE12E01780D4" fullContext="5F24588DDBB57421408B48F3E9FF5B85" translateForJs="false">Zielona dioda LED z sygnałem dźwiękowym</TranslationEntry>
    <TranslationEntry name="D8E8D8C2826E62D2AB60AD218AC48204" fullContext="5F24588DDBB57421408B48F3E9FF5B85" translateForJs="false"> - Przejście/strefa jest aktualnie odblokowane/rozbrojona </TranslationEntry>
    <TranslationEntry name="D97E7D43E908DA44CC52CB5680DBE160" fullContext="5F24588DDBB57421408B48F3E9FF5B85" translateForJs="false">Pomarańczowe miganie diody z sygnałem dźwiękowym</TranslationEntry>
    <TranslationEntry name="4E8056991BD557DE2E0B30FAFA64668C" fullContext="5F24588DDBB57421408B48F3E9FF5B85" translateForJs="false"> - Nieznany stan — nie udało się skontaktować z Modułem RF</TranslationEntry>
    <TranslationEntry name="CE1FB17DF5DDB9A1BD87AAC32D8218DA" fullContext="5F24588DDBB57421408B48F3E9FF5B85" translateForJs="false">W przypadku używania bezprzewodowego breloka IR RF sterowanie tym elementem spowoduje sygnalizację zwrotną dotyczącą stanu tego elementu.</TranslationEntry>
    <TranslationEntry name="C5C48A09A8EEC02DF58901AF6815FFD1" fullContext="5F24588DDBB57421408B48F3E9FF5B85" translateForJs="false">Dwa zielone mignięcia</TranslationEntry>
    <TranslationEntry name="8147B11167408A3375F4A7B45172BABD" fullContext="5F24588DDBB57421408B48F3E9FF5B85" translateForJs="false">Trzy zielone błyski</TranslationEntry>
    <TranslationEntry name="4978348461F4C62C12C1E7B3BE38595C" fullContext="5F24588DDBB57421408B48F3E9FF5B85" translateForJs="false">Dwa czerwone błyski</TranslationEntry>
    <TranslationEntry name="3418C2E5C6322C580D75D509B108E4E7" fullContext="816626012CBA0EFDD2B3CA461734547A" translateForJs="false"> powyżej jest strefą, wówczas próby uzbrojenia z pilota uzbroją strefę z </TranslationEntry>
    <TranslationEntry name="768CCF72729C1BEE72CF253419BCA7EF" fullContext="816626012CBA0EFDD2B3CA461734547A" translateForJs="false"> włączone.</TranslationEntry>
    <TranslationEntry name="4EB35A611BC1F0B39F1FC8B08F8EC8C5" fullContext="816626012CBA0EFDD2B3CA461734547A" translateForJs="false">Zazwyczaj uzbrajanie za pomocą pilota odbywa się poza strefą, powodując natychmiastowe uzbrojenie strefy i eliminując potrzebę oczekiwania na zakończenie wyjścia. Jednak w niektórych okolicznościach wskaźniki stanu strefy znajdują się wewnątrz strefy, wymagając od użytkownika przebywania w uzbrajanej strefie.</TranslationEntry>
    <TranslationEntry name="9BCC56B1A1E635473B27AD4AD8A3143E" translateForJs="false">Akcje przycisku pierwszego</TranslationEntry>
    <TranslationEntry name="B1D1E3F3DAC01259CE5E97E8B907804B" fullContext="DBAB67EB36D5B602513E4588BD43BEA5" translateForJs="false">Określa akcję lub akcje do wykonania po naciśnięciu przycisku pierwszego. Jest to </TranslationEntry>
    <TranslationEntry name="1A4FF178168A93093AD2A5401E05A36B" fullContext="0DB3AD6DC2DA3D37341797E7BC593EC4" translateForJs="false"> przycisk na pilotach REM15 i REM2 lub </TranslationEntry>
    <TranslationEntry name="E10E1AA95A4D8AD4E775C54F211AD2E9" fullContext="DBAB67EB36D5B602513E4588BD43BEA5" translateForJs="false"> przycisk na pilocie REM1.</TranslationEntry>
    <TranslationEntry name="22D2020C256D979D84B5162084084CB2" translateForJs="false">Akcje przycisku drugiego</TranslationEntry>
    <TranslationEntry name="03AB44C1E83AC1001B4F804CB8AABF12" fullContext="0DB3AD6DC2DA3D37341797E7BC593EC4" translateForJs="false">Określa akcję lub akcje do wykonania po naciśnięciu Przycisku Dwa. Jest to </TranslationEntry>
    <TranslationEntry name="9580433030C0BFFCEE327B3E8BB0E72A" fullContext="CA499A936A8A49D3145ED1871BB48AF8" translateForJs="false"> przycisk na pilocie REM1</TranslationEntry>
    <TranslationEntry name="6F1466E46CB022FF941D11560C71D313" translateForJs="false">Akcje przycisków jeden i dwa</TranslationEntry>
    <TranslationEntry name="AED29E093772D4A5EDD9D0B0C2A3F9D0" fullContext="CA499A936A8A49D3145ED1871BB48AF8" translateForJs="false">Określa, jaką akcję lub akcje wykonać, gdy jednocześnie naciśnięte są Przycisk pierwszy i Przycisk drugi. Są to </TranslationEntry>
    <TranslationEntry name="600F997DB9CF3353D8A610421A2AA84F" fullContext="CA499A936A8A49D3145ED1871BB48AF8" translateForJs="false"> przyciski dla pilotów REM15 i REM2 lub </TranslationEntry>
    <TranslationEntry name="B5CC10870897FA13B168645C59E4270B" fullContext="CA499A936A8A49D3145ED1871BB48AF8" translateForJs="false"> przycisk i </TranslationEntry>
    <TranslationEntry name="F4C62C4B5028FCBEB7D152FC7AB9071E" translateForJs="false">Typ odpowiedzi przycisku</TranslationEntry>
    <TranslationEntry name="30529C4E8B386FE0FF981DE05CE3D501" fullContext="9F27FF1F736E5ED7BCD806BD97BF992F" translateForJs="false">Określa, czy naciśnięcie pojedynczego przycisku breloka zdalnego REM101 jest używane do sygnalizowania przymusu użytkownika lub wykonywania niestandardowej akcji. </TranslationEntry>
    <TranslationEntry name="B8E7B19348E748085D7F7FEA9DCB2407" fullContext="9F27FF1F736E5ED7BCD806BD97BF992F" translateForJs="false">Jeśli ustawione na alarm użytkownika, system wyśle zdarzenie alarmowe do stacji monitorowania po naciśnięciu przycisku. </TranslationEntry>
    <TranslationEntry name="9E4B039BD0F47CBA41334C98604DC6A7" fullContext="9F27FF1F736E5ED7BCD806BD97BF992F" translateForJs="false">Jeśli ustawiono wykonywanie niestandardowej akcji, można zdefiniować jedną lub więcej akcji poniżej.</TranslationEntry>
    <TranslationEntry name="B062C6C9AD78E3642EC8884ABA99744A" translateForJs="false" rules="unique=SingleButtonResponseType" notes="Must be unique amongst all &quot;SingleButtonResponseType&quot; entries">Wykonaj niestandardowe akcje + alarm użytkownika</TranslationEntry>
    <TranslationEntry name="3589DF009C2265AEE71577A1B430FE2F" translateForJs="false" rules="unique=SingleButtonResponseType" notes="Must be unique amongst all &quot;SingleButtonResponseType&quot; entries">Wykonaj niestandardowe akcje</TranslationEntry>
    <TranslationEntry name="8AE34E73F42CDC46CD82FF49FF713B66" translateForJs="false">Typ odpowiedzi</TranslationEntry>
    <TranslationEntry name="ADD5DFB116D1E4E313BF33E22C5AB1D2" translateForJs="false">Akcje przycisków</TranslationEntry>
    <TranslationEntry name="0B741A91414AA4F935DE2A36B3AAD833" fullContext="C7A3BB74608D4366EDDF47F4544969FF" translateForJs="false">Określa akcję lub akcje do wykonania po naciśnięciu przycisku zdalnego</TranslationEntry>
    <TranslationEntry name="761FED26F2BE4F61BC28604E51D54F09" fullContext="8A9BB3DED94EB9577DF6BFB977621B07" translateForJs="false">Określa akcję lub akcje do wykonania po naciśnięciu 'Przycisku pierwszego'. W zależności od typu pilota, aby wyzwolić 'Przycisk pierwszy', może być konieczne użycie kombinacji przycisków. Więcej informacji można znaleźć w dokumentacji pilota Inovonics.</TranslationEntry>
    <TranslationEntry name="E0685C00615B6224D4868AEDD4667850" fullContext="5C4B9C30703A6D954F00571035C15B50" translateForJs="false">Określa akcję lub akcje do wykonania po naciśnięciu 'Przycisku drugiego'. W zależności od typu pilota, aby wyzwolić 'Przycisk drugi', może być konieczne użycie kombinacji przycisków. Więcej informacji można znaleźć w dokumentacji pilota Inovonics.</TranslationEntry>
    <TranslationEntry name="0397CE7F2A728A8E5512AB1E9118778C" translateForJs="false">Akcje przycisku trzeciego</TranslationEntry>
    <TranslationEntry name="5C70F4C5D06671D771982B462F008831" fullContext="EAB36C7C87D5F9322700B0E59663339E" translateForJs="false">Określa akcję lub akcje do wykonania po naciśnięciu 'Przycisku trzeciego'. W zależności od typu pilota, aby wyzwolić 'Przycisk trzeci', może być konieczne użycie kombinacji przycisków. Więcej informacji można znaleźć w dokumentacji pilota Inovonics.</TranslationEntry>
    <TranslationEntry name="AE4A9A7DEB97EDB8EA995B600C4A2474" translateForJs="false">Akcje czwartego przycisku</TranslationEntry>
    <TranslationEntry name="396F2E213035D3A2667AE1C1FEAE000F" fullContext="C9D9236983E8C81D5F1EBBE8F9017CFB" translateForJs="false">Określa akcję lub akcje do wykonania po naciśnięciu 'Przycisku czwartego'. W zależności od typu pilota, aby wyzwolić 'Przycisk czwarty', może być konieczne użycie kombinacji przycisków. Więcej informacji można znaleźć w dokumentacji pilota Inovonics.</TranslationEntry>
    <TranslationEntry name="E3E07C7D974CEE4A188A408E5F851973" fullContext="C943CC3D8D8D1AC2798489054CF2AA98" translateForJs="false">Określa akcję lub akcje do wykonania po naciśnięciu przycisku I.</TranslationEntry>
    <TranslationEntry name="E44C4B6BC53741645B480C1D98BC1E0C" fullContext="FD9C5191108ECEA0389C621C84D14AFD" translateForJs="false">Określa akcję lub akcje do wykonania po naciśnięciu przycisku II.</TranslationEntry>
    <TranslationEntry name="84CEBFE42729092192BC6BA329612C43" translateForJs="false">Brelok zdalny</TranslationEntry>
    <TranslationEntry name="469F9C5F4658EE22C3363E72D04CB71F" fullContext="2174E64D0428A91044C43BBA50EC3970" translateForJs="false">Zdalne breloki</TranslationEntry>
    <TranslationEntry name="0EF7696265DD5DC163E355F160522165" fullContext="0EF7696265DD5DC163E355F160522165" translateForJs="false">Wybierz Szablon zdalnego breloka dla zdalnego breloka, który zostanie przypisany do tego użytkownika. Określi to, co będą robić przyciski na pilocie</TranslationEntry>
    <TranslationEntry name="78CF8CE506D5CD24BCD85ED03795E147" fullContext="78CF8CE506D5CD24BCD85ED03795E147" translateForJs="false">Numer seryjny</TranslationEntry>
    <TranslationEntry name="30ACA9E153FA7973324F1171543ABD66" translateForJs="false">Sparowany moduł</TranslationEntry>
    <TranslationEntry name="A749642E2AFEEA63AAC9D550E51ABF64" fullContext="A749642E2AFEEA63AAC9D550E51ABF64" translateForJs="false">Typ linii wejściowej</TranslationEntry>
    <TranslationEntry name="B910F7645C1D677F287E1E00C5A13E87" fullContext="478DEC82B722392D6B138C60D4A6665D" translateForJs="false">Tylko informacyjnie: Wyświetla sposób skonfigurowania linii wejściowej na </TranslationEntry>
    <TranslationEntry name="4E578224C5FF6A2B5BED51B0D53600AE" fullContext="478DEC82B722392D6B138C60D4A6665D" translateForJs="false"> strona modułu, na którym znajduje się dana linia wejściowa.</TranslationEntry>
    <TranslationEntry name="467B246F21B407B25689828B9E926F6B" translateForJs="false">Zawsze rejestruj zmiany stanu</TranslationEntry>
    <TranslationEntry name="97768392240121DBB1A414B8B31D7820" fullContext="252FBE6A0203028D297C53A6E58C7EF9" translateForJs="false">Jeśli włączone, zmiany stanu tej linii wejściowej będą zawsze rejestrować uproszczony komunikat w rejestrze zdarzeń ze wskaźnikiem, czy zmiana stanu linii wejściowej była Aktywna czy Bezpieczna. W przeciwnym razie rejestrowanie odbywa się tylko wtedy, gdy </TranslationEntry>
    <TranslationEntry name="05B4C2EDFD66240124BD78C04241B147" fullContext="252FBE6A0203028D297C53A6E58C7EF9" translateForJs="false">[System &gt; Serwis &gt; Włącz szczegółowe zdarzenia]</TranslationEntry>
    <TranslationEntry name="7A6CCFF3F291EB22A3AA04CFE7A17AC7" fullContext="252FBE6A0203028D297C53A6E58C7EF9" translateForJs="false"> jest włączone, co powoduje wysłanie komunikatu ze specyficzną zmianą linii wejściowej.</TranslationEntry>
    <TranslationEntry name="DE02D0FD7133215266B68F1FD1DAD11A" fullContext="EFCA3B1012EC3BDC1F0E303B29D1D795" translateForJs="false" rules="unique=RfDetectorType" notes="Must be unique amongst all &quot;RfDetectorType&quot; entries">Czujka ruchu</TranslationEntry>
    <TranslationEntry name="5A2E462B3E3064ED934B1E74CA47C940" fullContext="EFCA3B1012EC3BDC1F0E303B29D1D795" translateForJs="false" rules="unique=RfDetectorType" notes="Must be unique amongst all &quot;RfDetectorType&quot; entries">Drzwi / Czujka wibracyjna / Zabezpieczenie mienia</TranslationEntry>
    <TranslationEntry name="74FA47B37B347AED5ECF202AA186C00A" fullContext="EFCA3B1012EC3BDC1F0E303B29D1D795" translateForJs="false" rules="unique=RfDetectorType" notes="Must be unique amongst all &quot;RfDetectorType&quot; entries">Czujka dymu</TranslationEntry>
    <TranslationEntry name="0C6AE6CA582C36C0EDE24F1D7DC6F26B" fullContext="8A5FFA7911C9A3201038BEC48A15161D" translateForJs="false" rules="unique=RfDetectorType" notes="Must be unique amongst all &quot;RfDetectorType&quot; entries">Czujka</TranslationEntry>
    <TranslationEntry name="92917889A70BAA1E33B13C36953409E7" fullContext="8A5FFA7911C9A3201038BEC48A15161D" translateForJs="false" rules="unique=RfDetectorType" notes="Must be unique amongst all &quot;RfDetectorType&quot; entries">Alarm czujki 2</TranslationEntry>
    <TranslationEntry name="D3B3350CB648F345B0A21A048DF0CF45" fullContext="8A5FFA7911C9A3201038BEC48A15161D" translateForJs="false" rules="unique=RfDetectorType" notes="Must be unique amongst all &quot;RfDetectorType&quot; entries">Wzmacniacz</TranslationEntry>
    <TranslationEntry name="B81A4DC3714ED67700470CBC3A93DA33" fullContext="5FC5568F149B720E5E01DD703C44784B" translateForJs="false" rules="unique=SwapOptions" notes="Must be unique amongst all &quot;SwapOptions&quot; entries">Zamień stany aktywny i sabotaż</TranslationEntry>
    <TranslationEntry name="D2059EB6EA38849F4CC222F1F7A4B58B" translateForJs="false">Sprzętowa linia wejściowa</TranslationEntry>
    <TranslationEntry name="7DAB30B624B2172AA1E606AD4CC8ADF3" translateForJs="false">Zamień stany aktywne</TranslationEntry>
    <TranslationEntry name="D51DCC5C211C0BF765BD120BE4F08DFB" fullContext="5FC5568F149B720E5E01DD703C44784B" translateForJs="false">Określa, czy linia wejściowa </TranslationEntry>
    <TranslationEntry name="0E84BB834DDDF773A8733FCA67D5671E" fullContext="5FC5568F149B720E5E01DD703C44784B" translateForJs="false"> stan powinien zostać zamieniony z </TranslationEntry>
    <TranslationEntry name="84E1393F3A7A4BEB3A8814FC4AD30E3D" fullContext="5FC5568F149B720E5E01DD703C44784B" translateForJs="false"> stan, </TranslationEntry>
    <TranslationEntry name="493FAA3FAC9900128D2B8DC68B640879" fullContext="5FC5568F149B720E5E01DD703C44784B" translateForJs="false"> stan lub wcale. </TranslationEntry>
    <TranslationEntry name="91E3D549E3ED49958A0DA420D5058548" fullContext="5FC5568F149B720E5E01DD703C44784B" translateForJs="false"> - Linia wejściowa zachowuje domyślne działanie zgodnie ze zdefiniowaną konfiguracją EOL. Jest to domyślna wartość ustawiana dla wszystkich nowo tworzonych linii wejściowych.</TranslationEntry>
    <TranslationEntry name="06993C6D024A010A758208CE840FA6B2" fullContext="5FC5568F149B720E5E01DD703C44784B" translateForJs="false"> - Po wybraniu tej opcji stan alarmowy/aktywny linii wejściowej zostaje zamieniony miejscami ze stanem uszczelnionego/nieaktywnego. Stosuje się to w przypadku normalnie otwartego urządzenia detekcji, takiego jak czujka dymu, podłączonego do systemu. Urządzenie normalnie otwarte odwraca rezystancję End of Line i będzie wyglądało na uszczelnione w stanie alarmu, a w stanie alarmu, gdy jest uszczelnione. </TranslationEntry>
    <TranslationEntry name="8D790578EF062DAB717636952B306009" fullContext="5FC5568F149B720E5E01DD703C44784B" translateForJs="false">Uwaga: Opcja ta może być używana w przypadku czujek, przełączników i przycisków.</TranslationEntry>
    <TranslationEntry name="78ED39352307741622A8C079829CF2AD" fullContext="5FC5568F149B720E5E01DD703C44784B" translateForJs="false"> - Po wybraniu tej opcji stan alarmowy/aktywny linii wejściowej zostaje zamieniony miejscami ze stanem sabotażu. Ta opcja jest przeznaczona dla obiektów, gdzie większość linii wejściowych stosuje standardową logikę EOL, jednak niektóre czujki (np. przeciwpożarowe) zachowują się inaczej i wymagają zamiany stanów alarmu i sabotażu. </TranslationEntry>
    <TranslationEntry name="851BFB4027EDBA9C53388E1A3B8C5E9C" fullContext="5FC5568F149B720E5E01DD703C44784B" translateForJs="false">Uwaga: ta opcja może być stosowana tylko dla standardowych linii wejściowych EOL; nie można jej stosować dla linii dwustanowych (przełącznik/przycisk), ponieważ nie mają one stanu sabotażu.</TranslationEntry>
    <TranslationEntry name="5109C5689F8B26DB49FE2F281DC61B5D" translateForJs="false">Traktuj maskowanie jako stan alarmu</TranslationEntry>
    <TranslationEntry name="F8F10B5CF5B3A5596E6286A6EA4C1E2C" fullContext="F640923DE8B3B51FF144685216F9EB5B" translateForJs="false">Jeśli włączone, gdy linia wejściowa wykryje stan maskowania na podstawie wartości rezystancji końca linii (EOL), system automatycznie przełoży to na stan alarmu. Opcja ta jest stosowana przede wszystkim, gdy dwa fizyczne detektory są połączone w jedną linię wejściową — na przykład gdy dwa kontaktrony drzwi dwuskrzydłowych są podłączone do jednej linii wejściowej. W takim przypadku suma rezystancji EOL z dwóch stanów alarmu mogłaby być błędnie zinterpretowana jako maskowanie zamiast alarmu.</TranslationEntry>
    <TranslationEntry name="DCF4D181F8396070A102576FC8D2D6B6" fullContext="2B36BE0AF8077052B95BAB8296FBF521" translateForJs="false">Tylko informacyjnie: jest to fizyczna lokalizacja, w której linia wejściowa jest podłączona w systemie Inception.</TranslationEntry>
    <TranslationEntry name="18DB75C8F0D999899BCE3092F2FDBB79" translateForJs="false">Numer seryjny RF</TranslationEntry>
    <TranslationEntry name="3D21F8CC20BD737672BAF55F6C268770" fullContext="FA14319A8DB6A787D2D3B3EA6952E34E" translateForJs="false">Tylko informacyjnie: wyświetla numer seryjny wejścia RF.</TranslationEntry>
    <TranslationEntry name="EB07A082A0242B8CAD527EC2A519383B" translateForJs="false">Typ urządzenia RF</TranslationEntry>
    <TranslationEntry name="FA8A841055F61CA4CF3BF2790896EF48" fullContext="2627AAB9FDBFA9F596A8463139F46101" translateForJs="false">Tylko informacyjnie: wyświetla sposób skonfigurowania linii wejściowej RF na urządzeniu </TranslationEntry>
    <TranslationEntry name="A6AC3313195374229C568B833218693C" fullContext="2627AAB9FDBFA9F596A8463139F46101" translateForJs="false"> strona modułu RF, na którym znajduje się dana linia wejściowa.</TranslationEntry>
    <TranslationEntry name="8DA23C9812C7A6ACCB0210A10C67C59A" fullContext="C10D0AB41101ADDCE07EC3E3C419EBD3" translateForJs="false">Linia wejściowa obliczona</TranslationEntry>
    <TranslationEntry name="B28AA02F36DB24B3D19A855192B57307" translateForJs="false">Niestandardowa linia wejściowa</TranslationEntry>
    <TranslationEntry name="7A1408FC454FABE84891F6757C2E7461" translateForJs="false">Moduł sygnalizatora</TranslationEntry>
    <TranslationEntry name="2A0A98875B46BACC64CA57D7E7998377" translateForJs="false">Moduły sygnalizatorów</TranslationEntry>
    <TranslationEntry name="7C5BBFD9425011316C5B7B5FB8E530B0" translateForJs="false" rules="unique=LanguagePackType" notes="Must be unique amongst all &quot;LanguagePackType&quot; entries">Dostarczone przez producenta</TranslationEntry>
    <TranslationEntry name="AD89985C66827DAF24A4ECD3F5B5B567" translateForJs="false" rules="unique=LanguagePackType" notes="Must be unique amongst all &quot;LanguagePackType&quot; entries">Użytkownik przesłany</TranslationEntry>
    <TranslationEntry name="3EBEB3E1020C3C40775769A438B24187" translateForJs="false">Pakiet językowy</TranslationEntry>
    <TranslationEntry name="5FD24C157D722F21796E7F2AF681A76F" translateForJs="false">Pakiety językowe</TranslationEntry>
    <TranslationEntry name="FFB1102F163FD093377EE0369D9DA3BC" translateForJs="false">Profil terminala</TranslationEntry>
    <TranslationEntry name="F4660AA9BC5EF32EDA109A28D5905D58" translateForJs="false">Domyślne preferencje menu</TranslationEntry>
    <TranslationEntry name="F829BC2166E39CFE78C38C8DE2AA0D4B" translateForJs="false">Preferencje LCD</TranslationEntry>
    <TranslationEntry name="C8923951BAA5DB29C4E8CF5792BFD213" fullContext="10B11D11E2C90CA0ACA6C19345D6C80E" translateForJs="false">Określa, które menu jest wyświetlane użytkownikowi po zalogowaniu się do Terminala LCD. Dotyczy wyłącznie normalnego logowania (PIN + OK); jeśli użytkownik loguje się przy użyciu skrótu sterowania strefą (PIN + ON w celu uzbrojenia lub PIN + OFF w celu rozbrojenia), zostanie przekierowany do </TranslationEntry>
    <TranslationEntry name="4A0905819810ABCD849B8F683B558EE6" fullContext="10B11D11E2C90CA0ACA6C19345D6C80E" translateForJs="false"> menu automatycznie. Podobnie, jeśli ze strefą skojarzoną z terminalem jest aktywny alarm, tryb wejścia, tryb wyjścia lub strefa ma się wkrótce automatycznie uzbroić, wówczas </TranslationEntry>
    <TranslationEntry name="6EC86694A8172565D048D7290DE699B5" fullContext="10B11D11E2C90CA0ACA6C19345D6C80E" translateForJs="false"> zostanie również wyświetlone.</TranslationEntry>
    <TranslationEntry name="F5D9A136460AE4B781E8C55035BE1817" fullContext="10B11D11E2C90CA0ACA6C19345D6C80E" translateForJs="false"> — Domyślny ekran menu głównego, wyświetlający wszystkie opcje menu dostępne dla użytkownika końcowego. Dostęp do niego jest również możliwy przez naciśnięcie klawisza MENU na terminalu LCD.</TranslationEntry>
    <TranslationEntry name="FDBDE5D80165574ADB173641C2D20822" fullContext="10B11D11E2C90CA0ACA6C19345D6C80E" translateForJs="false"> - Przenosi użytkownika do </TranslationEntry>
    <TranslationEntry name="27E4614752C586F1ADC7B4AA1DDBD744" fullContext="10B11D11E2C90CA0ACA6C19345D6C80E" translateForJs="false"> ekran, umożliwiając uzbrojenie i rozbrojenie stref w systemie.</TranslationEntry>
    <TranslationEntry name="08D74FCFBD1093E4BDD994842D143AEC" fullContext="10B11D11E2C90CA0ACA6C19345D6C80E" translateForJs="false" rules="unique=TerminalLoginPreference" notes="Must be unique amongst all &quot;TerminalLoginPreference&quot; entries">Sterowanie linią wyjściową</TranslationEntry>
    <TranslationEntry name="814D5A73D29D0102BD490ADE342CF715" fullContext="10B11D11E2C90CA0ACA6C19345D6C80E" translateForJs="false"> ekran, umożliwiający sterowanie liniami wyjściowymi oznaczonymi jako </TranslationEntry>
    <TranslationEntry name="822AF78FFD43A0A1EF897AF643B3166C" fullContext="BEBD8FA919A1CB37637D52DA85F36522" translateForJs="false">Sterowany przez użytkownika</TranslationEntry>
    <TranslationEntry name="E35A30D7B40ABAC36F7B49A8CB0B0852" fullContext="E35A30D7B40ABAC36F7B49A8CB0B0852" translateForJs="false" rules="unique=TerminalLoginPreference" notes="Must be unique amongst all &quot;TerminalLoginPreference&quot; entries">Sterowanie przejściem</TranslationEntry>
    <TranslationEntry name="76EB70216037ECCC07AC42B2F4283B30" fullContext="10B11D11E2C90CA0ACA6C19345D6C80E" translateForJs="false"> ekran umożliwiający odblokowanie i zablokowanie przejść w systemie z terminala.</TranslationEntry>
    <TranslationEntry name="5047B4B65B476CC49B992BF129CFBE32" fullContext="10B11D11E2C90CA0ACA6C19345D6C80E" translateForJs="false">Uwaga: Jeśli ustawisz wartość inną niż </TranslationEntry>
    <TranslationEntry name="9187F4435F6ED3950403AC525A62DADD" fullContext="10B11D11E2C90CA0ACA6C19345D6C80E" translateForJs="false">, upewnij się, że mają uprawnienie do menu w </TranslationEntry>
    <TranslationEntry name="740CDA01CDF7918611B82E1B691ECF05" fullContext="10B11D11E2C90CA0ACA6C19345D6C80E" translateForJs="false">Uprawnienia terminala</TranslationEntry>
    <TranslationEntry name="4B92753A57207155CAB9A56DA462AB5E" fullContext="10B11D11E2C90CA0ACA6C19345D6C80E" translateForJs="false"> sekcja poniżej. Ponadto w menu sterowania użytkownik może sterować tylko elementami przypisanymi do </TranslationEntry>
    <TranslationEntry name="4FBC2F49C833B136EB615D1E34900E28" translateForJs="false">Ukryj komunikat powitalny logowania</TranslationEntry>
    <TranslationEntry name="64647D45ECF20AA88DBCFFA6F344E192" fullContext="7912A7BA8A3E8BC2D93D8F4D6791820C" translateForJs="false">Ukrywa wiadomość powitalną, która normalnie wyświetla się przez kilka sekund po zalogowaniu się użytkownika.</TranslationEntry>
    <TranslationEntry name="AE7E3E95AAEA7DE5BE8EE5BEF35F497F" translateForJs="false">Wyświetl rejestr zdarzeń</TranslationEntry>
    <TranslationEntry name="B37993A7FA22C0CF04333E5E744DAD47" translateForJs="false">Uprawnienia terminala LCD</TranslationEntry>
    <TranslationEntry name="689B66AEB13926178D59A8CB8947EBB7" fullContext="96F46F726DE403B4B4942B0623616137" translateForJs="false">Określa możliwość podglądu przez użytkownika </TranslationEntry>
    <TranslationEntry name="1B33577DD579CD17046DA244843271F5" fullContext="0B8D005B7AE0EB29F49C4649D1657A73" translateForJs="false">[Rejestr zdarzeń]</TranslationEntry>
    <TranslationEntry name="E4B80FA15C7F04FEB0E6A4062DA9C578" fullContext="01A1EE00F2D5664772579CDC4DDAA357" translateForJs="false"> menu.</TranslationEntry>
    <TranslationEntry name="3682D1665CF331373000C20680732D3A" fullContext="01A1EE00F2D5664772579CDC4DDAA357" translateForJs="false" rules="unique=TerminalPermission" notes="Must be unique amongst all &quot;TerminalPermission&quot; entries">Odmów</TranslationEntry>
    <TranslationEntry name="C394C56C3AF14EA6AE67FFCC0B3D17AC" fullContext="01A1EE00F2D5664772579CDC4DDAA357" translateForJs="false"> menu nie będzie dostępne z żadnego Terminala LCD.</TranslationEntry>
    <TranslationEntry name="45F0FB72A0DEFDFDB01DE4B5A5A6876B" fullContext="01A1EE00F2D5664772579CDC4DDAA357" translateForJs="false" rules="unique=TerminalPermission" notes="Must be unique amongst all &quot;TerminalPermission&quot; entries">Zezwól</TranslationEntry>
    <TranslationEntry name="7633D7C4892E07604411682A46130A53" fullContext="0B8D005B7AE0EB29F49C4649D1657A73" translateForJs="false"> menu może być wyświetlane, umożliwiając użytkownikowi przeglądanie zdarzeń w rejestrze zdarzeń.</TranslationEntry>
    <TranslationEntry name="F71DB0864DFA21FF7583D62FACFADE03" translateForJs="false">Zmień PIN użytkownika</TranslationEntry>
    <TranslationEntry name="5CED72F483B9AB12B3335DCEE1CD1CE1" fullContext="0961712635FE15C725567716F3287506" translateForJs="false">[Użytkownicy &gt; Zmień PIN]</TranslationEntry>
    <TranslationEntry name="180866DA56B5FE69D8B1BD723950480B" fullContext="0961712635FE15C725567716F3287506" translateForJs="false"> menu może być wyświetlane, umożliwiając użytkownikowi zmianę własnych PIN-ów zabezpieczających.</TranslationEntry>
    <TranslationEntry name="DF36E73FE2FD2A17F25F96A0C6781FA3" fullContext="0961712635FE15C725567716F3287506" translateForJs="false">W zależności od sposobu zarządzania kodami PIN w obiekcie, umożliwienie użytkownikowi zmiany własnego PIN może być niepożądane, gdyż mógłby on odkryć kody PIN innych użytkowników</TranslationEntry>
    <TranslationEntry name="8E4CEBCE21DE185B0247D2A8DE21D3DC" fullContext="74CDD9CBB41D72CF03DA17EB648E52A6" translateForJs="false">[Sterowanie strefą]</TranslationEntry>
    <TranslationEntry name="93E75A793E48FEE3089679FD89E0821D" fullContext="74CDD9CBB41D72CF03DA17EB648E52A6" translateForJs="false">[Sterowanie &gt; Strefy]</TranslationEntry>
    <TranslationEntry name="59266B6A68E0573FF9BB20EEC2887C88" fullContext="74CDD9CBB41D72CF03DA17EB648E52A6" translateForJs="false"> menu.</TranslationEntry>
    <TranslationEntry name="4DA624E7CBF6E3D139AEE67B76F8BD4A" fullContext="74CDD9CBB41D72CF03DA17EB648E52A6" translateForJs="false">[Sterowanie&gt;Strefy]</TranslationEntry>
    <TranslationEntry name="BA86B52D0A34B2124E3960D90071E66B" fullContext="74CDD9CBB41D72CF03DA17EB648E52A6" translateForJs="false"> menu nie będą dostępne z żadnego Terminala LCD.</TranslationEntry>
    <TranslationEntry name="10437EE118119B3F8FBA12A6D433A006" fullContext="74CDD9CBB41D72CF03DA17EB648E52A6" translateForJs="false"> menu mogą być przeglądane, umożliwiając użytkownikowi uzbrojenie i rozbrojenie stref. </TranslationEntry>
    <TranslationEntry name="73CB24F59298FEF3543F6E27851F2124" fullContext="74CDD9CBB41D72CF03DA17EB648E52A6" translateForJs="false">Uwaga: Możliwość sterowania strefą przez użytkownika z terminala LCD wymaga spełnienia następujących warunków: </TranslationEntry>
    <TranslationEntry name="8585201DB59D9DC4ECB102F6F8CF4DD5" fullContext="DD3A449EA80B9B8C688C9BE5B354E9F9" translateForJs="false">Strefa jest przypisana do </TranslationEntry>
    <TranslationEntry name="BF02F1A8040F4CB7E05C595E1EA09238" fullContext="BB0F52D759B8570DEA59992DB2960ECA" translateForJs="false">[Sterowanie &gt; Przejścia]</TranslationEntry>
    <TranslationEntry name="CCCC2EF93C684520DE38533C4AD68453" fullContext="BB0F52D759B8570DEA59992DB2960ECA" translateForJs="false"> menu może być wyświetlane, umożliwiając użytkownikowi blokowanie i odblokowywanie przejść. </TranslationEntry>
    <TranslationEntry name="44AB656A13EBB1EFF7965276C3505943" fullContext="BB0F52D759B8570DEA59992DB2960ECA" translateForJs="false">Uwaga: możliwość sterowania przejściem przez użytkownika z terminala LCD wymaga, aby: </TranslationEntry>
    <TranslationEntry name="A5F2EBD8AA23421EAC6B1B1891893CFA" fullContext="32863267498C5BB81B1ACD2F6292A14A" translateForJs="false">Przejście jest przypisane do </TranslationEntry>
    <TranslationEntry name="7CAEF575D77CE40FD917E10C8ACD39EC" fullContext="01A1EE00F2D5664772579CDC4DDAA357" translateForJs="false">[Sterowanie &gt; Linie wyjściowe]</TranslationEntry>
    <TranslationEntry name="373DCC20217C8105EA4C60E10B8472A0" fullContext="01A1EE00F2D5664772579CDC4DDAA357" translateForJs="false"> menu może być wyświetlane, umożliwiając użytkownikowi sterowanie liniami wyjściowymi. </TranslationEntry>
    <TranslationEntry name="E9B9559849DFFBCCFE32957C175AF8BF" fullContext="4905B9EE0D96A4A1EE521376F67CD240" translateForJs="false">Uwaga: Możliwość sterowania linią wyjściową przez użytkownika z Terminala LCD wymaga: </TranslationEntry>
    <TranslationEntry name="CCB967F4185CD569247C16D67DBC5D6B" fullContext="01A1EE00F2D5664772579CDC4DDAA357" translateForJs="false">Linia wyjściowa skonfigurowana jako </TranslationEntry>
    <TranslationEntry name="94898649863BCA08A3420D208BBE0015" fullContext="D7F4947903481A6EED59F509C51A2019" translateForJs="false"> na </TranslationEntry>
    <TranslationEntry name="AF8236F76745ED911FC42730C4FD2299" fullContext="06003330CA04A9BEBE61059110B779D0" translateForJs="false">[Konfiguracja &gt; Linie wyjściowe &gt; Ustaw jako sterowne przez użytkownika]</TranslationEntry>
    <TranslationEntry name="D8A19691C58A2BCCC781D42DE81DD99E" fullContext="01A1EE00F2D5664772579CDC4DDAA357" translateForJs="false"> strona, a linia wyjściowa jest przypisana do </TranslationEntry>
    <TranslationEntry name="B6B2EA48661546FFA3DDEFA5DA7F9CA7" fullContext="A39E332BFEE59EAA9B5BBF20E35E07FB" translateForJs="false">[Sterowanie &gt; Linie wejściowe]</TranslationEntry>
    <TranslationEntry name="F7F30C41572FD23AE339479708A5B931" fullContext="A39E332BFEE59EAA9B5BBF20E35E07FB" translateForJs="false"> menu może być wyświetlane, umożliwiając użytkownikowi trwałe izolowanie lub odizolowywanie (ponowne włączenie) linii wejściowych. </TranslationEntry>
    <TranslationEntry name="86A58991F61656089A87607244728942" fullContext="D7C650007045F79CA2EF4048DCD55713" translateForJs="false">[Ogólny test &gt; Test komunikacji alarmowej]</TranslationEntry>
    <TranslationEntry name="1C44A3B37591B297657C7E4CE60CD927" fullContext="D7C650007045F79CA2EF4048DCD55713" translateForJs="false"> menu może być wyświetlane, umożliwiając użytkownikowi ręczne wysłanie wiadomości testowej przez naciśnięcie przycisku OK. </TranslationEntry>
    <TranslationEntry name="B72B2473CBAC5E5AAB202F5470132B46" fullContext="D7C650007045F79CA2EF4048DCD55713" translateForJs="false">Uwaga: Aby przetestować komunikację alarmową, należy najpierw skonfigurować raportowanie alarmów przez </TranslationEntry>
    <TranslationEntry name="26CF3C12DD58AF33AC98BB476BAB38CC" translateForJs="false">Wyświetl informacje o systemie</TranslationEntry>
    <TranslationEntry name="C952B3B2B0E7AE26269516261B4A31CE" fullContext="6F3A648D5AE9FC586DD2B673E4DEC918" translateForJs="false">[System &gt; Informacje o systemie]</TranslationEntry>
    <TranslationEntry name="6B7A4D9CD6DADC29115CF2476BC77D9C" fullContext="6F3A648D5AE9FC586DD2B673E4DEC918" translateForJs="false"> menu może być wyświetlane, umożliwiając użytkownikowi identyfikację numeru seryjnego kontrolera Inception, wersji firmware oraz rewizji płyty PCB.</TranslationEntry>
    <TranslationEntry name="875F87B1D0C972741E7CBA5D24F22F5E" fullContext="875F87B1D0C972741E7CBA5D24F22F5E" translateForJs="false">Edytuj ustawienia sieciowe</TranslationEntry>
    <TranslationEntry name="EB503A4EB7947945D69A1F80EB3C6612" fullContext="4B129827933A248640EA98D01C64E7EE" translateForJs="false">[System &gt; Ustawienia sieciowe]</TranslationEntry>
    <TranslationEntry name="672BBCF0D468BF8B0C27D89FF1106B6E" fullContext="4B129827933A248640EA98D01C64E7EE" translateForJs="false"> menu może być wyświetlane, umożliwiając użytkownikowi włączenie lub wyłączenie DHCP, identyfikację adresu IP kontrolera oraz ręczną konfigurację ustawień sieci.  </TranslationEntry>
    <TranslationEntry name="03B58ECA33A38C569D74BB1D2215A789" fullContext="4B129827933A248640EA98D01C64E7EE" translateForJs="false">Uwaga: To menu powinno być dostępne wyłącznie dla Instalatora lub administratora systemu, ponieważ zmiany wprowadzone w tym menu mogą powodować problemy z połączeniem z interfejsem webowym Inception.</TranslationEntry>
    <TranslationEntry name="38F11170217E70D9B2615D6761CBBD37" translateForJs="false">Przeglądaj komunikaty/ostrzeżenia systemowe</TranslationEntry>
    <TranslationEntry name="F291CFB21D03D4CE162FD3E278328F8E" fullContext="F48E70991C49CAECF2AEB8FC137D7CF1" translateForJs="false">[Komunikaty &gt; Komunikaty systemowe]</TranslationEntry>
    <TranslationEntry name="AAA09124FB6219FCD0961CC5963B855F" fullContext="F48E70991C49CAECF2AEB8FC137D7CF1" translateForJs="false"> menu może być wyświetlane, umożliwiając użytkownikowi przeglądanie bieżących komunikatów systemowych i usuwanie ich przez potwierdzenie. </TranslationEntry>
    <TranslationEntry name="C82718015C2870CCBD0D6DD4510D24A5" fullContext="F48E70991C49CAECF2AEB8FC137D7CF1" translateForJs="false">Jeśli w systemie istnieją jakiekolwiek komunikaty systemowe, a strefa skojarzona z terminalem nie jest w alarmie, użytkownik zobaczy </TranslationEntry>
    <TranslationEntry name="25619790F54E62B28ECA5824EA4C80BC" fullContext="F48E70991C49CAECF2AEB8FC137D7CF1" translateForJs="false">[Komunikaty systemowe]</TranslationEntry>
    <TranslationEntry name="70BC65976B46F84C565E5A0B23DDBA3B" fullContext="F48E70991C49CAECF2AEB8FC137D7CF1" translateForJs="false"> menu po zalogowaniu do terminalu. Komunikaty systemowe mają charakter informacyjny i informują użytkownika o zdarzeniach, które miały miejsce w przeszłości, takich jak przyczyna niedawnej nieudanej próby uzbrojenia strefy, resetowanie systemu lub przywrócenie problemu zdrowotnego, i wymagają jedynie potwierdzenia, aby je usunąć.</TranslationEntry>
    <TranslationEntry name="E947D5B84C65FEB86CE445DE0E68CC28" translateForJs="false">Ogranicz widok użytkownika do elementów sterowalnych</TranslationEntry>
    <TranslationEntry name="E929964F77474D38FFA4D6566100C53F" fullContext="4ADB1B1A432EA47A7039A1EFAA52B5E0" translateForJs="false">Jeśli włączone, gdy użytkownik odwiedza stronę </TranslationEntry>
    <TranslationEntry name="F3FB8DBE9948EC34E67C826304EFDB50" fullContext="C3277CC7E756E6B426593E5EDFE49443" translateForJs="false">[Steruj strefami]</TranslationEntry>
    <TranslationEntry name="5DB40F890C859A5ABD949B8A700BD2E3" fullContext="E2092012D09196F628A489496EEFBB35" translateForJs="false">[Sterowanie przejściami]</TranslationEntry>
    <TranslationEntry name="E99EC2E316C081049F874D5544767120" fullContext="4ADB1B1A432EA47A7039A1EFAA52B5E0" translateForJs="false">[Sterowanie liniami wyjściowymi]</TranslationEntry>
    <TranslationEntry name="37CDEED7F8AF90A98E02FD72367318EA" fullContext="FC06AB625A23F62FCF57D3CD23EA8581" translateForJs="false"> menu, będą mogli widzieć tylko elementy, do których mają uprawnienia do sterowania. Często włączane dla profili użytkowników końcowych, zapewniając im prostszą listę elementów do wyświetlenia.</TranslationEntry>
    <TranslationEntry name="4DA85B65C9A0148480FF27202E9B0348" translateForJs="false">Sterowanie trybem serwisowym</TranslationEntry>
    <TranslationEntry name="2DF406AFE1FADDC371E39DDBFF1B4A2F" fullContext="FCE48E1113498371FF945A37E22A7CB7" translateForJs="false">[Instalator &gt; Tryb serwisowy]</TranslationEntry>
    <TranslationEntry name="E63654742D146C9C7926147093DFD6DF" fullContext="FCE48E1113498371FF945A37E22A7CB7" translateForJs="false"> menu może być wyświetlane, umożliwiając użytkownikowi włączenie lub wyłączenie trybu serwisowego. Jeśli tryb serwisowy jest włączony, zostanie automatycznie wyłączony po ośmiu godzinach. </TranslationEntry>
    <TranslationEntry name="A87C76F14B94DEC02E268CC42186F758" fullContext="FCE48E1113498371FF945A37E22A7CB7" translateForJs="false">Uwaga: To menu powinno być dostępne tylko dla instalatora, ponieważ włączenie trybu serwisowego wyłączy sygnalizatory alarmów stref i raportowanie alarmów.</TranslationEntry>
    <TranslationEntry name="8B8A0890604E0AA33C97E917BBB5D974" translateForJs="false">Konfiguruj EOL linii wejściowej</TranslationEntry>
    <TranslationEntry name="A97CD4AD48CD5393112A987771F75C6F" translateForJs="false">Menu instalatora LCD</TranslationEntry>
    <TranslationEntry name="F2AC7F732A203440BF042C6E1FBAB68E" fullContext="48EF2CBA76F621702D0B15A421B0BEB1" translateForJs="false">[Instalator &gt; Ustawienia &gt; Ustawienia EOL linii wejściowej]</TranslationEntry>
    <TranslationEntry name="75229928061FFCCC8538A403B1C4F34E" fullContext="48EF2CBA76F621702D0B15A421B0BEB1" translateForJs="false"> menu może być wyświetlane, umożliwiając użytkownikowi zmianę ustawień EOL dla wszystkich linii wejściowych.</TranslationEntry>
    <TranslationEntry name="2E8031E7A8091DC007345732220BE2DB" fullContext="48EF2CBA76F621702D0B15A421B0BEB1" translateForJs="false">Uwaga: To menu powinno być dostępne wyłącznie dla Instalatora, ponieważ zmiana ustawień EOL linii wejściowej może narazić bezpieczeństwo obiektu.</TranslationEntry>
    <TranslationEntry name="E8CA735754DD2CBDB9E28349BE6D1538" translateForJs="false">Kopia zapasowa/przywracanie bazy danych z dysku USB</TranslationEntry>
    <TranslationEntry name="DF91950F1F69A0BE140EED646C00F1E3" fullContext="C995C09D776FD2C140452A0BF116596D" translateForJs="false">[Instalator &gt; Baza danych]</TranslationEntry>
    <TranslationEntry name="F950C13FB70BDAB14DA578228C34D469" fullContext="C995C09D776FD2C140452A0BF116596D" translateForJs="false"> menu może być wyświetlane, umożliwiając użytkownikowi tworzenie kopii zapasowej i przywracanie bazy danych systemu z dysku USB.</TranslationEntry>
    <TranslationEntry name="A62A7D1E9C25D25CA3E40D1AB92831EC" fullContext="C995C09D776FD2C140452A0BF116596D" translateForJs="false">Uwaga: To menu powinno być dostępne wyłącznie dla instalatora, ponieważ przywrócenie bazy danych systemu może skutkować utratą danych i wymaga ponownego uruchomienia kontrolera Inception.</TranslationEntry>
    <TranslationEntry name="8999988BADE805CC935AB69BD35CDEF0" translateForJs="false">Aktualizuj firmware systemu</TranslationEntry>
    <TranslationEntry name="4DD3A5CEEA4B3B0824133BD2499DDF40" fullContext="9756C92E20ECE93E4B48D22670EDC2DA" translateForJs="false">[Instalator &gt; Firmware]</TranslationEntry>
    <TranslationEntry name="C22569B11242DCD801D9CA485911560F" fullContext="9756C92E20ECE93E4B48D22670EDC2DA" translateForJs="false"> menu może być wyświetlane, umożliwiając użytkownikowi aktualizację firmware kontrolera z dysku USB.</TranslationEntry>
    <TranslationEntry name="055989CA4DCC151B71A4CA6D44345DA7" fullContext="9756C92E20ECE93E4B48D22670EDC2DA" translateForJs="false">Aby skorzystać z tej funkcji, plik firmware kontrolera musi znajdować się na dysku USB podłączonym do kontrolera Inception.</TranslationEntry>
    <TranslationEntry name="D688844E2EC718A837DCAFFD69DAC5A8" fullContext="9756C92E20ECE93E4B48D22670EDC2DA" translateForJs="false">Uwaga: To menu powinno być dostępne wyłącznie dla Instalatora lub administratora systemu, ponieważ aktualizacja firmware kontrolera powinna być przeprowadzana z zachowaniem ostrożności.</TranslationEntry>
    <TranslationEntry name="C6B12846039B47C96DDD39D6D9740F7F" fullContext="8F34A9B690FA53B22D3DD127897F676C" translateForJs="false">[Instalator &gt; LAN Secure]</TranslationEntry>
    <TranslationEntry name="1B9B826CB23E94141B91299723B79136" fullContext="8F34A9B690FA53B22D3DD127897F676C" translateForJs="false"> menu może być wyświetlane, umożliwiając użytkownikowi zabezpieczenie LAN z terminala.</TranslationEntry>
    <TranslationEntry name="B90127E1BED194ACC8149DFF817DEAD3" fullContext="8F34A9B690FA53B22D3DD127897F676C" translateForJs="false">Uwaga: To menu powinno być dostępne wyłącznie dla Instalatora, ponieważ zabezpieczenie LAN zapobiega podstawieniu modułu.</TranslationEntry>
    <TranslationEntry name="71A02A8FAF92D317EED9B6DE2BBFB942" translateForJs="false">Pomiń problemy ze zdrowiem systemu</TranslationEntry>
    <TranslationEntry name="FA4960C8695EA5CE55836ADDAE2A9490" translateForJs="false">Uprawnienia terminala dotykowego</TranslationEntry>
    <TranslationEntry name="050132E7ADE7588596CBBF20A3533EC6" fullContext="24405DFBDFE755BE4A904C7CF4A90AB7" translateForJs="false">Określa możliwość użytkownika do pomijania (izolowania) modułów sprzętowych z terminala z ekranem dotykowym.</TranslationEntry>
    <TranslationEntry name="5E283A24168435CAE848CA04AF97860F" fullContext="24405DFBDFE755BE4A904C7CF4A90AB7" translateForJs="false"> - Próba ominięcia za pomocą kodu PIN tego użytkownika z menu Stan systemu spowoduje błąd nieprawidłowego kodu PIN. Użytkownik nie będzie mógł wymusić uzbrojenia strefy zablokowanej przez problemy ze stanem systemu.</TranslationEntry>
    <TranslationEntry name="6D4D90F834418EC6982958F36B18283B" fullContext="24405DFBDFE755BE4A904C7CF4A90AB7" translateForJs="false"> — Użytkownik będzie mógł pomijać problemy ze stanem technicznym systemu.</TranslationEntry>
    <TranslationEntry name="C5A70280770B2C1923730F5B1E75D82A" translateForJs="false">Menu ustawień dostępu</TranslationEntry>
    <TranslationEntry name="2312790C05832BD922DDFA9F6F9827BE" fullContext="8ADF084EAC459D9783C4DDC299855BCE" translateForJs="false">Określa możliwość dostępu użytkownika do podmenu Ustawienia na terminalu z ekranem dotykowym.</TranslationEntry>
    <TranslationEntry name="FAE485E9D5248CF726667A8D4E3DB839" fullContext="8ADF084EAC459D9783C4DDC299855BCE" translateForJs="false"> - Podmenu Ustawienia na terminalach z ekranem dotykowym zostanie wyłączone.</TranslationEntry>
    <TranslationEntry name="2D14EE81D120FEAF2FBD6BA6DE995D54" fullContext="8ADF084EAC459D9783C4DDC299855BCE" translateForJs="false"> - Podmenu Ustawienia na terminalach dotykowych zostanie włączone.</TranslationEntry>
    <TranslationEntry name="B9074452FAB8046C6DDEC4FBB6F1652E" translateForJs="false">Menu technika dostępu</TranslationEntry>
    <TranslationEntry name="2DE3BA87662F37CF681870A161058EBA" fullContext="1605E8E577753CAC793EF12454284C2A" translateForJs="false">Określa możliwość dostępu użytkownika do podmenu Technik na terminalu z ekranem dotykowym.</TranslationEntry>
    <TranslationEntry name="44F218408C81FF2CA159CAC8B67DB289" fullContext="1605E8E577753CAC793EF12454284C2A" translateForJs="false"> - Podmenu Technik na terminalach dotykowych zostanie wyłączone.</TranslationEntry>
    <TranslationEntry name="E5BAF5DE9A04CF0A0FA3A70FB2849E8E" fullContext="1605E8E577753CAC793EF12454284C2A" translateForJs="false"> - Podmenu technika na terminalach dotykowych zostanie włączone.</TranslationEntry>
    <TranslationEntry name="5BE998D01BCC5AABAFCBCD33E5C25270" fullContext="5BE998D01BCC5AABAFCBCD33E5C25270" translateForJs="false" rules="unique=EntityChangeNotifications" notes="Must be unique amongst all &quot;EntityChangeNotifications&quot; entries">Kabiny windy</TranslationEntry>
    <TranslationEntry name="E7661750FE6735878B67CD0197871188" translateForJs="false">Czytniki kabiny</TranslationEntry>
    <TranslationEntry name="FEBF590786BE1445E1658AC2AB8911EB" fullContext="96590C6B31D407C878DAE8D28364F356" translateForJs="false">Określa czytniki, które mogą sterować tą kabiną windy, umożliwiając użytkownikowi prezentację PIN, karty lub innego identyfikatora. W razie potrzeby do tej samej kabiny windy można przypisać wiele czytników, co umożliwia montaż czytników w różnych lokalizacjach lub różnych typów.</TranslationEntry>
    <TranslationEntry name="43F668325F3DC1D4155AF38E2C6CB05E" fullContext="96590C6B31D407C878DAE8D28364F356" translateForJs="false">Aby dodać czytnik do kabiny windy, kliknij </TranslationEntry>
    <TranslationEntry name="93C0A3D28231933A163CBF7C4466642C" fullContext="524FBD0FAC791491009CB7E73E79D00D" translateForJs="false"> przycisk spowoduje otwarcie okna, w którym można wybrać czytniki do dodania. Jeśli w tym oknie nie ma żadnych czytników, nowe czytniki można skonfigurować, przechodząc do </TranslationEntry>
    <TranslationEntry name="4CE83AAAC28CEB4E7C83F22E513654CB" fullContext="4697BCAF4CA54899D5DA40205566A7D8" translateForJs="false">[Konfiguracja &gt; Sprzęt ]</TranslationEntry>
    <TranslationEntry name="F5C22B81455E0E7D8F8D32A9C674FA0A" fullContext="CFB367B710A358A5A74D5694F0C0ABA3" translateForJs="false">Tryb dostępu czytnika</TranslationEntry>
    <TranslationEntry name="8F1AD9FCD0C8DAE571F9FD9846974F1B" fullContext="8D759C63AEDE74F0CC1245D90273A699" translateForJs="false">Określa, ile różnych typów identyfikatorów jest wymaganych do uzyskania dostępu do przycisków kabiny windy. To pole jest używane w połączeniu z polem </TranslationEntry>
    <TranslationEntry name="FC24D194DAEE6F9A45649413B3B1E122" fullContext="8D759C63AEDE74F0CC1245D90273A699" translateForJs="false">Tryb dostępu do czytnika — Określone identyfikatory</TranslationEntry>
    <TranslationEntry name="81393BD23E462089C371636EB16F492A" fullContext="8D759C63AEDE74F0CC1245D90273A699" translateForJs="false"> pole do określenia, które typy identyfikatorów czytniki kabiny windy będą akceptować lub odrzucać (w domyślnej konfiguracji akceptowane są wszystkie typy identyfikatorów).</TranslationEntry>
    <TranslationEntry name="6BA9D7E4AE8E56AF33F486C9A8ABEDA9" fullContext="CFB367B710A358A5A74D5694F0C0ABA3" translateForJs="false"> - pojedynczy prawidłowy identyfikator (akceptowanego typu) umożliwi dostęp.</TranslationEntry>
    <TranslationEntry name="2E94B60361682FABD3033763D962267F" fullContext="CFB367B710A358A5A74D5694F0C0ABA3" translateForJs="false"> - wymagane są dwa identyfikatory różnych typów (np. Karta i PIN), aby uzyskać dostęp. Drugi identyfikator musi być przedstawiony w ciągu 10 sekund od pierwszego.</TranslationEntry>
    <TranslationEntry name="AE733BB8F26C3CF47219171A7E27BCB6" fullContext="CFB367B710A358A5A74D5694F0C0ABA3" translateForJs="false"> — wymagane są trzy identyfikatory różnych typów (np. karta, PIN i dane biometryczne — odcisk palca) w celu uzyskania dostępu. Każdy identyfikator musi być przedstawiony w ciągu 10 sekund od poprzedniego.</TranslationEntry>
    <TranslationEntry name="3EBDF1B770721E6024C0A689EC13B961" fullContext="1AB4E4DEDE57D499781EB0378B5F9F8C" translateForJs="false">Określa typy identyfikatorów wymagane do dostępu do przycisków kabiny windy. Gdy lista jest pusta, akceptowane są wszystkie typy identyfikatorów; gdy lista zawiera pozycje, akceptowane są tylko typy identyfikatorów z listy, a inne identyfikatory są odrzucane. Gdy identyfikator zostanie zaprezentowany przy czytniku, odebrane dane mogą być przetwarzane inaczej w zależności od tego, któremu szablonowi identyfikatora w systemie odpowiada. </TranslationEntry>
    <TranslationEntry name="012C3B38D1A2D8E71DB7B48ABAF40597" fullContext="1AB4E4DEDE57D499781EB0378B5F9F8C" translateForJs="false"> na kabinie windy i umożliwić akceptowanie tylko </TranslationEntry>
    <TranslationEntry name="BE4C2762810DE1D5BC9AFB4DD49DB3B1" fullContext="1AB4E4DEDE57D499781EB0378B5F9F8C" translateForJs="false"> jest włączone dla kabiny windy, a użytkownik z 2 </TranslationEntry>
    <TranslationEntry name="3A6CD68E083B0D835E6D419961DCE6D1" fullContext="1AB4E4DEDE57D499781EB0378B5F9F8C" translateForJs="false"> typ identyfikatorów przyłoży oba kolejno do czytnika, drugi odczyt karty nie umożliwi dostępu — do ukończenia próby dostępu wymagany jest identyfikator innej kategorii.</TranslationEntry>
    <TranslationEntry name="5B3EC15499A125805B5BBF8E4AFCEC8C" fullContext="28247A89310AFA8E4677920C02935272" translateForJs="false">Przyciski</TranslationEntry>
    <TranslationEntry name="2CAE5F41DCEEB47CF2286A99A5A02951" fullContext="4697BCAF4CA54899D5DA40205566A7D8" translateForJs="false">Umożliwia konfigurowanie przycisków windy dla kabiny windy. Przyciski windy reprezentują fizyczny przycisk w kabinie windy, który po naciśnięciu zabiera użytkownika na piętro. Konfiguracja przycisku, którym ta kabina windy może sterować, wymaga zarówno </TranslationEntry>
    <TranslationEntry name="A96D898F9A339947F348569B66A3BC8C" fullContext="4697BCAF4CA54899D5DA40205566A7D8" translateForJs="false"> dla miejsca docelowego przycisku oraz linię wyjściową umożliwiającą włączanie i wyłączanie przycisku. Opcjonalnie można również określić linię wejściową sygnalizującą naciśnięcie przycisku.</TranslationEntry>
    <TranslationEntry name="432CD6549D6C04D0A390880DC5F2A0F5" fullContext="4697BCAF4CA54899D5DA40205566A7D8" translateForJs="false">Aby dodać przyciski do kabiny windy, kliknij </TranslationEntry>
    <TranslationEntry name="F8A5535E11EDEECA69F9A8C80BF85684" fullContext="4697BCAF4CA54899D5DA40205566A7D8" translateForJs="false"> przycisk — zostanie otwarte okno wyświetlające wszystkie skonfigurowane piętra w systemie. Po wybraniu piętra można przypisać linię wyjściową, która może aktywować przycisk, oraz linię wejściową, która dostarcza sygnalizację zwrotną naciśnięcia przycisku. Dodatkowe piętra można skonfigurować, przechodząc do </TranslationEntry>
    <TranslationEntry name="F30FBC7240072A9C791A414D5E0821B9" fullContext="E6CF88C9BFFB1C5659C4B78DBDE3DB0F" translateForJs="false">[Konfiguracja &gt; Kontrola dostępu &gt; Piętra windy]</TranslationEntry>
    <TranslationEntry name="EF190FED2BD0D0F3DF37A1F018434309" fullContext="4697BCAF4CA54899D5DA40205566A7D8" translateForJs="false"> strona i nowe linie wyjściowe oraz linie wejściowe można skonfigurować na </TranslationEntry>
    <TranslationEntry name="BC58285E8973C12E7DF7465A94EE0ADB" fullContext="28247A89310AFA8E4677920C02935272" translateForJs="false">Linie wyjściowe sygnalizacji zwrotnej</TranslationEntry>
    <TranslationEntry name="83B8B58B44957F2650860EAAF7F1107D" fullContext="0A9054507154D966539E8A45393C4134" translateForJs="false">Umożliwia konfigurację szeregu linii wyjściowych, które mogą zapewniać sygnalizację zwrotną interakcji użytkownika z kabiną windy. </TranslationEntry>
    <TranslationEntry name="63C980603FE048A0A153B0688DF42024" fullContext="0A9054507154D966539E8A45393C4134" translateForJs="false">Aby dodać linie wyjściowe sygnalizacji zwrotnej do kabiny windy, kliknij </TranslationEntry>
    <TranslationEntry name="24CE2F90648AD0C8454A1E5B510EA5F3" fullContext="0A9054507154D966539E8A45393C4134" translateForJs="false"> przycisk spowoduje otwarcie okna, w którym można wybrać linie wyjściowe do dodania. Nowe linie wyjściowe można tworzyć na stronie </TranslationEntry>
    <TranslationEntry name="3E52C3F580C1F9E51AB831F740D0FAFD" fullContext="0A9054507154D966539E8A45393C4134" translateForJs="false">Po dodaniu liniom wyjściowym należy przypisać </TranslationEntry>
    <TranslationEntry name="3477BFA9AA7D55EF2BD68DB958B40D1F" fullContext="0A9054507154D966539E8A45393C4134" translateForJs="false">, który określi typ sygnalizacji zwrotnej generowanej przez linię wyjściową. Linie wyjściowe można skonfigurować z jednym z następujących zachowań:</TranslationEntry>
    <TranslationEntry name="AF9C49A1C41E0A9B430D0EFFFBFF1E5D" fullContext="0A9054507154D966539E8A45393C4134" translateForJs="false"> — Włączy się po odczycie karty aktywującym piętra windy i pozostanie włączone do czasu </TranslationEntry>
    <TranslationEntry name="239BD82F1988F73336E94EADD46F9155" fullContext="4AEA72B3A19DCE7F7ADBF6A805F0FF0C" translateForJs="false">Domyślny czas przycisku</TranslationEntry>
    <TranslationEntry name="AE30FCE72298BF43C44B6FB61D1945B5" fullContext="0A9054507154D966539E8A45393C4134" translateForJs="false"> wygasa lub zostaje wybrane prawidłowe piętro przez sygnalizację zwrotną przycisku.</TranslationEntry>
    <TranslationEntry name="EB34F5B68777838226DBF3195430BDBA" fullContext="0A9054507154D966539E8A45393C4134" translateForJs="false"> - Włączy się po odczycie karty, który nie włącza żadnych pięter windy. Włączy się również, gdy zostanie wykryte sygnalizowanie zwrotne przycisku dla przycisku, który nie jest włączony. Po włączeniu linia wyjściowa pozostanie włączona do momentu, gdy </TranslationEntry>
    <TranslationEntry name="F1E847D2242E5ED5514C25F7F4EEBEAD" fullContext="69605AF763FCBBD83E11F2EE6E76CC11" translateForJs="false">Czas trwania włączenia przycisków windy, gdy użytkownik prezentuje ważną kartę lub PIN przy skonfigurowanym czytniku kabiny. Czas ten powinien być ustawiony tak, aby umożliwić użytkownikowi dokonanie wyboru piętra po prezentacji identyfikatora.</TranslationEntry>
    <TranslationEntry name="4C643011C0DFF73481AEE8AB8D144785" fullContext="69605AF763FCBBD83E11F2EE6E76CC11" translateForJs="false">Jeśli dostępna jest sygnalizacja zwrotna przycisków, tzn. do przycisków windy podłączono linie wejściowe w celu wykrywania, które piętro wybierze użytkownik, czas włączenia przycisku zostanie skrócony po dokonaniu wyboru.</TranslationEntry>
    <TranslationEntry name="B96B0D5E40DBE0017826B9BC0954FA54" translateForJs="false">Rozszerzony czas przycisku</TranslationEntry>
    <TranslationEntry name="09AF2F17911DDD64AE46B36BA55A5346" fullContext="4AEA72B3A19DCE7F7ADBF6A805F0FF0C" translateForJs="false">Czas trwania, przez który przyciski windy będą włączone, jeśli do kabiny windy uzyska dostęp użytkownik wymagający czasu dłuższego niż </TranslationEntry>
    <TranslationEntry name="F878D678BE2DEA45880771F92E56CAC9" fullContext="4AEA72B3A19DCE7F7ADBF6A805F0FF0C" translateForJs="false"> do dokonania wyboru piętra. Wydłużony czas naciśnięcia przycisku działa dla każdego użytkownika osobno i wymaga </TranslationEntry>
    <TranslationEntry name="5CDC530D9C93BD34AE17D52A999B39EE" fullContext="4AEA72B3A19DCE7F7ADBF6A805F0FF0C" translateForJs="false">Ta opcja jest przeznaczona dla użytkowników potrzebujących więcej czasu na wybranie piętra, na przykład kierowca dostarczający paczki lub użytkownik z niepełnosprawnością ruchową.</TranslationEntry>
    <TranslationEntry name="B8D01E86622CA5CE1187B41000A23844" translateForJs="false">Alternatywny tryb dostępu</TranslationEntry>
    <TranslationEntry name="42E0D3F483048E8F33DDF0C737AD2B79" fullContext="CFB367B710A358A5A74D5694F0C0ABA3" translateForJs="false">Włącz alternatywny tryb dostępu</TranslationEntry>
    <TranslationEntry name="72609335F6E887FC7200AC0C402F199B" fullContext="1D5606C9BAD767E81ED799F9D96443F5" translateForJs="false">Jeśli włączone, umożliwia tej kabinie windy korzystanie z alternatywnego programowania dostępu, jeśli przypisany harmonogram jest aktywny. Umożliwia to zmianę niektórych opcji dostępu dla kabiny windy w zależności od pory dnia. Należy pamiętać, że jeśli jest włączone, </TranslationEntry>
    <TranslationEntry name="E8139E458C98BC39DD7E8FEF58198878" fullContext="1D5606C9BAD767E81ED799F9D96443F5" translateForJs="false">W ciągu dnia użytkownik może korzystać z Karty lub PIN, aby uzyskać dostęp do kabiny windy dla wygody, jednak poza godzinami pracy obiekt może wymagać użycia zarówno Karty, jak i PIN w celu zwiększenia bezpieczeństwa. Podobnie tryby dostępu mogą się różnić w zależności od dni roboczych a weekendów itd.</TranslationEntry>
    <TranslationEntry name="DF0BF81795F4E58DD2D00ED190E3C87C" fullContext="7470A4CF85923F7FE694D728C1D131FD" translateForJs="false">Aby można było użyć alternatywnego trybu dostępu, należy skonfigurować harmonogram. Harmonogram może składać się z jednego lub więcej warunków wyzwalających, które przyjmują wartość Prawda lub Fałsz (np. gdy przedział czasowy jest aktywny lub gdy strefa jest uzbrojona), które są przetwarzane łącznie w celu obliczenia, czy harmonogram powinien być aktywny. Logika harmonogramu może przetwarzać warunki tak, że harmonogram trybu alternatywnego jest aktywny tylko wtedy, gdy WSZYSTKIE warunki są prawdziwe, lub aktywny, gdy KTÓRYKOLWIEK z warunków jest prawdziwy. Gdy stan harmonogramu jest aktywny, stosowany jest poniższy alternatywny zestaw opcji, zastępując domyślne ustawienia windy.</TranslationEntry>
    <TranslationEntry name="3D28FAB9F27555FC37B4DC9C1066BE1A" fullContext="1AB4E4DEDE57D499781EB0378B5F9F8C" translateForJs="false">Alternatywny tryb dostępu czytnika</TranslationEntry>
    <TranslationEntry name="FE298CF257FEE17EBA2F33E7379276B8" fullContext="CFB367B710A358A5A74D5694F0C0ABA3" translateForJs="false"> warunek jest aktywny, ta opcja będzie używana zamiast normalnego </TranslationEntry>
    <TranslationEntry name="69EEFE483A7908AA0312638AF9D2A826" fullContext="CFB367B710A358A5A74D5694F0C0ABA3" translateForJs="false"> opcja, ta opcja określa, jakie typy identyfikatorów są wymagane do dostępu do przycisków kabiny windy.</TranslationEntry>
    <TranslationEntry name="1B1232383D568E435F7FA49D7C6B8F40" translateForJs="false">Alternatywny tryb dostępu czytnika — określone identyfikatory</TranslationEntry>
    <TranslationEntry name="F3F6D0343D56CE88CE7958170ED05CB3" fullContext="F3F6D0343D56CE88CE7958170ED05CB3" translateForJs="false">Piętro</TranslationEntry>
    <TranslationEntry name="579AC861488B37BF3061B82CB9EE522B" translateForJs="false">Linia wyjściowa przycisku</TranslationEntry>
    <TranslationEntry name="6D248817BA33C41BD72CA12D07A9F7D3" translateForJs="false">Linia wejściowa sygnalizacji zwrotnej</TranslationEntry>
    <TranslationEntry name="615794CB1487D307F4F4E9FB25F70081" fullContext="615794CB1487D307F4F4E9FB25F70081" translateForJs="false" rules="unique=EntityChangeNotifications" notes="Must be unique amongst all &quot;EntityChangeNotifications&quot; entries">Piętra windy</TranslationEntry>
    <TranslationEntry name="85E2B636000472F509F561AE4FB77E1D" fullContext="276A03D3BE2474A95964E4B176229E84" translateForJs="false">Umożliwia harmonogramowi sterowanie piętrem windy. Gdy przedział czasowy jest ważny, piętro zostanie ustawione jako dostępne swobodnie, a gdy jest nieważny, piętro zostanie zabezpieczone. Tej funkcji można używać razem z </TranslationEntry>
    <TranslationEntry name="AAC8EBF49E3878383FADA43446BCD7B1" fullContext="4DE6F3C5676CA32603A30DE25EB00DA1" translateForJs="false">Śledź stan strefy</TranslationEntry>
    <TranslationEntry name="D99FAF55943770A5A815B10B178CDA50" fullContext="276A03D3BE2474A95964E4B176229E84" translateForJs="false"> funkcja na tej stronie. W takim przypadku piętro zostanie ustawione na wolny dostęp, gdy przedział czasowy jest ważny i gdy </TranslationEntry>
    <TranslationEntry name="973BF5D0CD79F37894170BF671172EC5" fullContext="BCF820E0F5FB7CBA84BA02EE0A392019" translateForJs="false">Powiązana strefa</TranslationEntry>
    <TranslationEntry name="13FCAEC45BB2BB03D09D4DBA340C79F7" fullContext="276A03D3BE2474A95964E4B176229E84" translateForJs="false"> jest rozbrojona. W przeciwnym razie, jeśli śledzona strefa jest uzbrojona lub przedział czasowy jest nieważny, przejście pozostanie zablokowane. </TranslationEntry>
    <TranslationEntry name="BDB321F22B0F436DF0D3DE6A49900AEC" fullContext="6551E1A8770B94C9C3E4DA7328429431" translateForJs="false">Można to wykorzystać na przykład do umożliwienia wolnego dostępu do piętra w godzinach pracy, ale tylko po tym, jak pracownik uzyska dostęp do piętra, a tym samym strefa na tym piętrze zostanie rozbrojona. </TranslationEntry>
    <TranslationEntry name="B0BF7A3D7FBEDAA92A30F2A0C1784941" fullContext="276A03D3BE2474A95964E4B176229E84" translateForJs="false">Uwaga: Jeśli użytkownik nadpisał stan piętra jako zabezpieczone lub dostępne swobodnie z poziomu interfejsu internetowego, nadpisanie ma priorytet. Jednak gdy przedział czasowy zmienia stan, nadpisanie (o ile nie jest to Wyłączenie z dostępu) jest automatycznie usuwane, a piętro domyślnie powraca do normalnego zachowania.</TranslationEntry>
    <TranslationEntry name="B23ABC56BBDB78BB462380A122CECB69" fullContext="D6772AC36BE0BF32B447AE9C726E579E" translateForJs="false">Pozwala powiązać strefę z piętrem windy. Jest to strefa używana przez </TranslationEntry>
    <TranslationEntry name="D6CCEAD8781B0AE2AAEC561440EEB875" fullContext="D6772AC36BE0BF32B447AE9C726E579E" translateForJs="false"> poniższa opcja, aby zapewnić zabezpieczenie piętra, gdy strefa jest uzbrojona, ewentualnie zastępując </TranslationEntry>
    <TranslationEntry name="8FCDBD512CF0448B1C4AD6C3FD2C5651" fullContext="D6772AC36BE0BF32B447AE9C726E579E" translateForJs="false">Jeśli dostępna jest sygnalizacja zwrotna przycisków, tzn. linie wejściowe zostały podłączone w celu wykrycia, który przycisk windy wybrał użytkownik, jest to strefa, która zostanie rozbrojona, gdy użytkownik wybierze to piętro, jeśli </TranslationEntry>
    <TranslationEntry name="9FF788347D3FD6282D229D4346005C93" fullContext="D6772AC36BE0BF32B447AE9C726E579E" translateForJs="false"> poniższa opcja jest włączona. Ponadto lokalizacja użytkownika zostanie zaktualizowana do tej strefy.</TranslationEntry>
    <TranslationEntry name="FB628E6762ED5CD49E1B1C0F9CB378F1" fullContext="D6772AC36BE0BF32B447AE9C726E579E" translateForJs="false">Uwaga: W kabinie windy użytkownikowi zostanie odmówiony dostęp do piętra, jeśli istnieje powiązana strefa, strefa jest uzbrojona, a użytkownik nie ma uprawnień do rozbrojenia tej strefy. Dotyczy to nawet sytuacji, gdy użytkownik ma uprawnienia dostępu do piętra windy, ponieważ mogłoby to oznaczać, że użytkownik potencjalnie wychodzi z windy na uzbrojonym obszarze, którego nie może kontrolować. Jest to kolejny sposób ograniczenia dostępu do piętra, gdzie użytkownik normalnie może uzyskać dostęp do piętra po odczycie swojego identyfikatora, ale dopiero po tym, jak autoryzowany użytkownik uzyska dostęp do strefy i ją rozbroi.</TranslationEntry>
    <TranslationEntry name="4FA0B9036575081039C85DF71E9DE4F9" fullContext="B0A971ECBE63B3915EEFE3044583A394" translateForJs="false">Jeśli włączone, użytkownik uzyskujący dostęp do tego piętra przez kabinę windy automatycznie rozbroi </TranslationEntry>
    <TranslationEntry name="B58D9CF7973D78E3237354E4232E21E3" fullContext="B0A971ECBE63B3915EEFE3044583A394" translateForJs="false">. Użytkownik musi mieć odpowiednie uprawnienia do rozbrojenia strefy. Może to być wygodne, gdyż eliminuje konieczność rozbrajania strefy z poziomu Terminala LCD przy użyciu PIN użytkownika po wejściu do strefy.</TranslationEntry>
    <TranslationEntry name="293194F407092CCD558706490BFE244C" fullContext="B0A971ECBE63B3915EEFE3044583A394" translateForJs="false">Może to jednak stanowić zagrożenie bezpieczeństwa. Jeśli karta zostałaby upuszczona na zewnątrz i znaleziona przez inną osobę, mogłaby ona wejść do kabiny windy, wybrać piętro i rozbroić strefę, bez konieczności znajomości dodatkowego numeru PIN.</TranslationEntry>
    <TranslationEntry name="08CDDD8EDF2C5F2CC5159E71400C7DBD" fullContext="B0A971ECBE63B3915EEFE3044583A394" translateForJs="false">Uwaga: Sygnalizacja zwrotna przycisków w kabinie windy jest wymagana do działania tej funkcji. Wymaga to podłączenia linii wejściowych do przycisków windy, aby system Inception wiedział, które piętro wybrał użytkownik.</TranslationEntry>
    <TranslationEntry name="C0A971C44E2B360123CA32CB58AA8F23" fullContext="D8BA791A9CFC2193746C86D137329397" translateForJs="false">Umożliwia </TranslationEntry>
    <TranslationEntry name="7F1C093919F72A56BA587EA70963F616" fullContext="0B6EF4D207919D4EB61083B60578791B" translateForJs="false"> stan do sterowania piętrem. Gdy strefa jest uzbrojona, piętro zostanie zabezpieczone, jednak po rozbronieniu piętro nie zostanie ustawione na wolny dostęp. Ta funkcja jest zaprojektowana do użytku razem z </TranslationEntry>
    <TranslationEntry name="DD7EC6E3ABC874DA63743AF1BA4198E7" fullContext="0B6EF4D207919D4EB61083B60578791B" translateForJs="false"> opcja znaleziona na tej stronie. W takim przypadku piętro zostanie ustawione na wolny dostęp, gdy przedział czasowy jest aktywny i strefa jest rozbrojona. W przeciwnym razie, jeśli śledzona strefa jest uzbrojona lub przedział czasowy jest nieaktywny, przejście pozostanie zabezpieczone.</TranslationEntry>
    <TranslationEntry name="0AFED8C57CC9AB7F4912F148153EF249" fullContext="0B6EF4D207919D4EB61083B60578791B" translateForJs="false">Można to wykorzystać na przykład do umożliwienia swobodnego dostępu do piętra w godzinach pracy, ale dopiero po tym, jak pracownik po raz pierwszy uzyska dostęp do piętra, a tym samym strefa na tym piętrze zostanie rozbrojona.</TranslationEntry>
    <TranslationEntry name="71661C04D455B04C22E6DCB51D743841" fullContext="0B6EF4D207919D4EB61083B60578791B" translateForJs="false">Uwaga: jeśli użytkownik nadpisał stan piętra na zabezpieczony lub w trybie wolnego dostępu z interfejsu internetowego, nadpisanie ma pierwszeństwo. Jednak gdy powiązana strefa zmieni stan na uzbrojony lub rozbrojony, nadpisanie (chyba że nadpisano na tryb blokady) jest automatycznie czyszczone i piętro powraca do normalnego zachowania.</TranslationEntry>
    <TranslationEntry name="A8683BE34C4605CD25095821A41DF850" translateForJs="false">Powiadamiacz</TranslationEntry>
    <TranslationEntry name="2D6CCC7F8F03D5DC4E11196C2F83D356" fullContext="4D25441374042AC222E55F650DA8081D" translateForJs="false">To pole wyboru włącza i wyłącza monitorowanie zdarzeń systemowych przez notyfikator. Można go użyć do tymczasowego wyłączenia przetwarzania bez konieczności usuwania lub edytowania programowania.</TranslationEntry>
    <TranslationEntry name="E9306F7BBC675DF2FDC595D977471D71" translateForJs="false">TESTY WEWNĘTRZNE — jawnie włącz program powiadamiający</TranslationEntry>
    <TranslationEntry name="4BF54034E01231B691CD572B06B49344" fullContext="A2899AFA8D87FA9C290E48F9A4F49ADC" translateForJs="false">IRSupport</TranslationEntry>
    <TranslationEntry name="A249F4E658665AD8DE10F83A6C32B475" fullContext="A2899AFA8D87FA9C290E48F9A4F49ADC" translateForJs="false"> Wariant produktu domyślnie wyłącza wszystkie powiadamiacze w systemie, aby zapobiec sytuacjom takim jak przywracanie kopii zapasowej bazy danych klienta na testowy system Inception w celu diagnozy i automatyczne wysyłanie niechcianych powiadomień. To pole wyboru można włączyć w połączeniu z </TranslationEntry>
    <TranslationEntry name="D48BDEFEBFD963BC0F6F71DFD08C0BF8" fullContext="A2899AFA8D87FA9C290E48F9A4F49ADC" translateForJs="false"> pole wyboru, aby jawnie włączyć program powiadamiający w systemie IRSupport.</TranslationEntry>
    <TranslationEntry name="28D241FAF5A0332BD490B76C82129195" translateForJs="false">Limit harmonogramu wysyłania</TranslationEntry>
    <TranslationEntry name="36F8A48B3EC6514E55D9F9C412DE1874" fullContext="3F08964B61ECE30BC7AEFC2C5668C348" translateForJs="false">Monitorowanie zdarzeń dla tego powiadamiacza można opcjonalnie ograniczyć do określonych pór dnia. Ograniczenie monitorowania zdarzeń może na przykład pozwolić na wysyłanie zdarzeń tylko o określonych porach dnia lub do określonych osób w wybranych godzinach, a do innych osób w pozostałych godzinach.</TranslationEntry>
    <TranslationEntry name="2B07BEF5F1B437B6C0666C2FF8B504E1" fullContext="3F08964B61ECE30BC7AEFC2C5668C348" translateForJs="false">Jeśli wybrany jest przedział czasowy, monitorowanie zdarzeń przez ten notyfikator będzie odbywać się tylko wtedy, gdy przedział czasowy jest aktywny. W przeciwnym razie notyfikator będzie zawsze monitorował zdarzenia do wysłania.</TranslationEntry>
    <TranslationEntry name="1CFB97BC6F2DAD438A6C15F0D9E81D37" fullContext="F0ED5D88C595FEAA2A49599C512D5A97" translateForJs="false">Wyślij przez powiadomienie push</TranslationEntry>
    <TranslationEntry name="8831EDF7570E839C8E48A271C87F29B1" fullContext="751AA91D86D0DF7CCF89BDB2E6DB2CDB" translateForJs="false">Jeśli włączone, ten powiadamiacz będzie wysyłał wiadomości do odbiorców dotyczące zdarzeń za pomocą powiadomień push. Aby otrzymywać powiadomienia push, odbiorca musi mieć zainstalowaną aplikację IR Connect na smartfonie i być zalogowany przy użyciu powiązanego konta IR Connect.</TranslationEntry>
    <TranslationEntry name="5B962A8663E3D6A7D83ADA565ECA9302" fullContext="751AA91D86D0DF7CCF89BDB2E6DB2CDB" translateForJs="false">Powiązanie konta IR Connect z użytkownikiem Inception można wykonać na stronie </TranslationEntry>
    <TranslationEntry name="EE01E5AF6990496897455912BECD3BA9" fullContext="751AA91D86D0DF7CCF89BDB2E6DB2CDB" translateForJs="false"> strona. W </TranslationEntry>
    <TranslationEntry name="41952AF2CC7F36275601CFD3D46C6098" fullContext="751AA91D86D0DF7CCF89BDB2E6DB2CDB" translateForJs="false"> sekcji, </TranslationEntry>
    <TranslationEntry name="B0E974E2975BEA0DBF0AFBE18F8BE31F" fullContext="751AA91D86D0DF7CCF89BDB2E6DB2CDB" translateForJs="false">Powiązany użytkownik aplikacji IR Connect</TranslationEntry>
    <TranslationEntry name="2044E29D045F6B7476DB44EE6C7C4E3E" fullContext="751AA91D86D0DF7CCF89BDB2E6DB2CDB" translateForJs="false"> wyświetli aktualnie powiązane konto. Ikona łańcucha po prawej stronie pola umożliwia powiązanie użytkownika z kontem IR Connect.</TranslationEntry>
    <TranslationEntry name="5AFFFFD658823A4D3F0D389DE1DB40A2" fullContext="3B090617F338C0F72F3BF18048FF1CEC" translateForJs="false">Uwaga: Aby włączyć powiadomienia push na smartfonie użytkownika, wymagana jest subskrypcja aplikacji. Aby uzyskać więcej informacji na temat konfiguracji, skontaktuj się z instalatorem systemu zabezpieczeń.</TranslationEntry>
    <TranslationEntry name="6AA14A0B15C4E77ADFD379918974D606" fullContext="3B090617F338C0F72F3BF18048FF1CEC" translateForJs="false">Aplikację IR Connect można pobrać z Apple App Store i Google Play Store.</TranslationEntry>
    <TranslationEntry name="8F88A48A07277042F4A1E60EFCF35190" translateForJs="false">Limit czasu ponownych prób powiadomień push</TranslationEntry>
    <TranslationEntry name="7722A14478129C835BFE9E089ECCF2AC" fullContext="F0ED5D88C595FEAA2A49599C512D5A97" translateForJs="false"> opcja jest włączona, to ustawienie określa, jak długo Inception będzie próbował ponownie wysyłać nieudane powiadomienia push generowane przez ten notyfikator (np. z powodu awarii sieci). Możesz skonfigurować dłuższy czas ponownych prób (do 24 godzin) dla ważniejszych powiadomień, aby mieć pewność, że zostaną wysłane po rozwiązaniu problemów z siecią. Jeśli żadne powiadomienia nie będą mogły zostać pomyślnie wysłane w limicie czasu ponownych prób, wygasną i do rejestru zdarzeń zostanie zapisany błąd. Pamiętaj, że limit czasu ponownych prób dotyczy wyłącznie prawidłowych powiadomień push, które nie powiodły się z powodu problemów z siecią lub usługą SkyTunnel; powiadomienia, które nie powiodły się z powodu brakujących identyfikatorów użytkowników IR Connect lub brakujących subskrypcji, zostaną odrzucone.</TranslationEntry>
    <TranslationEntry name="E2F39278620AFA1386D3AF2B6072635B" fullContext="01DA3EFCCB92F4C44145E8FEE42EC374" translateForJs="false">Wyślij e-mailem</TranslationEntry>
    <TranslationEntry name="9BF8D8C45B2607216E383760B99B9FA4" fullContext="7EBF9ED07FBD80EE987A88B3A4A758E3" translateForJs="false">Jeśli włączone, ten powiadamiacz będzie wysyłał wiadomości do odbiorców dotyczące zdarzeń za pomocą poczty e-mail. Aby korzystać z poczty e-mail jako ścieżki powiadomień, ustawienia serwera e-mail muszą być skonfigurowane na stronie </TranslationEntry>
    <TranslationEntry name="F7BB489711323C127B39C4703D19067F" fullContext="6C879861CD81951790530BF11EF36556" translateForJs="false">[Konfiguracja &gt; Ogólne &gt; System]</TranslationEntry>
    <TranslationEntry name="05C955A3965650FC29A00273105DFAC1" fullContext="7EBF9ED07FBD80EE987A88B3A4A758E3" translateForJs="false">Wiadomości e-mail wysyłane przez ten notyfikator będą używać tematu ustawionego w </TranslationEntry>
    <TranslationEntry name="E3868F7E6E90B6B55F60AC7D71DCB8CE" fullContext="7EBF9ED07FBD80EE987A88B3A4A758E3" translateForJs="false">Temat e-maila</TranslationEntry>
    <TranslationEntry name="B3FF70FDB3C48C4A31E88864153907EB" fullContext="407306CEEB8646899EB30DF13841E356" translateForJs="false"> opcja poniżej. </TranslationEntry>
    <TranslationEntry name="A6B4604488736015456D640018691DA6" fullContext="D3A9D11FEE51AE04EA4DC74475674C8F" translateForJs="false">Aby zapobiec wysyłaniu zbyt wielu e-maili i potencjalnemu zapełnieniu skrzynki odbiorczej lub oznaczeniu skonfigurowanego serwera SMTP jako serwera spamu, Inception będzie starał się grupować wiadomości, jeśli pojawią się blisko siebie. Wiadomości będą grupowane tylko wtedy, gdy są wysyłane na ten sam adres odbiorcy i mają ten sam temat. Wszelkie zgrupowane wiadomości będą zawierać datę i godzinę ich wystąpienia w treści wiadomości.</TranslationEntry>
    <TranslationEntry name="1FB5C41F864185A9A9A05B579FE07D73" fullContext="D3A9D11FEE51AE04EA4DC74475674C8F" translateForJs="false">Gdy ma zostać wysłany e-mail, Inception odczeka 15 sekund na wypadek, gdyby wystąpiły inne zdarzenia dla tego samego adresu odbiorcy i tematu, po czym zgrupuje je w jedną wiadomość e-mail. Po wysłaniu, jeśli pojawią się nowe wiadomości dla tego samego adresu odbiorcy i z tym samym tematem, Inception odczeka przez skonfigurowany </TranslationEntry>
    <TranslationEntry name="C25ACBAB814D02108EE4C0D2BEB2F799" fullContext="267811808BF435241168F3E6ABE443F8" translateForJs="false">Czas limitu częstotliwości</TranslationEntry>
    <TranslationEntry name="D6B7C4420BCDCFD02F5CE7B1EE0B62A4" fullContext="7EBF9ED07FBD80EE987A88B3A4A758E3" translateForJs="false"> (skonfigurowane na </TranslationEntry>
    <TranslationEntry name="4173939CD32CE416565182BEC57E17F5" fullContext="7EBF9ED07FBD80EE987A88B3A4A758E3" translateForJs="false"> strona) przed wysłaniem tych komunikatów.</TranslationEntry>
    <TranslationEntry name="1F911FFA508D8E41693DDB7A63CD9323" fullContext="01DA3EFCCB92F4C44145E8FEE42EC374" translateForJs="false"> opcja jest włączona, będzie to temat używany dla wszystkich e-maili wysyłanych za pomocą tego powiadamiacza. Wybrany temat może służyć np. do wskazania odbiorcy rodzaju otrzymywanego powiadomienia.</TranslationEntry>
    <TranslationEntry name="05D3775555DA51016B32D6E1EF28D269" fullContext="01DA3EFCCB92F4C44145E8FEE42EC374" translateForJs="false">Wiadomości e-mail z tym samym tematem mogą być grupowane razem (patrz opis opcji </TranslationEntry>
    <TranslationEntry name="2AF170BCBDE35917C4809FE3CC18487E" fullContext="01DA3EFCCB92F4C44145E8FEE42EC374" translateForJs="false"> opcja powyżej, aby uzyskać więcej informacji). Aby ograniczyć liczbę wysyłanych wiadomości, temat można ustawić na taki sam, jak w innych powiadamiaczach. W przeciwnym razie, aby wysyłać wiadomości z tego powiadamiacza oddzielnie, można wprowadzić inny temat.</TranslationEntry>
    <TranslationEntry name="5959CF158E76F7C6F27BFF2917EE05B1" translateForJs="false">Odbiorcy</TranslationEntry>
    <TranslationEntry name="A1FC80425A6AC979EE1C3BD5DDE691FE" fullContext="0B9EE021944D5C7819576782B91582A2" translateForJs="false">Określa, którzy użytkownicy powinni otrzymywać powiadomienia od tego notyfikatora. Można wybrać wielu użytkowników do powiadamiania o zdarzeniach, a ten sam użytkownik może być wybrany w wielu notyfikatorach, jeśli to konieczne.</TranslationEntry>
    <TranslationEntry name="8576BA74080ED13F71CDDAFC83507C01" fullContext="0B9EE021944D5C7819576782B91582A2" translateForJs="false">Jeśli ten powiadamiacz wysyła wiadomości e-mail, wybrani użytkownicy muszą mieć przypisany adres e-mail. Ustawienie to jest konfigurowane w </TranslationEntry>
    <TranslationEntry name="94393B2373E3D306F39330083F4A3B8F" fullContext="CA0E31CBDBFC66CFD1BCBCB27F587EF3" translateForJs="false"> ustawienie na </TranslationEntry>
    <TranslationEntry name="CA956302B13A2DE687D445B9B5D4759A" translateForJs="false">Powiadomienia strefy</TranslationEntry>
    <TranslationEntry name="52692C21282D721EB8FC9DD6A1BF7363" fullContext="F7C9A3C70104096CB60C3563E1ADB8FC" translateForJs="false">Jeśli włączone, zdarzenia ze wszystkich stref będą monitorowane w celu sprawdzenia, czy należy wysłać komunikat powiadomienia. W przeciwnym razie można wybrać konkretne strefy do monitorowania za pomocą opcji </TranslationEntry>
    <TranslationEntry name="E6B92884740651885439471C497CFDB8" fullContext="804B247F75883E7DFA70057E09A5E98D" translateForJs="false">Określone strefy</TranslationEntry>
    <TranslationEntry name="A8F96EE4FA0DB72133CDF3C48CA70826" fullContext="3611EA6376CF8B2551D6ED191ADD29B4" translateForJs="false"> opcja poniżej.</TranslationEntry>
    <TranslationEntry name="BFC2A84B9C93148FFC907677CD87900C" fullContext="F7C9A3C70104096CB60C3563E1ADB8FC" translateForJs="false">Aby otrzymywać powiadomienia o zdarzeniach strefowych, należy włączyć tę opcję lub wybrać co najmniej jedną strefę w </TranslationEntry>
    <TranslationEntry name="E27B2A6D0B77B0E20CC4DC2838365DC7" fullContext="4A5AEC4540C3E910D8AD7F82754CA763" translateForJs="false">Filtruje, dla których stref ten powiadamiacz będzie monitorował zdarzenia dotyczące określonych stref. Dostępne tylko jeśli </TranslationEntry>
    <TranslationEntry name="A2D32667760FB796FB4227B4633A73E5" fullContext="4A5AEC4540C3E910D8AD7F82754CA763" translateForJs="false"> opcja powyżej jest wyłączona. Umożliwia to tworzenie różnych elementów powiadamiania monitorujących określone zdarzenia dla określonych stref.</TranslationEntry>
    <TranslationEntry name="B4A473268E27C930F1790A60A57F60F4" fullContext="4A5AEC4540C3E910D8AD7F82754CA763" translateForJs="false">Aby otrzymywać powiadomienia o zdarzeniach stref, należy wybrać co najmniej jedną strefę lub </TranslationEntry>
    <TranslationEntry name="4F03D198AE83DFE5DA9383AAE835D647" fullContext="F8859FDF76E135964A0EF9A871B528E8" translateForJs="false"> opcja powyżej musi być włączona.</TranslationEntry>
    <TranslationEntry name="A431BBF777139A113E5940E4875636D7" fullContext="87AEDCB721CB9FD31587ABC61FC87789" translateForJs="false" rules="unique=AreaArmNotifications" notes="Must be unique amongst all &quot;AreaArmNotifications&quot; entries">Pomyślne uzbrojenia</TranslationEntry>
    <TranslationEntry name="92D6456A87D4C27DA09E56E994A5DAB7" fullContext="87AEDCB721CB9FD31587ABC61FC87789" translateForJs="false" rules="unique=AreaArmNotifications" notes="Must be unique amongst all &quot;AreaArmNotifications&quot; entries">Nieudane uzbrojenia</TranslationEntry>
    <TranslationEntry name="40D56BFE0039E5C310F2A266F1F37100" fullContext="87AEDCB721CB9FD31587ABC61FC87789" translateForJs="false" rules="unique=AreaArmNotifications" notes="Must be unique amongst all &quot;AreaArmNotifications&quot; entries">Wszystkie uzbrojenia</TranslationEntry>
    <TranslationEntry name="D9C67E8E4988F77E277FC51873D419C5" translateForJs="false">Strefa się uzbraja</TranslationEntry>
    <TranslationEntry name="2F62F08932411C1867D695EB1BD5DDD4" fullContext="87AEDCB721CB9FD31587ABC61FC87789" translateForJs="false">Umożliwia użytkownikom otrzymywanie powiadomień o próbach uzbrojenia stref. Strefy, dla których można otrzymywać powiadomienia, są określane przez </TranslationEntry>
    <TranslationEntry name="0AD3716E4A2F1F72A493C4A3D3A80F83" fullContext="1D3A600D943D0FBD2A31F5C07AE102D8" translateForJs="false"> lub </TranslationEntry>
    <TranslationEntry name="242C185C27647746E9789EA11D6F5516" fullContext="1D3A600D943D0FBD2A31F5C07AE102D8" translateForJs="false"> opcje powyżej.</TranslationEntry>
    <TranslationEntry name="9D0F1B00C7870B87F0D0E532037DBB55" fullContext="87AEDCB721CB9FD31587ABC61FC87789" translateForJs="false"> - Zdarzenia uzbrojenia strefy nie będą wysyłane.</TranslationEntry>
    <TranslationEntry name="FE7B8A6C8ACE54071AE52B5CCA099EFD" fullContext="87AEDCB721CB9FD31587ABC61FC87789" translateForJs="false"> - Powiadomienie zostanie wysłane przy każdym pomyślnym uzbrojeniu strefy. Komunikat będzie zawierał informację o tym, która strefa została uzbrojona i kto ją uzbroił (użytkownik, akcja automatyczna lub system)</TranslationEntry>
    <TranslationEntry name="12BDF7BA40E5C1D817061AAFFE1EADC8" fullContext="87AEDCB721CB9FD31587ABC61FC87789" translateForJs="false"> - Powiadomienie zostanie wysłane dla każdej nieudanej próby uzbrojenia strefy. Komunikat będzie zawierał informację o tym, który użytkownik podjął próbę uzbrojenia, która strefa była uzbrajan i dlaczego uzbrojenie nie powiodło się (z powodu nieuszczelnionych linii wejściowych lub braku uprawnień)</TranslationEntry>
    <TranslationEntry name="1EE8373E2BF55163A64E57F1C9325201" fullContext="87AEDCB721CB9FD31587ABC61FC87789" translateForJs="false"> — powiadamiane będą zarówno udane, jak i nieudane próby uzbrojenia</TranslationEntry>
    <TranslationEntry name="D0F2783DBB5CB9847A68D78919DC7C31" fullContext="050816BF79D4ABD532A17036BF0B079E" translateForJs="false" rules="unique=AreaDisarmNotifications" notes="Must be unique amongst all &quot;AreaDisarmNotifications&quot; entries">Tylko po skasowaniu alarmu</TranslationEntry>
    <TranslationEntry name="65F11648B634A4E86350B559EFD0799F" fullContext="050816BF79D4ABD532A17036BF0B079E" translateForJs="false" rules="unique=AreaDisarmNotifications" notes="Must be unique amongst all &quot;AreaDisarmNotifications&quot; entries">Nieudane rozbrojenia</TranslationEntry>
    <TranslationEntry name="5C6D153BDEE8AE9429982FBDC39C0BE5" fullContext="050816BF79D4ABD532A17036BF0B079E" translateForJs="false" rules="unique=AreaDisarmNotifications" notes="Must be unique amongst all &quot;AreaDisarmNotifications&quot; entries">Wszystkie rozbrojenia</TranslationEntry>
    <TranslationEntry name="746EDE2FE55A511757B6E5423D721DD7" translateForJs="false">Strefa się rozbraja</TranslationEntry>
    <TranslationEntry name="D0266D7105919E2AC559B4154E17E866" fullContext="050816BF79D4ABD532A17036BF0B079E" translateForJs="false">Umożliwia użytkownikom otrzymywanie powiadomień o próbach rozbrojenia strefy. Strefy, o których można otrzymywać powiadomienia, są określane przez </TranslationEntry>
    <TranslationEntry name="6E924A7200869841B61E39068D3F64D7" fullContext="050816BF79D4ABD532A17036BF0B079E" translateForJs="false"> - Zdarzenia rozbrojenia strefy nie będą wysyłane.</TranslationEntry>
    <TranslationEntry name="D4B77629D6DC414F898003044741281E" fullContext="050816BF79D4ABD532A17036BF0B079E" translateForJs="false"> - Powiadamiane będą wszelkie rozbrojenia strefy, które anulują aktywny alarm w strefie. Komunikat będzie zawierał informację o tym, która strefa została rozbrojona i kto ją rozbroił (użytkownik, akcja automatyki lub system). Będzie również zawierał informację, że rozbrojenie nastąpiło w celu anulowania aktywnego alarmu.</TranslationEntry>
    <TranslationEntry name="47423627D00699F2C9E5CA04C8178387" fullContext="050816BF79D4ABD532A17036BF0B079E" translateForJs="false"> - Powiadomienie zostanie wysłane dla każdej nieudanej próby rozbrojenia strefy. Komunikat będzie zawierał informację o tym, który użytkownik podjął próbę rozbrojenia i którą strefę próbował rozbroić. Nieudane rozbrojenia mają miejsce z powodu niewystarczających uprawnień.</TranslationEntry>
    <TranslationEntry name="2AD0C5F58B373A625194DCB8935F0018" fullContext="050816BF79D4ABD532A17036BF0B079E" translateForJs="false"> — powiadamiane będą wszystkie próby rozbrojenia, zarówno udane, jak i nieudane</TranslationEntry>
    <TranslationEntry name="054E1D071598A8EF9E798D693A2C707D" fullContext="9F9C56199E156A8B30748F421786B383" translateForJs="false" rules="unique=AreaArmValidationNotifications" notes="Must be unique amongst all &quot;AreaArmValidationNotifications&quot; entries">Uzbrojono poza harmonogramem</TranslationEntry>
    <TranslationEntry name="A219EAD4ED4F5513FA33E27D3D0BFBD2" fullContext="9F9C56199E156A8B30748F421786B383" translateForJs="false" rules="unique=AreaArmValidationNotifications" notes="Must be unique amongst all &quot;AreaArmValidationNotifications&quot; entries">Nie uzbrojono przed końcem harmonogramu</TranslationEntry>
    <TranslationEntry name="8DFC210BFFE796A63B87F389B83B78E4" fullContext="99794750CD35106392FB8DC2FB527BDB" translateForJs="false" rules="unique=AreaArmValidationNotifications" notes="Must be unique amongst all &quot;AreaArmValidationNotifications&quot; entries">Wszystkie walidacje</TranslationEntry>
    <TranslationEntry name="CE5F3133A6D8C1A808D782DF4F21896A" fullContext="F012CE17BAC46737C884149826BB3C28" translateForJs="false">Weryfikacja uzbrojenia</TranslationEntry>
    <TranslationEntry name="2CA0B3FD800FB552D5BDB0ADBEA9DF6A" fullContext="9F9C56199E156A8B30748F421786B383" translateForJs="false">Umożliwia użytkownikom otrzymywanie powiadomień, jeśli strefa nie zostanie uzbrojona o właściwej porze. Obejmuje to sytuację, gdy użytkownik lub system uzbroi strefę o nieprawidłowej porze, lub gdy strefa nie zostanie uzbrojona do określonego czasu. Strefy, dla których można otrzymywać powiadomienia, są określane przez </TranslationEntry>
    <TranslationEntry name="B7FC8465D088FEED2562F94B8A49E3FA" fullContext="9F9C56199E156A8B30748F421786B383" translateForJs="false">Aby korzystać z weryfikacji uzbrojenia, należy ustawić przedział czasowy w </TranslationEntry>
    <TranslationEntry name="A36EA66990D63C9FD760E272644D8CEE" fullContext="9F9C56199E156A8B30748F421786B383" translateForJs="false">Prawidłowy harmonogram uzbrojenia</TranslationEntry>
    <TranslationEntry name="3C196C24106D37AB79037A09F825E4C4" fullContext="9F9C56199E156A8B30748F421786B383" translateForJs="false"> - Nie jest wykonywana żadna weryfikacja uzbrojenia strefy</TranslationEntry>
    <TranslationEntry name="82F9B821A1E07E692803FB3433851D2D" fullContext="9F9C56199E156A8B30748F421786B383" translateForJs="false"> - Komunikat zostanie wysłany, jeśli pomyślne uzbrojenie nastąpi w czasie, gdy przedział czasowy w </TranslationEntry>
    <TranslationEntry name="6E074D94325AA556BD44B0893E305085" fullContext="9F9C56199E156A8B30748F421786B383" translateForJs="false"> opcja jest nieaktywna. Ta opcja umożliwia wysłanie komunikatu, jeśli strefa jest uzbrojona poza normalnym harmonogramem, wskazując na przykład, że sklep zamknął się wcześniej. Komunikat będzie zawierał informację o tym, która strefa była uzbrojona i kto ją uzbroił (użytkownik, automatyczna akcja lub system).</TranslationEntry>
    <TranslationEntry name="7DDC78CCFF90C7C978B3BB1E920D992E" fullContext="9F9C56199E156A8B30748F421786B383" translateForJs="false"> - Komunikat zostanie wysłany, jeśli strefa nie jest uzbrojona, gdy przedział czasowy w </TranslationEntry>
    <TranslationEntry name="A208BD51978F455B85523CA96590D93B" fullContext="9F9C56199E156A8B30748F421786B383" translateForJs="false"> opcja przechodzi ze stanu aktywnego do nieaktywnego. Na przykład, jeśli sklep powinien być zawsze uzbrojony o określonej godzinie, można wysłać komunikat informujący, że system pozostał rozbrojony lub że coś jest niezgodne z normą.</TranslationEntry>
    <TranslationEntry name="C2CED78A07012446756D056B8C418DAF" fullContext="9F9C56199E156A8B30748F421786B383" translateForJs="false"> - Oba typy weryfikacji uzbrojenia strefy będą przetwarzane i raportowane</TranslationEntry>
    <TranslationEntry name="8C40042D74B1F78DF7D9574172F8A5B8" fullContext="F012CE17BAC46737C884149826BB3C28" translateForJs="false">Ustawia przedział czasowy, w którym dozwolone jest uzbrajanie stref. Zob. </TranslationEntry>
    <TranslationEntry name="5BA19AAC0DE4D1FAFBC1AEA84A648AEA" fullContext="B07B8963E64749CF9700DBD25E834258" translateForJs="false"> opcja powyżej zawiera więcej informacji o typach walidacji, o których można otrzymywać powiadomienia.</TranslationEntry>
    <TranslationEntry name="561F04BC9A88400577EC5E1B317D1671" fullContext="99794750CD35106392FB8DC2FB527BDB" translateForJs="false" rules="unique=AreaDisarmValidationNotifications" notes="Must be unique amongst all &quot;AreaDisarmValidationNotifications&quot; entries">Rozbrojono poza harmonogramem</TranslationEntry>
    <TranslationEntry name="5FA75E857387B4CEBAB15F011B35448B" fullContext="99794750CD35106392FB8DC2FB527BDB" translateForJs="false" rules="unique=AreaDisarmValidationNotifications" notes="Must be unique amongst all &quot;AreaDisarmValidationNotifications&quot; entries">Nie rozbroiono przed końcem harmonogramu</TranslationEntry>
    <TranslationEntry name="33B0F7C6D4015029E06986199654F70C" fullContext="B07B8963E64749CF9700DBD25E834258" translateForJs="false">Weryfikacja rozbrojenia</TranslationEntry>
    <TranslationEntry name="6636BF520789ED4C9FD08F84D19D1558" fullContext="99794750CD35106392FB8DC2FB527BDB" translateForJs="false">Umożliwia użytkownikom otrzymywanie powiadomień, jeśli strefa nie zostanie rozbrojona o właściwej porze. Obejmuje to sytuację, gdy użytkownik lub system rozbroi strefę o nieprawidłowej porze, lub gdy strefa nie zostanie rozbrojona do określonego czasu. Strefy, dla których można otrzymywać powiadomienia, są określane przez </TranslationEntry>
    <TranslationEntry name="ADE11BB913F8AAB110F8017545AD1002" fullContext="99794750CD35106392FB8DC2FB527BDB" translateForJs="false">Aby korzystać z weryfikacji rozbrojenia, należy ustawić przedział czasowy w </TranslationEntry>
    <TranslationEntry name="C07A14530EC5461CED3965F34496BF4B" fullContext="99794750CD35106392FB8DC2FB527BDB" translateForJs="false">Prawidłowy harmonogram rozbrojenia</TranslationEntry>
    <TranslationEntry name="18D2A17221213C5AE0FEC9BFEF7F9DEA" fullContext="99794750CD35106392FB8DC2FB527BDB" translateForJs="false"> — nie jest wykonywana walidacja rozbrojenia strefy</TranslationEntry>
    <TranslationEntry name="D2C1F27D4A6CC497F85687C85A9CD330" fullContext="99794750CD35106392FB8DC2FB527BDB" translateForJs="false"> - Komunikat zostanie wysłany, jeśli pomyślne rozbrojenie nastąpi w czasie, gdy przedział czasowy w </TranslationEntry>
    <TranslationEntry name="CF09206D063D515BCB5065405922C84F" fullContext="99794750CD35106392FB8DC2FB527BDB" translateForJs="false"> opcja jest nieaktywna. Opcja ta umożliwia wysłanie komunikatu, jeśli strefa zostanie rozbrojona poza normalnym harmonogramem — na przykład sygnalizując, że ktoś potencjalnie uzyskuje dostęp do sklepu w nieuprawnionym czasie. Komunikat będzie zawierał informację o tym, która strefa została rozbrojona i kto ją rozbroił (użytkownik lub akcja automatyki).</TranslationEntry>
    <TranslationEntry name="13F53B11AB6C204F272320C2CF343D84" fullContext="99794750CD35106392FB8DC2FB527BDB" translateForJs="false"> — zostanie wysłana wiadomość, jeśli strefa nie zostanie rozbrojona w czasie określonym w </TranslationEntry>
    <TranslationEntry name="9FA57629E3CAE14BB53722C5CA203DE0" fullContext="99794750CD35106392FB8DC2FB527BDB" translateForJs="false"> opcja przechodzi ze stanu aktywnego do nieaktywnego. Na przykład, jeśli sklep powinien być zawsze rozbrojony o określonej godzinie na początku godzin pracy, można wysłać komunikat informujący, że system nie został jeszcze rozbrojony i otwarty.</TranslationEntry>
    <TranslationEntry name="DA0E5CF96547F919E5C28718FC30290E" fullContext="99794750CD35106392FB8DC2FB527BDB" translateForJs="false"> - Oba typy weryfikacji rozbrojenia strefy będą przetwarzane i raportowane</TranslationEntry>
    <TranslationEntry name="6685E9E79EACD4677CD47EEDAB4A0D0B" fullContext="B07B8963E64749CF9700DBD25E834258" translateForJs="false">Ustawia przedział czasowy, w którym dozwolone jest rozbrajanie stref. Zob. </TranslationEntry>
    <TranslationEntry name="3A35065CA8A981CF593616E6D9F72A5E" translateForJs="false">Izolacje linii wejściowych</TranslationEntry>
    <TranslationEntry name="8DFF326CB154A03382157B9DB1B91A21" fullContext="941357F4B66A88DA4134D88C236C1B95" translateForJs="false">Umożliwia powiadamianie użytkowników o zaizolowaniu linii wejściowej w strefie. Pozwala to użytkownikowi wiedzieć, że część systemu może nie być monitorowana w chwili uzbrojenia strefy. Strefy, dla których mogą być wysyłane powiadomienia, są określone przez </TranslationEntry>
    <TranslationEntry name="76DFD4B4E640CE1ADB23CB8E62192305" fullContext="941357F4B66A88DA4134D88C236C1B95" translateForJs="false">Tymczasowe izolacje mogą nastąpić, jeśli linia wejściowa nie była bezpieczna podczas uzbrajania strefy, wymagając zaizolowania linii wejściowej, aby uzbrojenie mogło zostać zakończone. Stałe izolacje są również zgłaszane, często z powodu wadliwej linii wejściowej, aby zapobiec konieczności jej tymczasowego izolowania przy każdym uzbrojeniu strefy.</TranslationEntry>
    <TranslationEntry name="FA2B06E1BEEDAC10ECC3499E7A34C599" fullContext="33A8697ECBCBF7F52026C2BFCA6005C9" translateForJs="false" rules="unique=InputsWhenToSend" notes="Must be unique amongst all &quot;InputsWhenToSend&quot; entries">Tylko pierwsze zdarzenie w strefie</TranslationEntry>
    <TranslationEntry name="F62708131B13934950FA92671966ECC9" fullContext="D4DB8891EECBE1FFEA99117C0C432C82" translateForJs="false" rules="unique=InputsWhenToSend" notes="Must be unique amongst all &quot;InputsWhenToSend&quot; entries">Wszystkie zdarzenia</TranslationEntry>
    <TranslationEntry name="47BC6D618CD68A9CFDD5FB019788A706" fullContext="804B247F75883E7DFA70057E09A5E98D" translateForJs="false">Zdarzenia linii wejściowych</TranslationEntry>
    <TranslationEntry name="5A07095C66B72ED291E5C4EDE96FB29B" fullContext="33A8697ECBCBF7F52026C2BFCA6005C9" translateForJs="false">Umożliwia użytkownikom otrzymywanie powiadomień, gdy zdarzenia alarmowe linii wejściowych wystąpią w strefie. Strefy, dla których można otrzymywać powiadomienia, są określane przez </TranslationEntry>
    <TranslationEntry name="172B01B9177A3E4C06126D4C4705CD54" fullContext="33A8697ECBCBF7F52026C2BFCA6005C9" translateForJs="false">Ta opcja określa jedynie liczbę zdarzeń alarmowych, które powinny być wysyłane, natomiast </TranslationEntry>
    <TranslationEntry name="9649BCC5920BBC0E737691ADC569BE0D" fullContext="804B247F75883E7DFA70057E09A5E98D" translateForJs="false">Typy zdarzeń linii wejściowej</TranslationEntry>
    <TranslationEntry name="E6892FD7553C591C00BFD3E775608996" fullContext="33A8697ECBCBF7F52026C2BFCA6005C9" translateForJs="false"> opcja poniżej określa, jakie typy zdarzeń powinny być monitorowane.</TranslationEntry>
    <TranslationEntry name="D19F0EDAF90723327E6D1014B3122F9C" fullContext="33A8697ECBCBF7F52026C2BFCA6005C9" translateForJs="false"> - Zdarzenia linii wejściowych strefy nie powinny być wysyłane.</TranslationEntry>
    <TranslationEntry name="B937A14E5FD664CE664A39244614B528" fullContext="33A8697ECBCBF7F52026C2BFCA6005C9" translateForJs="false"> - Aby zapobiec generowaniu zbyt wielu wiadomości, ta opcja pozwala wysyłać tylko pierwsze zdarzenie linii wejściowej pasujące do typów wybranych w </TranslationEntry>
    <TranslationEntry name="B6A4B69A26A4AC35B6E64DF395462A7F" fullContext="33A8697ECBCBF7F52026C2BFCA6005C9" translateForJs="false"> poniższa opcja ma zostać wysłana. Zostanie ona zresetowana po rozbronieniu strefy. Jeśli monitorowanych jest wiele stref, na strefę zostanie wysłane co najwyżej jedno zdarzenie.</TranslationEntry>
    <TranslationEntry name="C6CA65B1D278EE5E4F0E6A75CF09720F" fullContext="33A8697ECBCBF7F52026C2BFCA6005C9" translateForJs="false"> — Wszelkie zdarzenia linii wejściowych pasujące do jednego z typów wybranych w </TranslationEntry>
    <TranslationEntry name="94A99796BDDB9AA5ADC13463A9445273" fullContext="33A8697ECBCBF7F52026C2BFCA6005C9" translateForJs="false"> opcja poniżej zostanie wysłana.</TranslationEntry>
    <TranslationEntry name="C2C389EEE374A8998EEF647A9EEC1D24" fullContext="D5A201BB1A9B3F91A2C8A164E3215DD2" translateForJs="false">Umożliwia użytkownikowi otrzymywanie powiadomień wyłącznie o określonych typach zdarzeń linii wejściowych w strefie. Strefy, o których można otrzymywać powiadomienia, są określane przez </TranslationEntry>
    <TranslationEntry name="9CA70A6D957D618AF6981DC62B0564EA" fullContext="D5A201BB1A9B3F91A2C8A164E3215DD2" translateForJs="false">Dla tego notyfikatora można wybrać wiele typów zdarzeń linii wejściowych do monitorowania, podczas gdy </TranslationEntry>
    <TranslationEntry name="47727074309C24FFB8B233D9CA408FC9" fullContext="D5A201BB1A9B3F91A2C8A164E3215DD2" translateForJs="false"> powyższa opcja określa, ile zdarzeń alarmowych należy wysłać na strefę. Różne linie wejściowe mogą raportować różne typy zdarzeń, w zależności od </TranslationEntry>
    <TranslationEntry name="33D209F1789F602AFBD65D3F1A4943A8" fullContext="D5A201BB1A9B3F91A2C8A164E3215DD2" translateForJs="false"> powiązanych z tą linią wejściową w strefie.</TranslationEntry>
    <TranslationEntry name="B5739BCC00AA7DD3D75F8C709E4FE61D" fullContext="D5A201BB1A9B3F91A2C8A164E3215DD2" translateForJs="false"> - Zgłaszane, gdy linia wejściowa z typem </TranslationEntry>
    <TranslationEntry name="32DA49FECA05E850327C11B0277B6EF4" fullContext="D5A201BB1A9B3F91A2C8A164E3215DD2" translateForJs="false"> wyzwala alarm strefy</TranslationEntry>
    <TranslationEntry name="862C4DDAA0A47770924AF8C6DE4C8F3F" fullContext="D5A201BB1A9B3F91A2C8A164E3215DD2" translateForJs="false"> - Raportowane, gdy linia wejściowa z rezystorami końca linii wyzwala stan sabotażu, przy dowolnym typie linii wejściowej innym niż </TranslationEntry>
    <TranslationEntry name="CB9AC24BFC58B856A9AB6DD1D45F1C11" fullContext="D5A201BB1A9B3F91A2C8A164E3215DD2" translateForJs="false"> - Zgłaszane, jeśli linia wejściowa jest linią RF wyzwalającą stan niskiego poziomu naładowania baterii, przy dowolnym typie linii wejściowej innym niż </TranslationEntry>
    <TranslationEntry name="1F0219F6F37D91C66CEB0DC81EA97EED" fullContext="D5A201BB1A9B3F91A2C8A164E3215DD2" translateForJs="false"> - Zgłaszane, gdy linia wejściowa jest linią RF, która nie odpowiada do odbiornika RF, przy dowolnym typie linii wejściowej innym niż </TranslationEntry>
    <TranslationEntry name="DCDD70C972F561E631A9E6ABAADD940D" fullContext="D5A201BB1A9B3F91A2C8A164E3215DD2" translateForJs="false"> - Tylko rynki europejskie. Zgłaszane, gdy linia wejściowa z rezystorami końca linii wyzwala stan maskowania, co wskazuje na możliwe zakrycie czujki.</TranslationEntry>
    <TranslationEntry name="1ED65C7DE77BCD63F56800B35024505E" translateForJs="false">Zdarzenia przywrócenia linii wejściowej</TranslationEntry>
    <TranslationEntry name="C1519299E9D3939BEFC6AB9D1CDDCA48" fullContext="804B247F75883E7DFA70057E09A5E98D" translateForJs="false">Umożliwia powiadamianie użytkowników również wtedy, gdy zdarzenie linii wejściowej zostaje przywrócone. W przypadku zdarzeń środowiskowych, takich jak czujniki temperatury lub wody, wiedza o przywróceniu stanu może być pomocna. W przypadku standardowych zdarzeń włamania jest to mniej przydatne, gdyż podwaja liczbę otrzymywanych powiadomień i ważniejsze jest wiedzieć, gdy drzwi się otworzyły lub wykryto ruch, niż gdy drzwi się zamknęły lub ruch ustał.</TranslationEntry>
    <TranslationEntry name="9F08E2CA4E79F6AA0A6AB0F3E4CDBC6B" fullContext="804B247F75883E7DFA70057E09A5E98D" translateForJs="false">Strefy, o których można otrzymywać powiadomienia, są określane przez </TranslationEntry>
    <TranslationEntry name="B3C335DDCBBDBAFF7D2961800F8CD1B9" fullContext="804B247F75883E7DFA70057E09A5E98D" translateForJs="false">Zdarzenia przywrócenia będą wysyłane tylko dla typów linii wejściowych wybranych w </TranslationEntry>
    <TranslationEntry name="4DBB7DADDF6CC5EEF176A49B5B2A86AB" fullContext="804B247F75883E7DFA70057E09A5E98D" translateForJs="false"> opcja powyżej. Ilość zdarzeń przywrócenia jest również ograniczona przez powyższe </TranslationEntry>
    <TranslationEntry name="3D15392494F1FBB06D5D667F48969712" translateForJs="false">Powiadomienia przejścia</TranslationEntry>
    <TranslationEntry name="605F51D15376073B516D3B2D7AE0FA8C" fullContext="3611EA6376CF8B2551D6ED191ADD29B4" translateForJs="false">Jeśli włączone, zdarzenia ze wszystkich przejść będą monitorowane, aby sprawdzić, czy należy wysłać komunikat powiadomienia. W przeciwnym razie konkretne przejścia do monitorowania można wybrać przy użyciu </TranslationEntry>
    <TranslationEntry name="B64B6ED2AEB063FC246DEDAA67B44F1E" fullContext="1D3A600D943D0FBD2A31F5C07AE102D8" translateForJs="false">Określone przejścia</TranslationEntry>
    <TranslationEntry name="B03473AC3362E12B6EA48D8F8FF10F00" fullContext="3611EA6376CF8B2551D6ED191ADD29B4" translateForJs="false">Aby powiadamiać o zdarzeniach przejść, musi być włączona ta opcja lub w </TranslationEntry>
    <TranslationEntry name="009169970497EC07C31FF77B66C10778" fullContext="F8859FDF76E135964A0EF9A871B528E8" translateForJs="false">Filtruje, które przejścia ten powiadamiacz będzie monitorował pod kątem zdarzeń dotyczących określonych przejść. Dostępne tylko jeśli </TranslationEntry>
    <TranslationEntry name="2337356B6E54166B38ACAB931BD086C7" fullContext="F8859FDF76E135964A0EF9A871B528E8" translateForJs="false"> opcja powyżej jest wyłączona. Pozwala to na tworzenie różnych elementów powiadamiania monitorujących konkretne zdarzenia dla konkretnych przejść.</TranslationEntry>
    <TranslationEntry name="AEF3A42B0E6124DEE818227C28092068" fullContext="F8859FDF76E135964A0EF9A871B528E8" translateForJs="false">Aby powiadamiać o zdarzeniach przejścia, należy wybrać co najmniej jedno przejście lub zaznaczyć opcję </TranslationEntry>
    <TranslationEntry name="60B75AFF3AFF5CECD9E21D6E516EB0C6" fullContext="1A7AA87A1BAEE613B39EB18902481FD8" translateForJs="false" rules="unique=DoorHeldEvents" notes="Must be unique amongst all &quot;DoorHeldEvents&quot; entries">Gdy ostrzeżenie się zaczyna</TranslationEntry>
    <TranslationEntry name="C89C893C99BDFF12032C0AC465156255" fullContext="1A7AA87A1BAEE613B39EB18902481FD8" translateForJs="false" rules="unique=DoorHeldEvents" notes="Must be unique amongst all &quot;DoorHeldEvents&quot; entries">Po zakończeniu ostrzeżenia</TranslationEntry>
    <TranslationEntry name="5E25DEB3421D40FF706F041A10C5B74E" fullContext="1A7AA87A1BAEE613B39EB18902481FD8" translateForJs="false" rules="unique=DoorHeldEvents" notes="Must be unique amongst all &quot;DoorHeldEvents&quot; entries">Na początku i na końcu ostrzeżenia</TranslationEntry>
    <TranslationEntry name="471D6A451CE6DAB99D1AB136150B39BF" translateForJs="false">Drzwi przytrzymane (DOTL)</TranslationEntry>
    <TranslationEntry name="AF3F1A050E614EB74E4B980833F1C2EE" fullContext="1A7AA87A1BAEE613B39EB18902481FD8" translateForJs="false">Umożliwia powiadamianie użytkowników, jeśli drzwi były przytrzymane otwarte zbyt długo. Przejścia, o których można otrzymywać powiadomienia, są określone przez </TranslationEntry>
    <TranslationEntry name="DCFEF5DEC0E52F78EE60E5568BCA9B4D" fullContext="1A7AA87A1BAEE613B39EB18902481FD8" translateForJs="false">O tym, czy drzwi są zbyt długo otwarte, decyduje ustawienie </TranslationEntry>
    <TranslationEntry name="3C45118FB1724E0E88F784C65BA5E767" fullContext="1A7AA87A1BAEE613B39EB18902481FD8" translateForJs="false"> opcji przejścia. Po upływie czasu przytrzymania rozpoczyna się faza ostrzeżenia, aby powiadomić pobliskich użytkowników o otwartych drzwiach, często za pomocą sygnalizatorów dźwiękowych. Ta faza ostrzeżenia pozwala użytkownikom zamknąć drzwi, zanim problem się nasili, ewentualnie powiadamiając stację monitorowania o problemie lub wysyłając powiadomienia.</TranslationEntry>
    <TranslationEntry name="5301EAECFB6979BB0C833FF380901BB9" fullContext="357AA7F5515725EDBE9C6D24AFC35A40" translateForJs="false"> — Nie będą wysyłane żadne zdarzenia dostępu użytkownika.</TranslationEntry>
    <TranslationEntry name="683CC66BB3AC17E741989026C7ADE71F" fullContext="1A7AA87A1BAEE613B39EB18902481FD8" translateForJs="false"> - Powiadomienie zostanie wysłane po rozpoczęciu fazy ostrzeżenia o zbyt długim otwarciu przejścia. Może to umożliwić pobliskiemu użytkownikowi zamknięcie drzwi przed eskalacją zdarzenia.</TranslationEntry>
    <TranslationEntry name="2EB4917672C45EB1DF1A95D88911094A" fullContext="1A7AA87A1BAEE613B39EB18902481FD8" translateForJs="false"> - Powiadomienie zostanie wysłane, gdy drzwi będą przytrzymane zbyt długo i nikt ich nie zamknął. Zdarzenie jest wysyłane po zakończeniu fazy ostrzegawczej lub natychmiast, jeśli faza ostrzegawcza nie jest skonfigurowana.</TranslationEntry>
    <TranslationEntry name="4BDAC6E63E205670FC1B93D746E57C7F" fullContext="1A7AA87A1BAEE613B39EB18902481FD8" translateForJs="false"> — Powiadomienie zostanie wysłane po rozpoczęciu i zakończeniu fazy ostrzeżenia o przytrzymaniu.</TranslationEntry>
    <TranslationEntry name="95D755E4BCDAC248FD320186E9BC8920" fullContext="357AA7F5515725EDBE9C6D24AFC35A40" translateForJs="false" rules="unique=AccessEvents" notes="Must be unique amongst all &quot;AccessEvents&quot; entries">Wszystkie zdarzenia dostępu</TranslationEntry>
    <TranslationEntry name="4AF6A07317F7DC77952F64A4299A3D6A" fullContext="357AA7F5515725EDBE9C6D24AFC35A40" translateForJs="false">Umożliwia użytkownikom otrzymywanie powiadomień o próbach dostępu użytkownika. Przejścia, o których można otrzymywać powiadomienia, są określone przez </TranslationEntry>
    <TranslationEntry name="5B2B4184FEA3B1ED83D4EC8797A1095B" fullContext="357AA7F5515725EDBE9C6D24AFC35A40" translateForJs="false"> - Powiadomienie zostanie wysłane przy każdej udanej próbie dostępu użytkownika przez przejście. Komunikat będzie zawierał informację o tym, które przejście zostało udostępnione i kto uzyskał dostęp</TranslationEntry>
    <TranslationEntry name="5C1E96D6C4D319BF49E94B3A84C4D389" fullContext="357AA7F5515725EDBE9C6D24AFC35A40" translateForJs="false"> - Powiadomienie zostanie wysłane dla każdej próby dostępu użytkownika, której odmówiono przez przejście. Komunikat będzie zawierał informację o przejściu, przy którym podjęto próbę, kto złożył żądanie i dlaczego żądanie nie powiodło się (z powodu blokady przejścia, uzbrojenia strefy po drugiej stronie przejścia lub braku uprawnień)</TranslationEntry>
    <TranslationEntry name="FECCF69D7A87B0CC97C21CF294179678" fullContext="357AA7F5515725EDBE9C6D24AFC35A40" translateForJs="false"> — Powiadamiane będą zarówno udane, jak i nieudane próby dostępu przez przejście</TranslationEntry>
    <TranslationEntry name="FFA0F506A9F342873481D843673B24AB" fullContext="FFA0F506A9F342873481D843673B24AB" translateForJs="false">Naruszenia anti-passback</TranslationEntry>
    <TranslationEntry name="F64601BC81C39A06E686DD064063BB30" fullContext="6688DEF26EF250DB143F5DC5EE9F6337" translateForJs="false">Umożliwia powiadamianie użytkowników, jeśli użytkownik wywołał naruszenie anti-passback przy przejściu. Przejścia, o których można otrzymywać powiadomienia, są określone przez </TranslationEntry>
    <TranslationEntry name="439612A2C0F80F13854033D9BD9152DA" fullContext="6688DEF26EF250DB143F5DC5EE9F6337" translateForJs="false">Zdarzenie zawiera informacje o użytkowniku, który spowodował naruszenie, przejściu, na którym doszło do zdarzenia, strefie, do której wchodził, oraz ostatniej znanych lokalizacji użytkownika.</TranslationEntry>
    <TranslationEntry name="2ED7688931E6F0BD94A498FF521E543D" fullContext="6688DEF26EF250DB143F5DC5EE9F6337" translateForJs="false">Logika anti-passback musi być włączona na przejściu, aby mogło dochodzić do naruszeń. Zobacz </TranslationEntry>
    <TranslationEntry name="04100F43A502C8AB2A574D499B0CDC89" fullContext="6688DEF26EF250DB143F5DC5EE9F6337" translateForJs="false"> sekcji na stronie </TranslationEntry>
    <TranslationEntry name="D4F3B8DCADA1BFF36167D5DEB59AFDCC" fullContext="6688DEF26EF250DB143F5DC5EE9F6337" translateForJs="false">[Konfiguracja &gt; Kontrola dostępu &gt; Przejście]</TranslationEntry>
    <TranslationEntry name="F60A3C93D19B8B4545EA60B506129E02" fullContext="F60A3C93D19B8B4545EA60B506129E02" translateForJs="false" rules="unique=ScheduledDoorEvents" notes="Must be unique amongst all &quot;ScheduledDoorEvents&quot; entries">Swobodny dostęp</TranslationEntry>
    <TranslationEntry name="3F6B4DE88508A478E4D92D3A65E3F0BB" translateForJs="false">Zdarzenia zaplanowane</TranslationEntry>
    <TranslationEntry name="D9279F707E79C36D09DB7AE90AABC6FF" fullContext="1D3A600D943D0FBD2A31F5C07AE102D8" translateForJs="false" rules="unique=DoorOverrides" notes="Must be unique amongst all &quot;DoorOverrides&quot; entries">Tylko blokady przejść</TranslationEntry>
    <TranslationEntry name="6C37CBDA8237A098B8B2A811927B1D3C" fullContext="1D3A600D943D0FBD2A31F5C07AE102D8" translateForJs="false" rules="unique=DoorOverrides" notes="Must be unique amongst all &quot;DoorOverrides&quot; entries">Wszystkie zdarzenia nadpisania</TranslationEntry>
    <TranslationEntry name="FD0C51D8C1768225747C8CE65183404A" translateForJs="false">Nadpisania stanu przejścia</TranslationEntry>
    <TranslationEntry name="0C625476FB73C47DFB7EEACF16A4A29B" fullContext="1D3A600D943D0FBD2A31F5C07AE102D8" translateForJs="false">Umożliwia powiadamianie użytkowników, gdy stan przejścia został nadpisany przez użytkownika lub system. Dotyczy to na przykład nadpisania przejścia do stanu odblokowanego, gdy normalnie jest zablokowane, lub zablokowanego, gdy normalnie jest odblokowane. Obejmuje również blokadę przejścia uniemożliwiającą jakiemukolwiek użytkownikowi uzyskanie dostępu. Przejścia, dla których można skonfigurować powiadomienia, są określane przez </TranslationEntry>
    <TranslationEntry name="81E46708FAF6028C4BD6463A61A4C3DB" fullContext="1D3A600D943D0FBD2A31F5C07AE102D8" translateForJs="false"> — Nie będą wysyłane żadne zdarzenia zastąpienia przejścia.</TranslationEntry>
    <TranslationEntry name="1BA87B1E60F6D8F6403110DFC1D0903E" fullContext="1D3A600D943D0FBD2A31F5C07AE102D8" translateForJs="false"> - Użytkownicy będą powiadamiani, gdy przejście zostanie ustawione w stan Zablokowane — brak dostępu. Stan ten uniemożliwia jakiemukolwiek użytkownikowi uzyskanie dostępu przez przejście, pozwalając na jego awaryjne zamknięcie. Wszelkie próby dostępu użytkowników, którym pomimo tego zostanie przyznany dostęp przez przejście, będą powiadamiane. Komunikat będzie zawierał informację, które przejście zostało zablokowane i kto je zablokował.</TranslationEntry>
    <TranslationEntry name="A5199AFE469FB01A640DB9CD3C2B3959" fullContext="1D3A600D943D0FBD2A31F5C07AE102D8" translateForJs="false"> - Użytkownicy będą powiadamiani o wszystkich zdarzeniach nadpisania przejścia. Obejmuje to nadpisanie stanu przejścia na Zablokowane, Odblokowane i Wyłączone z dostępu, a także usunięcie nadpisania w celu powrotu do normalnego zachowania. Komunikat będzie zawierał informacje o tym, które przejście zostało nadpisane, w jaki sposób zostało nadpisane i kto je sterował.</TranslationEntry>
    <TranslationEntry name="D580AFB56BBDFE51D71397D5DC7DDE38" translateForJs="false">Użycie nieaktywnych identyfikatorów</TranslationEntry>
    <TranslationEntry name="7E7C885579A454FB96EFEABDAA1585ED" fullContext="27EC12B8EB7D9E291A0905D1E870320F" translateForJs="false">Jeśli włączone, umożliwia powiadamianie użytkowników, jeśli użytkownik wykona odczyt karty przy czytniku przy przejściu z nieaktywnym identyfikatorem (tj. zgubionym/skradzionym).</TranslationEntry>
    <TranslationEntry name="64055278FFFCDBAA1EBCCA1F65E00156" fullContext="27EC12B8EB7D9E291A0905D1E870320F" translateForJs="false">Zdarzenie zawiera informacje o użytym identyfikatorze, użytkowniku powiązanym z identyfikatorem oraz przejściu/czytniku, przy którym identyfikator został odczytany.</TranslationEntry>
    <TranslationEntry name="6065CB60F3B2EDB721B2CD30BC7430A6" translateForJs="false">Powiadomienia sprzętowe</TranslationEntry>
    <TranslationEntry name="CF618E724C6CA2502CC4C6308548C3B2" fullContext="E59785D4EA80BD19D642C88F17A6658B" translateForJs="false">Umożliwia powiadamianie użytkowników, gdy dowolny moduł przejdzie w tryb offline lub wróci do trybu online. </TranslationEntry>
    <TranslationEntry name="0CC2EC0E3208600FB9059D99279E0E92" fullContext="E59785D4EA80BD19D642C88F17A6658B" translateForJs="false">Moduł jest uważany za offline, jeśli nie skontaktuje się z kontrolerem w skonfigurowanym </TranslationEntry>
    <TranslationEntry name="FB8A742BF429475117D5ABE104A435C3" fullContext="E59785D4EA80BD19D642C88F17A6658B" translateForJs="false">Czas odpytywania</TranslationEntry>
    <TranslationEntry name="389C346A901443F41AB18BCE07720236" fullContext="E59785D4EA80BD19D642C88F17A6658B" translateForJs="false">, i pozostaje offline aż do </TranslationEntry>
    <TranslationEntry name="D22C093CBF18ADCC4CA5AFC11103FD0F" fullContext="138C9AA045465A7099E9E960F11F4024" translateForJs="false">Czas awarii modułu</TranslationEntry>
    <TranslationEntry name="D2677CFE7880E6ADFDCD895319BD118C" fullContext="E59785D4EA80BD19D642C88F17A6658B" translateForJs="false"> wygasa (można skonfigurować na stronie </TranslationEntry>
    <TranslationEntry name="4BF91284C754F818DDDE8FF6E73B9A82" fullContext="69856929F2617ED37B376A6385AA13B5" translateForJs="false"> strona).</TranslationEntry>
    <TranslationEntry name="6051E897FF679DF055F99FDBAD013DB0" translateForJs="false">Problemy z zasilaniem i akumulatorem</TranslationEntry>
    <TranslationEntry name="F7F841346F702B3A0D3A14B671426341" fullContext="E544D23942C5970F5A73EBD6A40B9667" translateForJs="false">Umożliwia użytkownikom otrzymywanie powiadomień o problemach z zasilaniem lub baterią dotyczących dowolnego modułu w systemie. Komunikaty powiadomień będą wysyłane zarówno w momencie wystąpienia problemu, jak i po jego usunięciu.</TranslationEntry>
    <TranslationEntry name="D6D3011B5EBCDCC42A26454ABD4BFDE3" fullContext="E544D23942C5970F5A73EBD6A40B9667" translateForJs="false">Problemy z zasilaniem i baterią modułu obejmują następujące sytuacje:</TranslationEntry>
    <TranslationEntry name="B8EB979FA01DAE0651F5BACB17887168" fullContext="B8EB979FA01DAE0651F5BACB17887168" translateForJs="false" rules="unique=ModuleTroubleType" notes="Must be unique amongst all &quot;ModuleTroubleType&quot; entries">Brak zasilania sieciowego</TranslationEntry>
    <TranslationEntry name="BD2E4FCF87C2F729302F9C4DA26D9D6B" fullContext="E544D23942C5970F5A73EBD6A40B9667" translateForJs="false">Wykryto zwarcie</TranslationEntry>
    <TranslationEntry name="1678E59980A9F84E0AF3F9D204019D4D" translateForJs="false">Sabotaże systemowe</TranslationEntry>
    <TranslationEntry name="0274B3DD0A0695FA3305E57EB1A947F2" fullContext="38837701457B050963CA7196C2382628" translateForJs="false">Umożliwia użytkownikom otrzymywanie powiadomień o zdarzeniach sabotażu systemu dla dowolnego modułu w systemie. Komunikaty powiadomień będą wysyłane zarówno gdy problem wystąpi, jak i gdy zostanie przywrócony.</TranslationEntry>
    <TranslationEntry name="88AB951239851A0DC7C55D7B61F38B6A" fullContext="38837701457B050963CA7196C2382628" translateForJs="false">Sabotaże systemowe są często wskaźnikami możliwego naruszenia bezpieczeństwa systemu. Zdarzenia sabotażu systemowego obejmują dowolne z poniższych:</TranslationEntry>
    <TranslationEntry name="E853AB9C74712F990E881A0D3EDA076E" fullContext="A5EAE51CA0C684CD98579E6A92A79B56" translateForJs="false">Umożliwia powiadamianie użytkowników w przypadku wykrycia potencjalnego podstawienia modułu.</TranslationEntry>
    <TranslationEntry name="4629B671C7012126509C0F8D10C95E48" fullContext="A5EAE51CA0C684CD98579E6A92A79B56" translateForJs="false">Podczas uruchomienia systemu, gdy wszystkie moduły sprzętowe są skonfigurowane i online, przeprowadzany jest proces zabezpieczenia LAN w celu identyfikacji wszystkich obecnych modułów. Następnie, jeśli połączy się moduł, który nie był online podczas procesu zabezpieczenia LAN, jest on uznawany za podmieniony. Może to być częścią konserwacji, np. wymiana uszkodzonego modułu, lub może stanowić zagrożenie dla bezpieczeństwa obiektu poprzez zastąpienie istniejącego modułu fałszywą wersją.</TranslationEntry>
    <TranslationEntry name="DEF12E9161C451080A92AEF66CF22F50" fullContext="A5EAE51CA0C684CD98579E6A92A79B56" translateForJs="false">W przypadku wykrycia błędu podstawienia modułu technik musi sprawdzić sprzęt i sieć LAN, aby upewnić się, że system jest bezpieczny, a następnie przeprowadzić nowy proces zabezpieczania LAN.</TranslationEntry>
    <TranslationEntry name="AC5D3BCB1B4A8449FD4FF437E455AA5F" translateForJs="false">Blokada PIN terminala LCD</TranslationEntry>
    <TranslationEntry name="F6ADB2598BF449080AA575AB9B62D8B7" fullContext="CA0E31CBDBFC66CFD1BCBCB27F587EF3" translateForJs="false">Umożliwia powiadamianie użytkowników, jeśli terminal LCD uruchomił tryb blokady PIN. Może to wskazywać, że ktoś próbuje zgadnąć PIN użytkownika w celu uzyskania dostępu do systemu.</TranslationEntry>
    <TranslationEntry name="0A90FA5027B237E488DD857F73DF05F6" fullContext="CA0E31CBDBFC66CFD1BCBCB27F587EF3" translateForJs="false">Blokada PIN jest wyzwalana, gdy wielokrotnie z rzędu wystąpią nieudane próby wprowadzenia PIN na Terminalu LCD. Liczba prób wymaganych do wyzwolenia blokady PIN jest konfigurowana indywidualnie dla każdego terminala za pomocą ustawienia </TranslationEntry>
    <TranslationEntry name="649F60025DBD0AE2ADE8E6A2C2C48203" fullContext="EC466519A3340053F45FC982258265AA" translateForJs="false">Maksymalna liczba prób logowania</TranslationEntry>
    <TranslationEntry name="4DF42FDA3D71A50FD5C8107CC9E55C7B" translateForJs="false">Izolacje sprawności modułu</TranslationEntry>
    <TranslationEntry name="5BD9150577AF0CD36E8CC16BFBD151AE" fullContext="117131FAE8DA7AB2DEABD4A22609A3AD" translateForJs="false">Umożliwia użytkownikom otrzymywanie powiadomień, gdy wszelkie problemy zdrowotne związane z modułem są pomijane lub izolowane. Pomijanie problemów zdrowotnych powoduje tymczasowe zatrzymanie monitorowania modułu przez system, często umożliwiając uzbrajanie stref. </TranslationEntry>
    <TranslationEntry name="D45A62E64C4A9F52BBDF1BC9A0EAC78E" fullContext="117131FAE8DA7AB2DEABD4A22609A3AD" translateForJs="false">Tymczasowe izolowanie następuje, gdy problem z kondycją modułu istniał w momencie uzbrajania strefy, co umożliwia pomyślne uzbrojenie. Izolacja trwa do rozbrojenia strefy. Użytkownicy mogą również trwale izolować moduły od zgłaszania problemów, gdy moduł ma trwałą usterkę, eliminując konieczność tymczasowego izolowania problemu przy każdym uzbrajaniu strefy.</TranslationEntry>
    <TranslationEntry name="F35583DE386E8DF6DE15744C51E685BE" translateForJs="false">Powiadomienia systemowe</TranslationEntry>
    <TranslationEntry name="E27E03B4501134223297D4A7807702BB" fullContext="97C84066F7EA37EDDA891EE045DFD8DA" translateForJs="false">Umożliwia powiadamianie użytkowników o resecie systemu Inception. Powiadomienie będzie zawierało przyczynę resetu, jeśli można ją wykryć, np. utrata zasilania, aktualizacja firmware, przywrócenie bazy danych i inne.</TranslationEntry>
    <TranslationEntry name="DE2CF78D1450295099D0F71582A1EB14" fullContext="C105FA56D401768B0B3D3BBD35FB2279" translateForJs="false">Umożliwia powiadamianie użytkowników o wystąpieniu zdarzenia pod przymusem.</TranslationEntry>
    <TranslationEntry name="13E102BA143412C5E338683378A8631C" fullContext="C105FA56D401768B0B3D3BBD35FB2279" translateForJs="false">Zdarzenia przymusu użytkownika mogą być wyzwalane na kilka sposobów:</TranslationEntry>
    <TranslationEntry name="788CEE7E232211D4F417B9CA485981A1" fullContext="C105FA56D401768B0B3D3BBD35FB2279" translateForJs="false">Brelok RF zdalny</TranslationEntry>
    <TranslationEntry name="0D41FFE54C76E9128203D111F7095262" fullContext="C105FA56D401768B0B3D3BBD35FB2279" translateForJs="false"> — jednoprzyciski brelok RF można skonfigurować w trybie przymusu użytkownika, wyzwalając alarm przymusu użytkownika po naciśnięciu przycisku</TranslationEntry>
    <TranslationEntry name="65083B260D36298C8A8BCDD1F3C5756D" fullContext="C105FA56D401768B0B3D3BBD35FB2279" translateForJs="false">Terminal — wylogowanie pod przymusem</TranslationEntry>
    <TranslationEntry name="8D146E23E47D01BD967A1EA920E24FF4" fullContext="C105FA56D401768B0B3D3BBD35FB2279" translateForJs="false"> - Jeśli włączone (przez włączenie </TranslationEntry>
    <TranslationEntry name="B9AA6BEBC0233FEAF814E4D0BE5DBC04" fullContext="C105FA56D401768B0B3D3BBD35FB2279" translateForJs="false">Raportowanie alarmu użytkownika</TranslationEntry>
    <TranslationEntry name="AA512F26C54BEF7B20D3BDB0EFA70DC0" fullContext="C105FA56D401768B0B3D3BBD35FB2279" translateForJs="false"> strona), zdarzenie alarmu użytkownika może zostać wyzwolone przez naciśnięcie </TranslationEntry>
    <TranslationEntry name="4FC963E213BBA362778F5C175EB4D5FF" fullContext="A636974F3DFF11C3AAC0F7FDA3BA06EF" translateForJs="false">POMOC</TranslationEntry>
    <TranslationEntry name="A8D65860D2AD837BC11B438FD0305B89" fullContext="C105FA56D401768B0B3D3BBD35FB2279" translateForJs="false"> przycisk na terminalu trzy razy z rzędu, gdy terminal jest wylogowany</TranslationEntry>
    <TranslationEntry name="CA52953F90065BBD3E5112A861485D85" fullContext="C105FA56D401768B0B3D3BBD35FB2279" translateForJs="false">Systemowy użytkownik alarmowy</TranslationEntry>
    <TranslationEntry name="D23D27206A4526A521C3D674A10BDA3A" fullContext="C105FA56D401768B0B3D3BBD35FB2279" translateForJs="false"> - Jeśli włączone (w </TranslationEntry>
    <TranslationEntry name="DB7380746A3CA6715AF36CDBBEF00428" fullContext="32863267498C5BB81B1ACD2F6292A14A" translateForJs="false"> sekcji </TranslationEntry>
    <TranslationEntry name="92D5504C70991DF4125F0E5323D1507B" fullContext="C105FA56D401768B0B3D3BBD35FB2279" translateForJs="false"> strona), zdarzenie alarmu przymusu jest wyzwalane, gdy na Terminalu LCD lub klawiaturze czytnika zostanie wprowadzony PIN użytkownika przymusu. </TranslationEntry>
    <TranslationEntry name="E16440DB6EB2E26F50CAFC7F3386EEFA" fullContext="C105FA56D401768B0B3D3BBD35FB2279" translateForJs="false">Komunikat będzie zawierał nazwę użytkownika, jeśli jest znana, lub moduł, w którym zdarzenie zostało wyzwolone.</TranslationEntry>
    <TranslationEntry name="C75F30F12125EDDB80C28C22B14AFED3" translateForJs="false">Słaba bateria pilota RF</TranslationEntry>
    <TranslationEntry name="D10A0F2EF4866B39468D72FE62D796E3" fullContext="0676A0F2BB38D06488B5A584CBCEB88C" translateForJs="false">Umożliwia powiadamianie użytkowników, gdy pilot RF przypisany do użytkownika zgłosi zdarzenie niskiego stanu baterii. Powiadomienie będzie zawierało nazwę użytkownika będącego właścicielem pilota.</TranslationEntry>
    <TranslationEntry name="996B4973DC93491DCC4C358714446AB3" fullContext="0676A0F2BB38D06488B5A584CBCEB88C" translateForJs="false">Zdarzenia niskiego poziomu baterii są dostępne wyłącznie z pilotów Inovonics.</TranslationEntry>
    <TranslationEntry name="9F8173F2580B72679BD7E50AD05C45D3" translateForJs="false">Logowanie do interfejsu WWW</TranslationEntry>
    <TranslationEntry name="1E5A46588632F634F083B590F8E6FA71" fullContext="724BCD65EAE87632C96C908649B1A44B" translateForJs="false">Umożliwia powiadamianie użytkowników, gdy użytkownik pomyślnie zaloguje się do interfejsu internetowego Inception. Powiadomienie będzie zawierało nazwę użytkownika, który się zalogował.</TranslationEntry>
    <TranslationEntry name="72DFB7497EDD45A1AF6BDADB8B5B4E53" translateForJs="false">Blokada interfejsu sieciowego</TranslationEntry>
    <TranslationEntry name="1F751992D6B8DAD06EA5A1A464C3A0AA" fullContext="47D505D9EEE05EA1713468ABB59A4C10" translateForJs="false">Umożliwia powiadamianie użytkowników, jeśli Inception uruchomi tryb blokady interfejsu WWW. Może to wskazywać, że ktoś próbuje odgadnąć dane logowania użytkownika do sieci web, aby uzyskać dostęp do systemu.</TranslationEntry>
    <TranslationEntry name="FB592F628A5C6CCB5A7FAD6B1105A2A3" fullContext="47D505D9EEE05EA1713468ABB59A4C10" translateForJs="false">Blokada interfejsu internetowego jest uruchamiana, gdy wielokrotnie nieudane próby logowania przez internet następują po sobie. Liczba prób wymaganych do uruchomienia blokady interfejsu internetowego wynosi trzy, uniemożliwiając jakimkolwiek użytkownikom logowanie przez krótki czas. Jeśli nieudane próby logowania będą kontynuowane, czas blokady interfejsu internetowego będzie się zwiększał, zmniejszając skuteczność ataku siłowego.</TranslationEntry>
    <TranslationEntry name="880D09B9866EFD5BF7DA360C6AD3A938" translateForJs="false">Zmiana trybu serwisowego</TranslationEntry>
    <TranslationEntry name="08112441E255CCC1C90882C3702B5264" fullContext="A2DC772ABB778B069DF78EA1AC53C203" translateForJs="false">Umożliwia powiadamianie użytkowników o każdym włączeniu lub wyłączeniu trybu serwisowego w systemie. Komunikat będzie zawierał informację o tym, który użytkownik włączył lub wyłączył tryb serwisowy.</TranslationEntry>
    <TranslationEntry name="FAA3723C93B6DEAB56F369DE7B9F0FEE" fullContext="A2DC772ABB778B069DF78EA1AC53C203" translateForJs="false">Tryb serwisowy umożliwia tymczasowe wyłączenie funkcji takich jak sygnalizatory i raportowanie alarmów, co pozwala na konserwację systemu bez konieczności modyfikowania programowania. Jednak wykonanie tego bez uprawnień może naruszyć bezpieczeństwo systemu.</TranslationEntry>
    <TranslationEntry name="5AA4735F012A2741969EBBB64FF05E82" translateForJs="false">Błąd raportowania alarmu</TranslationEntry>
    <TranslationEntry name="F5A04710D4E9630FE39E47E08E20A278" fullContext="36F44EC40EE87508AE868B9D4CCB9F87" translateForJs="false">Umożliwia powiadamianie użytkowników o przerwaniu lub przywróceniu ścieżki raportowania alarmów do stacji monitorowania alarmów.</TranslationEntry>
    <TranslationEntry name="DB091D5F348A07A725BE73C612FA59C6" fullContext="36F44EC40EE87508AE868B9D4CCB9F87" translateForJs="false">Awarie ścieżki raportowania są zazwyczaj również znane stacji monitorowania, ponieważ ścieżki raportowania są odpytywane. Wszelkie alarmy, które wystąpią podczas niedostępności ścieżki, zostaną umieszczone w kolejce do wysłania po przywróceniu połączenia.</TranslationEntry>
    <TranslationEntry name="54F71C3F6F025990F3B8CD10361A5E96" translateForJs="false" rules="unique=EntityChangeNotifications" notes="Must be unique amongst all &quot;EntityChangeNotifications&quot; entries">Ustawienia daty i czasu</TranslationEntry>
    <TranslationEntry name="E4709A73A287A5F033F5B1B5142CB74D" fullContext="E4709A73A287A5F033F5B1B5142CB74D" translateForJs="false" rules="unique=EntityChangeNotifications" notes="Must be unique amongst all &quot;EntityChangeNotifications&quot; entries">Ustawienia systemowe</TranslationEntry>
    <TranslationEntry name="76D8F3C00672F61B39846B2112D356A8" translateForJs="false" rules="unique=EntityChangeNotifications" notes="Must be unique amongst all &quot;EntityChangeNotifications&quot; entries">Ustawienia powiadomień</TranslationEntry>
    <TranslationEntry name="102F1BF5574E08D1443B42A330A7B867" translateForJs="false">Zmiany elementów</TranslationEntry>
    <TranslationEntry name="5F7910B2D4F5AE153FD181F41A7D678E" fullContext="CA344C247E5338D56D218E6375177962" translateForJs="false">Umożliwia powiadamianie użytkowników o każdej zmianie konfiguracji w systemie. Komunikat będzie zawierał informację o tym, który użytkownik dokonał zmiany, który element został zmieniony oraz czy element został utworzony, zaktualizowany czy usunięty.</TranslationEntry>
    <TranslationEntry name="470F743C220E9A5CEF0A1A89E3475E38" fullContext="CA344C247E5338D56D218E6375177962" translateForJs="false">Dla powiadamiacza można określić wiele typów elementów do monitorowania, umożliwiając użytkownikom otrzymywanie informacji o modyfikacjach ustawień, których nie należy zmieniać.</TranslationEntry>
    <TranslationEntry name="62DADC05C4BCC3D3638C96FB0F1CB0FA" fullContext="D157231CBDF1F84F254637243FFA3D25" translateForJs="false">Jeśli włączone, linia wyjściowa stanie się elementem z uprawnieniami. Można ją przypisać bezpośrednio do użytkownika lub dodać do grupy uprawnień użytkownika. Po przypisaniu do użytkownika będzie on mógł sterować linią wyjściową z interfejsu internetowego za pomocą </TranslationEntry>
    <TranslationEntry name="5E60FED0173233D9580FF9E8D66E72EC" fullContext="0383CCE1A9DAAF17F6311794EFD93C8E" translateForJs="false">[Panel główny]</TranslationEntry>
    <TranslationEntry name="A9303152C7DE02735B7603AC6E06AA50" fullContext="D157231CBDF1F84F254637243FFA3D25" translateForJs="false">[Konfiguracja &gt; Linie wyjściowe]</TranslationEntry>
    <TranslationEntry name="5F75C7D4A210B222B0596FAC72CB29C7" fullContext="D157231CBDF1F84F254637243FFA3D25" translateForJs="false">[Stan / Sterowanie &gt; Sterowanie liniami wyjściowymi]</TranslationEntry>
    <TranslationEntry name="39F9DC34661859CCDEFAF20AEA3B3BFB" fullContext="D157231CBDF1F84F254637243FFA3D25" translateForJs="false"> strony. Użytkownik może również sterować linią wyjściową przez Terminal LCD, logując się i przechodząc do </TranslationEntry>
    <TranslationEntry name="84383BFF552450738D1547331DD40CD8" fullContext="54E19E955D33C2C3DBD639F222548293" translateForJs="false">[MENU]</TranslationEntry>
    <TranslationEntry name="F2577A6FC29B900FE7D4C6321346BE48" fullContext="D157231CBDF1F84F254637243FFA3D25" translateForJs="false">[3]</TranslationEntry>
    <TranslationEntry name="35DBA5D75538A9BBE0B4DA4422759A0E" fullContext="46C167CAA0F5D8E9E867E65D5E2B1557" translateForJs="false">[1]</TranslationEntry>
    <TranslationEntry name="54FA68188AB8AEFF98305B0789746463" fullContext="27B1084680D4FC661B5873B5A4E02584" translateForJs="false">Wylogowany z kontrolowalnego</TranslationEntry>
    <TranslationEntry name="502C66D3390F53A8EC83C43025989486" fullContext="7F69A18079D8B0407CA1D2821D005D7D" translateForJs="false">Jeśli włączone, linią wyjściową można sterować z terminala LCD bez konieczności logowania przez użytkownika. </TranslationEntry>
    <TranslationEntry name="00515C2A1EBABCD00EF812BA7FDF95C6" fullContext="7F69A18079D8B0407CA1D2821D005D7D" translateForJs="false">Naciśnięcie </TranslationEntry>
    <TranslationEntry name="55EEAFF70B2DABC78F77505D3C894666" fullContext="956726917E32E939649D7937728D3F36" translateForJs="false">[GÓRA]</TranslationEntry>
    <TranslationEntry name="FEE116259976AFC173AEBB92506D2CC0" fullContext="7F69A18079D8B0407CA1D2821D005D7D" translateForJs="false"> klawisz na terminalu wyświetli linie wyjściowe, a </TranslationEntry>
    <TranslationEntry name="C9E3D11B08E709D68B444332ADC904D7" fullContext="9E4688213E5ED5662BB1992FCFE099F2" translateForJs="false">[WŁĄCZONE]</TranslationEntry>
    <TranslationEntry name="C49CD49E23496AA4D869125966947190" fullContext="9E4688213E5ED5662BB1992FCFE099F2" translateForJs="false">[WYŁĄCZONE]</TranslationEntry>
    <TranslationEntry name="5A9B6159FA73A609B743F7901B38B26C" fullContext="7F69A18079D8B0407CA1D2821D005D7D" translateForJs="false"> przyciski będą sterować liniami wyjściowymi. </TranslationEntry>
    <TranslationEntry name="DA41A32F63B12DA4F57E49697DFC3094" fullContext="7F69A18079D8B0407CA1D2821D005D7D" translateForJs="false">Ta opcja stanowi kompromis między bezpieczeństwem a wygodą i nie zaleca się jej włączania dla linii wyjściowych, którymi mogą sterować tylko wybrane osoby. </TranslationEntry>
    <TranslationEntry name="ED8EEA2F7E841FBFCF90C419895D1233" fullContext="7F69A18079D8B0407CA1D2821D005D7D" translateForJs="false">Możesz ograniczyć terminale umożliwiające sterowanie liniami wyjściowymi bez logowania, wyłączając opcję </TranslationEntry>
    <TranslationEntry name="617F9893293256DE472F4BD3C89777DB" fullContext="BEBD8FA919A1CB37637D52DA85F36522" translateForJs="false">Sterowanie liniami wyjściowymi po wylogowaniu</TranslationEntry>
    <TranslationEntry name="1924C62717617F8BAC98247F56A5A3D0" fullContext="7F69A18079D8B0407CA1D2821D005D7D" translateForJs="false"> opcja, umożliwiająca oferowanie tej funkcjonalności tylko przez określone terminale.</TranslationEntry>
    <TranslationEntry name="F11E4D00A3B036DD661259DC5BFE3F43" translateForJs="false">Sprzętowa linia wyjściowa</TranslationEntry>
    <TranslationEntry name="4F96BD01F27794C770A4966711AD1A42" fullContext="9102623D11F0DE7DFA8EDC336827AE79" translateForJs="false">Informacja: to jest fizyczna lokalizacja, w której linia wyjściowa jest podłączona w systemie Inception.</TranslationEntry>
    <TranslationEntry name="806555B035EF2CA74D63BE067F856AA1" fullContext="69856929F2617ED37B376A6385AA13B5" translateForJs="false">Odwróć stan linii wyjściowej</TranslationEntry>
    <TranslationEntry name="0EDAE5DE44BC810D6680139895055305" fullContext="390A8C13D34B985F79F48FEFDC079958" translateForJs="false">Jeśli włączone, fizyczna linia wyjściowa sprzętowa będzie w stanie przeciwnym do wyświetlanego w systemie.</TranslationEntry>
    <TranslationEntry name="1AD1A355B0459D812A4580D9210D6AD3" fullContext="390A8C13D34B985F79F48FEFDC079958" translateForJs="false">Jest to przydatne podczas korzystania z </TranslationEntry>
    <TranslationEntry name="FBC67656FA0C5D841DD253F0E6968C88" fullContext="69856929F2617ED37B376A6385AA13B5" translateForJs="false">Normalnie zamknięty</TranslationEntry>
    <TranslationEntry name="454F353E5F097954503629C40F1C835C" fullContext="390A8C13D34B985F79F48FEFDC079958" translateForJs="false"> styki przekaźnikowego wyjścia, umożliwiając włączenie lub wyłączenie linii wyjściowej </TranslationEntry>
    <TranslationEntry name="B568547188A0D6BC3D98A27318EC4E38" fullContext="390A8C13D34B985F79F48FEFDC079958" translateForJs="false"> w systemie i pokaż ten stan, ale fizyczna linia wyjściowa będzie zamknięta.</TranslationEntry>
    <TranslationEntry name="04FD646CF6915454AD0897FE9D3D6D29" translateForJs="false">Niestandardowa linia wyjściowa</TranslationEntry>
    <TranslationEntry name="BFA40DB99E13ED2FE413EA8F1507CDA9" translateForJs="false">Grupa uprawnień</TranslationEntry>
    <TranslationEntry name="9235E9379D85E2751347CAC02186D471" fullContext="F60F175DB890218ACC499D661EE851C6" translateForJs="false">Uprawnienia określają, do jakich stref, przejść i linii wyjściowych użytkownik ma dostęp lub możliwość sterowania w systemie. Uprawnienia określają również, jakimi elementami użytkownik może sterować za pomocą interfejsu internetowego. Uprawnienia są tworzone przy użyciu </TranslationEntry>
    <TranslationEntry name="BD8523D1D22ABC6231AB368DF1CD315C" fullContext="F60F175DB890218ACC499D661EE851C6" translateForJs="false"> struktura. </TranslationEntry>
    <TranslationEntry name="8304C30B39F5F529736680E480C77B75" fullContext="F60F175DB890218ACC499D661EE851C6" translateForJs="false"> określa, co uprawnienie pozwala użytkownikowi sterować i w jaki sposób, np. dostęp do przejścia lub rozbrojenie strefy. Opcja </TranslationEntry>
    <TranslationEntry name="E05D71051AEE81EFF4CE248F2145B546" fullContext="F60F175DB890218ACC499D661EE851C6" translateForJs="false"> określa, kiedy to uprawnienie obowiązuje, np. </TranslationEntry>
    <TranslationEntry name="D832B494562C7075601FD0670138B633" fullContext="F60F175DB890218ACC499D661EE851C6" translateForJs="false">, lub na podstawie przedziału czasowego, stanu strefy lub stanu przejścia na przykład.</TranslationEntry>
    <TranslationEntry name="EE29DBD9FBD52B1B5AA7F886D3DDE82C" fullContext="F60F175DB890218ACC499D661EE851C6" translateForJs="false">Aby dodać uprawnienia, kliknij </TranslationEntry>
    <TranslationEntry name="5BEA5982247C88147C72DD9272C595E7" fullContext="F60F175DB890218ACC499D661EE851C6" translateForJs="false"> przycisk — otworzy się okno, w którym wybierzesz dozwolone elementy. Jeśli ta lista jest pusta, programowanie przejść, stref i linii wyjściowych nie zostało zakończone.</TranslationEntry>
    <TranslationEntry name="864415E51468445B488AD6081716B4FE" fullContext="F60F175DB890218ACC499D661EE851C6" translateForJs="false">Aby użytkownik mógł sterować linią wyjściową, musi być ona skonfigurowana jako linia wyjściowa sterowana przez użytkownika w </TranslationEntry>
    <TranslationEntry name="02F56F7556F4A8F850009A9205649B33" fullContext="F60F175DB890218ACC499D661EE851C6" translateForJs="false"> strona — w przeciwnym razie nie pojawi się na liście dodawanych elementów.</TranslationEntry>
    <TranslationEntry name="A1318BD6CBB9CB2CD9719D084037CC6F" fullContext="ACB4F26BB0840AE56738E668B35971D9" translateForJs="false">Każde uprawnienie może być oznaczone jako </TranslationEntry>
    <TranslationEntry name="07B24695972920D9E959A908947F9AB3" fullContext="ACB4F26BB0840AE56738E668B35971D9" translateForJs="false">. Użytkownik musi mieć przypisane </TranslationEntry>
    <TranslationEntry name="260B148FEE44F369031A9371FC6636D6" fullContext="ACB4F26BB0840AE56738E668B35971D9" translateForJs="false"> uprawnienie, aby móc coś wykonać. Jeśli ustawiono na </TranslationEntry>
    <TranslationEntry name="D841B0EC96778344723537256B7316AE" fullContext="F60F175DB890218ACC499D661EE851C6" translateForJs="false">, następnie gdy </TranslationEntry>
    <TranslationEntry name="B910B0F4D8C881E2EFB470C9B8D45BCE" fullContext="F60F175DB890218ACC499D661EE851C6" translateForJs="false"> warunek jest spełniony, użytkownik nie będzie mógł wykonać akcji wymienionej w </TranslationEntry>
    <TranslationEntry name="D46474BA021D37B4C5B651F4C780A5AD" fullContext="F60F175DB890218ACC499D661EE851C6" translateForJs="false"> kolumna. Ta </TranslationEntry>
    <TranslationEntry name="095D0DD454FEDAABE31A0C60A20E6C65" fullContext="F60F175DB890218ACC499D661EE851C6" translateForJs="false"> uprawnienie zastąpi wszystkie inne </TranslationEntry>
    <TranslationEntry name="7786A8B960E20DF58A6B1A9708A67C7A" fullContext="F60F175DB890218ACC499D661EE851C6" translateForJs="false"> uprawnienia, co oznacza, że nawet jeśli to samo uprawnienie zostało przyznane w innym miejscu, użytkownik nadal będzie odmawiany. Stosuje się to podczas łączenia grup uprawnień. Na przykład, jeśli chcesz, aby ta grupa uprawnień obejmowała te same uprawnienia co jedna lub więcej innych grup uprawnień, z jednym lub dwoma wyjątkami. Te wyjątki można dodać jako </TranslationEntry>
    <TranslationEntry name="F05627005FF419BD7F19D08287D3DA73" fullContext="F60F175DB890218ACC499D661EE851C6" translateForJs="false"> wiersz. </TranslationEntry>
    <TranslationEntry name="D2A7C894DA977827B9C08F46D2074C56" translateForJs="false">Stan systemu</TranslationEntry>
    <TranslationEntry name="B42C81BFD27515F7D0853142EFEEA692" translateForJs="false">Grupa procesów</TranslationEntry>
    <TranslationEntry name="1D5D76A031DEBF73EB82DFDA0FA5EE6E" translateForJs="false">Grupy procesów</TranslationEntry>
    <TranslationEntry name="5F02280E7B7E31F548C5351044116AF1" translateForJs="false" rules="unique=SirenTone" notes="Must be unique amongst all &quot;SirenTone&quot; entries">Brak tonu</TranslationEntry>
    <TranslationEntry name="999A06F28346262EF9E1699D9FC1AB56" translateForJs="false" rules="unique=SirenTone" notes="Must be unique amongst all &quot;SirenTone&quot; entries">Dzwonek</TranslationEntry>
    <TranslationEntry name="8E9014DDFCE21BEB1B3CD7DA888CBDEA" translateForJs="false" rules="unique=SirenTone" notes="Must be unique amongst all &quot;SirenTone&quot; entries">Skanowanie</TranslationEntry>
    <TranslationEntry name="BD2B7E5F85A6EA65065C4EBC6D7C95BB" translateForJs="false" rules="unique=SirenTone" notes="Must be unique amongst all &quot;SirenTone&quot; entries">Pożar</TranslationEntry>
    <TranslationEntry name="11CE2D0C33F6C59321AF220FA3BD6985" translateForJs="false" rules="unique=SirenTone" notes="Must be unique amongst all &quot;SirenTone&quot; entries">Ewakuacja</TranslationEntry>
    <TranslationEntry name="4E5E247C20AB935EB6DCDA8A4176176E" translateForJs="false" rules="unique=SirenTone" notes="Must be unique amongst all &quot;SirenTone&quot; entries">Sygnał dźwiękowy</TranslationEntry>
    <TranslationEntry name="56525AE64D370C0B448AC0D60710EF17" translateForJs="false" rules="unique=SirenTone" notes="Must be unique amongst all &quot;SirenTone&quot; entries">Ostrzeżenie</TranslationEntry>
    <TranslationEntry name="B8A96C2EAE94F8948C6F0CEE396196E8" translateForJs="false" rules="unique=SirenTone" notes="Must be unique amongst all &quot;SirenTone&quot; entries">Błąd (Sygnał)</TranslationEntry>
    <TranslationEntry name="E01B412A22CF93DA209B7BD9CF611CC6" translateForJs="false" rules="unique=SirenTone" notes="Must be unique amongst all &quot;SirenTone&quot; entries">Sukces (sygnał dźwiękowy)</TranslationEntry>
    <TranslationEntry name="5267F3D6B4D55D20662C89DD04C3B71D" translateForJs="false" rules="unique=SirenTone" notes="Must be unique amongst all &quot;SirenTone&quot; entries">Pojedynczy sygnał dźwiękowy (krótki)</TranslationEntry>
    <TranslationEntry name="326B7A4B4F5882D77C6E0DB16C1F9241" translateForJs="false" rules="unique=SirenTone" notes="Must be unique amongst all &quot;SirenTone&quot; entries">Podwójny sygnał dźwiękowy (krótki)</TranslationEntry>
    <TranslationEntry name="06CB70F3A1C03758244D5D2F3C37DADE" fullContext="9E19A5D1F5D625C5AEF1865E03C2D37D" translateForJs="false">Tylko informacja: przejście, z którym połączony jest ten czytnik. Zmianę przejścia można dokonać przez </TranslationEntry>
    <TranslationEntry name="4EE3E143B8783C5A874496F594CD5A44" fullContext="49192784381D167097BD95A4382DD6CD" translateForJs="false">Tylko informacja: strona przejścia, po której zlokalizowany jest ten czytnik. Zmianę lokalizacji można dokonać przez </TranslationEntry>
    <TranslationEntry name="67D5FA646389C92F72CF4C6A5978EEB6" fullContext="67D5FA646389C92F72CF4C6A5978EEB6" translateForJs="false">Akcja 3-krotnego odczytu</TranslationEntry>
    <TranslationEntry name="E9DC01FAB7F677545647EA9DA32E9A66" fullContext="46C965343544A040192250C4FC868017" translateForJs="false">Określa akcję wykonywaną, gdy użytkownik trzykrotnie odczyta kartę na czytniku. </TranslationEntry>
    <TranslationEntry name="A8B001806A66F8A0A12F532CBC83544A" fullContext="46C965343544A040192250C4FC868017" translateForJs="false"> - żadna akcja nie zostanie wykonana. </TranslationEntry>
    <TranslationEntry name="77E28D0840C2A68CCE14779F07F806E2" fullContext="46C965343544A040192250C4FC868017" translateForJs="false">Uzbrój strefę po drugiej stronie przejścia</TranslationEntry>
    <TranslationEntry name="D6A1AD3E55328DF69E597C686681539E" fullContext="46C965343544A040192250C4FC868017" translateForJs="false"> - spowoduje to uzbrojenie strefy znajdującej się po przeciwnej stronie przejścia od miejsca, w którym znajduje się ten czytnik; strefa ta jest skonfigurowana w ustawieniach przejścia na stronie </TranslationEntry>
    <TranslationEntry name="F0337D9ED24B7859949AA097621AE22A" fullContext="46C965343544A040192250C4FC868017" translateForJs="false"> strona. Żądanie uzbrojenia nie powiedzie się, jeśli użytkownik nie ma uprawnień do uzbrojenia strefy lub jeśli w tej strefie znajdują się niezabezpieczone linie wejściowe. </TranslationEntry>
    <TranslationEntry name="18200094894522E252E692B48F034C2E" fullContext="482B8865469C8C97DECAA1B74F083B13" translateForJs="false" rules="unique=AreaToArm" notes="Must be unique amongst all &quot;AreaToArm&quot; entries">Uzbrój wszystkie strefy</TranslationEntry>
    <TranslationEntry name="90D470E53447DFEEDE27D8996725F648" fullContext="46C965343544A040192250C4FC868017" translateForJs="false"> - spowoduje uzbrojenie każdej strefy w systemie, do której użytkownik ma uprawnienia. Żądanie uzbrojenia zakończy się niepowodzeniem, jeśli użytkownik nie ma uprawnień do uzbrajania żadnej strefy lub jedna ze stref, którymi może sterować, zawiera niespokojone linie wejściowe.</TranslationEntry>
    <TranslationEntry name="90E6EA19833F47C92FC4D58646E78B88" fullContext="46C965343544A040192250C4FC868017" translateForJs="false">Jeśli żądanie uzbrojenia zakończy się niepowodzeniem, użytkownik może podjąć próbę znalezienia niezabezpieczonej linii wejściowej i jej naprawy lub spróbować uzbroić strefę za pomocą Terminala LCD lub interfejsu internetowego, który dostarczy dodatkowych informacji o przyczynie niepowodzenia.</TranslationEntry>
    <TranslationEntry name="270142D0457F3C7AE7AFA2E3124B7489" fullContext="46C965343544A040192250C4FC868017" translateForJs="false">Czytnik SIFER/OSDP odtworzy ton potwierdzenia po pomyślnym uzbrojeniu i rozbrojeniu stref za pomocą akcji 3-krotnego odczytu karty. Dodatkową sygnalizację zwrotną dla uzbrajania strefy można zaprogramować w </TranslationEntry>
    <TranslationEntry name="3A86E841321823456B155AFBE544A7F5" fullContext="D471604D5BE7B763E59E1566E64FD202" translateForJs="false">[Konfiguracja &gt; Strefy &gt; Edytuj strefę]</TranslationEntry>
    <TranslationEntry name="BAEBDD6D641CC5CBF0A819561B4B84C7" fullContext="BAEBDD6D641CC5CBF0A819561B4B84C7" translateForJs="false">Typ czytnika</TranslationEntry>
    <TranslationEntry name="BB6D18916DD55C00A523A83ABAC707E4" fullContext="08D25696D2953536D787F476F37E69F3" translateForJs="false">Tylko informacyjnie: możliwa jest zmiana typu czytnika przez stronę </TranslationEntry>
    <TranslationEntry name="A160C5A17DC19A762ED143E833600236" translateForJs="false">Programowanie czytnika</TranslationEntry>
    <TranslationEntry name="20521B7DF42FDB6CA5ACDBFE86E9EBD2" translateForJs="false">Wyłącz blokadę czytnika</TranslationEntry>
    <TranslationEntry name="B541FE192BB8E3FD6630FD6E92E19E62" fullContext="D26557B0884D8C0D0E49013D75A5D0A1" translateForJs="false">Jeśli ustawione, funkcja blokady czytnika dla tego czytnika zostanie wyłączona.</TranslationEntry>
    <TranslationEntry name="E9576A56AE27486F1B1142B7BE4B0259" fullContext="D26557B0884D8C0D0E49013D75A5D0A1" translateForJs="false">Funkcja blokady czytnika pomaga chronić system przed atakami siłowymi, gdy wielokrotnie próbuje się różnych kart dostępu lub numerów PIN w celu podszywania się pod użytkownika. Jeśli przy czytniku zostaną zaprezentowane wielokrotne karty dostępu lub identyfikatory PIN, które nie są dopasowane do żadnego użytkownika, zostaje uruchomiona blokada czytnika. Zliczane są tylko identyfikatory niedopasowane do użytkownika; próby odmówione z powodu uprawnień nie są zliczane. </TranslationEntry>
    <TranslationEntry name="D466944DF2E8AC9078596A6BCC458D12" fullContext="D26557B0884D8C0D0E49013D75A5D0A1" translateForJs="false">Trzy kolejne nieudane próby identyfikatora uruchamiają blokadę na tym czytniku, która trwa 90 sekund. Po uruchomieniu, wszystkie identyfikatory prezentowane przy czytniku będą ignorowane do momentu upłynięcia czasu blokady. Po upłynięciu czasu blokady, kolejne nieprawidłowe identyfikatory spowodują ponowne uruchomienie 90-sekundowego czasu blokady.</TranslationEntry>
    <TranslationEntry name="436FC7AE8A8EBAB75D9615D3E6DEC7A5" fullContext="D26557B0884D8C0D0E49013D75A5D0A1" translateForJs="false">Edycja i zapisanie użytkownika w systemie resetuje liczbę nieprawidłowych prób identyfikatora dla wszystkich czytników i usuwa blokadę czytnika, jeśli została uruchomiona. Umożliwia to przypisywanie kart do użytkowników poprzez odczyt nieznanej karty przy czytniku, a następnie przypisanie tego zdarzenia odczytu do użytkownika bez obawy o uruchomienie blokady czytnika.</TranslationEntry>
    <TranslationEntry name="DC2C9138131744DC939A995CE1035681" fullContext="8E68B7FE2DB095FAC07D5C2357E4011A" translateForJs="false">Tylko informacyjnie: jest to moduł, do którego podłączony jest czytnik.</TranslationEntry>
    <TranslationEntry name="A103AB1617D5E5E6FAB13496DE52B4DA" translateForJs="false" rules="unique=AreaToArm" notes="Must be unique amongst all &quot;AreaToArm&quot; entries">Uzbrój strefę po drugiej stronie przejścia</TranslationEntry>
    <TranslationEntry name="B068584D9D7EC5DA5E80DA1223E8DD39" translateForJs="false" rules="unique=AreaToArm" notes="Must be unique amongst all &quot;AreaToArm&quot; entries">Uzbrój strefę po tej samej stronie przejścia</TranslationEntry>
    <TranslationEntry name="FD41898A1006898E1F5DCF4C87FE41D8" translateForJs="false" rules="unique=ReaderType" notes="Must be unique amongst all &quot;ReaderType&quot; entries">Wiegand</TranslationEntry>
    <TranslationEntry name="5668B2D6AF4A69C0695A6D4363FC5D36" translateForJs="false" rules="unique=ReaderType" notes="Must be unique amongst all &quot;ReaderType&quot; entries">SIFER</TranslationEntry>
    <TranslationEntry name="B7312E8FA61EFBB5E4FA0DE7E625152B" translateForJs="false" rules="unique=ReaderType" notes="Must be unique amongst all &quot;ReaderType&quot; entries">Ogólny OSDP</TranslationEntry>
    <TranslationEntry name="7FC94ADB2881A45DCF78F1E284CACC3D" translateForJs="false" rules="unique=WiegandKeypadType" notes="Must be unique amongst all &quot;WiegandKeypadType&quot; entries">Nie jest klawiaturą</TranslationEntry>
    <TranslationEntry name="BE1F4B6CD97D9E1D1BC9E196205D144B" translateForJs="false" rules="unique=WiegandKeypadType" notes="Must be unique amongst all &quot;WiegandKeypadType&quot; entries">HID / Wodoodporny</TranslationEntry>
    <TranslationEntry name="2ED1AFE3C9215523E4272F46E6186B31" translateForJs="false" rules="unique=WiegandKeypadType" notes="Must be unique amongst all &quot;WiegandKeypadType&quot; entries">Motorola</TranslationEntry>
    <TranslationEntry name="CE24B504F0D23959A048D8C2CD06C1B1" fullContext="CE24B504F0D23959A048D8C2CD06C1B1" translateForJs="false">Typ klawiatury</TranslationEntry>
    <TranslationEntry name="2DBA13DFE8AC49A94EE87A860F161E15" fullContext="F898595146F004BFC08DA4AB79941F43" translateForJs="false">Umożliwia wybór typu klawiatury Wiegand. Wybrany typ określi sposób interpretowania informacji o naciśnięciach klawiszy PIN. </TranslationEntry>
    <TranslationEntry name="DEF10EAAC7DACC4C6FF694A51A35F389" fullContext="DEF10EAAC7DACC4C6FF694A51A35F389" translateForJs="false">Strefa do sterowania z klawiatury</TranslationEntry>
    <TranslationEntry name="8CCE1E8CDD38E50B810047C631D6A1CA" fullContext="D8BA791A9CFC2193746C86D137329397" translateForJs="false">prawy dolny róg</TranslationEntry>
    <TranslationEntry name="E42CDD3BDC650FC3499417C2EC2CD92F" fullContext="D8BA791A9CFC2193746C86D137329397" translateForJs="false"> klawisz na klawiaturze używany do sterowania stanem strefy (często klawisz # lub klawisz WŁ./WYŁ. na klawiaturze zewnętrznej Inner Range).</TranslationEntry>
    <TranslationEntry name="B355C43CCC5E9DD485036ED38C35D3A5" fullContext="D8BA791A9CFC2193746C86D137329397" translateForJs="false">Jeśli ustawiono na </TranslationEntry>
    <TranslationEntry name="1F05C358317E8DC56ECE70210C9A09AA" fullContext="D8BA791A9CFC2193746C86D137329397" translateForJs="false">, klawisz będzie działał normalnie, żądając dostępu do przejścia dla wprowadzonego numeru PIN. W przeciwnym razie klawisz użyje wprowadzonego numeru PIN do sterowania strefą zamiast żądania dostępu do przejścia. Sposób sterowania strefą zależy od aktualnego stanu strefy. Jeśli strefa jest uzbrojona (w tym gdy aktywne jest opóźnienie na wejście lub wyjście), aktywny jest alarm lub strefa ma się za chwilę uzbroić, system podejmie próbę rozbrojenia strefy. W przeciwnym razie system podejmie próbę uzbrojenia strefy. Użytkownik, który wprowadził PIN, musi również posiadać odpowiednie uprawnienia, aby te działania się powiodły.</TranslationEntry>
    <TranslationEntry name="8251DFFB42FA9F8F858879AD14431225" translateForJs="false" rules="unique=SiferVolume" notes="Must be unique amongst all &quot;SiferVolume&quot; entries">Najgłośniejszy</TranslationEntry>
    <TranslationEntry name="954E3A7B3F57AAFBC6C23DD8D36CFEA3" translateForJs="false" rules="unique=SiferVolume" notes="Must be unique amongst all &quot;SiferVolume&quot; entries">Głośno</TranslationEntry>
    <TranslationEntry name="87F8A6AB85C9CED3702B4EA641AD4BB5" translateForJs="false" rules="unique=SiferVolume" notes="Must be unique amongst all &quot;SiferVolume&quot; entries">Średni</TranslationEntry>
    <TranslationEntry name="098753F8980036F4B936E3D4B6997111" translateForJs="false" rules="unique=SiferVolume" notes="Must be unique amongst all &quot;SiferVolume&quot; entries">Cicho</TranslationEntry>
    <TranslationEntry name="5F1282BC64B486F9A6E038161F9A1D1A" translateForJs="false" rules="unique=SiferIndicatorBrightness" notes="Must be unique amongst all &quot;SiferIndicatorBrightness&quot; entries">Najjaśniejszy</TranslationEntry>
    <TranslationEntry name="45C1428DBDF63826B7B1A999E012DF3B" translateForJs="false" rules="unique=SiferIndicatorBrightness" notes="Must be unique amongst all &quot;SiferIndicatorBrightness&quot; entries">Jasny</TranslationEntry>
    <TranslationEntry name="8ED64CE6E8032DDB62A463FFA78881D9" translateForJs="false" rules="unique=SiferIndicatorBrightness" notes="Must be unique amongst all &quot;SiferIndicatorBrightness&quot; entries">Przyciemnienie</TranslationEntry>
    <TranslationEntry name="7E69C72BC0F277D70F2A6B3DDF7EF68E" fullContext="4220D4DA842A7B19BCBBA3394E5C8B11" translateForJs="false" rules="unique=OSDPFeedbackMode" notes="Must be unique amongst all &quot;OSDPFeedbackMode&quot; entries">Stan przejścia</TranslationEntry>
    <TranslationEntry name="6CAAC97DD7248E952DE66A10EEC28120" fullContext="4220D4DA842A7B19BCBBA3394E5C8B11" translateForJs="false" rules="unique=OSDPFeedbackMode" notes="Must be unique amongst all &quot;OSDPFeedbackMode&quot; entries">Stan strefy, ta sama strona</TranslationEntry>
    <TranslationEntry name="3E5CF60EC8B2C9A7859CD7403799B5A2" fullContext="4220D4DA842A7B19BCBBA3394E5C8B11" translateForJs="false" rules="unique=OSDPFeedbackMode" notes="Must be unique amongst all &quot;OSDPFeedbackMode&quot; entries">Stan strefy, druga strona</TranslationEntry>
    <TranslationEntry name="9594EEC95BE70E7B1710F730FDDA33D9" translateForJs="false" rules="unique=SIFERLEDColour" notes="Must be unique amongst all &quot;SIFERLEDColour&quot; entries">Niebieski</TranslationEntry>
    <TranslationEntry name="E90DFB84E30EDF611E326EEB04D680DE" translateForJs="false" rules="unique=SIFERLEDColour" notes="Must be unique amongst all &quot;SIFERLEDColour&quot; entries">Czarny</TranslationEntry>
    <TranslationEntry name="25A81701FBFA4A1EFDF660A950C1D006" translateForJs="false" rules="unique=SIFERLEDColour" notes="Must be unique amongst all &quot;SIFERLEDColour&quot; entries">Biały</TranslationEntry>
    <TranslationEntry name="EE38E4D5DD68C4E440825018D549CB47" translateForJs="false" rules="unique=SIFERLEDColour" notes="Must be unique amongst all &quot;SIFERLEDColour&quot; entries">Czerwony</TranslationEntry>
    <TranslationEntry name="D382816A3CBEED082C9E216E7392EED1" translateForJs="false" rules="unique=SIFERLEDColour" notes="Must be unique amongst all &quot;SIFERLEDColour&quot; entries">Zielony</TranslationEntry>
    <TranslationEntry name="88068E33C78EB72F1B371C7110846085" translateForJs="false" rules="unique=SIFERLEDColour" notes="Must be unique amongst all &quot;SIFERLEDColour&quot; entries">Bursztynowy</TranslationEntry>
    <TranslationEntry name="CAF3A042A037C064B7513ED640C22F77" translateForJs="false" rules="unique=SIFERLEDColour" notes="Must be unique amongst all &quot;SIFERLEDColour&quot; entries">Szary</TranslationEntry>
    <TranslationEntry name="023C239D2F2538F140A20E72C7B73F20" translateForJs="false" rules="unique=SIFERLEDColour" notes="Must be unique amongst all &quot;SIFERLEDColour&quot; entries">Turkusowy</TranslationEntry>
    <TranslationEntry name="909CEA0C97058CFE2E3EA8D675CB08E1" translateForJs="false" rules="unique=SIFERLEDColour" notes="Must be unique amongst all &quot;SIFERLEDColour&quot; entries">Pomarańczowy</TranslationEntry>
    <TranslationEntry name="B9BA865FEC061C9706D2FD7CE49C0CC7" translateForJs="false" rules="unique=SIFERLEDColour" notes="Must be unique amongst all &quot;SIFERLEDColour&quot; entries">Fioletowy</TranslationEntry>
    <TranslationEntry name="8DC5344BC0746E1CC5ABF896CA03BBDF" translateForJs="false" rules="unique=SIFERLEDColour" notes="Must be unique amongst all &quot;SIFERLEDColour&quot; entries">Różowy</TranslationEntry>
    <TranslationEntry name="B91CC2C1416FCCA942B61C7AC5B1A9AC" translateForJs="false" rules="unique=SIFERLEDColour" notes="Must be unique amongst all &quot;SIFERLEDColour&quot; entries">Magenta</TranslationEntry>
    <TranslationEntry name="FFFECAC98899BF152FA73A094155EC58" translateForJs="false" rules="unique=SIFERLEDColour" notes="Must be unique amongst all &quot;SIFERLEDColour&quot; entries">Ciemnoczerwony</TranslationEntry>
    <TranslationEntry name="43E44004E3EBF26BD5F1E10090F75DB2" translateForJs="false" rules="unique=SIFERLEDColour" notes="Must be unique amongst all &quot;SIFERLEDColour&quot; entries">Ciemny cyjan</TranslationEntry>
    <TranslationEntry name="6E953BB167951FD367552C08D198A353" translateForJs="false" rules="unique=SIFERLEDColour" notes="Must be unique amongst all &quot;SIFERLEDColour&quot; entries">Ciemna zieleń</TranslationEntry>
    <TranslationEntry name="E9144225F9C7B6C99C111AFA8A9719AD" translateForJs="false" rules="unique=SIFERLEDColour" notes="Must be unique amongst all &quot;SIFERLEDColour&quot; entries">Ciemnożółty</TranslationEntry>
    <TranslationEntry name="560173BA980B9F5F7F8D9D3CCE1C2446" translateForJs="false" rules="unique=SIFERLEDColour" notes="Must be unique amongst all &quot;SIFERLEDColour&quot; entries">Ciemnoniebieski</TranslationEntry>
    <TranslationEntry name="1381943E2D50B6C3F80280ECC3754AC8" translateForJs="false" rules="unique=SIFERLEDColour" notes="Must be unique amongst all &quot;SIFERLEDColour&quot; entries">Jasny zielony</TranslationEntry>
    <TranslationEntry name="01EB0CA4AAD903270FDC3C70BD7F4E48" translateForJs="false" rules="unique=SIFERLEDColour" notes="Must be unique amongst all &quot;SIFERLEDColour&quot; entries">Jasnoniebieski</TranslationEntry>
    <TranslationEntry name="3B6A0A379749E58273C4F4FA719FCBA5" translateForJs="false" rules="unique=SIFERLEDColour" notes="Must be unique amongst all &quot;SIFERLEDColour&quot; entries">Jasny żółty</TranslationEntry>
    <TranslationEntry name="5E5D325A30DADE89599B084F0142247A" translateForJs="false">Zapewnij sygnalizację zwrotną stanu przejścia</TranslationEntry>
    <TranslationEntry name="95FB5196749E1B8DEC90BA3C2FAF89E5" fullContext="6441F45A0580D1101E2B7FB46870935B" translateForJs="false">Jeśli włączone, czytnik SIFER/OSDP zapewni sygnalizację zwrotną dla następujących stanów:</TranslationEntry>
    <TranslationEntry name="4BC3C654F08A814ADBA70F391BFA9AD3" fullContext="BFA1025F317BCE0C6A3429323F1768AD" translateForJs="false">DOTL</TranslationEntry>
    <TranslationEntry name="2A8671A5874D6E6033A160F443FEF8B9" fullContext="6441F45A0580D1101E2B7FB46870935B" translateForJs="false"> - Jeśli przejście jest przytrzymywane zbyt długo otwarte, czytnik będzie emitował sygnał dźwiękowy do momentu zamknięcia kontaktronu lub styku językowego. Funkcjonalność DOTL jest konfigurowana w </TranslationEntry>
    <TranslationEntry name="8EE339A53665E857550909D81413F244" fullContext="CA110B773FBAE87626F1F3CA493C8F56" translateForJs="false">[Konfiguracja &gt; Kontrola dostępu &gt; Przejścia]</TranslationEntry>
    <TranslationEntry name="EC45F491811EEAEBE84D7927D2B4C8B6" fullContext="6441F45A0580D1101E2B7FB46870935B" translateForJs="false"> — Gdy użytkownik bez uprawnień dostępu przez przejście odczyta kartę, czytnik SIFER wyda pojedynczy sygnał dźwiękowy, a duża dioda LED zaświeci się na czerwono.</TranslationEntry>
    <TranslationEntry name="FB0EA64002045F6004FB5F3CEA5A8293" fullContext="6441F45A0580D1101E2B7FB46870935B" translateForJs="false"> — Gdy przejście zostanie odblokowane w dowolny sposób, czytnik SIFER wyda pojedynczy sygnał dźwiękowy, a duża dioda LED zaświeci się na zielono.</TranslationEntry>
    <TranslationEntry name="C4F4ACB56DB4989774D069E1E01C44BA" translateForJs="false">Zapewnij sygnalizację zwrotną stanu strefy (ta sama strona)</TranslationEntry>
    <TranslationEntry name="32BB4F941207A8C0315451F65042B8C1" fullContext="DE1443568286034E7EB23446C183DD8B" translateForJs="false">Jeśli włączone, czytnik SIFER/OSDP będzie wyświetlał sygnalizację zwrotną dla strefy znajdującej się po tej samej stronie przejścia co czytnik. Sygnalizacja zwrotna jest dostarczana dla następujących stanów strefy: </TranslationEntry>
    <TranslationEntry name="4DE702F4ED35ABAB42995B47E13830B3" fullContext="7265A4FDF29FFC288CFAF19316983D28" translateForJs="false">Uzbrojenie strefy udane</TranslationEntry>
    <TranslationEntry name="B2DA7D48C57D8041D98374CD435E7A1C" fullContext="7265A4FDF29FFC288CFAF19316983D28" translateForJs="false"> - Po pomyślnym uzbrojeniu strefy czytnik SIFER odtworzy ton pomyślnego uzbrojenia strefy, a duża dioda LED będzie migać na zielono.</TranslationEntry>
    <TranslationEntry name="7B185A34DE9B430BD992D41B9ACD8360" fullContext="7265A4FDF29FFC288CFAF19316983D28" translateForJs="false">Niepowodzenie uzbrojenia strefy</TranslationEntry>
    <TranslationEntry name="1E18567AC0CF32ABCC1117D8B378AF69" fullContext="7265A4FDF29FFC288CFAF19316983D28" translateForJs="false"> — gdy uzbrojenie strefy zakończy się niepowodzeniem z powodu uprawnień lub niedomkniętych linii wejściowych, czytnik SIFER odtworzy ton niepowodzenia uzbrojenia strefy i duża dioda LED będzie migać na czerwono.</TranslationEntry>
    <TranslationEntry name="BBC37E387F2419B4015455AB86FBF948" fullContext="7265A4FDF29FFC288CFAF19316983D28" translateForJs="false">Aktywny alarm strefy</TranslationEntry>
    <TranslationEntry name="C4B2D42931019C4C3B51F40CA0133052" fullContext="7265A4FDF29FFC288CFAF19316983D28" translateForJs="false"> - Gdy w strefie jest aktywny alarm, czytnik SIFER będzie odtwarzać ton alarmu strefy, a mała dioda LED będzie szybko migać na czerwono do momentu rozbrojenia strefy.</TranslationEntry>
    <TranslationEntry name="EE9BBC561DB32B8A075B056B8C661B53" fullContext="7265A4FDF29FFC288CFAF19316983D28" translateForJs="false">Opóźnienie na wejście aktywne</TranslationEntry>
    <TranslationEntry name="9BECAB21FD31BE4187DD5C5E65059646" fullContext="7265A4FDF29FFC288CFAF19316983D28" translateForJs="false"> - Gdy aktywny jest tryb opóźnienia na wejście strefy, czytnik SIFER odtworzy ton opóźnienia na wejście, a mała dioda LED będzie migać na zielono przez czas trwania opóźnienia na wejście.</TranslationEntry>
    <TranslationEntry name="AB3272B83CAB1923D96D57C2E9B1DD37" fullContext="7265A4FDF29FFC288CFAF19316983D28" translateForJs="false">Opóźnienie na wyjście aktywne</TranslationEntry>
    <TranslationEntry name="336A4DB4E4794708661998595AFAD698" fullContext="7265A4FDF29FFC288CFAF19316983D28" translateForJs="false"> — gdy aktywny jest tryb opóźnienia na wyjście strefy, czytnik SIFER odtworzy ton opóźnienia na wyjście, a mała dioda LED będzie migać na zielono przez czas trwania opóźnienia na wyjście.</TranslationEntry>
    <TranslationEntry name="268634747D66ECDAB1EDDC7E5270F2CE" fullContext="7265A4FDF29FFC288CFAF19316983D28" translateForJs="false">Strefa wkrótce się uzbroi</TranslationEntry>
    <TranslationEntry name="2845014CE7856C30AC4849F72E9EDDC9" fullContext="7265A4FDF29FFC288CFAF19316983D28" translateForJs="false"> - Gdy strefa ma się automatycznie uzbroić, czytnik SIFER wyda ton ostrzeżenia o automatycznym uzbrojeniu strefy, a mała dioda LED będzie migać na pomarańczowo, dopóki strefa nie zostanie automatycznie uzbrojona lub ręcznie rozbrojona.</TranslationEntry>
    <TranslationEntry name="FBACDD8FFD499C75DB271439C4F7C4FF" fullContext="7265A4FDF29FFC288CFAF19316983D28" translateForJs="false">Uwaga: Powyższe stany są priorytetyzowane przez system w kolejności ich wymienienia. Jeśli czytnik SIFER jest skonfigurowany do zapewniania sygnalizacji zwrotnej stanu strefy dla stref po obu stronach przejścia, obie strefy są sprawdzane i stan strefy o wyższym priorytecie zostanie wyświetlony.</TranslationEntry>
    <TranslationEntry name="5C674D6D4F047284F12C859F6717A3AF" translateForJs="false">Zapewnij sygnalizację zwrotną stanu strefy (druga strona)</TranslationEntry>
    <TranslationEntry name="2553461962DB42D6EBE9AE5480B88FE4" fullContext="7265A4FDF29FFC288CFAF19316983D28" translateForJs="false">Jeśli włączone, czytnik SIFER/OSDP będzie wyświetlał sygnalizację zwrotną dla strefy po drugiej stronie przejścia niż czytnik. Sygnalizacja zwrotna jest dostarczana dla następujących stanów strefy: </TranslationEntry>
    <TranslationEntry name="C9711B474085CB95A0F432BFADA22CD2" fullContext="7E078F6AF1291FFD6804BDC52A7E6600" translateForJs="false">Dioda statusu do śledzenia</TranslationEntry>
    <TranslationEntry name="70CF74EA3615C5AEB6BFC29EE3F6F6B2" fullContext="EA3D3D84757BFEE5DF8F46402E50FCAC" translateForJs="false">Określa przeznaczenie diody LED stanu czytnika. W przypadku czytników SIFER jest to mała dioda LED, w przypadku innych czytników OSDP jest to jedyna dioda LED. Ta dioda LED może być używana do wyświetlania stałego koloru lub stanu przejścia lub strefy. </TranslationEntry>
    <TranslationEntry name="03D0ABAC2A277BC7300393E4B48D533E" fullContext="EA3D3D84757BFEE5DF8F46402E50FCAC" translateForJs="false"> - dioda LED stanu będzie miała kolor wybrany w polu koloru LED na tej stronie.  </TranslationEntry>
    <TranslationEntry name="76415DA6955800CD7F691156EBE1DD2B" fullContext="EA3D3D84757BFEE5DF8F46402E50FCAC" translateForJs="false"> - Dioda stanu zaświeci się na czerwono, gdy przejście jest zablokowane, i na zielono, gdy przejście jest odblokowane. Dioda stanu miga też na czerwono, jeśli użytkownik wykona odczyt karty i odmówiono mu dostępu do przejścia. Wybranie tej opcji zastąpi </TranslationEntry>
    <TranslationEntry name="4D0003A5A25C0A41799A849416C1338B" fullContext="4220D4DA842A7B19BCBBA3394E5C8B11" translateForJs="false">Kolor małej diody LED</TranslationEntry>
    <TranslationEntry name="754EF30FFA4A3B70611F2F1EB420614C" fullContext="EA3D3D84757BFEE5DF8F46402E50FCAC" translateForJs="false"> pole dla czytników SIFER lub </TranslationEntry>
    <TranslationEntry name="7D7CF858FD671B7222A2D186D3F3FAA5" fullContext="7D7CF858FD671B7222A2D186D3F3FAA5" translateForJs="false">Kolor diody LED</TranslationEntry>
    <TranslationEntry name="FAE66D2BFACEE3796426DC808FBECF39" fullContext="EA3D3D84757BFEE5DF8F46402E50FCAC" translateForJs="false"> pole dla czytników OSDP na tej stronie.</TranslationEntry>
    <TranslationEntry name="80E7C20F212C9BBACABB938A95A004EB" fullContext="EA3D3D84757BFEE5DF8F46402E50FCAC" translateForJs="false">Stan strefy, ta sama strona i druga strona</TranslationEntry>
    <TranslationEntry name="D2B37BD6F96DCDC2E9E820CB2E682190" fullContext="EA3D3D84757BFEE5DF8F46402E50FCAC" translateForJs="false"> - Dioda LED stanu świeci na czerwono, gdy strefa jest uzbrojona, i na zielono, gdy strefa jest rozbrojona. Można ją używać do wyświetlania stanu strefy po tej samej lub po przeciwnej stronie co czytnik. Dioda LED stanu miga na zielono, gdy użytkownik uzyska dostęp do przejścia, i na czerwono, gdy dostęp zostanie odmówiony. Wybranie tej opcji zastąpi ustawienie pola diody LED stanu poniżej (</TranslationEntry>
    <TranslationEntry name="1AFCD421BA9DFF0E79EA7B08D64DB7E8" fullContext="7AE760F28F230BAC99288AFF993D24D9" translateForJs="false"> klawisz ([#]) na klawiaturze SIFER/OSDP używany do sterowania stanem strefy.</TranslationEntry>
    <TranslationEntry name="033570A1CA6178A986D673826C360E3A" translateForJs="false">Numer seryjny czytnika</TranslationEntry>
    <TranslationEntry name="ECD034D80E6A571432181378C4C5AC4E" fullContext="D346D6B6AA6D0EA525AEF99AC00A0A04" translateForJs="false">Tylko informacyjnie: przypisanie sprzętu można zmienić za pomocą </TranslationEntry>
    <TranslationEntry name="96B3CABD62EA3D63C7403668C9E0AE6F" fullContext="32C0A2B65C49E169399B55173C154B8E" translateForJs="false"> strona. Jest to numer identyfikacyjny czytnika SIFER/IR — numer ten jest wydrukowany na tylnej stronie czytnika.</TranslationEntry>
    <TranslationEntry name="BD7A9717D29C5DDCAB1BC175EDA1E298" translateForJs="false">Głośność</TranslationEntry>
    <TranslationEntry name="B67B16986339EDB81105F4111FBD4416" fullContext="795F3CAA90DCEBBF83CC2BB00D28E61D" translateForJs="false">Ustawia głośność tonów generowanych przez czytnik SIFER. Istnieje wiele akcji, które generują sygnał dźwiękowy, takich jak odczyt karty, sterowanie strefą itp.</TranslationEntry>
    <TranslationEntry name="B25323F99788CE64617F018B8A9F5F70" translateForJs="false">Jasność</TranslationEntry>
    <TranslationEntry name="0405C16C95FE0A72747F9ED2013844DE" fullContext="4E5883A9B7BA3B2EBA783095598AC11F" translateForJs="false">Ustawia jasność dużej i małej diody LED czytników SIFER.</TranslationEntry>
    <TranslationEntry name="3F57A5915A3030415A8E1CF1CB4ED873" fullContext="3F57A5915A3030415A8E1CF1CB4ED873" translateForJs="false">Kolor dużej diody LED</TranslationEntry>
    <TranslationEntry name="8B80C95CA64ACC6B927DBF815FD5DBC7" fullContext="3347122D6D9C48BDC62216841FDB1C70" translateForJs="false">Ustawia kolor dużej diody LED. </TranslationEntry>
    <TranslationEntry name="4A18FB1834EDB5B23B7AED3BA8FBF099" fullContext="2E70ECDAD1E92655604A64001A29D095" translateForJs="false">Ustawia kolor małej diody LED. Dotyczy tylko sytuacji, gdy powyższa </TranslationEntry>
    <TranslationEntry name="FBAEFB2C12C7CD1374A2EE96BBBBCC64" fullContext="7E078F6AF1291FFD6804BDC52A7E6600" translateForJs="false"> opcja jest ustawiona na </TranslationEntry>
    <TranslationEntry name="3BA5197682FD400023A7DF975F38961C" translateForJs="false">Adres czytnika</TranslationEntry>
    <TranslationEntry name="6E3ADE45728A3C68BDD360C9FF6331FC" fullContext="55D0441B03CC46A6C51E509DEAC8DC77" translateForJs="false"> strona. Jest to adres magistrali OSDP czytnika OSDP, za pomocą którego czytnik identyfikuje się z modułem.</TranslationEntry>
    <TranslationEntry name="7F27CDD9711931D98EDCA3C7A789C2B3" fullContext="63F923C297794D5E6DAF5E1DFD22D433" translateForJs="false">Ustawia kolor diody LED. </TranslationEntry>
    <TranslationEntry name="4E728075D27F9C1A8BA20E3EC3DBFC29" translateForJs="false">Numer EAC</TranslationEntry>
    <TranslationEntry name="4F12AAE54D8FE84C7C29BE09DA9B157E" fullContext="D346D6B6AA6D0EA525AEF99AC00A0A04" translateForJs="false">Obliczony numer EAC bezprzewodowego zamka Aperio. </TranslationEntry>
    <TranslationEntry name="862CF824472CB2DB54C4F8062B8FA62E" fullContext="D346D6B6AA6D0EA525AEF99AC00A0A04" translateForJs="false">Ten numer EAC można znaleźć w aplikacji Aperio Programming Application, przypisany przez koncentrator nadrzędny zamka do zamka na podstawie własnego numeru EAC koncentratora i numeru zamka.  </TranslationEntry>
    <TranslationEntry name="77C7A31A31697D9ED52C56AA79A0AD62" translateForJs="false">Czytniki SIFER</TranslationEntry>
    <TranslationEntry name="0D586CAE19628A7E45B3A0CF026EBC79" translateForJs="false">Czytnik OSDP</TranslationEntry>
    <TranslationEntry name="3393C9C29DB0E55779D8AB6FAFD4D4E7" translateForJs="false">Czytniki OSDP</TranslationEntry>
    <TranslationEntry name="BCD1B68617759B1DFCFF0403A6B5A8D1" fullContext="7AAA8AB8B169D91CCFA0F4380E9A6124" translateForJs="false" rules="unique=ReportFormats" notes="Must be unique amongst all &quot;ReportFormats&quot; entries">PDF</TranslationEntry>
    <TranslationEntry name="4C4AD5FCA2E7A3F74DBB1CED00381AA4" fullContext="7AAA8AB8B169D91CCFA0F4380E9A6124" translateForJs="false" rules="unique=ReportFormats" notes="Must be unique amongst all &quot;ReportFormats&quot; entries">HTML</TranslationEntry>
    <TranslationEntry name="250D745AC70DBB7545CA76407467FFC2" fullContext="7AAA8AB8B169D91CCFA0F4380E9A6124" translateForJs="false" rules="unique=ReportFormats" notes="Must be unique amongst all &quot;ReportFormats&quot; entries">Multi-PDF (skompresowany)</TranslationEntry>
    <TranslationEntry name="8BB82A6B17A6FD63220E4FC11CA3464D" translateForJs="false" rules="unique=ReportFormats" notes="Must be unique amongst all &quot;ReportFormats&quot; entries">CSV (wartości rozdzielone przecinkami)</TranslationEntry>
    <TranslationEntry name="8B01BB790A7ED09574A35CE9FBD9395F" fullContext="9925D706FAAEE008FFE8C244ED84D225" translateForJs="false" rules="unique=ReportType" notes="Must be unique amongst all &quot;ReportType&quot; entries">Podsumowanie uprawnień użytkownika</TranslationEntry>
    <TranslationEntry name="87A5CA456D70F001F53C0B1528791D43" fullContext="9925D706FAAEE008FFE8C244ED84D225" translateForJs="false" rules="unique=ReportType" notes="Must be unique amongst all &quot;ReportType&quot; entries">Podsumowanie uprawnień elementu</TranslationEntry>
    <TranslationEntry name="732CABDE6BFC84822B5FD47A5288B789" fullContext="732CABDE6BFC84822B5FD47A5288B789" translateForJs="false" rules="unique=ReportType" notes="Must be unique amongst all &quot;ReportType&quot; entries">Szczegóły użytkownika</TranslationEntry>
    <TranslationEntry name="DFC122DA0CC097CB97706295046FA9C2" fullContext="9925D706FAAEE008FFE8C244ED84D225" translateForJs="false" rules="unique=ReportType" notes="Must be unique amongst all &quot;ReportType&quot; entries">Czas na obiekcie (odczyt wejścia, odczyt wyjścia)</TranslationEntry>
    <TranslationEntry name="00B507308978F514DFFFFFA84844150D" fullContext="9925D706FAAEE008FFE8C244ED84D225" translateForJs="false" rules="unique=ReportType" notes="Must be unique amongst all &quot;ReportType&quot; entries">Czas przebywania w obiekcie (pierwsze wejście, ostatnie wyjście)</TranslationEntry>
    <TranslationEntry name="8D78FE32C20D35F391EC39BC82C8C84E" translateForJs="false" rules="unique=ReportType" notes="Must be unique amongst all &quot;ReportType&quot; entries">Naruszenia anti-passback użytkownika</TranslationEntry>
    <TranslationEntry name="5B034A7F986710BBA5780D8F1EF39BF6" fullContext="75CDF28BE07D1E4FC436231F56C0659F" translateForJs="false" rules="unique=ReportTimeframeType" notes="Must be unique amongst all &quot;ReportTimeframeType&quot; entries">Ostatnie zdarzenia</TranslationEntry>
    <TranslationEntry name="39B9E051F9FE75E65C7A330BB00499D4" fullContext="75CDF28BE07D1E4FC436231F56C0659F" translateForJs="false" rules="unique=ReportTimeframeType" notes="Must be unique amongst all &quot;ReportTimeframeType&quot; entries">Zakres dat</TranslationEntry>
    <TranslationEntry name="CED79F0D157551AF3377CD1C8D40868C" translateForJs="false">Konfiguracja raportu</TranslationEntry>
    <TranslationEntry name="113478B86963CC735DED3D85D7D6049D" fullContext="7AAA8AB8B169D91CCFA0F4380E9A6124" translateForJs="false">Parametry raportu</TranslationEntry>
    <TranslationEntry name="F5A5DB5B1CBBDA70E30DF7A99EF534D0" fullContext="F5A5DB5B1CBBDA70E30DF7A99EF534D0" translateForJs="false">Typ raportu</TranslationEntry>
    <TranslationEntry name="20BBA7800F872799CFF4E1CBD3D15999" fullContext="9925D706FAAEE008FFE8C244ED84D225" translateForJs="false">Typ raportu do wygenerowania.</TranslationEntry>
    <TranslationEntry name="ECD5D3F0C2652B2AC367F2372FBA316D" fullContext="9925D706FAAEE008FFE8C244ED84D225" translateForJs="false"> - Generuje raport pokazujący listę zdarzeń, w których użytkownicy żądali dostępu przez przejścia lub dostępu do kabin windy, w tym czas zdarzenia dostępu oraz czy dostęp został przyznany, czy odmówiony. Opcjonalnie filtrowalny według użytkowników, przejść lub kabin windy oraz statusu Przyznania/Odmowy dostępu.</TranslationEntry>
    <TranslationEntry name="61EFDBA5B4609EDDA3E26BC87BA1EFA0" fullContext="9925D706FAAEE008FFE8C244ED84D225" translateForJs="false"> - Generuje raport przedstawiający listę zdarzeń, w których użytkownicy lub system żądali uzbrojenia lub rozbrojenia stref. Opcjonalne filtrowanie według stref, użytkowników, zdarzeń uzbrojenia/rozbrojenia, zdarzeń użytkownika/systemu oraz zdarzeń zakończonych sukcesem/niepowodzeniem.</TranslationEntry>
    <TranslationEntry name="3186292C60AD97EDA31C20677BE8A6F8" fullContext="9925D706FAAEE008FFE8C244ED84D225" translateForJs="false"> - Generuje raport zawierający listę uprawnień do elementów i grup uprawnień przypisanych do każdego użytkownika. Umożliwia generowanie różnych poziomów szczegółowości raportu w zależności od wymaganej ilości informacji. Opcjonalnie można filtrować według użytkowników i elementów.</TranslationEntry>
    <TranslationEntry name="F2E6BB0D227A170C2C3389114617980E" fullContext="9925D706FAAEE008FFE8C244ED84D225" translateForJs="false"> - Generuje raport zawierający listę wszystkich Użytkowników posiadających uprawnienie do interakcji z każdym elementem. Podobny do Podsumowania uprawnień użytkowników, lecz raport jest grupowany według elementów. Opcjonalnie można filtrować według Użytkowników i Elementów.</TranslationEntry>
    <TranslationEntry name="8FF7EB31F392DCFBEF49DBC03CBFFD39" fullContext="9925D706FAAEE008FFE8C244ED84D225" translateForJs="false"> - Generuje raport wyświetlający listę użytkowników wraz ze strefą, w której aktualnie przebywają. Opcjonalnie filtrowanie według stref.</TranslationEntry>
    <TranslationEntry name="6CF883E06968FDDD6DD4E2AF1BAB7AC3" fullContext="9925D706FAAEE008FFE8C244ED84D225" translateForJs="false"> - Generuje raport wyświetlający wszystkich użytkowników, którzy nie korzystali z systemu (np. nie uzyskali dostępu do przejścia, nie uzbrajali strefy) przez określony czas (domyślnie 1 miesiąc).</TranslationEntry>
    <TranslationEntry name="AAAD57104C571878F4ACC2374B23683F" fullContext="9925D706FAAEE008FFE8C244ED84D225" translateForJs="false"> - Generuje raport zawierający szczegółowe podsumowania użytkowników w systemie. Szczegóły pokazane dla każdego użytkownika obejmują (jeśli dotyczy) Nazwę użytkownika, Notatki, Profil terminala LCD, Adres e-mail, Przypisane karty i breloki zdalne i inne. Opcjonalnie można filtrować według użytkowników i użytkowników, którzy są wygaśli/wygasający wkrótce.</TranslationEntry>
    <TranslationEntry name="9E27C772D6B5352A3597EF47E3A65950" fullContext="9925D706FAAEE008FFE8C244ED84D225" translateForJs="false"> - Generuje raport pokazujący listę przedziałów czasowych, w których użytkownicy przebywali na obiekcie, na podstawie zdarzeń dostępu z wybranych Czytników wejścia/wyjścia. Opcjonalnie filtrowalny według użytkowników. Ten typ raportu jest zalecany, jeśli obiekt ma ścisłe zasady odczytu karty przy wejściu i wyjściu. Raport pokaże czas między każdym odczytem wejścia a każdym odczytem wyjścia, wyświetlając dla każdego użytkownika każdą wizytę na obiekcie w ramach okresu raportowania. Czytniki wejścia i wyjścia muszą być określone.</TranslationEntry>
    <TranslationEntry name="CA8248298736550916081D3EC7C74527" fullContext="9925D706FAAEE008FFE8C244ED84D225" translateForJs="false"> - Generuje raport pokazujący listę użytkowników, którzy każdego dnia przebywali na obiekcie i przez jaki czas, na podstawie pierwszego i ostatniego zdarzenia odczytu karty przy czytniku w danym dniu (jeden dzień jest traktowany jako 12:00–23:59). Opcjonalnie filtrowalny według użytkowników i przejść. Ten typ raportu jest zalecany, jeśli użytkownicy przebywają na obiekcie tylko w regularnych godzinach dziennych (tj. bez nocnych zmian przechodzących przez północ) i jeśli obiekt nie ma ściśle określonych czytników wejścia/wyjścia.</TranslationEntry>
    <TranslationEntry name="BBA0A07B152F484B0F1F9F46EC3EB82C" fullContext="9925D706FAAEE008FFE8C244ED84D225" translateForJs="false"> - Generuje raport pokazujący listę zdarzeń, w których użytkownicy lub system zażądali zabezpieczenia lub odblokowania jednostek (boksów) magazynowych. Opcjonalnie filtrowalny według jednostek magazynowych, użytkowników, zdarzeń zabezpieczenia/odblokowania, zdarzeń użytkownika/systemu, zdarzeń zakończonych sukcesem/niepowodzeniem oraz tego, czy zdarzenia kontroli wakatów powinny być uwzględnione.</TranslationEntry>
    <TranslationEntry name="FD7B0F89D8EEABF69D2BC7015F4C82E7" fullContext="9925D706FAAEE008FFE8C244ED84D225" translateForJs="false"> — Generuje raport zawierający listę zdarzeń zgłoszonych przez Zintegrowane połączenie lub jego Urządzenia zintegrowane. Opcjonalnie można filtrować według Urządzeń zintegrowanych oraz konkretnych typów zdarzeń.</TranslationEntry>
    <TranslationEntry name="AC87ECBF6D11A84BA0D45399B8A2C732" translateForJs="false">Format pliku</TranslationEntry>
    <TranslationEntry name="D1B6831585333637CEDADB369E28E1F3" fullContext="11774CA2A241537005B3BF9AB3C6B694" translateForJs="false">Wybiera format pliku raportu.</TranslationEntry>
    <TranslationEntry name="5FFDBDE4125EA678A3ACC6F8C8EDB809" fullContext="11774CA2A241537005B3BF9AB3C6B694" translateForJs="false"> - Generuje raport jako pojedynczy dokument PDF. UWAGA: Ta opcja może nie być w stanie obsłużyć tworzenia bardzo dużych raportów (np. raporty podsumowania uprawnień użytkowników o ponad 500 stronach) ze względu na ograniczenia systemowe; dodaj filtry do danych, aby zmniejszyć rozmiar raportu, lub wybierz jeden z innych formatów pliku, jeśli potrzebujesz utworzyć bardzo duży raport.</TranslationEntry>
    <TranslationEntry name="3A7296B1A263709E09EED4E03FF798FF" fullContext="11774CA2A241537005B3BF9AB3C6B694" translateForJs="false"> — Generuje raport jako pojedynczy dokument HTML.</TranslationEntry>
    <TranslationEntry name="FEAC705C94F130D7D29E467E5CAE2A1B" fullContext="11774CA2A241537005B3BF9AB3C6B694" translateForJs="false"> — Generuje raport jako serię pojedynczych dokumentów PDF o maksymalnie około 150 stronach każdy, spakowanych razem do pobrania w jednym pliku ZIP.</TranslationEntry>
    <TranslationEntry name="CC8D68C551C4A9A6D5313E07DE4DEAFD" fullContext="11774CA2A241537005B3BF9AB3C6B694" translateForJs="false">CSV</TranslationEntry>
    <TranslationEntry name="DCEFFF9F9D7F2F47A102315EB51F3B4D" fullContext="11774CA2A241537005B3BF9AB3C6B694" translateForJs="false"> - Generuje raport jako plik tekstowy z wartościami rozdzielanymi przecinkami (CSV), idealny do obróbki lub przetwarzania w zewnętrznych aplikacjach, np. arkuszach kalkulacyjnych. UWAGA: Raporty CSV zawierają wyłącznie tekst i nie posiadają formatowania dostępnego w innych typach plików; jeśli czytelność raportu jest istotna, należy rozważyć użycie jednego z formatów PDF lub HTML.</TranslationEntry>
    <TranslationEntry name="FB988F484E2C15B2A450E5B4C6255E46" translateForJs="false">Nazwa raportu</TranslationEntry>
    <TranslationEntry name="94FA2EBE84848E111CD1D1136B089272" fullContext="22DDF21F0AC7D16E62B1DA7F80741DE3" translateForJs="false">Wygeneruj raport, o który użytkownicy prosili z tytułem w formacie "Nazwa raportu (Typ raportu)". Użytkownik może podać nazwę dla raportu w polu Nazwa raportu.</TranslationEntry>
    <TranslationEntry name="8CC0930E2EF12504424A8799342B6612" fullContext="22DDF21F0AC7D16E62B1DA7F80741DE3" translateForJs="false"> Domyślnie nazwa raportu będzie odpowiadać typowi raportu, a w takim przypadku tekst tytułu będzie wyświetlany jako 'Typ raportu'.</TranslationEntry>
    <TranslationEntry name="793D7B7E16B3F92AE7E6541588EAFDDD" translateForJs="false">Typ przedziału czasowego raportu</TranslationEntry>
    <TranslationEntry name="99DB89E2921D96CD2213D8AF503AF5CE" fullContext="75CDF28BE07D1E4FC436231F56C0659F" translateForJs="false">Typ przedziału czasowego, który zostanie użyty do pobierania zdarzeń uwzględnianych w generowanym raporcie.</TranslationEntry>
    <TranslationEntry name="1F189C14ECB937B4700AD1BCDC065769" fullContext="75CDF28BE07D1E4FC436231F56C0659F" translateForJs="false"> - Umożliwia określenie okresu czasu od chwili obecnej, z którego zdarzenia zostaną uwzględnione w generowanym raporcie. Na przykład wybranie 2 tygodni jako Przedziału czasowego dla tej opcji spowoduje uwzględnienie zdarzeń z ostatnich 2 tygodni w raporcie.</TranslationEntry>
    <TranslationEntry name="2AB1CD18BD05644EA0261BB8B652EE72" fullContext="75CDF28BE07D1E4FC436231F56C0659F" translateForJs="false"> - Umożliwia określenie daty początkowej i końcowej definiującej przedział czasowy, z którego mają być pobierane zdarzenia.</TranslationEntry>
    <TranslationEntry name="5FB7DC4BCCED7462A888793F08882986" fullContext="1B68ACE7BABD66C5E316CE50DC8CC4ED" translateForJs="false">Określa datę początkową wyszukiwania zdarzeń, które zostaną uwzględnione w generowanym raporcie.</TranslationEntry>
    <TranslationEntry name="CAC3659411727F8E99D98C6E39570EAF" fullContext="BCDF22818A9DEDABDA92FE1533476BB6" translateForJs="false">Określa datę końcową wyszukiwania zdarzeń, które zostaną uwzględnione w generowanym raporcie.</TranslationEntry>
    <TranslationEntry name="E1A49A5EA702F54021C844B78139837D" translateForJs="false">Przedział czasowy</TranslationEntry>
    <TranslationEntry name="07906C9B2D02C045C08628FC9BFAA5C5" fullContext="6DCEA36A2102FA1A2162E53D3FCA6D60" translateForJs="false">Określa, jak daleko wstecz w czasie sięgnąć podczas generowania raportu.</TranslationEntry>
    <TranslationEntry name="61287418B908897106ECD19F66E2FA84" translateForJs="false">Filtruj do konkretnych stref</TranslationEntry>
    <TranslationEntry name="7684CC2CF7D8BAA6DFF6C0D59FC1180F" fullContext="AB7668F9F7EDEDF565CEF5BFA64EB164" translateForJs="false">Opcjonalnie filtruj wyniki raportu, aby uwzględniać tylko użytkowników aktualnie przebywających w określonych strefach. Domyślnie (gdy lista jest pusta) w raporcie uwzględniane są wszystkie strefy.</TranslationEntry>
    <TranslationEntry name="F6B91BB2C9CC275E2A2B0F1D965E6290" translateForJs="false">Wyklucz użytkowników nieobecnych w strefach</TranslationEntry>
    <TranslationEntry name="0E961EC324B0F1B3AFF642EE1F26899A" fullContext="F01E1AC44CCE32D75B499EFCF2843FD8" translateForJs="false">Określa, czy użytkownicy nieznający aktualnej strefy (tj. nieaktywni użytkownicy) mają być wykluczeni z raportu. UWAGA: Dotyczy tylko sytuacji, gdy raport nie jest filtrowany do konkretnych stref.</TranslationEntry>
    <TranslationEntry name="EA3F80D2535F67AFBCCF57294B4C509D" translateForJs="false">Filtruj do wybranych użytkowników</TranslationEntry>
    <TranslationEntry name="CADDC4EF746F29A29E44F4F80161D913" fullContext="A5EB710D3BC1B6C685C4F323C2C42F10" translateForJs="false">Opcjonalnie ogranicz wyniki raportu tylko do wybranych użytkowników. Domyślnie (gdy lista jest pusta) wszyscy użytkownicy są uwzględniani w raporcie.</TranslationEntry>
    <TranslationEntry name="68BC1EE7C93C330FC50926E120E194DB" translateForJs="false">Filtruj do określonych elementów</TranslationEntry>
    <TranslationEntry name="37E94039BD807138B7A6780CAF79A85A" fullContext="2610A4DBAA246CFECD6BD88FAAC35990" translateForJs="false">Opcjonalnie filtruj wyniki raportu, aby uwzględnić tylko wybrane elementy. Domyślnie (gdy lista jest pusta) wszystkie elementy (przejścia, strefy, linie wyjściowe) są uwzględniane w raporcie.</TranslationEntry>
    <TranslationEntry name="C8849DBA062DD70C0F61859D5A0DEBC3" fullContext="BE565DBD3D9AD8C2365F21FF0C9B382D" translateForJs="false" rules="unique=UserPermissionsReportFormat" notes="Must be unique amongst all &quot;UserPermissionsReportFormat&quot; entries">Pełne spłaszczone uprawnienia (standardowe)</TranslationEntry>
    <TranslationEntry name="C96F18478F37CFC903C12570ED9AC510" fullContext="BE565DBD3D9AD8C2365F21FF0C9B382D" translateForJs="false" rules="unique=UserPermissionsReportFormat" notes="Must be unique amongst all &quot;UserPermissionsReportFormat&quot; entries">W pełni spłaszczone uprawnienia + łańcuchy grup (zaawansowane)</TranslationEntry>
    <TranslationEntry name="F674B6C25192A2801A0A4BC56F571DC7" translateForJs="false" rules="unique=UserPermissionsReportFormat" notes="Must be unique amongst all &quot;UserPermissionsReportFormat&quot; entries">Tylko uprawnienia przypisane bezpośrednio (podstawowe)</TranslationEntry>
    <TranslationEntry name="240A75A199605E090683C2214CD17550" translateForJs="false">Poziom szczegółowości raportu</TranslationEntry>
    <TranslationEntry name="1E461E82779DBAB83F0E31126F6FB22C" fullContext="BE565DBD3D9AD8C2365F21FF0C9B382D" translateForJs="false">Wybiera poziom szczegółowości, który ma być uwzględniony w Raporcie uprawnień użytkownika.</TranslationEntry>
    <TranslationEntry name="44A01239E96CD0CD172889D1B4BA9AEF" fullContext="BE565DBD3D9AD8C2365F21FF0C9B382D" translateForJs="false"> - Raport pokazuje uproszczony widok wszystkich elementów, do których użytkownik ma dostęp zarówno poprzez bezpośrednie przypisanie, jak i Grupy uprawnień, a także warunki określające, kiedy te uprawnienia są dostępne (np. Zawsze, tylko w Godzinach pracy). Ten typ raportu najlepiej nadaje się do uzyskania wyraźnego obrazu wszystkich możliwych akcji, które użytkownicy mogą wykonywać w systemie.</TranslationEntry>
    <TranslationEntry name="B9EE2F46205A628C32993AAFBB7C27FF" fullContext="BE565DBD3D9AD8C2365F21FF0C9B382D" translateForJs="false"> - Raport zawiera wszystkie informacje z Pełnych spłaszczonych uprawnień (standardowych), a także opis przyczyny dostępności tych uprawnień dla użytkownika (np. bezpośrednio przypisane, odziedziczone z grupy uprawnień). Ten typ raportu najlepiej nadaje się do uzyskania bardzo szczegółowego wglądu we wszystkie możliwe akcje, które użytkownicy mogą wykonywać w systemie, oraz powody dostępności tych uprawnień.</TranslationEntry>
    <TranslationEntry name="6F60C99F6AC33D2E4E8195574AA29F03" fullContext="BE565DBD3D9AD8C2365F21FF0C9B382D" translateForJs="false">Tylko uprawnienia przypisane bezpośrednio (podstawowe)</TranslationEntry>
    <TranslationEntry name="69740D5FA45CB016F57A26E6CB08B58F" fullContext="BE565DBD3D9AD8C2365F21FF0C9B382D" translateForJs="false"> - Raport pokazuje wszystkie bezpośrednio przypisane uprawnienia dla każdego użytkownika, w tym grupy uprawnień, do których są przypisani. Raport ten nie spłaszcza grup uprawnień i pokazuje tylko bezpośrednie przypisania. Ten typ raportu najlepiej nadaje się do uzyskania prostego przeglądu elementów, do których każdy użytkownik ma bezpośrednio przypisane uprawnienia w systemie, lub sprawdzenia, którzy użytkownicy zostali przypisani do których grup uprawnień.</TranslationEntry>
    <TranslationEntry name="7E26AE33246E634508FD1A9EC29439F1" translateForJs="false" rules="unique=AccessStatusFilter" notes="Must be unique amongst all &quot;AccessStatusFilter&quot; entries">Zarówno przyznanie, jak i odmowa dostępu</TranslationEntry>
    <TranslationEntry name="121FE0511C2E8542441F4D892C747748" translateForJs="false" rules="unique=AccessStatusFilter" notes="Must be unique amongst all &quot;AccessStatusFilter&quot; entries">Tylko przyznanie dostępu</TranslationEntry>
    <TranslationEntry name="E7E68981556D2091A6C2A41A26FDE530" translateForJs="false" rules="unique=AccessStatusFilter" notes="Must be unique amongst all &quot;AccessStatusFilter&quot; entries">Tylko odmowy dostępu</TranslationEntry>
    <TranslationEntry name="BCA929A1B3DA045C91EC79D6F2C66B63" translateForJs="false">Filtruj do określonych przejść lub kabin windy</TranslationEntry>
    <TranslationEntry name="82F39CBB1CA90B629A43C0694C1B92B0" fullContext="AA3DFF18A7E337746CA0B830E00D1D92" translateForJs="false">Opcjonalnie filtruj wyniki raportu, aby uwzględniał tylko wybrane przejścia lub kabiny windy. Domyślnie (gdy lista jest pusta) w raporcie uwzględniane są wszystkie przejścia i kabiny windy.</TranslationEntry>
    <TranslationEntry name="4644263E7114B45D3420628E1F17DB38" translateForJs="false">Pokaż zdarzenia przyznania/odmowy dostępu</TranslationEntry>
    <TranslationEntry name="692287E30A821B149D9BC4DD640E52E9" fullContext="A3CBEC66EA5F365DB8D7CFBF681D35C6" translateForJs="false">Określa, czy uwzględniać tylko zdarzenia Przyznania dostępu, tylko zdarzenia Odmowy dostępu, czy oba (domyślnie wyświetlane są oba).</TranslationEntry>
    <TranslationEntry name="C8A9B52C0E0E28E8FBB2BCC06BF847AC" fullContext="709B1A7B53CAA029727E821C800A9FD2" translateForJs="false" rules="unique=UserDetailsExpiry" notes="Must be unique amongst all &quot;UserDetailsExpiry&quot; entries">Wygasłe użytkownicy</TranslationEntry>
    <TranslationEntry name="7E225CD8985C0EF68FAD565DB3C321F1" fullContext="709B1A7B53CAA029727E821C800A9FD2" translateForJs="false" rules="unique=UserDetailsExpiry" notes="Must be unique amongst all &quot;UserDetailsExpiry&quot; entries">Użytkownicy wkrótce wygasający</TranslationEntry>
    <TranslationEntry name="0DA60FC5A27AB58F497CBC55E752630C" fullContext="709B1A7B53CAA029727E821C800A9FD2" translateForJs="false" rules="unique=UserDetailsExpiry" notes="Must be unique amongst all &quot;UserDetailsExpiry&quot; entries">Użytkownicy wygasający w ciągu</TranslationEntry>
    <TranslationEntry name="5F6724FAF1487355D85DF6C0D46FE2B8" translateForJs="false">Filtruj według daty wygaśnięcia</TranslationEntry>
    <TranslationEntry name="5DF3492C63BB7F73A8C00E4AB713B10E" fullContext="709B1A7B53CAA029727E821C800A9FD2" translateForJs="false">Opcjonalnie ogranicz raport tylko do użytkowników, którym wygasł dostęp lub których dostęp wygasa wkrótce.</TranslationEntry>
    <TranslationEntry name="CBA0A95CDB7FE02B0E06B32803C8FE82" fullContext="709B1A7B53CAA029727E821C800A9FD2" translateForJs="false"> — Pokaż wszystkich użytkowników niezależnie od statusu wygaśnięcia.</TranslationEntry>
    <TranslationEntry name="86ED067599F8A2537B5746640BEE77F6" fullContext="709B1A7B53CAA029727E821C800A9FD2" translateForJs="false"> - Pokaż tylko użytkowników wygasłych.</TranslationEntry>
    <TranslationEntry name="9F8A1CAEC2395752F65863011EA39827" fullContext="709B1A7B53CAA029727E821C800A9FD2" translateForJs="false"> — Pokaż tylko użytkowników, którym dostęp wygasa wkrótce, </TranslationEntry>
    <TranslationEntry name="2AD12C082C95761F41582DE3EDDD76B7" fullContext="709B1A7B53CAA029727E821C800A9FD2" translateForJs="false">Wygasa w ciągu</TranslationEntry>
    <TranslationEntry name="2C9567BF34C8C2944D5B0D2974C69DFD" fullContext="709B1A7B53CAA029727E821C800A9FD2" translateForJs="false"> opcja kontroluje przedział czasowy do wyszukiwania.</TranslationEntry>
    <TranslationEntry name="3B29DFB3F4C6D065E96636952536A56B" fullContext="709B1A7B53CAA029727E821C800A9FD2" translateForJs="false"> — Pokaż tylko użytkowników, którzy mają wygasnąć w określonym przedziale czasowym z Datą początkową i Datą końcową.</TranslationEntry>
    <TranslationEntry name="7A1484B66A7C81B982E4F3B17E5F40B5" fullContext="62CE9EB89E940A2E0121DB1BFA7AF050" translateForJs="false">Określa, jak daleko w przyszłość raport ma szukać użytkowników, którym grozi wygaśnięcie.</TranslationEntry>
    <TranslationEntry name="72CB20C0504559524344606E528C7DF6" fullContext="C3E89C41C22F0642DB924ECFCCB8F7EC" translateForJs="false">Określa datę początkową dla wyszukiwania użytkowników, którym grozi wygaśnięcie w danym zakresie dat.</TranslationEntry>
    <TranslationEntry name="E7AEAC5A98A7F8DC5F86DCA095A2C63F" fullContext="E95D27B41096AA8A5F9DF38634288781" translateForJs="false">Określa datę końcową dla wyszukiwania użytkowników, którym grozi wygaśnięcie w danym zakresie dat.</TranslationEntry>
    <TranslationEntry name="469C4425FFD5FC95F1DF71E7F393F659" fullContext="5BD9D67E3DDB745487AC8397508471BD" translateForJs="false" rules="unique=AreaControlArmDisarmFilter" notes="Must be unique amongst all &quot;AreaControlArmDisarmFilter&quot; entries">Tylko zdarzenia uzbrojenia</TranslationEntry>
    <TranslationEntry name="B4D5E32F316DF77B8BD0CD190A7E2D62" fullContext="5BD9D67E3DDB745487AC8397508471BD" translateForJs="false" rules="unique=AreaControlArmDisarmFilter" notes="Must be unique amongst all &quot;AreaControlArmDisarmFilter&quot; entries">Tylko zdarzenia rozbrojenia</TranslationEntry>
    <TranslationEntry name="EF649A9D6A0432B0649045F31FC30E92" fullContext="32EC7ACB91A066143A250FAE65414959" translateForJs="false" rules="unique=AreaControlUserSystemFilter" notes="Must be unique amongst all &quot;AreaControlUserSystemFilter&quot; entries">Tylko zdarzenia sterowania użytkownika</TranslationEntry>
    <TranslationEntry name="ED9F6D4632C00AAFBBD1E6ABA9C527FD" fullContext="32EC7ACB91A066143A250FAE65414959" translateForJs="false" rules="unique=AreaControlUserSystemFilter" notes="Must be unique amongst all &quot;AreaControlUserSystemFilter&quot; entries">Tylko zdarzenia sterowania systemem</TranslationEntry>
    <TranslationEntry name="2649DB583B81EEBC0BAA7B0EE01711A6" fullContext="198CC579BD5B1F3065032BC7093FFCA2" translateForJs="false" rules="unique=AreaControlSuccessFailureFilter" notes="Must be unique amongst all &quot;AreaControlSuccessFailureFilter&quot; entries">Tylko zdarzenia pomyślnego uzbrojenia/rozbrojenia</TranslationEntry>
