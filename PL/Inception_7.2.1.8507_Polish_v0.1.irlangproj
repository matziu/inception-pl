    <TranslationEntry name="88479CA28453FFFBE9FA11C757726824" translateForJs="false">Sterowanie ręczne</TranslationEntry>
    <TranslationEntry name="3F57C91FD35D8EF7801C8D5469E31992" translateForJs="false">Brak w systemie zewnętrznym</TranslationEntry>
    <TranslationEntry name="F3EA2226BFD87C77F77FD5E33575B71D" translateForJs="false">Stan połączenia</TranslationEntry>
