    <TranslationEntry name="7641E5F4E7E8517BD0477FD81E3DE1B8" translateForJs="false" rules="unique=DiallerCountryCodes" notes="Must be unique amongst all &quot;DiallerCountryCodes&quot; entries">Uniwersalny</TranslationEntry>
    <TranslationEntry name="551FE18EF47D4E6E9D943B9A68ADA21D" translateForJs="false" rules="unique=DiallerCountryCodes" notes="Must be unique amongst all &quot;DiallerCountryCodes&quot; entries">Tajwan</TranslationEntry>
    <TranslationEntry name="5E7D2DB5393584D73183C146BD37ADF5" fullContext="B5AC87FF100EF9D6F8F3E23D530CB8D2" translateForJs="false" rules="unique=GSMPathStatusSourceType" notes="Must be unique amongst all &quot;GSMPathStatusSourceType&quot; entries">Integracja urządzenia</TranslationEntry>
    <TranslationEntry name="F8872673DBC54A9F480441B064984127" fullContext="B5AC87FF100EF9D6F8F3E23D530CB8D2" translateForJs="false" rules="unique=GSMPathStatusSourceType" notes="Must be unique amongst all &quot;GSMPathStatusSourceType&quot; entries">Jedna linia wejściowa</TranslationEntry>
    <TranslationEntry name="0185EA4E103F7437430ACDDE3BED4CF5" fullContext="B5AC87FF100EF9D6F8F3E23D530CB8D2" translateForJs="false">Określa sposób, w jaki urządzenie alarmowe raportuje stan ścieżki. Urządzenia alarmowe mogą raportować stan ścieżki bezpośrednio za pomocą integracji wysokiego poziomu lub poprzez przełączanie stanu jednej lub kilku linii wejściowych. Używane urządzenie alarmowe określa, która opcja powinna być wybrana. UWAGA: Zmiany stanu ścieżki będą rejestrowane w rejestrze zdarzeń tylko wtedy, gdy urządzenie alarmowe jest aktualnie połączone z Inception.</TranslationEntry>
    <TranslationEntry name="CE131847BF2E0A2983E7CEFDF7E3C0DD" fullContext="B5AC87FF100EF9D6F8F3E23D530CB8D2" translateForJs="false"> - Integracja wysokiego poziomu dla urządzenia alarmowego raportuje stan ścieżki bezpośrednio.</TranslationEntry>
    <TranslationEntry name="39C1A6A90A8D34A8FAFC618BDE138CDF" fullContext="B5AC87FF100EF9D6F8F3E23D530CB8D2" translateForJs="false"> - Urządzenie alarmowe raportuje swój stan ścieżki poprzez sterowanie stanem wyjścia sprzętowego, aby wskazać dostępność ścieżek. To wyjście urządzenia powinno być podłączone do Inception jako linia wejściowa i wybrane w polu Linia wejściowa stanu ścieżki.</TranslationEntry>
    <TranslationEntry name="AA778D7C59F4EEA12490427A30AC0487" translateForJs="false">Linia wejściowa statusu trasy</TranslationEntry>
    <TranslationEntry name="FDD1E9D9A2F214E25FC51AE82097C68B" fullContext="B2BB315A32AD77AC4AFCF0674D796961" translateForJs="false">Określa linię wejściową, której stan ma być używany do wyznaczania statusu ścieżki urządzenia alarmowego. Domyślnie, gdy linia wejściowa jest w stanie alarmu, oznacza to </TranslationEntry>
    <TranslationEntry name="59998558DCE772D2991C0422BDEA7442" fullContext="B2BB315A32AD77AC4AFCF0674D796961" translateForJs="false">Ścieżka niedostępna</TranslationEntry>
    <TranslationEntry name="D20055267EEB77F30D07ACE36E672CA6" fullContext="B2BB315A32AD77AC4AFCF0674D796961" translateForJs="false">, jednak to zachowanie można odwrócić za pomocą </TranslationEntry>
    <TranslationEntry name="A386AE356CFC385C3C75ADA58B130F27" fullContext="F7D51BCE0A838F35002B563484E1E0AD" translateForJs="false" rules="unique=SwapOptions" notes="Must be unique amongst all &quot;SwapOptions&quot; entries">Zamień stany aktywny i zabezpieczony</TranslationEntry>
    <TranslationEntry name="697119C95411AA3B2B5EDCCEF3EFE0AC" fullContext="D471604D5BE7B763E59E1566E64FD202" translateForJs="false"> opcja na </TranslationEntry>
    <TranslationEntry name="11BAE07C87A3673F2B924534FF703090" fullContext="F7D51BCE0A838F35002B563484E1E0AD" translateForJs="false">[Konfiguracja &gt; Linie wejściowe &gt; Sprzętowe linie wejściowe]</TranslationEntry>
    <TranslationEntry name="C88306F568C2BAA4F7B9B88ADE1CB3E2" fullContext="B2BB315A32AD77AC4AFCF0674D796961" translateForJs="false"> jeśli jest to pożądane.</TranslationEntry>
    <TranslationEntry name="263485BDC392A068C22DB476BFB5D0F2" translateForJs="false">Konfiguracja podstawowa</TranslationEntry>
    <TranslationEntry name="A7EA889E62FD168598BB556F9EEB3260" fullContext="3E06CBEE4B9303B417E1C696640850FB" translateForJs="false">Opóźnienie na wejście to czas, który użytkownik ma na rozbrojenie strefy bez generowania alarmów. Opóźnienie na wejście jest uruchamiane, gdy użytkownik wchodzi do uzbrojonej strefy i wyzwala linię wejściową przypisaną do </TranslationEntry>
    <TranslationEntry name="076BB77659751A3DEBBF466A93247988" fullContext="3E06CBEE4B9303B417E1C696640850FB" translateForJs="false"> grupę procesów. Zaleca się, aby czas opóźnienia na wejście był wystarczająco długi, aby użytkownik mógł dotrzeć do klawiatury i rozbroić strefę.</TranslationEntry>
    <TranslationEntry name="071994DF9F14EAF170AEE72DBB1400BF" fullContext="7370F2D6BA7E6AC8D897ED06432A12F9" translateForJs="false">Opóźnienie na wyjście to czas, jaki użytkownik ma na opuszczenie strefy po jej uzbrojeniu. Liniom wejściowym przypisanym do </TranslationEntry>
    <TranslationEntry name="8E0C4E984DBB4B30A86C232B15DF8490" fullContext="CE954D7EA1A1F5B28C231BE002B839C0" translateForJs="false"> lub </TranslationEntry>
    <TranslationEntry name="DEFE105B9F9C42F46C73E4F59C1CD967" fullContext="11228401AB59FA63A344DB2A532A031D" translateForJs="false">Przekazanie (droga wejścia/wyjścia)</TranslationEntry>
    <TranslationEntry name="5C9FD8CAD049F5F3A4CFF2F367E56C1B" fullContext="7370F2D6BA7E6AC8D897ED06432A12F9" translateForJs="false"> grupy procesów tworzą ścieżkę wyjścia i po wyzwoleniu nie wygenerują alarmu strefy podczas opóźnienia na wyjście.</TranslationEntry>
    <TranslationEntry name="F58EE53083E017C97C5299017C4218B9" fullContext="7370F2D6BA7E6AC8D897ED06432A12F9" translateForJs="false">Zaleca się, aby czas opóźnienia na wyjście był wystarczająco długi, by użytkownik mógł z powodzeniem opuścić budynek.</TranslationEntry>
    <TranslationEntry name="17CC8D32EEB5C1F43763B48F8D9FAD6E" fullContext="7370F2D6BA7E6AC8D897ED06432A12F9" translateForJs="false">Opóźnienie na wyjście jest wyzwalane tylko wtedy, gdy strefa jest uzbrajana z terminala LCD lub interfejsu WWW za pomocą </TranslationEntry>
    <TranslationEntry name="A49B5FF7354CC136E93BDB1E1633014E" fullContext="7AAA8AB8B169D91CCFA0F4380E9A6124" translateForJs="false"> opcja.</TranslationEntry>
    <TranslationEntry name="6A1A91CCC6975360B49883AB94EB95FD" fullContext="576FED3F7C5C0F6F756C04BE82456A64" translateForJs="false">Opóźnienie tymczasowego rozbrojenia (odroczone uzbrojenie)</TranslationEntry>
    <TranslationEntry name="18FAA40EEB3A8FDA99F0498234258619" fullContext="888B3C5BD34A49363D09DFD65FCB71BB" translateForJs="false">Tymczasowe rozbrojenie to funkcja pozwalająca użytkownikowi rozbroić strefę, przy czym strefa automatycznie uzbroi się ponownie po zakończeniu </TranslationEntry>
    <TranslationEntry name="5E10405B325BEE7DEBADB0B799A18C48" fullContext="0575738AC8423BD5997894E343E7744A" translateForJs="false">Opóźnienie tymczasowego rozbrojenia</TranslationEntry>
    <TranslationEntry name="E5A4A505074C35E77795278EDB162776" fullContext="888B3C5BD34A49363D09DFD65FCB71BB" translateForJs="false"> czas. Tymczasowe rozbrojenie, zwane też odroczeniem uzbrojenia, jest często stosowane w celu zapewnienia, że strefa nie zostanie przypadkowo pozostawiona rozbrojona po wyjściu użytkownika z obiektu. Funkcja tymczasowego rozbrojenia jest powszechnie stosowana dla użytkowników, którzy wchodzą do strefy na krótki okres czasu, takich jak sprzątacze lub osoby uzyskujące dostęp do strefy poza godzinami pracy. </TranslationEntry>
    <TranslationEntry name="34E4F13EBCFAE08F4B0408D3D6C5A6D7" fullContext="888B3C5BD34A49363D09DFD65FCB71BB" translateForJs="false">Jeśli w strefie jest używana funkcja tymczasowego rozbrojenia, zaleca się użycie </TranslationEntry>
    <TranslationEntry name="37CE2367CAB71BDB8476003DF9CA8419" fullContext="888B3C5BD34A49363D09DFD65FCB71BB" translateForJs="false"> opcja poniżej, ponieważ ostrzega użytkowników, że strefa wkrótce ponownie się uzbroi. Ta opcja daje użytkownikowi czas na opuszczenie strefy lub ponowne jej rozbrojenie. </TranslationEntry>
    <TranslationEntry name="B917C43E380E43FF5C3E9E89F2E00DB0" fullContext="888B3C5BD34A49363D09DFD65FCB71BB" translateForJs="false">Użytkownik nie musi wykonywać żadnej specjalnej czynności, aby tymczasowo rozbroić strefę — decyzja o tym, czy strefa jest rozbrajana normalnie czy tymczasowo, zależy od uprawnień użytkownika. Aby zezwolić użytkownikowi na tymczasowe rozbrojenie strefy, przypisz użytkownikowi uprawnienie do sterowania strefą z opcją </TranslationEntry>
    <TranslationEntry name="2F471E23C5B14E0E7A320593E2AEC470" fullContext="2F471E23C5B14E0E7A320593E2AEC470" translateForJs="false">Rozbrój strefę</TranslationEntry>
    <TranslationEntry name="A8D235A46C204502DE616B0B291D7D49" fullContext="888B3C5BD34A49363D09DFD65FCB71BB" translateForJs="false"> opcja ustawiona na </TranslationEntry>
    <TranslationEntry name="54453FEB6C9D24D043866ECBA1F23450" fullContext="888B3C5BD34A49363D09DFD65FCB71BB" translateForJs="false">Tylko tymczasowe rozbrojenie</TranslationEntry>
    <TranslationEntry name="AE82043FDE130E503897B7315450B693" fullContext="888B3C5BD34A49363D09DFD65FCB71BB" translateForJs="false">. Gdy użytkownik żąda rozbrojenia strefy, system najpierw sprawdza, czy użytkownik ma uprawnienia do normalnego rozbrojenia strefy. Jeśli nie, sprawdza, czy użytkownik ma uprawnienia do tymczasowego rozbrojenia strefy. Dzięki temu normalne uprawnienia do rozbrojenia mają pierwszeństwo. Dotyczy to każdego żądania rozbrojenia od użytkownika, niezależnie od tego, czy pochodzi z terminala, interfejsu internetowego, odczytu karty czy naciśnięcia przycisku pilota.</TranslationEntry>
    <TranslationEntry name="CF9017013B02A8D618BBA2D5DC0A87EB" fullContext="888B3C5BD34A49363D09DFD65FCB71BB" translateForJs="false">Tymczasowe rozbrojenie może być użyte z </TranslationEntry>
    <TranslationEntry name="FC8D9C126237C74657A4810B67BEA473" fullContext="C3277CC7E756E6B426593E5EDFE49443" translateForJs="false">Harmonogram automatycznego uzbrojenia</TranslationEntry>
    <TranslationEntry name="DEBC8D0C19B2BB5DC5C317F950A80C5D" fullContext="888B3C5BD34A49363D09DFD65FCB71BB" translateForJs="false"> poniższa opcja zapewniająca, że strefa nie pozostanie rozbrojona przez noc. Użytkownik może otrzymać uprawnienie do rozbrojenia strefy normalnie w ciągu dnia, ale tylko tymczasowe rozbrojenie w nocy. Jeśli użytkownik zostanie po zaplanowanym czasie automatycznego uzbrojenia, gdy anuluje automatyczne uzbrojenie, strefa zostanie tylko tymczasowo rozbrojona, co zapewni uzbrojenie strefy po jego wyjściu, gdyby zapomniał. </TranslationEntry>
    <TranslationEntry name="AABB05ACE38DD0EBEFFF66797BB9C779" fullContext="888B3C5BD34A49363D09DFD65FCB71BB" translateForJs="false">Przy wyborze </TranslationEntry>
    <TranslationEntry name="9834440D8FE88388F352A69AE7850E91" fullContext="888B3C5BD34A49363D09DFD65FCB71BB" translateForJs="false"> czas, zaleca się wybranie opóźnienia dłuższego niż to, czego użytkownik zazwyczaj potrzebuje. Na przykład, jeśli sprzątacz zazwyczaj pracuje przez godzinę i pół, należy wybrać dwie godziny. Zapobiega to konieczności wielokrotnego rozbrajania strefy przez użytkownika po każdym upływie czasu opóźnienia, jednocześnie umożliwiając mu pozostanie dłużej niż przez wskazany czas, jeśli jest to wymagane w rzadkich sytuacjach, poprzez ponowne rozbrojenie. </TranslationEntry>
    <TranslationEntry name="984526BAC2D9684234615C64C1F9D441" fullContext="9070B56F2535117EF2DFB97B97C72077" translateForJs="false">Zapewnia dodatkowy czas przed automatycznym uzbrojeniem strefy, umożliwiając użytkownikom opuszczenie strefy lub ręczne rozbrojenie. Automatyczne uzbrojenie strefy może nastąpić wskutek braku aktywności w strefie, harmonogramu lub odroczonego uzbrojenia strefy. Czas ostrzeżenia przed automatycznym uzbrojeniem może być używany do generowania sygnału ostrzegawczego w sygnalizatorach, liniach wyjściowych sygnalizatorów, czytnikach i klawiaturach. Daje to użytkownikowi czas na opuszczenie strefy lub rozbrojenie strefy w celu anulowania uzbrojenia.</TranslationEntry>
    <TranslationEntry name="5F515613360C4EF1929CD036CD7B7E60" fullContext="5F515613360C4EF1929CD036CD7B7E60" translateForJs="false">ID raportowania</TranslationEntry>
    <TranslationEntry name="F1CC5D3E84F4A66A3A0CCDC721E3CC7A" fullContext="9E2CA8488D10F6C23B8146F587EB6EE9" translateForJs="false">Identyfikator raportowania to identyfikator grupy lub strefy używany przez różne formaty raportowania obsługiwane przez system Inception. Identyfikator raportowania strefy jest niezbędny dla większości centrów alarmowych do identyfikowania i interpretowania otwarć/zamknięć stref i alarmów. System automatycznie generuje te identyfikatory za każdym razem, gdy tworzona jest nowa strefa. </TranslationEntry>
    <TranslationEntry name="60E9D41C2EB4D59A743464672DE2A6FC" fullContext="9E2CA8488D10F6C23B8146F587EB6EE9" translateForJs="false">Możliwe jest ręczne przypisywanie identyfikatorów, jednak w większości przypadków jest to niepotrzebne. Upewnij się, że jeśli przypisujesz identyfikatory ręcznie, są one unikalne dla wszystkich stref w systemie, tzn. żadne dwie strefy nie mają tego samego numeru ID. Dotyczy to również identyfikatora raportowania obszaru zdrowia systemu znajdującego się w obszarze </TranslationEntry>
    <TranslationEntry name="634ACF7755C20AB2E2AD8647BACF48D5" fullContext="EC466519A3340053F45FC982258265AA" translateForJs="false">[Konfiguracja &gt; Ogólne &gt; Raportowanie alarmów]</TranslationEntry>
    <TranslationEntry name="0804FF161EED3291B977313AF1AB9B33" fullContext="391BC28AA1395479C8538D39DDAE137C" translateForJs="false" rules="unique=OpenReportingMode" notes="Must be unique amongst all &quot;OpenReportingMode&quot; entries">Raportuj otwarcia i zamknięcia</TranslationEntry>
    <TranslationEntry name="4772265578CEA38D769EA064D081C8AA" fullContext="391BC28AA1395479C8538D39DDAE137C" translateForJs="false" rules="unique=OpenReportingMode" notes="Must be unique amongst all &quot;OpenReportingMode&quot; entries">Raportuj otwarcia tylko po alarmach</TranslationEntry>
    <TranslationEntry name="A63AB8D9BD8FA43D5F270B59A9BB2355" translateForJs="false" rules="unique=OpenReportingMode" notes="Must be unique amongst all &quot;OpenReportingMode&quot; entries">Nie raportuj</TranslationEntry>
    <TranslationEntry name="1DB2D8C5633A47300465E7FD8890E1EE" fullContext="D0CA1FB6849FC43FC702771B9429ED7A" translateForJs="false" rules="unique=InputReportingMode" notes="Must be unique amongst all &quot;InputReportingMode&quot; entries">Raportuj wszystkie alarmy</TranslationEntry>
    <TranslationEntry name="571D033A4B9B407C56D2A6D8113E5349" fullContext="D0CA1FB6849FC43FC702771B9429ED7A" translateForJs="false" rules="unique=InputReportingMode" notes="Must be unique amongst all &quot;InputReportingMode&quot; entries">Raportuj alarmy pozawłamaniowe</TranslationEntry>
    <TranslationEntry name="AD0584D9174E060B664EC77D74AACE3A" fullContext="AD0584D9174E060B664EC77D74AACE3A" translateForJs="false" rules="unique=AreaAutoArmModes" notes="Must be unique amongst all &quot;AreaAutoArmModes&quot; entries">Cała strefa</TranslationEntry>
    <TranslationEntry name="64CF200A40B247165412A3655F1B6701" fullContext="64CF200A40B247165412A3655F1B6701" translateForJs="false" rules="unique=AreaAutoArmModes" notes="Must be unique amongst all &quot;AreaAutoArmModes&quot; entries">Tryb obwodowy</TranslationEntry>
    <TranslationEntry name="B24AD9BC2D30DAEF3AD77E4881260D69" fullContext="B24AD9BC2D30DAEF3AD77E4881260D69" translateForJs="false" rules="unique=AreaAutoArmModes" notes="Must be unique amongst all &quot;AreaAutoArmModes&quot; entries">Tryb nocny</TranslationEntry>
    <TranslationEntry name="A1A1074AAC8F8BF8B8D0F74EC520BECA" fullContext="0575738AC8423BD5997894E343E7744A" translateForJs="false" rules="unique=AutoArmActivityCancelType" notes="Must be unique amongst all &quot;AutoArmActivityCancelType&quot; entries">Czasowe rozbrojenie</TranslationEntry>
    <TranslationEntry name="2C13DF8BD214410A38069D1CD8841419" fullContext="0575738AC8423BD5997894E343E7744A" translateForJs="false" rules="unique=AutoArmActivityCancelType" notes="Must be unique amongst all &quot;AutoArmActivityCancelType&quot; entries">Pełne rozbrojenie</TranslationEntry>
    <TranslationEntry name="966B09BCC8F40D4A142F72A20C6D9D85" fullContext="391BC28AA1395479C8538D39DDAE137C" translateForJs="false">Określa sposób wysyłania zdarzeń otwarcia (rozbrojenia) i zamknięcia (uzbrojenia) do stacji monitorowania. </TranslationEntry>
    <TranslationEntry name="C189C39F5F81F400BD0AAA9DC88583B7" fullContext="391BC28AA1395479C8538D39DDAE137C" translateForJs="false"> - Strefa wygeneruje raport dla obu zdarzeń. </TranslationEntry>
    <TranslationEntry name="75CA98A1B66E98C9471633C37C82D0E1" fullContext="391BC28AA1395479C8538D39DDAE137C" translateForJs="false"> - Ogranicza ogólną liczbę wysyłanych raportów otwarcia, wysyłając otwarcia tylko w przypadku wystąpienia alarmu w strefie. </TranslationEntry>
    <TranslationEntry name="A62AE378A6FABFE4997A0BE340253A88" fullContext="D0CA1FB6849FC43FC702771B9429ED7A" translateForJs="false">Nie raportuj</TranslationEntry>
    <TranslationEntry name="FD2B9B884E562E8E0012FFBC6C2905EA" fullContext="391BC28AA1395479C8538D39DDAE137C" translateForJs="false"> - dla tej strefy nie będzie odbywało się raportowanie otwarcia i zamknięcia.</TranslationEntry>
    <TranslationEntry name="765F29FDC1DFD2D491C2452D0181C48A" translateForJs="false">Raportowanie zdarzeń linii wejściowej</TranslationEntry>
    <TranslationEntry name="255ED45EBC9932DC938DFC47EC1ED47D" fullContext="D0CA1FB6849FC43FC702771B9429ED7A" translateForJs="false">Określa, które zdarzenia alarmowe linii wejściowych są raportowane do stacji monitorowania po ich wystąpieniu. Uwaga: dotyczy to tylko raportowania zdarzeń linii wejściowych; reakcje sygnalizatorów będą nadal następować niezależnie od wybranej opcji.</TranslationEntry>
    <TranslationEntry name="65C10EC7D3F5FA4E81CDA6E3BB9CB4E4" fullContext="D0CA1FB6849FC43FC702771B9429ED7A" translateForJs="false"> - Wszystkie alarmy linii wejściowych są raportowane. Jest to opcja domyślna i najczęściej używana.</TranslationEntry>
    <TranslationEntry name="0FEEAD1ADA0AF5615AE40421CE30D744" fullContext="D0CA1FB6849FC43FC702771B9429ED7A" translateForJs="false"> - Zdarzenia alarmu włamaniowego (generowane przez </TranslationEntry>
    <TranslationEntry name="54828F327F31ABD59F2F459C0247756D" fullContext="D0CA1FB6849FC43FC702771B9429ED7A" translateForJs="false">Natychmiastowy</TranslationEntry>
    <TranslationEntry name="FC763CB31E9938F37737394681228F83" fullContext="6CE9C32BCD06D241B0B5B58F6940E08C" translateForJs="false">, </TranslationEntry>
    <TranslationEntry name="074DE7E7C226D5C60F8AF14C20725352" fullContext="D5A201BB1A9B3F91A2C8A164E3215DD2" translateForJs="false">Podstawowy</TranslationEntry>
    <TranslationEntry name="7DD4DA3051CFDFB5F4B47B6C9A860385" fullContext="D5A201BB1A9B3F91A2C8A164E3215DD2" translateForJs="false">Przekazanie</TranslationEntry>
    <TranslationEntry name="BA5B1865E4496A7F249C5D061D556AFC" fullContext="D0CA1FB6849FC43FC702771B9429ED7A" translateForJs="false"> typy linii wejściowych) nie będą wysyłane. Wszystkie inne typy zdarzeń (w tym zdarzenia sabotażu od linii włamaniowych) — takie jak alarmy awaryjne, pożarowe, Duress i środowiskowe — będą nadal zgłaszane. Często stosowane, gdy ludzie przebywają w pobliżu uzbrojonej strefy, na przykład w sekcji budynku lub gdy strefa na dole jest uzbrojona w domu. W przypadku zdarzenia włamaniowego sygnalizatory uruchomią się, aby zwrócić uwagę i skłonić intruza do opuszczenia obiektu, ale stacja monitorowania nie zostanie powiadomiona.</TranslationEntry>
    <TranslationEntry name="D99168FED9F3E06C7A362E229CB4B3AA" fullContext="D0CA1FB6849FC43FC702771B9429ED7A" translateForJs="false"> - Żadne zdarzenia alarmów linii wejściowych nie będą raportowane dla tej strefy. Reakcje sygnalizatora nadal będą występować w zależności od typu linii wejściowej.</TranslationEntry>
    <TranslationEntry name="BA8F18B9988DD8C1D68EC3DFFC6E1376" fullContext="8436AC57073AC3C8152D67C5F21A6406" translateForJs="false">Monitorowane linie wejściowe</TranslationEntry>
    <TranslationEntry name="40B756C15D649A36FF65271BC2B4E12D" fullContext="2A3601B14797687132D4DD07F2E40D56" translateForJs="false">Umożliwia dodawanie lub usuwanie linii wejściowych ze strefy. Po dodaniu linii wejściowej można jej przypisać </TranslationEntry>
    <TranslationEntry name="35700438DB99E633D9AC86FFAAD5A8D2" fullContext="9284B2779C432D538FA8C1D5E4817534" translateForJs="false">Typ linii wejściowej (grupa procesów)</TranslationEntry>
    <TranslationEntry name="0A2540B3DD40FB12497A9EDCD1DA5AA3" fullContext="2A3601B14797687132D4DD07F2E40D56" translateForJs="false"> aby określić sposób przetwarzania przez strefę zmian stanów linii wejściowych. </TranslationEntry>
    <TranslationEntry name="6A4C77DC949846AF01ECA6F1EB10618A" fullContext="123C2C1CB0EA6165D56A4AE83677B4A1" translateForJs="false">[Mapa wejść strefy]</TranslationEntry>
    <TranslationEntry name="E81952223C616BDB2F630C76B1D0ED42" fullContext="2A3601B14797687132D4DD07F2E40D56" translateForJs="false"> strona zapewnia uproszczony proces dodawania linii wejściowych do stref.</TranslationEntry>
    <TranslationEntry name="4016C766576161EA585A687B5B56B3C4" fullContext="2A3601B14797687132D4DD07F2E40D56" translateForJs="false">Następujące </TranslationEntry>
    <TranslationEntry name="CC1DE4D39E81B34A4403B0FC893F0059" fullContext="2A3601B14797687132D4DD07F2E40D56" translateForJs="false">Typy linii wejściowych (grupy procesów)</TranslationEntry>
    <TranslationEntry name="0D9574DB7F2A81678D6D28E29F7D012C" fullContext="2A3601B14797687132D4DD07F2E40D56" translateForJs="false"> można wybrać:</TranslationEntry>
    <TranslationEntry name="CAEA8340E2D186A540518D08602AA065" fullContext="CAEA8340E2D186A540518D08602AA065" translateForJs="false">Automatyka</TranslationEntry>
    <TranslationEntry name="59696E342B7296C6F2153C4551E9BF60" fullContext="11228401AB59FA63A344DB2A532A031D" translateForJs="false"> - Żadne sygnalizatory ani stroboskopy nie są włączone, żadne alarmy nie są raportowane. Używane do celów automatyki — zautomatyzowana akcja może mieć warunek wyzwalający strefę </TranslationEntry>
    <TranslationEntry name="E10CB60007800EC6124B7F1EEFE00C8E" fullContext="11228401AB59FA63A344DB2A532A031D" translateForJs="false">Wykrywanie aktywnych linii wejściowych</TranslationEntry>
    <TranslationEntry name="6992DD6D5CA703B059F143E0BB844500" fullContext="11228401AB59FA63A344DB2A532A031D" translateForJs="false"> który wraz z wszystkimi innymi typami linii wejściowych spowoduje wyzwolenie.</TranslationEntry>
    <TranslationEntry name="8B85DDF1385616518E234664AE047577" fullContext="11228401AB59FA63A344DB2A532A031D" translateForJs="false" rules="unique=InputTypeNotifications" notes="Must be unique amongst all &quot;InputTypeNotifications&quot; entries">Siłowe otwarcie przejścia</TranslationEntry>
    <TranslationEntry name="E14CE3BB4858D5040F2954134D3B3B24" fullContext="11228401AB59FA63A344DB2A532A031D" translateForJs="false"> — Po wyzwoleniu linii wejściowej tony alarmowe odtwarzane są tylko na wewnętrznych sygnalizatorach, włączane są lampy stroboskopowe i do stacji monitorowania wysyłane jest zdarzenie siłowego otwarcia drzwi. Reakcja alarmowa nastąpi niezależnie od stanu uzbrojenia strefy. Używane przy przejściach, które powinny być otwierane tylko po odblokowaniu, na przykład po żądaniu dostępu lub naciśnięciu przycisku wyjścia (REX). Najlepiej używać z </TranslationEntry>
    <TranslationEntry name="58745BD70FA2004F0BFBA9DF516F655D" fullContext="11228401AB59FA63A344DB2A532A031D" translateForJs="false"> obliczona linia wejściowa, która jest dynamicznie tworzona, gdy przejście ma przypisane wejście kontaktronu lub językowe. Należy pamiętać, że przejścia z swobodnym wyjściem (np. zewnętrzne przejście, które można otworzyć od wewnątrz bez przycisku wyjścia REX lub </TranslationEntry>
    <TranslationEntry name="A3B0F3CD1976814B426B08D9775A6A5F" fullContext="11228401AB59FA63A344DB2A532A031D" translateForJs="false">odblokowanie</TranslationEntry>
    <TranslationEntry name="B148A651902F2EB165856EE3A9822AF7" fullContext="11228401AB59FA63A344DB2A532A031D" translateForJs="false"> przejście) nie powinno być monitorowane za pomocą tego typu linii wejściowej, ponieważ drzwi będą </TranslationEntry>
    <TranslationEntry name="74309231297EA96E92FAE6AC4F5D3C14" fullContext="11228401AB59FA63A344DB2A532A031D" translateForJs="false">siłowe otwarcie</TranslationEntry>
    <TranslationEntry name="27AD23D73FC365120EFE869021C95AFA" fullContext="11228401AB59FA63A344DB2A532A031D" translateForJs="false"> podczas tej akcji.</TranslationEntry>
    <TranslationEntry name="2F0932FB6F5A66B0B56AD212F1DA63FE" fullContext="11228401AB59FA63A344DB2A532A031D" translateForJs="false"> - Gdy linia wejściowa jest wyzwolona, żadne sygnalizatory ani stroboskopy nie są aktywowane, ale do stacji monitorowania wysyłane jest zdarzenie przytrzymanych otwartych drzwi. Zdarzenie jest wysyłane niezależnie od stanu uzbrojenia strefy. Używane jako opcja eskalacji, gdy ważne przejścia są przytrzymywane otwarte zbyt długo. Może wystąpić faza ostrzeżenia z lokalnymi sygnalizatorami dźwiękowymi, aby zwrócić uwagę i umożliwić zamknięcie drzwi; jeśli jednak nikt nie jest w pobliżu i ta faza minie, można wysłać zdarzenie, umożliwiając stacji monitorowania skontaktowanie się z kimś w celu zapewnienia zamknięcia drzwi. Najlepiej stosować z opcją </TranslationEntry>
    <TranslationEntry name="281530793C573047A1E1E8653056AC99" fullContext="11228401AB59FA63A344DB2A532A031D" translateForJs="false">Drzwi przytrzymane otwarte</TranslationEntry>
    <TranslationEntry name="CD7B3DD44EE5B626B4F3B777E9689B86" fullContext="11228401AB59FA63A344DB2A532A031D" translateForJs="false"> wyliczona linia wejściowa, która jest dynamicznie tworzona, gdy do przejścia przypisany jest czujnik kontaktronowy lub języczkowy.</TranslationEntry>
    <TranslationEntry name="F270EF5F48960D9BB7E93D3EEE8D7D91" fullContext="11228401AB59FA63A344DB2A532A031D" translateForJs="false"> — Po wyzwoleniu linii wejściowej nie są aktywowane żadne sygnalizatory ani lampy stroboskopowe, ale do stacji monitorowania wysyłane jest zdarzenie przymusu (duress). Zdarzenie przymusu zostanie wysłane niezależnie od stanu uzbrojenia strefy. W przypadku sabotażu wystąpi ta sama reakcja, z tą różnicą, że do stacji monitorowania zostanie wysłane zdarzenie sabotażu.</TranslationEntry>
    <TranslationEntry name="A3FA706F20BC0B7858B7AE6932261940" fullContext="11228401AB59FA63A344DB2A532A031D" translateForJs="false" rules="unique=InputTypeNotifications" notes="Must be unique amongst all &quot;InputTypeNotifications&quot; entries">Nagły wypadek</TranslationEntry>
    <TranslationEntry name="B1D78777DAB97048C83C58060D49D168" fullContext="11228401AB59FA63A344DB2A532A031D" translateForJs="false"> - Po wyzwoleniu linii wejściowej odtwarzane są dźwięki sygnalizatora ewakuacyjnego, włączane są stroboskopy i wysyłane jest zdarzenie alarmowe do stacji monitorowania. Reakcja alarmowa nastąpi niezależnie od stanu uzbrojenia strefy. W przypadku sabotażu wystąpi taka sama reakcja, z tą różnicą, że do stacji monitorowania zostanie wysłane zdarzenie sabotażu.</TranslationEntry>
    <TranslationEntry name="1B531AB76343253F9E0F23228ACAEE0A" fullContext="11228401AB59FA63A344DB2A532A031D" translateForJs="false" rules="unique=InputTypeNotifications" notes="Must be unique amongst all &quot;InputTypeNotifications&quot; entries">Środowiskowy</TranslationEntry>
    <TranslationEntry name="DC1EF9C29A4C5704C2D8674946BB9EA1" fullContext="11228401AB59FA63A344DB2A532A031D" translateForJs="false"> — Po wyzwoleniu linii wejściowej nie są aktywowane żadne sygnalizatory ani lampy stroboskopowe. Do stacji monitorowania zostaje jednak wysłane zdarzenie inne niż włamanie. Reakcja ta nastąpi niezależnie od stanu uzbrojenia strefy. Używane do reprezentowania alarmów niebędących alarmami intruzów, takich jak alarmy temperatury lub czujniki wody, w celu powiadamiania stacji monitorowania lub innych użytkowników o zdarzeniu. W przypadku sabotażu wystąpi ta sama reakcja, z tą różnicą, że do stacji monitorowania zostanie wysłane zdarzenie sabotażu.</TranslationEntry>
    <TranslationEntry name="A660ED588FCD30FE69884D951C6DA69D" fullContext="11228401AB59FA63A344DB2A532A031D" translateForJs="false"> - Gdy linia wejściowa zostanie wyzwolona przy uzbrojonej strefie i braku aktywnego opóźnienia na wejście lub wyjście, zostaną uruchomione sygnalizatory alarmowe, włączone stroboskopy i do stacji monitorowania zostanie wysłane zdarzenie włamania. Jeśli strefa zostanie rozbrojona, reakcje alarmowe nie nastąpią. W przypadku sabotażu nastąpi ta sama reakcja, z tym że do stacji monitorowania zostanie wysłane zdarzenie sabotażu zamiast zdarzenia włamania. Ta reakcja sabotażowa nastąpi niezależnie od stanu uzbrojenia strefy</TranslationEntry>
    <TranslationEntry name="49C5B70C33DA1108BBCA9EC5102D12AB" fullContext="11228401AB59FA63A344DB2A532A031D" translateForJs="false">Napad</TranslationEntry>
    <TranslationEntry name="5D460218ECFF70C68AA28DE973357A0D" fullContext="11228401AB59FA63A344DB2A532A031D" translateForJs="false"> - Raportuje z tym samym typem zdarzenia alarmowego co typ linii wejściowej napadowej, jednak uruchamiane są syreny alarmowe i strefa przechodzi w stan alarmu. Zdarzenia napadu są przetwarzane niezależnie od stanu uzbrojenia strefy. W przypadku sabotażu nastąpi ta sama reakcja, z tą różnicą, że do stacji monitorowania zostanie wysłane zdarzenie sabotażu zamiast alarmu. Ta reakcja na sabotaż wystąpi niezależnie od stanu uzbrojenia strefy.</TranslationEntry>
    <TranslationEntry name="85EE437D15B1C28579A245F38150BC53" fullContext="11228401AB59FA63A344DB2A532A031D" translateForJs="false">Alarm natychmiastowy</TranslationEntry>
    <TranslationEntry name="236F2EEA2191AF93CD133649CFB2CEB4" fullContext="11228401AB59FA63A344DB2A532A031D" translateForJs="false"> - Gdy linia wejściowa jest wyzwolona przy uzbrojonej strefie, uruchamiane są syreny alarmowe, włączane są stroboskopy i do stacji monitorowania wysyłane jest zdarzenie włamania. W stanie rozbrojenia reakcje alarmowe nie wystąpią. W przypadku sabotażu nastąpi ta sama reakcja, z tą różnicą, że do stacji monitorowania zostanie wysłane zdarzenie sabotażu zamiast włamania. Ta reakcja na sabotaż wystąpi niezależnie od stanu uzbrojenia strefy.</TranslationEntry>
    <TranslationEntry name="077262CC53A1FB1B5F651D31B6BF81BA" fullContext="11228401AB59FA63A344DB2A532A031D" translateForJs="false" rules="unique=InputTypeNotifications" notes="Must be unique amongst all &quot;InputTypeNotifications&quot; entries">Medyczny</TranslationEntry>
    <TranslationEntry name="AF5D72D78A89A85E46A2DF5C8E82B9A5" fullContext="11228401AB59FA63A344DB2A532A031D" translateForJs="false"> - Gdy linia wejściowa zostanie wyzwolona, zostaną uruchomione sygnalizatory alarmowe, włączone stroboskopy i do stacji monitorowania zostanie wysłane zdarzenie medyczne. Reakcja medyczna nastąpi niezależnie od stanu uzbrojenia strefy. W przypadku sabotażu nastąpi ta sama reakcja, z tym że do stacji monitorowania zostanie wysłane zdarzenie sabotażu zamiast zdarzenia medycznego.</TranslationEntry>
    <TranslationEntry name="9C23E106C08171A2F1EAB4F3289E9E33" fullContext="11228401AB59FA63A344DB2A532A031D" translateForJs="false"> - Gdy linia wejściowa zostanie wyzwolona, jeśli strefa jest uzbrojona i nie są aktywne żadne alarmy, zostanie uruchomiony tryb opóźnienia na wejście. Jeśli alarmy są aktywne lub strefa nie zostanie rozbrojona przed upływem opóźnienia na wejście, zostaną uruchomione sygnalizatory alarmowe, włączone stroboskopy i do stacji monitorowania zostanie wysłane zdarzenie włamania. Jeśli strefa zostanie rozbrojona, reakcje alarmowe nie nastąpią. W przypadku sabotażu nastąpi ta sama reakcja, z tym że do stacji monitorowania zostanie wysłane zdarzenie sabotażu zamiast zdarzenia włamania. Ta reakcja sabotażowa nastąpi niezależnie od stanu uzbrojenia strefy.</TranslationEntry>
    <TranslationEntry name="BC93FD0FA19ED26B6ADF8293ADA55404" fullContext="11228401AB59FA63A344DB2A532A031D" translateForJs="false" rules="unique=InputTypeNotifications" notes="Must be unique amongst all &quot;InputTypeNotifications&quot; entries">Dym</TranslationEntry>
    <TranslationEntry name="D92143EC38F9134B96F7BAAB101ADE4D" fullContext="11228401AB59FA63A344DB2A532A031D" translateForJs="false"> — Po wyzwoleniu linii wejściowej odtwarzane są tony sygnalizatora ewakuacji pożarowej, włączane są lampy stroboskopowe i do stacji monitorowania wysyłane jest zdarzenie dymu. Reakcja na dym nastąpi niezależnie od stanu uzbrojenia strefy. W przypadku sabotażu wystąpi ta sama reakcja, z tą różnicą, że do stacji monitorowania zostanie wysłane zdarzenie sabotażu.</TranslationEntry>
    <TranslationEntry name="DC2BB1BFACB84DBD0D13918978F90AEC" fullContext="11228401AB59FA63A344DB2A532A031D" translateForJs="false"> — Po wyzwoleniu linii wejściowej odtwarzane są tony alarmowe sygnalizatorów, a strefa przechodzi w stan alarmu, niezależnie od stanu uzbrojenia strefy. Zdarzenia włamań są jednak raportowane tylko wtedy, gdy strefa jest uzbrojona. Używane do reprezentowania alarmu Jednostki (boksu), gdzie sygnalizatory mogą się włączyć w ciągu dnia w przypadku nieautoryzowanego dostępu do boksu, gdy obecny jest personel, natomiast sygnalizatory i raportowanie zdarzeń mogą być aktywowane poza godzinami pracy, gdy strefa jest uzbrojona. W przypadku sabotażu aktywowane są sygnalizatory strefy i do stacji monitorowania wysyłane jest zdarzenie sabotażu. Ta reakcja na sabotaż nastąpi niezależnie od stanu uzbrojenia strefy.</TranslationEntry>
    <TranslationEntry name="D48713A6E9BA0F14DFD1E027CEDB3351" fullContext="2A3601B14797687132D4DD07F2E40D56" translateForJs="false"> – przeznaczone do użytku z </TranslationEntry>
    <TranslationEntry name="9E21D12B9CD90E26E400CF875CA51046" fullContext="2A3601B14797687132D4DD07F2E40D56" translateForJs="false"> linie wejściowe dla Bezprzewodowych przejść, odpowiednie zdarzenie linii wejściowej *Niski poziom baterii* lub *Błąd odpytywania* zostanie wysłane do stacji monitorowania niezależnie od stanu uzbrojenia strefy. Jednak żadne stroboskopy ani sygnalizatory nie zostaną aktywowane. Zapewnia to sposób raportowania różnych stanów Bezprzewodowego przejścia bez zakłócania standardowych wzorców raportowania włamania. Należy pamiętać, że linie wejściowe, które nie są </TranslationEntry>
    <TranslationEntry name="6BEF300E5A0825628E8EA5F881B19632" fullContext="2A3601B14797687132D4DD07F2E40D56" translateForJs="false"> nie są obsługiwane przez tę grupę procesów.</TranslationEntry>
    <TranslationEntry name="B6357DDBBA54BC43C73781D27EEE9EA1" fullContext="F6EC761D7B903B4DE4D002188C50086A" translateForJs="false">Wielotrybo uzbrajanie (pełne/zewnętrzne/nocne)</TranslationEntry>
    <TranslationEntry name="BE0CA73071685F31E6E70D8F0A47126C" fullContext="61BBA7B22CD847106927899FB9ADA524" translateForJs="false">Jeśli włączone, strefę można uzbroić w kilku różnych trybach. Zastępuje to podstawowy tryb uzbrojenia, umożliwiając uzbrojenie strefy w trybie pełnym (Away), zewnętrznym (Stay) lub nocnym (Instant). Tryby te są powszechnie stosowane w scenariuszach domowych, gdzie zewnętrzna część budynku powinna być uzbrojona, gdy ludzie są w środku. Podobnie jak w standardowym trybie uzbrojenia, dotyczy to wyłącznie typów linii włamaniowych. Linie wejściowe takie jak pożarowe i Duress będą monitorowane niezależnie od trybu uzbrojenia.</TranslationEntry>
    <TranslationEntry name="B00627B165B885057A6F512FF2A8CE61" fullContext="61BBA7B22CD847106927899FB9ADA524" translateForJs="false">Tryby uzbrojenia mają następujące zachowanie:</TranslationEntry>
    <TranslationEntry name="AD90AF073B069075335029C1B5575263" fullContext="61BBA7B22CD847106927899FB9ADA524" translateForJs="false"> - Dokładnie takie samo zachowanie jak standardowy tryb uzbrojenia. Cała strefa jest uzbrajana z opóźnieniem na wyjście, jeśli jest wymagane. Przeznaczone do użytku, gdy wszyscy opuszczają strefę.</TranslationEntry>
    <TranslationEntry name="4161FF71996D7FDF8BC832631A635AD9" fullContext="61BBA7B22CD847106927899FB9ADA524" translateForJs="false"> - Uzbraja jedynie obwód zewnętrzny strefy. Przeznaczone do użytku w sytuacji, gdy osoby pozostają w strefie, zabezpieczając jedynie obwód zewnętrzny budynku. Monitorowane są tylko linie wejściowe obwodu zewnętrznego (określone w </TranslationEntry>
    <TranslationEntry name="AE353D19581EB64057056748E75C0DEB" fullContext="61BBA7B22CD847106927899FB9ADA524" translateForJs="false">Linie wejściowe peryferii</TranslationEntry>
    <TranslationEntry name="4EADF356D1525D2287521352B9F2FE14" fullContext="61BBA7B22CD847106927899FB9ADA524" translateForJs="false"> opcja poniżej). Jeśli aktywuje się linia wejściowa podstawowa, rozpocznie się opóźnienie na wejście (np. ktoś otworzy drzwi).</TranslationEntry>
    <TranslationEntry name="65D9B14BA3669F3AAB3495A266F6F43A" fullContext="61BBA7B22CD847106927899FB9ADA524" translateForJs="false"> - Przeznaczone do użytku w sytuacji, gdy osoby pozostają w strefie, ale nikt nie wchodzi ani nie wychodzi. Monitorowane są linie wejściowe obwodu zewnętrznego i nocne linie wejściowe wnętrza (określone w </TranslationEntry>
    <TranslationEntry name="09165541E73CEB5270F1119209CD10F3" fullContext="61BBA7B22CD847106927899FB9ADA524" translateForJs="false"> opcja i </TranslationEntry>
    <TranslationEntry name="4254058EAD21B7E32485AF6D7D4D4664" fullContext="61BBA7B22CD847106927899FB9ADA524" translateForJs="false">Wewnętrzne linie wejściowe nocne</TranslationEntry>
    <TranslationEntry name="E4D6D034389AD280A6537C03047BDE48" fullContext="61BBA7B22CD847106927899FB9ADA524" translateForJs="false"> poniższa opcja). Jeśli jakakolwiek linia wejściowa obwodu zewnętrznego zostanie aktywowana (w tym linie wejściowe podstawowe), alarm zostanie natychmiast aktywowany. Pozwala to na ostrzeganie na przykład w przypadku włamania przez frontowe drzwi, gdy wszyscy śpią. Opcjonalnie można określić dodatkowe wewnętrzne linie wejściowe nocne w celu monitorowania większego obszaru w tym trybie. Te wewnętrzne linie wejściowe są traktowane jako linie wejściowe podstawowe, wyzwalając opóźnienie na wejście (a tym samym nie uruchamiając sygnalizatorów natychmiast), jeśli ktoś je aktywuje.</TranslationEntry>
    <TranslationEntry name="A87C2AF873D427D078D6D88E502C78C7" fullContext="61BBA7B22CD847106927899FB9ADA524" translateForJs="false">Po włączeniu, </TranslationEntry>
    <TranslationEntry name="1571044FAA9E46609F29F0131F58158A" fullContext="61BBA7B22CD847106927899FB9ADA524" translateForJs="false"> opcja poniżej staje się dostępna, gdzie należy podać linie wejściowe, które mają być monitorowane w trybach zewnętrznym i nocnym. Będą to linie wejściowe, takie jak kontaktrony okienne lub drzwiowe, chroniące potencjalne punkty wejścia do strefy.</TranslationEntry>
    <TranslationEntry name="A7A692F95B2B3F60CF0C9A2BC218A708" fullContext="61BBA7B22CD847106927899FB9ADA524" translateForJs="false"> opcja staje się również dostępna, umożliwiając monitorowanie dodatkowych linii wejściowych (a tym samym większej części budynku) w trybie nocnym. Będą to linie wejściowe monitorujące miejsca, do których nie powinny udawać się osoby, gdy budynek jest uzbrojony na noc, takie jak parter lub pokoje dzienne, gdy użytkownicy śpią.</TranslationEntry>
    <TranslationEntry name="99F1404996AC1F0E585FFC3D631B797D" fullContext="61BBA7B22CD847106927899FB9ADA524" translateForJs="false">Aby zapobiec przypadkowym alarmom w trybie zewnętrznym, linie zewnętrzne, które mogą być często otwierane (przejścia, niektóre okna itp.), można ustawić jako linie podstawowe. Spowoduje to uruchomienie opóźnienia na wejście w trybie zewnętrznym i da szansę na rozbrojenie strefy. W trybie natychmiastowym jednak nadal natychmiast przejdą w stan alarmu. </TranslationEntry>
    <TranslationEntry name="8AA51D8E60122E54F0F6B16FCD028A57" fullContext="61BBA7B22CD847106927899FB9ADA524" translateForJs="false">Jest to opcja dla każdej strefy z osobna — możesz mieć strefę Dom w trybie wielotryby, ale standardowe uzbrojenie dla stref Garaż i Warsztat.</TranslationEntry>
    <TranslationEntry name="D6909187AE133737ED2AF56CB33BB4A9" fullContext="8436AC57073AC3C8152D67C5F21A6406" translateForJs="false">Dostępne, gdy </TranslationEntry>
    <TranslationEntry name="5A802C69C3FA787FA61E4865FE90A232" fullContext="FB83D4B2CB938C38FD9FCD344EA6AEEB" translateForJs="false"> opcja powyżej jest włączona. Ta opcja umożliwia określenie zewnętrznych linii wejściowych czujek włamaniowych strefy.</TranslationEntry>
    <TranslationEntry name="0620EBC3813AFB08E7C5F0353A9F0B16" fullContext="FB83D4B2CB938C38FD9FCD344EA6AEEB" translateForJs="false">Gdy ta strefa jest uzbrojona w trybie zewnętrznym lub nocnym, monitorowane będą tylko linie wejściowe czujek włamaniowych (podstawowe, przekazujące, natychmiastowe) określone na tej liście. Linie wejściowe na tej liście muszą również znajdować się na liście </TranslationEntry>
    <TranslationEntry name="BF726E5A021B19C999153061028DBD25" fullContext="8436AC57073AC3C8152D67C5F21A6406" translateForJs="false"> lista powyżej. Należy zauważyć, że typy linii wejściowych inne niż włamaniowe (dym, przymus itp.) nie muszą być uwzględnione na tej liście — będą monitorowane niezależnie od trybu uzbrojenia.</TranslationEntry>
    <TranslationEntry name="516AD46828287C0F096E9C2E179D7FD0" fullContext="FB83D4B2CB938C38FD9FCD344EA6AEEB" translateForJs="false">Te linie wejściowe zazwyczaj reprezentują punkty detekcji włamań chroniące obwód strefy, takie jak kontaktrony drzwiowe i okienne. Tryby uzbrojenia zewnętrznego i nocnego byłyby używane, gdy ludzie znajdują się wewnątrz strefy, dlatego wewnętrzne czujki ruchu na ogół nie byłyby uwzględniane na tej liście.</TranslationEntry>
    <TranslationEntry name="889B4903FC8A4EFCFFBED8613FBFD909" fullContext="8436AC57073AC3C8152D67C5F21A6406" translateForJs="false"> opcja powyżej jest włączona. Ta opcja umożliwia monitorowanie dodatkowych linii wejściowych w trybie uzbrojenia Nocnego (Natychmiastowego). </TranslationEntry>
    <TranslationEntry name="0F44CF63257C81FB6FDCEFEB32565D19" fullContext="8436AC57073AC3C8152D67C5F21A6406" translateForJs="false">Gdy ta strefa jest uzbrojona w trybie nocnym, oprócz linii wejściowych zewnętrznych monitorowane będą również linie wejściowe czujek włamaniowych (podstawowe, przekazujące, natychmiastowe) określone na tej liście. Wszelkie nocne linie wejściowe wewnętrzne są traktowane jako linie podstawowe, wyzwalając opóźnienie na wejście po aktywacji. Pozwala to na monitorowanie większego obszaru budynku, gdy wszyscy śpią, bez natychmiastowego aktywowania sygnalizatorów przy wejściu do tej sekcji.</TranslationEntry>
    <TranslationEntry name="E4699AA12EF8F128DC1E329CD59A55E2" fullContext="8436AC57073AC3C8152D67C5F21A6406" translateForJs="false">Linie wejściowe na tej liście muszą również znajdować się na </TranslationEntry>
    <TranslationEntry name="970C41ADDD4110681935621ED9EAB9A3" fullContext="3431B65A88063B9AC339EFB214726585" translateForJs="false">Liczba impulsów</TranslationEntry>
    <TranslationEntry name="C03DE0D79D330EEB9132444582081856" fullContext="1191A7D6E051B34B49B8E1280E6F9316" translateForJs="false">Liczba impulsów określa liczbę aktywacji alarmu linii wejściowej wymaganą do wyzwolenia alarmu strefy. Aktywacje są zliczane zarówno z wielokrotnego wyzwolenia tej samej linii wejściowej, jak i z różnych linii wejściowych w strefie — i muszą wystąpić w obrębie </TranslationEntry>
    <TranslationEntry name="133E7F3D31610AA3254FE3E6225EDC5F" fullContext="1191A7D6E051B34B49B8E1280E6F9316" translateForJs="false">Czas trwania impulsu</TranslationEntry>
    <TranslationEntry name="3FB188675D96D085FDEF56806D459900" fullContext="1191A7D6E051B34B49B8E1280E6F9316" translateForJs="false"> czas na wyzwolenie alarmu. Po wyzwoleniu alarmu zliczanie impulsów zostaje zatrzymane, a każda kolejna aktywacja jest przetwarzana normalnie.</TranslationEntry>
    <TranslationEntry name="CE4DEE8246A85FD15363C4E52F4A6832" fullContext="1191A7D6E051B34B49B8E1280E6F9316" translateForJs="false">Zliczanie impulsów linii wejściowej jest często stosowane w celu ograniczenia fałszywych alarmów, ignorując jednorazowe aktywacje i przetwarzając tylko powtarzające się aktywacje. Fałszywe alarmy mogą wynikać z wielu przyczyn, na przykład poruszania się zwierząt domowych, przepływu powietrza z systemu klimatyzacji lub burzy poruszającej przedmiotami i wyzwalającej czujki ruchu lub wibracji.</TranslationEntry>
    <TranslationEntry name="16D6BB92F376294B3F19470A611E8AF5" fullContext="3431B65A88063B9AC339EFB214726585" translateForJs="false">Zliczanie impulsów dotyczy tylko zdarzeń alarmowych z linii wejściowych podstawowych, przekazujących lub natychmiastowych. Inne zdarzenia typów linii wejściowych, takie jak napad, wykrycie dymu, pomoc medyczna lub alarmowe, będą przetwarzane normalnie. Podobnie wszelkie zdarzenia sabotażu linii wejściowej będą przetwarzane normalnie.</TranslationEntry>
    <TranslationEntry name="028DF12B7BA03CA6FD9FEFDF800B5EE8" fullContext="1191A7D6E051B34B49B8E1280E6F9316" translateForJs="false">Przy wyborze wartości liczby impulsów ważne jest uwzględnienie środowiska, które chroni ta strefa. Środowisko o wysokim poziomie zabezpieczeń wymagałoby niższej liczby impulsów, aby wyzwolenie nastąpiło szybciej, natomiast w lokalizacji z domowymi zwierzętami lub w trudnym środowisku może być wymagana wyższa liczba, aby odfiltrować przypadkowe aktywacje. </TranslationEntry>
    <TranslationEntry name="49F558D55C2B8619E9928FA0E4F531A4" fullContext="3431B65A88063B9AC339EFB214726585" translateForJs="false">Aby wyłączyć zliczanie impulsów, należy </TranslationEntry>
    <TranslationEntry name="08B5019E02D4BA0210EA46B5650A904F" fullContext="3431B65A88063B9AC339EFB214726585" translateForJs="false"> powinno być ustawione na 0 lub 1.</TranslationEntry>
    <TranslationEntry name="D1B3D0D699B7AE587934FBC42BECBBE9" fullContext="3431B65A88063B9AC339EFB214726585" translateForJs="false">Przedział czasu, w którym musi wystąpić określona liczba aktywacji alarmu linii wejściowej, zanim zostanie zgłoszony alarm. Liczba aktywacji jest konfigurowana w </TranslationEntry>
    <TranslationEntry name="7644DB0F78F03E2BF050ECD25CA0C828" fullContext="3431B65A88063B9AC339EFB214726585" translateForJs="false"> powyżej.</TranslationEntry>
    <TranslationEntry name="5FB4FEA3852DE4F94DA33FBC65AD272F" fullContext="3431B65A88063B9AC339EFB214726585" translateForJs="false">Oprócz zliczania impulsów, alarm strefy zostanie również wyzwolony, jeśli zostanie wykryta aktywacja, która pozostaje aktywna dłużej niż czas trwania impulsu bez przywrócenia. Zapobiega to omijaniu zliczania impulsów przez aktywację linii wejściowej bez przywrócenia.</TranslationEntry>
    <TranslationEntry name="2A5F69B5151B53A534B768A18B56F029" translateForJs="false">Linie wejściowe zakończenia wyjścia</TranslationEntry>
    <TranslationEntry name="4756CFECB7E312C62B665889ED4DFC98" fullContext="4A945A82F50A63F50F2D9D079F13C6D7" translateForJs="false">Można wybrać jedną lub więcej linii wejściowych, które służą do skrócenia aktywnego opóźnienia wyjścia. Są one często używane, aby zapobiec uruchamianiu pełnego czasu długich opóźnień wyjścia, gdy użytkownik już opuścił strefę.</TranslationEntry>
    <TranslationEntry name="949E3F08069B2948AD07747621D5E542" fullContext="4A945A82F50A63F50F2D9D079F13C6D7" translateForJs="false">Najczęściej stosuje się główną linię wejściową strefy lub kontaktron na przejściu wyjściowym lub czujnik języka zamka, albo przycisk na zewnątrz budynku, aby upewnić się, że użytkownik opuścił strefę przed skróceniem opóźnienia na wyjście. Wskazane linie wejściowe nie muszą być liniami monitorowanymi przez strefę — można użyć dowolnych linii wejściowych w systemie.</TranslationEntry>
    <TranslationEntry name="31EAB5F47254EB7FA08D58E8845D2F4A" fullContext="4A945A82F50A63F50F2D9D079F13C6D7" translateForJs="false">Aby aktywować tę funkcję, dowolna z określonych linii wejściowych musi przejść ze stanu aktywnego do stanu bezpiecznego. Wbudowane jest małe opóźnienie podczas przetwarzania linii wejściowej, która spowodowała zakończenie opóźnienia wyjścia, aby zapobiec fałszywym alarmom. Dzięki temu linia wejściowa ma czas na ustabilizowanie się, na przykład jeśli linia wejściowa jest kontaktronem drzwi lub czujnikiem języczkowym, który mógłby chwilowo drgać przy zamykaniu drzwi.</TranslationEntry>
    <TranslationEntry name="DD98ECA37F539DCF6E605A97043D095E" fullContext="B1C7CE51162BF1B778770ED4C2425190" translateForJs="false">Ignoruj problemy ze sprawnością modułu</TranslationEntry>
    <TranslationEntry name="82077B4170C8DC0C842E2EFBD89ED87D" fullContext="319EE2D0E5000E4574341334F19296C7" translateForJs="false">Ignorowanie problemów ze stanem modułów dla tej strefy wpływa na dwie główne funkcje systemu:</TranslationEntry>
    <TranslationEntry name="B39FB0CCDC6EB4992F31E2039A8BDA21" fullContext="319EE2D0E5000E4574341334F19296C7" translateForJs="false">Reakcja na sabotaż strefy</TranslationEntry>
    <TranslationEntry name="FF850817956B034AC7DE823FA14283AB" fullContext="319EE2D0E5000E4574341334F19296C7" translateForJs="false"> - Domyślnie, jeśli moduł sygnalizuje problem z sabotażem (np. sabotaż sygnalizatora lub obudowy), wszystkie strefy w systemie generują odpowiedź alarmową — uruchamiają sygnalizatory i stroboskopy. Może to być niepożądane w przypadku stref niebędących strefami alarmowymi, ponieważ wymagałyby one rozbrojenia. Włączenie tej opcji powoduje wyłączenie danej strefy z automatycznej reakcji na sabotaż.</TranslationEntry>
    <TranslationEntry name="A1511BDAE48AC968B4E083C54FCD2A21" fullContext="319EE2D0E5000E4574341334F19296C7" translateForJs="false">Kontrola stanu systemu przy uzbrajaniu strefy</TranslationEntry>
    <TranslationEntry name="217D8EB13F01D50F7551F3CFEADADBCA" fullContext="6B84C55F05D9A4499AEF73D8C79DD875" translateForJs="false"> - </TranslationEntry>
    <TranslationEntry name="4F80409B74DCFAB68C12DFA76705FB97" fullContext="CAAADCC2576CDFD7550FB4F9FC73B15E" translateForJs="false">Weryfikuj stan systemu przy uzbrajaniu strefy</TranslationEntry>
    <TranslationEntry name="32842598EB69A326238C9546341B7DCE" fullContext="CAAADCC2576CDFD7550FB4F9FC73B15E" translateForJs="false">[Konfiguracja &gt; Ogólne &gt; Ustawienia]</TranslationEntry>
    <TranslationEntry name="31C2D2CC9736C72C9E3AB6EB0A0CEF92" fullContext="319EE2D0E5000E4574341334F19296C7" translateForJs="false"> strona powoduje, że próby uzbrojenia strefy sprawdzają wszelkie problemy zdrowotne modułów lub problemy z komunikacją alarmową w systemie. Są one automatycznie pomijane, gdy system uzbraja strefę; jednak jeśli użytkownik uzbraja strefę, próba uzbrojenia może się nie powieść. Umożliwia to użytkownikowi naprawienie problemu przed ponowną próbą uzbrojenia lub pominięcie problemu i kontynuowanie uzbrajania. Jeśli takie zachowanie jest niepożądane dla tej strefy, istnieją dwie opcje, aby tego uniknąć. Po pierwsze, włączenie opcji </TranslationEntry>
    <TranslationEntry name="1E0C244D52A9BDAAA3C6ACF38E321823" fullContext="319EE2D0E5000E4574341334F19296C7" translateForJs="false"> opcja uniemożliwi tej strefie testowanie stanu systemu podczas uzbrajania. Alternatywnie, </TranslationEntry>
    <TranslationEntry name="5489D0965F9FDEA2C971381B503159BB" fullContext="319EE2D0E5000E4574341334F19296C7" translateForJs="false">Automatycznie izoluj niezabezpieczone linie wejściowe przy uzbrajaniu przez użytkownika</TranslationEntry>
    <TranslationEntry name="D8BAF696628593E84E2C4BD3A7BA2572" fullContext="6E0E9EE32ADF90C026F9F75434458712" translateForJs="false"> opcja w </TranslationEntry>
    <TranslationEntry name="9B57602F628A703E3F3A612EAB5D5023" fullContext="9284B2779C432D538FA8C1D5E4817534" translateForJs="false">Automatyczne uzbrojenie</TranslationEntry>
    <TranslationEntry name="2A38BFC14326DBED636A669B1ABD3527" fullContext="319EE2D0E5000E4574341334F19296C7" translateForJs="false"> sekcja poniżej może być użyta do automatycznego nadpisywania tych problemów.</TranslationEntry>
    <TranslationEntry name="7C79E78CBAEC426051E8955559E1FA76" translateForJs="false">Uwzględnij linie wejściowe ścieżki wyjścia w kontroli uszczelnienia</TranslationEntry>
    <TranslationEntry name="F9420016EBDE107DDD398E43A2643B05" fullContext="3F00885001B9B6C7BAE1D70B380EDD4A" translateForJs="false">Określa, czy linie wejściowe drogi wyjściowej (Handover/Exit Path) są uwzględniane w kontroli uszczelnienia podczas próby uzbrojenia strefy z opóźnieniem na wyjście. Domyślnie linie wejściowe drogi wyjściowej są ignorowane w kontroli uszczelnienia przed uzbrojeniem, gdy aktywne jest opóźnienie na wyjście. Włączenie tej opcji spowoduje, że próby uzbrojenia z opóźnieniem na wyjście zakończą się niepowodzeniem, jeśli podczas kontroli którekolwiek linie wejściowe drogi wyjściowej są aktywne, i wyświetlony zostanie monit o zaizolowanie lub ponowne uszczelnienie linii wejściowych przed ponowną próbą uzbrojenia strefy.</TranslationEntry>
    <TranslationEntry name="AD9901ED78FAD0DBA922891BB1A8E445" translateForJs="false">Skasuj stan alarmu gdy wszystkie linie wejściowe bezpieczne</TranslationEntry>
    <TranslationEntry name="534B4BF1F5FF0408CFBE45A7060F78F2" fullContext="39A1A10B4AC4372EA0C7274D2B3F4958" translateForJs="false">Gdy ta opcja jest włączona, uszczelnienie wszystkich aktywnych linii wejściowych w strefie spowoduje skasowanie stanu alarmu. Następnie nastąpi </TranslationEntry>
    <TranslationEntry name="EA4A4064299DE904014C4D1E9DF2DBC5" fullContext="39A1A10B4AC4372EA0C7274D2B3F4958" translateForJs="false">Alarm anulowany</TranslationEntry>
    <TranslationEntry name="7C8BFECF78B71F380E4500E88FC797B2" fullContext="39A1A10B4AC4372EA0C7274D2B3F4958" translateForJs="false"> zdarzenie zostanie wysłane do stacji monitorowania, a wszystkie sygnalizatory i stroboskopy zostaną zatrzymane.</TranslationEntry>
    <TranslationEntry name="B3A39CD2339343D8B1B884DA954CB387" fullContext="39A1A10B4AC4372EA0C7274D2B3F4958" translateForJs="false">Ta nowa opcja jest przeznaczona specjalnie dla stref monitorujących linie wejściowe z zatrzaskiem, gdzie wymagane jest dodatkowe działanie w celu zabezpieczenia linii wejściowej (linie wejściowe Duress lub przyciski awaryjnego wyjścia z ręcznym zwolnieniem, linie wejściowe alarmu jednostki (boksu) z </TranslationEntry>
    <TranslationEntry name="74F7304B158019CA4F8ABFF58F3C1849" fullContext="39A1A10B4AC4372EA0C7274D2B3F4958" translateForJs="false">Kasuj alarm jednostki gdy linie wejściowe zostaną zabezpieczone</TranslationEntry>
    <TranslationEntry name="60922FFD2F102B967CE61E48840EF901" fullContext="39A1A10B4AC4372EA0C7274D2B3F4958" translateForJs="false"> ustawiony itd.). </TranslationEntry>
    <TranslationEntry name="BBFD7C786E7162ED1E244C0E527D5C3E" fullContext="39A1A10B4AC4372EA0C7274D2B3F4958" translateForJs="false">Na przykład, gdy </TranslationEntry>
    <TranslationEntry name="0126C00FA98820CB1A6B2E90D884CD3E" fullContext="39A1A10B4AC4372EA0C7274D2B3F4958" translateForJs="false"> opcja jest odznaczona w bloku magazynowym, ta opcja strefy jest włączona, a obliczona linia wejściowa jednostki (boksu) monitorowanej przez strefę wyzwala alarm — właściciel jednostki (boksu) może wykonać </TranslationEntry>
    <TranslationEntry name="7E7123B0D269AD5D9EC8D12C52A8ED8A" fullContext="7E7123B0D269AD5D9EC8D12C52A8ED8A" translateForJs="false">Odblokuj</TranslationEntry>
    <TranslationEntry name="184D02C149B4BAFA96A16BC37EBF9E29" fullContext="17938230C868F1836F9EFD0D87CE5F70" translateForJs="false">Skasuj alarmy</TranslationEntry>
    <TranslationEntry name="9ED87EBD25433EDF6A2EBF9B93C3C6B5" fullContext="39A1A10B4AC4372EA0C7274D2B3F4958" translateForJs="false"> akcja na swojej jednostce. Strefa odpowiedzialna za monitorowanie linii wejściowej jednostki (boksu) automatycznie przywróci swoje alarmy i prześle </TranslationEntry>
    <TranslationEntry name="0740E98EF040A052F485D3227062D897" fullContext="39A1A10B4AC4372EA0C7274D2B3F4958" translateForJs="false"> zdarzenie do stacji monitorowania i dezaktywuje wszystkie stroboskopy i sygnalizatory. Eliminuje to konieczność ręcznego dostępu administratora obiektu do systemu, rozbrajania strefy i ponownego uzbrajania w celu wznowienia monitorowania linii wejściowych.</TranslationEntry>
    <TranslationEntry name="31A90D2D2ED7376F87DEC651710D5982" fullContext="39A1A10B4AC4372EA0C7274D2B3F4958" translateForJs="false">Zaleca się stosowanie Contact ID do raportowania alarmów przy użyciu tej opcji, ponieważ w tym protokole zdefiniowany jest odpowiedni typ zdarzenia.</TranslationEntry>
    <TranslationEntry name="BBF5EFA2602E59E8F7819C0B7217F35D" translateForJs="false">Sygnalizatory</TranslationEntry>
    <TranslationEntry name="B0D66BE568A4BD19B169CDF42031BD11" translateForJs="false">Urządzenia sygnalizacyjne</TranslationEntry>
    <TranslationEntry name="F3611D09C5333E94C3DE5B0970CFBCDC" fullContext="03A9422870F848AB140C5F1A1AFD3E0A" translateForJs="false">Określa, które moduły aktywują sterowniki sygnalizatorów po wyzwoleniu sygnalizatora. Aby dodać urządzenie sygnalizatora, kliknij </TranslationEntry>
    <TranslationEntry name="E1EA3D726CD98FC09EF108F6C38E5578" fullContext="11228401AB59FA63A344DB2A532A031D" translateForJs="false">Dodaj elementy</TranslationEntry>
    <TranslationEntry name="C3BA57FDF14B23437B163965C3004AE9" fullContext="03A9422870F848AB140C5F1A1AFD3E0A" translateForJs="false"> przycisk, co spowoduje wyświetlenie wszystkich dostępnych urządzeń sygnalizacyjnych. Tylko moduły z wyjściami S1INT (wewnętrzny) i S2EXT (zewnętrzny) mogą sterować sygnalizatorami rogowymi 8 omów — na przykład Ekspander LAN 8 stref. Wszystkie Typy linii wejściowych (Grupy procesów) zdolne do wyzwolenia sygnalizatora uruchomią zarówno wewnętrzne, jak i zewnętrzne linie wyjściowe sygnalizatora. </TranslationEntry>
    <TranslationEntry name="4F4D69735226AFE9E2C4D48D6CAD3333" fullContext="03A9422870F848AB140C5F1A1AFD3E0A" translateForJs="false">Oprócz generowania tonów sygnalizatora, urządzenia sygnalizatora mogą służyć do sygnalizacji zwrotnej dźwiękowej informującej o pomyślnym uzbrojeniu strefy, nieudanym uzbrojeniu, ostrzeżeniach o automatycznym uzbrojeniu, opóźnieniu na wejście i opóźnieniu na wyjście.</TranslationEntry>
    <TranslationEntry name="96610888B88FC017EBF10096E3FAA0AA" fullContext="96610888B88FC017EBF10096E3FAA0AA" translateForJs="false">Przypisz urządzenia sygnalizatora do tej strefy.</TranslationEntry>
    <TranslationEntry name="CAF50E8B0C0922A09C4A6899FFEB2A50" fullContext="67F55B3AA9FABA56BD2FC303D4F2E556" translateForJs="false">Określa, które moduły aktywują linie wyjściowe sygnalizatora S1INT i S2EXT, gdy zostanie wyzwolona linia wejściowa zaprogramowana do generowania sygnałów alarmowych. Określa również, które linie wyjściowe sygnalizatora zostaną aktywowane dla sygnałów powodzenia uzbrojenia strefy, niepowodzenia uzbrojenia strefy i ostrzeżeń o automatycznym uzbrojeniu, a także opóźnienia na wejście i opóźnienia na wyjście, jeśli wymagana jest aktywacja sygnalizatora. </TranslationEntry>
    <TranslationEntry name="DDF422EE853A11D6FABE2C27FA2E86D1" fullContext="16541EF9099536D74A1A9ECC6111D3E4" translateForJs="false">Linie wyjściowe sygnalizatorów</TranslationEntry>
    <TranslationEntry name="77BF2090BA0736DF7E677DF200FCDD61" fullContext="71E5A8686B038D511BDD75FB6015E2D9" translateForJs="false">Określa, które dodatkowe linie wyjściowe włączą się po wyzwoleniu sygnalizatora; nie wymaga to zaprogramowania urządzenia sygnalizatora powyżej. Wyjście sygnalizatora jest powszechnie używane do sterowania piezosyrenekami. Po zdefiniowaniu wyjścia sygnalizatora i ustawieniu jego lokalizacji (wewnętrzna lub zewnętrzna), będzie ono działać jak urządzenie sygnalizatora tego samego typu. Aby dodać wyjście sygnalizatora, kliknij </TranslationEntry>
    <TranslationEntry name="138103C4E1D9C846D0AFD000E5B928C8" fullContext="71E5A8686B038D511BDD75FB6015E2D9" translateForJs="false">Dodaj element</TranslationEntry>
    <TranslationEntry name="2505388EE6D7D45DB6CB619150CA5EB5" fullContext="71E5A8686B038D511BDD75FB6015E2D9" translateForJs="false"> przycisk spowoduje otwarcie okna zawierającego wszystkie dostępne linie wyjściowe.</TranslationEntry>
    <TranslationEntry name="44995E90569E181DFD0024407CDC8C38" translateForJs="false">Czas sygnalizatora</TranslationEntry>
    <TranslationEntry name="947A50CC1E37273B0767D9E73C667EC8" fullContext="9E3735ACBA1087B1ECCD07F8C92F5A58" translateForJs="false">Czas aktywności sygnalizatora. Sygnalizator wyłączy się, jeśli użytkownik zaloguje się na klawiaturze lub rozbroi strefę.</TranslationEntry>
    <TranslationEntry name="27C465BAB6E76659CAA645B61DDAAD5C" fullContext="9E3735ACBA1087B1ECCD07F8C92F5A58" translateForJs="false">Uwaga: Lokalne przepisy określą maksymalny czas działania sygnalizatora.</TranslationEntry>
    <TranslationEntry name="84193A8E729AAB61CCAB0BD9406609E8" translateForJs="false">Nadpisz lokalizację reagowania na alarm</TranslationEntry>
    <TranslationEntry name="9D5FCE16D7979F53A0BE447C6CF51C5A" fullContext="C6AF5813D70607440CC417010146B657" translateForJs="false">Jeśli jest skonfigurowane, pojawi się dodatkowa opcja umożliwiająca podanie niestandardowej lokalizacji odpowiedzi na alarm.</TranslationEntry>
    <TranslationEntry name="28DB7AF8053B2697BAEEF078F2C12BE2" fullContext="C6AF5813D70607440CC417010146B657" translateForJs="false">Jeśli nie skonfigurowano, lokalizacja zostanie wywnioskowana z lokalizacji linii wejściowej.</TranslationEntry>
    <TranslationEntry name="1126B0EBC461ECF35F91E3D7FF835456" translateForJs="false">Lokalizacja reagowania na alarm</TranslationEntry>
    <TranslationEntry name="09274B2B9D407C77DCF7476B53324A23" fullContext="D50F3108A2EFF2DE799F1D7AF33C5CA8" translateForJs="false">Określa, czy sygnalizator wewnętrzny, zewnętrzny, czy oba powinny brzmieć podczas alarmu.</TranslationEntry>
    <TranslationEntry name="016BE0A39ED7909FC42DDC0FC172EEF5" translateForJs="false">Sygnalizator po uzbrojeniu strefy</TranslationEntry>
    <TranslationEntry name="B813D6EA9B2BBCDC843E998F23C3EA66" fullContext="74EA528236B89E3818DB0F6995C0234B" translateForJs="false">Określa, czy po pomyślnym uzbrojeniu strefy uruchamiają się sygnalizatory wewnętrzne, zewnętrzne, czy obydwa.</TranslationEntry>
    <TranslationEntry name="EBC56DCC6DDC53421A4DD58951DA2E29" translateForJs="false">Sygnalizator alarmu uzbrojenia strefy</TranslationEntry>
    <TranslationEntry name="FA94C1FE8C81BC17B0D0C0597E2555EB" fullContext="31CE97A616F59A6EB8660C24B97FB7CB" translateForJs="false">Określa, czy wewnętrzny, zewnętrzny, czy oba sygnalizatory emitują krótki sygnał wskazujący nieudane uzbrojenie strefy.</TranslationEntry>
    <TranslationEntry name="A3B1DE74FC4567E3BA0D9EEF4F0A8FA6" translateForJs="false">Sygnalizator opóźnienia na wejście</TranslationEntry>
    <TranslationEntry name="315F23A8009266B076509FEC72B53977" fullContext="EA1EF882EA0AA0915418BF3CC7BAD4FC" translateForJs="false">Określa, czy sygnalizator wewnętrzny, zewnętrzny, czy oba brzmią przez czas trwania opóźnienia na wejście.</TranslationEntry>
    <TranslationEntry name="15D2B9B3C22DB05654D7ACEE0E696F7C" translateForJs="false">Sygnalizator opóźnienia na wyjście</TranslationEntry>
    <TranslationEntry name="1D9C8A3C1D8E0ECB369A052E15A17275" fullContext="B47D2C142FCB11F0C49B4454E9EF20A2" translateForJs="false">Określa, czy sygnalizator wewnętrzny, zewnętrzny, czy oba brzmią przez czas trwania opóźnienia na wyjście.</TranslationEntry>
    <TranslationEntry name="2B542652D708AF0E8E0EA34FF76B30C7" translateForJs="false">Sygnalizator ostrzeżenia przed automatycznym uzbrojeniem</TranslationEntry>
    <TranslationEntry name="73BA223528F4E867A60910739E0ED699" fullContext="64FA85D983537D51C9CC63E2858233C1" translateForJs="false">Określa, czy podczas ostrzeżenia o automatycznym uzbrojeniu strefy uruchamiają się sygnalizatory wewnętrzne, zewnętrzne, czy obydwa.</TranslationEntry>
    <TranslationEntry name="99B109F361C961C2D9B626458C22F18E" translateForJs="false">Limit aktywacji sygnalizatora</TranslationEntry>
    <TranslationEntry name="23E4A9733202C72039C8244183181B5E" fullContext="74EE7862E843DB6B8EB627826E9F6D72" translateForJs="false">Ustaw maksymalną liczbę razy, kiedy ta strefa może aktywować sygnalizator. Jeśli wartość jest ustawiona na 0, liczba aktywacji będzie nieograniczona. Rozbrojenie strefy resetuje ten licznik.</TranslationEntry>
    <TranslationEntry name="3DE9E996703237F917932BB8CA893F9D" fullContext="3DE9E996703237F917932BB8CA893F9D" translateForJs="false">Sygnalizatory świetlne</TranslationEntry>
    <TranslationEntry name="A7CB391CBD3465A4652D0FC151FAEDC6" fullContext="4C144FCC3A4E2EEF4833E1C5B1BD8616" translateForJs="false">Stroboskopowe linie wyjściowe</TranslationEntry>
    <TranslationEntry name="6D0842360B34FF3621B0196100283A8B" fullContext="978E735AE9B3F222D67C0B5AEBA5CEA3" translateForJs="false">Określa, które linie wyjściowe będą aktywowane do sterowania stroboskopami. Każdy typ linii wejściowej zdolny do sterowania stroboskopem włączy wyjście stroboskopu; wyjście to pozostanie włączone do czasu rozbrojenia strefy. Aby dodać wyjście stroboskopu, kliknij </TranslationEntry>
    <TranslationEntry name="381ECD4F0523E62DC7322FAE957CF3BB" fullContext="978E735AE9B3F222D67C0B5AEBA5CEA3" translateForJs="false"> przycisk spowoduje wyświetlenie okna zawierającego wszystkie dostępne linie wyjściowe stroboskopu. Można dodać dowolną liczbę wyjść stroboskopu.</TranslationEntry>
    <TranslationEntry name="6D99359F174F1C0F6A9A4979D265D669" fullContext="6D99359F174F1C0F6A9A4979D265D669" translateForJs="false">Przypisz linie wyjściowe stroboskopu, które mają być wyzwalane, gdy uruchamiają się sygnalizatory strefy.</TranslationEntry>
    <TranslationEntry name="A7166FE0093F4B16D78BC16FA180948D" fullContext="4095AF302D6825C39E2C06C6B44B5934" translateForJs="false">Określa, która linia wyjściowa lub linie wyjściowe są fizycznie podłączone do stroboskopu lub będą działać jak stroboskop. Te linie wyjściowe będą aktywowane przez alarm strefy i wyłączą się po rozbronieniu strefy.</TranslationEntry>
    <TranslationEntry name="6296B51D35B7163459FD5BE086B78BBE" translateForJs="false">Sygnalizacja zwrotna udanego uzbrojenia</TranslationEntry>
    <TranslationEntry name="049CA9BF1B921E7FB179291C6DE8F59D" fullContext="862C9C7BAF503B5DC69E48982D4AF2C4" translateForJs="false">Jeśli włączone, wszystkie linie wyjściowe stroboskopów włączą się na trzy sekundy po pomyślnym uzbrojeniu strefy. Jest to często stosowane przy uzbrajaniu strefy za pomocą pilota lub czytnika, aby dać użytkownikowi wizualne potwierdzenie pomyślnego uzbrojenia.</TranslationEntry>
    <TranslationEntry name="564E47274B40AE04AFE05DA9B8BB8B46" translateForJs="false">Sygnalizacja zwrotna niepowodzenia uzbrojenia</TranslationEntry>
    <TranslationEntry name="EEEB2DAB9C5B55BFB37A67445FAD4A09" fullContext="F247A02F87FABCF4248E8470B2F84514" translateForJs="false">Jeśli włączone, wszystkie linie wyjściowe lamp stroboskopowych włączą się na sześć sekund, gdy próba uzbrojenia strefy się nie powiedzie. Jest to powszechnie stosowane podczas uzbrajania strefy za pomocą pilota lub czytnika, aby dać użytkownikowi wizualną informację, że uzbrojenie się nie powiodło i należy zbadać przyczynę.</TranslationEntry>
    <TranslationEntry name="3C08807D01B4F4D086CF246CA3413656" fullContext="576FED3F7C5C0F6F756C04BE82456A64" translateForJs="false">Można wybrać przedział czasowy do automatycznego uzbrajania strefy. Można to wykorzystać do uzbrojenia strefy późno w nocy, na wypadek gdyby użytkownik zapomniał ją uzbroić. Strefa zostanie automatycznie uzbrojona, gdy przedział czasowy stanie się ważny (początek przedziału czasowego). </TranslationEntry>
    <TranslationEntry name="E7F0812B26D335881D2184FA3B4C5DD0" fullContext="576FED3F7C5C0F6F756C04BE82456A64" translateForJs="false"> zaleca się używać z </TranslationEntry>
    <TranslationEntry name="9DCCF13F482454816A79E217A929C3FA" fullContext="576FED3F7C5C0F6F756C04BE82456A64" translateForJs="false"> opcja powyżej, która może ostrzegać użytkowników o zbliżającym się uzbrojeniu strefy. Daje to użytkownikowi czas na opuszczenie strefy lub rozbrojenie strefy w celu anulowania uzbrojenia. </TranslationEntry>
    <TranslationEntry name="2D5A66DB9EBE6B5F27FA6B3DF03CF96D" fullContext="576FED3F7C5C0F6F756C04BE82456A64" translateForJs="false">Uwaga: strefa nie będzie próbować ponownie się uzbroić, jeśli zaplanowane uzbrojenie zostało anulowane. Jeśli jest używane do uzbrajania strefy późno w nocy, aby zapewnić jej właściwe uzbrojenie przez całą noc, zaleca się używanie z </TranslationEntry>
    <TranslationEntry name="3347C7FEA9F427B3DA1EC05CE0128929" fullContext="576FED3F7C5C0F6F756C04BE82456A64" translateForJs="false"> funkcjonalność, aby zmniejszyć ryzyko pozostawienia strefy niezabezpieczonej, gdy użytkownik opuści obiekt.</TranslationEntry>
    <TranslationEntry name="680111FB7F7059936E94883D1F8DF5A4" translateForJs="false">Tryb harmonogramu automatycznego uzbrojenia</TranslationEntry>
    <TranslationEntry name="E9C05440E10A0415B90E90866089BCF1" fullContext="F6EC761D7B903B4DE4D002188C50086A" translateForJs="false">Gdy </TranslationEntry>
    <TranslationEntry name="90240C2C279F9B9BEAB09D1A306B6FDA" fullContext="F6EC761D7B903B4DE4D002188C50086A" translateForJs="false"> powyższa opcja jest używana, strefa automatycznie uzbroi się, gdy przedział czasowy stanie się aktywny. Jest to często używane w celu zapewnienia uzbrojenia strefy w nocy na wypadek, gdyby użytkownik zapomniał.</TranslationEntry>
    <TranslationEntry name="93845732E0521577BB5BD41B833192DB" fullContext="D7F4947903481A6EED59F509C51A2019" translateForJs="false">Jeżeli </TranslationEntry>
    <TranslationEntry name="F35DF21BF68400E992A87CBD66230D05" fullContext="F6EC761D7B903B4DE4D002188C50086A" translateForJs="false"> opcja jest włączona (w </TranslationEntry>
    <TranslationEntry name="C675485A5871C84A010A05659B95FD36" fullContext="F6EC761D7B903B4DE4D002188C50086A" translateForJs="false"> sekcja powyżej), strefę można uzbroić w trybie pełnym (Away), zewnętrznym (Stay) lub nocnym (Instant). Ta opcja określa, w jakim trybie strefa zostanie uzbrojona po aktywacji harmonogramu. Można to ustawić na przykład dla późnych godzin nocnych, aby zapewnić przejście strefy w tryb nocny.</TranslationEntry>
    <TranslationEntry name="AF3FF976D5E08DC3E492BC3F56089EDF" fullContext="D471604D5BE7B763E59E1566E64FD202" translateForJs="false">Automatyczne rozbrojenie gdy harmonogram nieaktywny</TranslationEntry>
    <TranslationEntry name="032D060921449BD587F6962F716A42CA" fullContext="C2B9E4E39D1F94970ACDBF6B0DA1FB85" translateForJs="false">Jeśli włączone, strefa zostanie automatycznie rozbrojona, gdy przedział czasowy wybrany w harmonogramie automatycznego uzbrojenia stanie się nieaktywny (koniec przedziału czasowego).</TranslationEntry>
    <TranslationEntry name="B4B14920755D0F2D4EE9D49340777BAE" fullContext="C2B9E4E39D1F94970ACDBF6B0DA1FB85" translateForJs="false">Uwaga: opcja ta może pozostawić strefę niezabezpieczoną w niepożądanym czasie, jeśli przedziały czasowe nie są odpowiednio zarządzane. Na przykład strefa może się rozbroić w dni wolne od pracy, gdy nikogo nie ma w pobliżu, pozostawiając obszar bez ochrony.</TranslationEntry>
    <TranslationEntry name="C5D1010FEC98B84464542D3EB75E28DB" translateForJs="false">Harmonogram czasu bezczynności automatycznego uzbrojenia (opcjonalny)</TranslationEntry>
    <TranslationEntry name="502F1607B1431FCA52232E41E590BA31" fullContext="3635E0D3BACD44A07A935E09DEC55112" translateForJs="false">Pole Harmonogram czasu bezczynności automatycznego uzbrojenia jest opcjonalnym polem, które może służyć do ograniczenia czasu aktywności logiki pola Czas bezczynności automatycznego uzbrojenia, na przykład: można chcieć, aby automatyczne uzbrojenie przy bezczynności następowało tylko poza godzinami pracy. Czas bezczynności będzie liczony od momentu aktywacji harmonogramu, na przykład: jeśli harmonogram staje się aktywny o 19:00, a Czas bezczynności wynosi 30 minut, strefa będzie mogła uzbroić się najwcześniej o 19:30. Jeśli nie ustawiono harmonogramu, logika automatycznego uzbrojenia przy bezczynności będzie zawsze aktywna.</TranslationEntry>
    <TranslationEntry name="187F977A67EF0540683CC8A209C451FB" fullContext="16541EF9099536D74A1A9ECC6111D3E4" translateForJs="false">Czas braku aktywności dla automatycznego uzbrojenia</TranslationEntry>
    <TranslationEntry name="255C8C4956334B5A16336D83548F9149" fullContext="25F6F76FB234E7F75DB26B7BA0CC9106" translateForJs="false">Czas bezczynności automatycznego uzbrojenia umożliwia automatyczne uzbrojenie strefy, jeśli przez określony czas nie zostanie wykryta aktywność linii wejściowych w strefie. Jest to powszechnie stosowane do automatycznego uzbrajania rzadko używanych stref bez konieczności interakcji użytkownika, co zapewnia ich częstsze zabezpieczenie. Aby ustawić czas bezczynności automatycznego uzbrojenia, wybierz czas trwania z listy rozwijanej.</TranslationEntry>
    <TranslationEntry name="23E1EDC6B0843C00B41D7E5F2696A01F" fullContext="25F6F76FB234E7F75DB26B7BA0CC9106" translateForJs="false">Opcjonalne pole Harmonogram czasu bezczynności (automatyczne uzbrojenie) pozwala ograniczyć godziny, w których aktywna jest logika automatycznego uzbrojenia po bezczynności. Jeśli nie ustawiono harmonogramu, logika ta jest aktywna zawsze.</TranslationEntry>
    <TranslationEntry name="02EDD93949F6D3C57D9822691B59F649" fullContext="CABA1F097719CBEAD4EDF9052DC39974" translateForJs="false">Elementem </TranslationEntry>
    <TranslationEntry name="35E5324F6F1CF6D9E6467D2B1DF99E6F" fullContext="25F6F76FB234E7F75DB26B7BA0CC9106" translateForJs="false"> opcja jest zalecana do użycia z </TranslationEntry>
    <TranslationEntry name="EE6956986F08D6695C511CA75112D1B6" fullContext="25F6F76FB234E7F75DB26B7BA0CC9106" translateForJs="false"> opcja powyżej, która może ostrzegać użytkowników o zbliżającym się uzbrojeniu strefy. Dzięki temu użytkownik ma czas na opuszczenie strefy lub rozbrojenie jej w celu anulowania uzbrojenia. Po rozpoczęciu czasu ostrzegawczego aktywność na liniach wejściowych nie anuluje uzbrojenia — można je zatrzymać wyłącznie przez rozbrojenie strefy.</TranslationEntry>
    <TranslationEntry name="8AE3C83B4113E63A944084C1EF4A8D78" fullContext="0575738AC8423BD5997894E343E7744A" translateForJs="false">Zezwól na aktywność linii wejściowych w celu anulowania ostrzeżenia o automatycznym uzbrojeniu</TranslationEntry>
    <TranslationEntry name="7C88FF090B18FA2BE267AE869F9CB155" fullContext="EB9D071DDD1740F5FADE94548CD483C8" translateForJs="false">Jeśli włączone, linie wejściowe strefy automatycznie anulują aktywny stan ostrzeżenia o uzbrojeniu, gdy wykryją aktywność. Opcja </TranslationEntry>
    <TranslationEntry name="BBD378C8C067F29C16DE50D42D1CB75E" fullContext="EB9D071DDD1740F5FADE94548CD483C8" translateForJs="false">Typ anulowania automatycznego uzbrojenia przez aktywność</TranslationEntry>
    <TranslationEntry name="5BA690B2DAF6C9B505A5ED27518C80E5" fullContext="EB9D071DDD1740F5FADE94548CD483C8" translateForJs="false"> poniższa opcja określa typ akcji, który zostanie wykonany w celu anulowania uzbrajania strefy.</TranslationEntry>
    <TranslationEntry name="AC5E1788B3652599A000087582291D92" fullContext="EB9D071DDD1740F5FADE94548CD483C8" translateForJs="false">Ta opcja umożliwia użytkownikowi znajdującemu się w strefie anulowanie zbliżającego się uzbrojenia strefy bez konieczności podchodzenia do terminala lub czytnika. Na przykład: sprzątacz przebywający na terenie obiektu po godzinach może aktywować czujkę ruchu, aby szybko anulować ostrzeżenie o uzbrojeniu, jeśli to konieczne.</TranslationEntry>
    <TranslationEntry name="BB16BA8CBA3C00EACD0C8118A5C32BA5" fullContext="0575738AC8423BD5997894E343E7744A" translateForJs="false">Określa reakcję systemu, która zostanie wyzwolona w przypadku wykrycia aktywności linii wejściowej strefy podczas </TranslationEntry>
    <TranslationEntry name="D5BD5E7FCE6AACCB5F0CD938410F834D" fullContext="0575738AC8423BD5997894E343E7744A" translateForJs="false"> opcja jest włączona.</TranslationEntry>
    <TranslationEntry name="AF1A47C1F546D66594CF9A1A656E0796" fullContext="0575738AC8423BD5997894E343E7744A" translateForJs="false"> - Ostrzeżenie przed uzbrojeniem zostanie anulowane, a strefa zostanie tymczasowo rozbrojona/odroczone uzbrojenie na określony czas (określony przez </TranslationEntry>
    <TranslationEntry name="0FB01C03945F850CE8D7CE67891384B3" fullContext="0575738AC8423BD5997894E343E7744A" translateForJs="false"> pole), po którym zacznie się automatycznie uzbrajaać ponownie.</TranslationEntry>
    <TranslationEntry name="B2B0A51B640C0842A5D0D87DC0FC60F0" fullContext="0575738AC8423BD5997894E343E7744A" translateForJs="false"> - Ostrzeżenie przed uzbrojeniem zostanie anulowane, a strefa zostanie trwale rozbrojona do czasu ponownego uzbrojenia przez użytkownika lub akcję systemową.</TranslationEntry>
    <TranslationEntry name="5F95E6658492A2ED252BFD3A824AA2E0" translateForJs="false">Automatyczna izolacja linii wejściowej</TranslationEntry>
    <TranslationEntry name="9F9870BB94DDB75AB2AAE92592CFBE65" fullContext="CAAADCC2576CDFD7550FB4F9FC73B15E" translateForJs="false">Jeśli opcja jest włączona, system automatycznie zaizoluje niezabezpieczone linie wejściowe w tej strefie podczas wstępnego testu przed uzbrojeniem, zamiast zgłaszać błąd uzbrojenia przy uzbrajaniu za pomocą czytnika lub pilota, lub monitować użytkownika o zabezpieczenie lub izolację linii, gdy uzbrojenie następuje z Terminala LCD lub interfejsu internetowego. Te linie wejściowe pozostaną zaizolowane, dopóki linia wejściowa nie powróci do stanu spoczynku lub strefa nie zostanie rozbrojona.</TranslationEntry>
    <TranslationEntry name="58BEBD08B04C0563479BA40924ACBAC7" fullContext="CAAADCC2576CDFD7550FB4F9FC73B15E" translateForJs="false">Ponadto, jeśli </TranslationEntry>
    <TranslationEntry name="6327916A76B3DA6717F1E1FD4F940A93" fullContext="CAAADCC2576CDFD7550FB4F9FC73B15E" translateForJs="false"> strona jest włączona, wszelkie problemy zdrowotne modułów lub problemy z komunikacją alarmową w systemie będą również uwzględniane w teście przed uzbrojeniem. Problemy te zostaną automatycznie pominięte i pozostaną pominięte do czasu rozbrojenia strefy.</TranslationEntry>
    <TranslationEntry name="F5C02BF8338DC26BE787F664F816C516" fullContext="CAAADCC2576CDFD7550FB4F9FC73B15E" translateForJs="false">Należy pamiętać, że linie wejściowe na ścieżce wyjścia (linie wejściowe z </TranslationEntry>
    <TranslationEntry name="F343FA94615047F5EFC68EEDE81316D8" fullContext="CAAADCC2576CDFD7550FB4F9FC73B15E" translateForJs="false"> typy linii wejściowych) są wykluczone z początkowego testu uszczelnienia przed uzbrojeniem, dlatego ta opcja nie będzie automatycznie izolować tych linii wejściowych. Opcja </TranslationEntry>
    <TranslationEntry name="724FC3CF975687ADC976B2C149AB18F7" fullContext="CAAADCC2576CDFD7550FB4F9FC73B15E" translateForJs="false">Automatyczna izolacja niezabezpieczonych linii wejściowych ścieżki wyjścia przy wyjściu</TranslationEntry>
    <TranslationEntry name="674E76C50554FAFFD74CF58E93545C7A" fullContext="CAAADCC2576CDFD7550FB4F9FC73B15E" translateForJs="false"> opcja poniżej może być używana do automatycznego izolowania tych linii wejściowych. </TranslationEntry>
    <TranslationEntry name="064CBBF8737ECD2FF31742D4F60BE260" fullContext="CAAADCC2576CDFD7550FB4F9FC73B15E" translateForJs="false">Tej opcji należy używać tylko po dokładnym rozważeniu, ponieważ jest to kompromis między wygodą a bezpieczeństwem i może być niepożądana. Na przykład drzwi lub okno może pozostać otwarte lub ktoś może przebywać w środku, gdy strefa jest uzbrojona. </TranslationEntry>
    <TranslationEntry name="65885EB813C629EBF9F3CA3FD184C694" translateForJs="false">Automatyczna izolacja niezabezpieczonych linii wejściowych ścieżki wyjścia przy wyjściu</TranslationEntry>
    <TranslationEntry name="91CF67ACD8F6C7D17D5CA32AB6C165D4" fullContext="4ADA07F4366596A8731D0F88040100E2" translateForJs="false">Jeśli opcja jest włączona, linie wejściowe na drodze wyjścia zostaną automatycznie zaizolowane po zakończeniu opóźnienia na wyjście. Jeśli linia wejściowa powróci do stanu spoczynku lub strefa zostanie rozbrojona, zaizolowana linia wejściowa zostanie automatycznie odizolowana. Linie wejściowe na drodze wyjścia nie są uwzględniane w wstępnym teście linii przed uzbrojeniem strefy. Funkcja ta jest powszechnie stosowana w celu uniknięcia uruchamiania alarmów przez uszkodzone linie wejściowe lub linie z opóźnieniem w przejściu do stanu spoczynku. Linie, które z opóźnieniem przeszły w stan spoczynku, zostaną automatycznie odizolowane po ich zabezpieczeniu.</TranslationEntry>
    <TranslationEntry name="791B1D10F4362636567F6EB8D5612CF8" fullContext="4ADA07F4366596A8731D0F88040100E2" translateForJs="false">Uwaga: tej opcji należy używać tylko po dokładnym rozważeniu, ponieważ jest to kompromis między wygodą a bezpieczeństwem i może być niepożądana. Chociaż może zapobiegać uruchamianiu sygnalizatorów przez wadliwe linie wejściowe zablokowane w stanie alarmu lub linie wejściowe, które wolno się uszczelniają, mogłoby to oznaczać, że przejście wyjściowe pozostanie niezabezpieczone. Ponadto linia wejściowa lub linie wejściowe przypisane do </TranslationEntry>
    <TranslationEntry name="B7FF3ABC9CD7C9510DB7D0F1F6C0F1E5" fullContext="4ADA07F4366596A8731D0F88040100E2" translateForJs="false"> grupę procesów można zaizolować, a jeśli nie jest zabezpieczona, następny użytkownik, który otworzy drzwi, nie wyzwoli opóźnienia na wejście, a zamiast tego zabrzmią alarmy.</TranslationEntry>
    <TranslationEntry name="AFBF0897A5A83FDD873DFB032EC695D3" translateForJs="false" rules="unique=SirenLocationOptions" notes="Must be unique amongst all &quot;SirenLocationOptions&quot; entries">Wewnętrzny</TranslationEntry>
    <TranslationEntry name="B206A1B4EA1097761F78E8876F6DA779" translateForJs="false" rules="unique=SirenLocationOptions" notes="Must be unique amongst all &quot;SirenLocationOptions&quot; entries">Zewnętrzny</TranslationEntry>
    <TranslationEntry name="130C5B3473C57FAA76E2A1C54E26F88E" translateForJs="false" rules="unique=SirenLocationOptions" notes="Must be unique amongst all &quot;SirenLocationOptions&quot; entries">Oba</TranslationEntry>
    <TranslationEntry name="99E5411DAF8AD228CA2CFD1336712EC5" fullContext="99E5411DAF8AD228CA2CFD1336712EC5" translateForJs="false">Przypisz linie wejściowe do tej strefy.</TranslationEntry>
    <TranslationEntry name="9B53A84F1532674B194C3CD4862562EC" fullContext="2989D458904F3ECAFAA6184027D2CEBB" translateForJs="false">Gdy strefa jest uzbrojona, monitoruje stan linii wejściowych. Gdy jedna z linii wejściowych dodanych do strefy zostanie wyzwolona, w zależności od grupy procesowej strefa może aktywować sygnalizatory i linie wyjściowe sygnalizatorów, wysyłać komunikaty alarmowe do stacji monitorowania itp.</TranslationEntry>
    <TranslationEntry name="82A443B3262C90B6D72537596CC9C09D" translateForJs="false">Linia wyjściowa sygnalizatora</TranslationEntry>
    <TranslationEntry name="8487707A9091CDB5D2B922D6F1F8C901" fullContext="8487707A9091CDB5D2B922D6F1F8C901" translateForJs="false">Przypisz linie wyjściowe, które mają być wyzwalane, gdy uruchamiają się sygnalizatory strefy.</TranslationEntry>
    <TranslationEntry name="D8633AB2DCDA10EDA8A559C0BA789600" fullContext="A2BA25F43CC7F8A5F137BEB0D4264963" translateForJs="false">Gdy zabrzmią sygnalizatory, wybrane linie wyjściowe zostaną włączone.</TranslationEntry>
    <TranslationEntry name="CE5BF551379459C1C61D2A204061C455" translateForJs="false">Lokalizacja</TranslationEntry>
    <TranslationEntry name="D79042AAF700A4EAC7D72633304503CE" fullContext="0A2878D8C3E30DA2CDD87B5715EF1A05" translateForJs="false">Akcja automatyczna</TranslationEntry>
    <TranslationEntry name="E7390CE8D0CE658ADFE8C398783D7D49" translateForJs="false">Włącz akcję</TranslationEntry>
    <TranslationEntry name="90B2095A0E42B0808DB44AF7E05A08C3" translateForJs="false">Warunek wyzwalający</TranslationEntry>
    <TranslationEntry name="9012201A9A7E8C5946DA8AE22717B23D" fullContext="0618E54083298DE32513A0B706C06FF6" translateForJs="false">To pole wyboru włącza i wyłącza zautomatyzowaną akcję. Można je użyć do tymczasowego wyłączenia akcji.</TranslationEntry>
    <TranslationEntry name="8017DA32095C30867C33F4BD75C8DF0D" fullContext="168F185F361A81E2CA7492FDB3C3B1BF" translateForJs="false">Warunek wyzwalający określa, kiedy dana zautomatyzowana akcja jest prawdziwa lub fałszywa. Gdy warunek wyzwalający zmienia się z fałszu na prawdę, można automatycznie wykonać zestaw akcji. Podobnie, gdy warunek wyzwalający zmienia się z prawdy na fałsz, można automatycznie wykonać inny zestaw akcji. </TranslationEntry>
    <TranslationEntry name="616117F5006AA07AD2603512C916AB46" fullContext="8D6CC5A867C702DF6484CCF7FDB3DFB2" translateForJs="false">Warunek wyzwalający może używać stanu dowolnej strefy, przejścia, linii wejściowej, linii wyjściowej lub przedziału czasowego i tworzy wyrażenie wyzwalające, które jest prawdziwe lub fałszywe. Na przykład wyrażenie wyzwalające może polegać na tym, że </TranslationEntry>
    <TranslationEntry name="51BE6078D43E6697AF9FBCDF69D247C3" fullContext="8D6CC5A867C702DF6484CCF7FDB3DFB2" translateForJs="false">Strefa budynku jest rozbrojona</TranslationEntry>
    <TranslationEntry name="6247C51F3E5E7A0115A85FC55A94F1DD" fullContext="8D6CC5A867C702DF6484CCF7FDB3DFB2" translateForJs="false">, lub że </TranslationEntry>
    <TranslationEntry name="4C57295BA7527E08E8D858C365785404" fullContext="8D6CC5A867C702DF6484CCF7FDB3DFB2" translateForJs="false">Główne przejście nie jest zablokowane</TranslationEntry>
    <TranslationEntry name="AFBFDD7935D69DC1D9A5EB1C11EC0BA9" fullContext="8D6CC5A867C702DF6484CCF7FDB3DFB2" translateForJs="false">. Można również tworzyć grupy, łączące wiele instrukcji lub nawet innych grup. Wszystkie te instrukcje i grupy będą łączone razem, a warunek wyzwalający nadal będzie albo prawdziwy, albo fałszywy.  </TranslationEntry>
    <TranslationEntry name="F19C8122874507C8625F31EC56C90F4E" fullContext="168F185F361A81E2CA7492FDB3C3B1BF" translateForJs="false">Grupy mogą być przetwarzane na jeden z dwóch sposobów: </TranslationEntry>
    <TranslationEntry name="F79BA51523CB838A060350F8846E7E59" fullContext="168F185F361A81E2CA7492FDB3C3B1BF" translateForJs="false" rules="unique=TriggerGroupType" notes="Must be unique amongst all &quot;TriggerGroupType&quot; entries">Prawda, gdy WSZYSTKIE z poniższych są prawdziwe</TranslationEntry>
    <TranslationEntry name="AB713555B439AB0E71A8280921FA3D9A" fullContext="168F185F361A81E2CA7492FDB3C3B1BF" translateForJs="false"> — ta grupa jest prawdziwa, gdy WSZYSTKIE warunki wyzwalające i grupy w tej grupie są prawdziwe; w przeciwnym razie jest fałszywa. </TranslationEntry>
    <TranslationEntry name="73267CE9291DCADC2BF2A57DD569BE38" fullContext="168F185F361A81E2CA7492FDB3C3B1BF" translateForJs="false" rules="unique=TriggerGroupType" notes="Must be unique amongst all &quot;TriggerGroupType&quot; entries">Prawda, gdy KTÓRYKOLWIEK z poniższych jest prawdziwy</TranslationEntry>
    <TranslationEntry name="884C82178ADA5014D2625342CCA50567" fullContext="168F185F361A81E2CA7492FDB3C3B1BF" translateForJs="false"> — ta grupa jest prawdziwa, gdy DOWOLNE z warunków wyzwalających i grup w tej grupie jest prawdziwe; w przeciwnym razie jest fałszywa. </TranslationEntry>
    <TranslationEntry name="99900D31D02CAD193805B852CD955F3D" fullContext="168F185F361A81E2CA7492FDB3C3B1BF" translateForJs="false">Wraz ze zmianami stanu stref, przejść, linii wejściowych, linii wyjściowych i przedziałów czasowych w systemie, warunek wyzwalający jest stale sprawdzany, a gdy zmieni się z prawdziwego na fałszywy lub z fałszywego na prawdziwy, zostaje wykonany odpowiedni zestaw akcji. </TranslationEntry>
    <TranslationEntry name="F1197C7991CAACD8E950543278E92CDC" fullContext="168F185F361A81E2CA7492FDB3C3B1BF" translateForJs="false">Umożliwia tworzenie zarówno prostych, jak i złożonych automatycznych odpowiedzi, potencjalnie wykonując odpowiedź tylko wtedy, gdy wiele elementów w systemie jest we właściwym stanie. </TranslationEntry>
    <TranslationEntry name="FA6AF7E64D9DA9D7E70238EB8F088669" translateForJs="false">Akcje, gdy prawda</TranslationEntry>
    <TranslationEntry name="4721492971A668CDF54BC845B7B71BA3" fullContext="E25207D9FB5775C1AD1E65281E648A45" translateForJs="false">Określa, jaką akcję lub akcje należy wykonać, gdy warunek wyzwalający zmienia się z fałszywego na prawdziwy. Te akcje są oparte na zboczu i umożliwiają sterowanie wieloma elementami (liniami wyjściowymi, strefami, przejściami, liniami wejściowymi, czytnikami itp.).</TranslationEntry>
    <TranslationEntry name="5EA127B1DA5EE61A5B56BF0A614E69DC" translateForJs="false">Akcje gdy fałsz</TranslationEntry>
    <TranslationEntry name="BA431D844E63B633D24785A624247FAC" fullContext="20432AE3331B6B327F6EA6B8F360DCDF" translateForJs="false">Określa akcję lub akcje do wykonania, gdy warunek wyzwalający zmieni się z prawdziwego na fałszywy. Akcje te są wyzwalane zboczem sygnału i umożliwiają sterowanie wieloma elementami (liniami wyjściowymi, strefami, przejściami, liniami wejściowymi, czytnikami itp.).</TranslationEntry>
    <TranslationEntry name="FB824E79CE9CFFD506AE3EFB60072FE4" translateForJs="false" rules="unique=ActionType" notes="Must be unique amongst all &quot;ActionType&quot; entries">Steruj linią wyjściową</TranslationEntry>
    <TranslationEntry name="26F28425043949E7290F47718CACB2E5" translateForJs="false" rules="unique=ActionType" notes="Must be unique amongst all &quot;ActionType&quot; entries">Steruj strefą</TranslationEntry>
    <TranslationEntry name="0FFED6219AEE85CBF68A276848CDB502" translateForJs="false" rules="unique=ActionType" notes="Must be unique amongst all &quot;ActionType&quot; entries">Steruj przejściem</TranslationEntry>
