    <TranslationEntry name="BC161D94A6249BA1FADA8BAF8D360B2E" fullContext="BC161D94A6249BA1FADA8BAF8D360B2E" translateForJs="false">Numer portu: </TranslationEntry>
    <TranslationEntry name="2F78446388DFA25B6DD5A9704322929A" fullContext="2F78446388DFA25B6DD5A9704322929A" translateForJs="false">Liczba obsługiwanych urządzeń: </TranslationEntry>
    <TranslationEntry name="63F6DBD1AD3357806EA0626235594C10" fullContext="63F6DBD1AD3357806EA0626235594C10" translateForJs="false">Typ urządzenia połączenia: </TranslationEntry>
    <TranslationEntry name="90729E9225F2406E8591E47A19A6FC72" fullContext="90729E9225F2406E8591E47A19A6FC72" translateForJs="false">Uruchom interfejs urządzenia</TranslationEntry>
    <TranslationEntry name="22560885F7F9BB56ACEF656A0FC4C0A1" fullContext="22560885F7F9BB56ACEF656A0FC4C0A1" translateForJs="false">Podrzędne kamery</TranslationEntry>
    <TranslationEntry name="641CF2C6D9F781560C1036C31C524EC3" fullContext="641CF2C6D9F781560C1036C31C524EC3" translateForJs="false">Monitoruje stany kamer podrzędnych Modułu IR Video.</TranslationEntry>
    <TranslationEntry name="0DC244CA254A2D70E80D2E49C7F2CB0A" fullContext="0DC244CA254A2D70E80D2E49C7F2CB0A" translateForJs="false">Numer kanału</TranslationEntry>
    <TranslationEntry name="AAEB007E215D49A43E8EC8DD2DC43C8C" fullContext="AAEB007E215D49A43E8EC8DD2DC43C8C" translateForJs="false">Nazwa kanału</TranslationEntry>
    <TranslationEntry name="E3487FD1B54104E02F7751ED85220FBA" fullContext="E3487FD1B54104E02F7751ED85220FBA" translateForJs="false">Więcej informacji</TranslationEntry>
    <TranslationEntry name="E38C6FA78B9872F88626EBB614729F37" fullContext="E38C6FA78B9872F88626EBB614729F37" translateForJs="false">Lokalizuj moduł</TranslationEntry>
    <TranslationEntry name="6715D1643AA8B8DFE90E4D383079ACFD" fullContext="6715D1643AA8B8DFE90E4D383079ACFD" translateForJs="false">Włącz buzzer</TranslationEntry>
    <TranslationEntry name="85605F587BBD7714FD88B3A360DFA306" fullContext="85605F587BBD7714FD88B3A360DFA306" translateForJs="false">Wyłącz buzzer</TranslationEntry>
    <TranslationEntry name="5DBDC974D36C36AE77A89A66DAB4BE00" fullContext="5DBDC974D36C36AE77A89A66DAB4BE00" translateForJs="false">Czas ostatniego testu: </TranslationEntry>
    <TranslationEntry name="FAF8E1DC9D33069C9F1E6E1EE7E6F9A5" fullContext="FAF8E1DC9D33069C9F1E6E1EE7E6F9A5" translateForJs="false">Wynik ostatniego testu: </TranslationEntry>
    <TranslationEntry name="8C068255CB8EEC9D8F6CFA832B257158" fullContext="8C068255CB8EEC9D8F6CFA832B257158" translateForJs="false">Aktualny stan testu baterii: </TranslationEntry>
    <TranslationEntry name="DDE95FAEDFA981DCF655579238AA1A3A" fullContext="DDE95FAEDFA981DCF655579238AA1A3A" translateForJs="false">Czas testu baterii modułu: </TranslationEntry>
    <TranslationEntry name="1C7D1F241A5C47F2B3B00EDD5C339F55" fullContext="1C7D1F241A5C47F2B3B00EDD5C339F55" translateForJs="false">Uruchom test baterii...</TranslationEntry>
    <TranslationEntry name="790E32AD815C0BF143F1BE02FBC1FE74" fullContext="790E32AD815C0BF143F1BE02FBC1FE74" translateForJs="false">Podłączone moduły</TranslationEntry>
    <TranslationEntry name="C57061EAC85315234BC4571694F99DB3" fullContext="C57061EAC85315234BC4571694F99DB3" translateForJs="false">Nazwa modułu</TranslationEntry>
    <TranslationEntry name="8724E5F4AAD56320917F233651891BDE" fullContext="8724E5F4AAD56320917F233651891BDE" translateForJs="false">Uruchom test baterii</TranslationEntry>
    <TranslationEntry name="68311558072AD45D1424E7C58CEFD695" fullContext="68311558072AD45D1424E7C58CEFD695" translateForJs="false">Czas trwania:</TranslationEntry>
    <TranslationEntry name="D4788F7BE9D8FA134509850C710C1BC1" fullContext="D4788F7BE9D8FA134509850C710C1BC1" translateForJs="false">Test siły sygnału</TranslationEntry>
    <TranslationEntry name="F35511B1761BBA048AE094EE7CB21E09" fullContext="F35511B1761BBA048AE094EE7CB21E09" translateForJs="false">Urządzenie jest teraz w trybie testowym i będzie nadawać sygnały testowe siły sygnału co 5 sekund przez najbliższe 2 minuty. W tym czasie można sprawdzić umieszczenie urządzenia, aby zapewnić optymalną jakość sygnału RF.</TranslationEntry>
    <TranslationEntry name="87557F11575C0AD78E4E28ABEDC13B6E" fullContext="87557F11575C0AD78E4E28ABEDC13B6E" translateForJs="false">Koniec</TranslationEntry>
    <TranslationEntry name="BF57BD6B812EBD17908BD389DAD988C9" fullContext="BF57BD6B812EBD17908BD389DAD988C9" translateForJs="false">Ulubione elementy (kliknij/dotknij, aby sterować)</TranslationEntry>
    <TranslationEntry name="05355C2CB4F24E48320EB44DE2A78CCC" fullContext="05355C2CB4F24E48320EB44DE2A78CCC" translateForJs="false">Strefy, przejścia i linie wyjściowe można wyświetlić tutaj, zapewniając szybki sposób sprawdzenia ich stanu i sterowania nimi. Aby wybrać elementy do wyświetlenia tutaj, </TranslationEntry>
    <TranslationEntry name="12BB1085CD4F2AAF56FD14027CB0FB92" fullContext="12BB1085CD4F2AAF56FD14027CB0FB92" translateForJs="false">skonfiguruj ulubione elementy w swoim</TranslationEntry>
    <TranslationEntry name="C81548F995F47FAFC1B58013D3811009" fullContext="C81548F995F47FAFC1B58013D3811009" translateForJs="false">poproś administratora systemu o skonfigurowanie ulubionych elementów</TranslationEntry>
    <TranslationEntry name="3F5864F0A411E168B6EBEF34E4AC3687" fullContext="3F5864F0A411E168B6EBEF34E4AC3687" translateForJs="false">Skróty technika</TranslationEntry>
    <TranslationEntry name="454ADEA7A834A37302A9C79AFD8826E6" fullContext="454ADEA7A834A37302A9C79AFD8826E6" translateForJs="false">Interfejs listy kontrolnej, który prowadzi od początku do końca przez uruchomienie systemu</TranslationEntry>
    <TranslationEntry name="2AC1BF96315F537FAE20BC0D1642E0EF" fullContext="2AC1BF96315F537FAE20BC0D1642E0EF" translateForJs="false">Konfiguruj każdy z modułów sprzętowych</TranslationEntry>
    <TranslationEntry name="46DBBD217F88171C819879D3EC0E25F9" fullContext="46DBBD217F88171C819879D3EC0E25F9" translateForJs="false">Skonfiguruj opcje raportowania alarmów oraz informacje do pobrania wymagane przez stacje monitorowania</TranslationEntry>
    <TranslationEntry name="F494E20387D3701EBCEEE810F75F8E8D" fullContext="F494E20387D3701EBCEEE810F75F8E8D" translateForJs="false">Włącz tryb serwisowy, aby podczas prac w systemie sygnalizatory nie były aktywowane, a alarmy nie były raportowane</TranslationEntry>
    <TranslationEntry name="B921EC725048AC7BBF8076EE5F9A5CD6" fullContext="B921EC725048AC7BBF8076EE5F9A5CD6" translateForJs="false">Testuj skonfigurowane linie wejściowe, linie wyjściowe i moduły sprzętowe bezpośrednio</TranslationEntry>
    <TranslationEntry name="9F95DF362E10B4719AFCA7F3C6E4B113" fullContext="9F95DF362E10B4719AFCA7F3C6E4B113" translateForJs="false">Skróty administracyjne</TranslationEntry>
    <TranslationEntry name="B79CC9753941A3C131F8F3EFB2FE8668" fullContext="B79CC9753941A3C131F8F3EFB2FE8668" translateForJs="false">Pobierz kopię zapasową bazy danych lub przywróć poprzednią.</TranslationEntry>
    <TranslationEntry name="3FEC41A769B92C2B8DA18F741B3135B9" fullContext="3FEC41A769B92C2B8DA18F741B3135B9" translateForJs="false">Wyświetl przegląd systemu, w tym wszelkie błędy lub ostrzeżenia w systemie</TranslationEntry>
    <TranslationEntry name="973291F860EEF138C71CC4B50F025740" fullContext="973291F860EEF138C71CC4B50F025740" translateForJs="false">Zarządzaj ustawieniami sieciowymi systemu</TranslationEntry>
    <TranslationEntry name="5ECB78695906823B3EA0B728E4BE8D24" fullContext="5ECB78695906823B3EA0B728E4BE8D24" translateForJs="false">Zarządzaj datą i czasem systemu</TranslationEntry>
    <TranslationEntry name="286AED70773E18F976D9691AFABD320C" fullContext="286AED70773E18F976D9691AFABD320C" translateForJs="false">Twórz i pobieraj raporty podsumowujące dotyczące systemu</TranslationEntry>
    <TranslationEntry name="D2431F88E38EECBC335BF1376491AE49" fullContext="D2431F88E38EECBC335BF1376491AE49" translateForJs="false">Skróty użytkownika</TranslationEntry>
    <TranslationEntry name="01BD288FE61EF4AEAF7184D570D2FE96" fullContext="01BD288FE61EF4AEAF7184D570D2FE96" translateForJs="false">Dodaj nowego użytkownika lub zarządzaj istniejącymi użytkownikami</TranslationEntry>
    <TranslationEntry name="9FE4C0EBFE2447F254049AEBA96E170B" fullContext="9FE4C0EBFE2447F254049AEBA96E170B" translateForJs="false">Skonfiguruj uprawnienia określające, co użytkownicy mogą robić i kiedy mogą to robić</TranslationEntry>
    <TranslationEntry name="A50F12DC083C1A16E2560AAC26B411B0" fullContext="A50F12DC083C1A16E2560AAC26B411B0" translateForJs="false">Zarządzaj czasem automatycznego uzbrajania stref i czasem wolnego dostępu do przejść</TranslationEntry>
    <TranslationEntry name="7E34178CE86256163E75073BC76DD07E" fullContext="7E34178CE86256163E75073BC76DD07E" translateForJs="false">Zaktualizuj swoje harmonogramy, które mogą określać czas uzbrajania stref, odblokowywania przejść i inne zaplanowane działania</TranslationEntry>
    <TranslationEntry name="D3098120913FB5867AFC66A011BF832E" fullContext="D3098120913FB5867AFC66A011BF832E" translateForJs="false">Skonfiguruj Święta — na przykład Kalendarze mogą być używane do zmiany Przedziałów czasowych w różnych dniach</TranslationEntry>
    <TranslationEntry name="1040968E2CF7EDFADE2F2BCA87D8AEC0" fullContext="1040968E2CF7EDFADE2F2BCA87D8AEC0" translateForJs="false">Samouczki</TranslationEntry>
    <TranslationEntry name="1B23728D4AC0AC03A70008784F0C1594" fullContext="1B23728D4AC0AC03A70008784F0C1594" translateForJs="false">Postępuj zgodnie z procesem dodawania nowego użytkownika do systemu</TranslationEntry>
    <TranslationEntry name="8C6508AFFD567D909E37AC33F7E4961C" fullContext="8C6508AFFD567D909E37AC33F7E4961C" translateForJs="false">Dodaj nowego użytkownika</TranslationEntry>
    <TranslationEntry name="8E09DBDCEAE3E1C0D01DC326B189BA9B" fullContext="8E09DBDCEAE3E1C0D01DC326B189BA9B" translateForJs="false">Skróty monitorowania stanu</TranslationEntry>
    <TranslationEntry name="3088B858320BEE298D864E106F80C4F8" fullContext="3088B858320BEE298D864E106F80C4F8" translateForJs="false">Przeglądaj historię zdarzeń systemu</TranslationEntry>
    <TranslationEntry name="EF50FAC05D48ABE61436494A7866262A" fullContext="EF50FAC05D48ABE61436494A7866262A" translateForJs="false">Przeglądaj stan stref i steruj nimi</TranslationEntry>
    <TranslationEntry name="749FBD6562D8C1B84B6931C1C328F811" fullContext="749FBD6562D8C1B84B6931C1C328F811" translateForJs="false">Wyświetl stan przejść i steruj nimi</TranslationEntry>
    <TranslationEntry name="A981CACFEC1CF1FEA1AA28A464F0E609" fullContext="A981CACFEC1CF1FEA1AA28A464F0E609" translateForJs="false">Wyświetlaj stan linii wejściowych i nimi steruj</TranslationEntry>
    <TranslationEntry name="2908F135C29E94FDD4CDCF702DB39DB8" fullContext="2908F135C29E94FDD4CDCF702DB39DB8" translateForJs="false">Wyświetl stan linii wyjściowych i steruj nimi</TranslationEntry>
    <TranslationEntry name="0753AC7651F9EA84C9EFB9F5145D11C8" fullContext="0753AC7651F9EA84C9EFB9F5145D11C8" translateForJs="false">Generuj szybki raport lokalizacji użytkownika</TranslationEntry>
    <TranslationEntry name="39B8796EAA045D595D625B452BFE49A9" fullContext="39B8796EAA045D595D625B452BFE49A9" translateForJs="false">Generuje i pobiera Raport lokalizacji użytkowników dla wszystkich użytkowników aktualnie przebywających na terenie obiektu</TranslationEntry>
    <TranslationEntry name="7CA5258CCEBE653A283706800868EABE" translateForJs="false">Wybierz swój region</TranslationEntry>
    <TranslationEntry name="C96F531C0EDA2DECE593A2F8DF3A58A8" translateForJs="false">Wybierz język</TranslationEntry>
    <TranslationEntry name="20666A48AE4257DF70947AFABF4354EF" fullContext="20666A48AE4257DF70947AFABF4354EF" translateForJs="false">Zmiany języka zostaną zastosowane po następnym ponownym uruchomieniu systemu.</TranslationEntry>
    <TranslationEntry name="5A9D7616B5690C569919362F77DC9EC5" translateForJs="false">Wybierz strefę czasową</TranslationEntry>
    <TranslationEntry name="CC044AC0CC825BDFD9CD40F1E0EDA945" fullContext="CC044AC0CC825BDFD9CD40F1E0EDA945" translateForJs="false">Wybierz strefę czasową</TranslationEntry>
    <TranslationEntry name="2DD4236FEF78FBC629BB62DF8DB709C0" fullContext="2DD4236FEF78FBC629BB62DF8DB709C0" translateForJs="false">Zastosuj klucz licencyjny</TranslationEntry>
    <TranslationEntry name="1D60C1E757B2621BE849F1DFBF331B3D" translateForJs="false">Klucze licencji</TranslationEntry>
    <TranslationEntry name="CDFF8BE4CA736DB9B0823A504EDA7E80" fullContext="CDFF8BE4CA736DB9B0823A504EDA7E80" translateForJs="false">Typ licencji</TranslationEntry>
    <TranslationEntry name="5D5C4AD5DB4BD841E161E43AC45BC5C6" fullContext="5D5C4AD5DB4BD841E161E43AC45BC5C6" translateForJs="false">Klucz licencyjny</TranslationEntry>
    <TranslationEntry name="694E8D1F2EE056F98EE488BDC4982D73" fullContext="694E8D1F2EE056F98EE488BDC4982D73" translateForJs="false">Ilość</TranslationEntry>
    <TranslationEntry name="66D87E2CFC764AB7955CE99810C1902B" translateForJs="false">Podsumowanie funkcji</TranslationEntry>
    <TranslationEntry name="DF35E15CE9EAD6AEEB87F70ED5538F4E" fullContext="DF35E15CE9EAD6AEEB87F70ED5538F4E" translateForJs="false">Licencjonowana funkcja</TranslationEntry>
    <TranslationEntry name="FAEAEC9EDA6BC4C8CB6E1A9156A858BE" fullContext="FAEAEC9EDA6BC4C8CB6E1A9156A858BE" translateForJs="false">Dostępność</TranslationEntry>
    <TranslationEntry name="81C5816814AAEE1631F51D45011905B5" fullContext="81C5816814AAEE1631F51D45011905B5" translateForJs="false">Jeśli chcesz zastosować klucz licencyjny, który nie został pobrany z serwisu licencyjnego Inner Range, można go tutaj wprowadzić i zastosować w tym systemie Inception.</TranslationEntry>
    <TranslationEntry name="7AE8E8D4F6A49C2FA0ACDF10F6E14C69" fullContext="7AE8E8D4F6A49C2FA0ACDF10F6E14C69" translateForJs="false">Jeśli klucz licencyjny będzie nieprawidłowy podczas nadejścia następnej aktualizacji licencji, zostanie utracony.</TranslationEntry>
    <TranslationEntry name="53E0116DEFFD6A990E192435672989C6" fullContext="53E0116DEFFD6A990E192435672989C6" translateForJs="false">Zaloguj się do Inception</TranslationEntry>
    <TranslationEntry name="474EE98FF915E054DF11BCDB34462382" fullContext="474EE98FF915E054DF11BCDB34462382" translateForJs="false">Wprowadź nazwę użytkownika i hasło.</TranslationEntry>
    <TranslationEntry name="048EB1A50C547BBCDF6909864468500B" fullContext="048EB1A50C547BBCDF6909864468500B" translateForJs="false">Przełącz na wprowadzanie PIN</TranslationEntry>
    <TranslationEntry name="23225E21A3497DF22CAE96B723E21611" fullContext="23225E21A3497DF22CAE96B723E21611" translateForJs="false">Przełącz na wprowadzanie hasła</TranslationEntry>
    <TranslationEntry name="9728461E28C3EE8E69B55873C82A787F" fullContext="9728461E28C3EE8E69B55873C82A787F" translateForJs="false">Numer seryjny: </TranslationEntry>
    <TranslationEntry name="3074B4226B588109F26BE979197570C2" fullContext="3074B4226B588109F26BE979197570C2" translateForJs="false">Odłącz system</TranslationEntry>
    <TranslationEntry name="E7187D885EAD1928AD87BC441AF9B7DF" fullContext="E7187D885EAD1928AD87BC441AF9B7DF" translateForJs="false">Ponowna synchronizacja identyfikatorów</TranslationEntry>
    <TranslationEntry name="691640958283C5AA72CEE8A18E4EAAEE" fullContext="691640958283C5AA72CEE8A18E4EAAEE" translateForJs="false">Wprowadź kod łączenia wygenerowany w portalu Mobile Access dla systemu Mobile Access, z którym chcesz połączyć Inception.</TranslationEntry>
    <TranslationEntry name="8E45430E6484208566AB822209489680" translateForJs="false">Wprowadź kod łączenia:</TranslationEntry>
    <TranslationEntry name="C0BCE0E73F2884E177FED1C491272ADB" translateForJs="false">Kod obiektu:</TranslationEntry>
    <TranslationEntry name="97E7C9A7D06EAC006A28BF05467FCC8B" fullContext="97E7C9A7D06EAC006A28BF05467FCC8B" translateForJs="false">Połącz</TranslationEntry>
    <TranslationEntry name="326A452FB69F9582D17C0A1E8D6E4345" fullContext="326A452FB69F9582D17C0A1E8D6E4345" translateForJs="false">Potwierdzam, że WSZYSTKIE mobilne identyfikatory zostaną wyczyszczone po odłączeniu.</TranslationEntry>
    <TranslationEntry name="45ADA1A8B02E7BF10200AEDCF56D13C8" fullContext="45ADA1A8B02E7BF10200AEDCF56D13C8" translateForJs="false">Resynchronizuj</TranslationEntry>
    <TranslationEntry name="589AF6ED02534C9ECFEB3ACE33BDC511" fullContext="589AF6ED02534C9ECFEB3ACE33BDC511" translateForJs="false">Zarządzaj mobilnym identyfikatorem</TranslationEntry>
    <TranslationEntry name="B451CAA3DA4BD7C6C06CD52D21077B21" fullContext="B451CAA3DA4BD7C6C06CD52D21077B21" translateForJs="false">Wyślij ponownie zaproszenie</TranslationEntry>
    <TranslationEntry name="69501D30B7089BF7E25993156A4A5D38" fullContext="74D81D9D9C26FEDCAEE3D1873AAE0AD0" translateForJs="false">Ponownie wyślij kod zaproszenia dla wybranego mobilnego identyfikatora, aby zostać zaakceptowanym przez aplikację IR Mobile Access. Kod zaproszenia można wysłać na ostatni adres e-mail użyty dla tego zaproszenia do identyfikatora lub na nowy adres e-mail.</TranslationEntry>
    <TranslationEntry name="109E8965006A71E34DD305AF018CEC95" fullContext="109E8965006A71E34DD305AF018CEC95" translateForJs="false">Cofnij identyfikator</TranslationEntry>
    <TranslationEntry name="81051BCC2CF1BEDF378224B0A93E2877" fullContext="448C7EFEF446B4F3D4B17ACF5A00415B" translateForJs="false" />
    <TranslationEntry name="593D90FD71979710B534C5DFBCB0FEBC" fullContext="448C7EFEF446B4F3D4B17ACF5A00415B" translateForJs="false">Odwołaj wybrany identyfikator, oznaczając mobilny identyfikator jako „Odwołany” i uniemożliwiając użytkownikowi dostęp do przejść i stref za pomocą tego identyfikatora.</TranslationEntry>
    <TranslationEntry name="9DDDD359D2E978B899FC4A1BCC01740F" fullContext="9DDDD359D2E978B899FC4A1BCC01740F" translateForJs="false">Usuń identyfikator</TranslationEntry>
    <TranslationEntry name="1C411FC7BC85B2D4E3D9B4ECF14CE76F" fullContext="35DEC80326E7DDE5BE85CA6C4741123D" translateForJs="false">Usuń wybrany identyfikator, odłączając go od użytkownika i całkowicie usuwając go z systemu Inception</TranslationEntry>
    <TranslationEntry name="75FED3E24123A5402AA60EC2126A74E5" fullContext="75FED3E24123A5402AA60EC2126A74E5" translateForJs="false">Wyślij ponownie zaproszenie do mobilnego identyfikatora</TranslationEntry>
    <TranslationEntry name="0E56F9DBD7A50D25426D8E1001086B3E" fullContext="0E56F9DBD7A50D25426D8E1001086B3E" translateForJs="false">Wprowadź adres e-mail, na który ma zostać ponownie wysłane zaproszenie.</TranslationEntry>
    <TranslationEntry name="27E4A4566AF4CB0FB4C01348E47C69B4" fullContext="66DBEF7329B737425666F5CBAECAE079" translateForJs="false">Pole wypełniane automatycznie poprzednio używanym adresem e-mail. Można je zmienić na nowy adres e-mail lub pozostawić bez zmian. Nowy kod zaproszenia dla tego mobilnego identyfikatora zostanie wysłany do użytkownika powiązanego z tym mobilnym identyfikatorem na podany adres e-mail.</TranslationEntry>
    <TranslationEntry name="F3CA07C2539962921960C1318607EA52" fullContext="9D4BFA3C4F642C9EAF92564F1E524918" translateForJs="false">Użytkownik może następnie zaakceptować to zaproszenie za pomocą aplikacji IR Mobile Access na swoim smartfonie. Po zaakceptowaniu mobilnego identyfikatora można go używać do uzyskiwania dostępu do przejść i stref, do których użytkownik ma uprawnienia.</TranslationEntry>
    <TranslationEntry name="88A9235F758098BCA5061D835E983BC5" fullContext="CF87E0324B72217A71061AC897BDEB75" translateForJs="false">Identyfikator nadal będzie powiązany z tym użytkownikiem, ale będzie miał status </TranslationEntry>
    <TranslationEntry name="EFB216EB79453B9AAB85CEE34F38C055" fullContext="CF87E0324B72217A71061AC897BDEB75" translateForJs="false">Unieważniony</TranslationEntry>
    <TranslationEntry name="BD397864A1074E93EB68B43646746DF4" fullContext="CF87E0324B72217A71061AC897BDEB75" translateForJs="false"> i nie może być używany do uzyskiwania dostępu do żadnych przejść ani stref w systemie Inception.</TranslationEntry>
    <TranslationEntry name="21313F76B111BC0DF501BF89FC96BA46" fullContext="21313F76B111BC0DF501BF89FC96BA46" translateForJs="false">Odwołaj</TranslationEntry>
    <TranslationEntry name="4165D9B7CB1EA960D2C4D318A169DCB5" fullContext="4F3BCFE648DEE21702C6ACE03BB62EE0" translateForJs="false">Spowoduje to usunięcie identyfikatora z listy mobilnych identyfikatorów użytkownika i całkowite usunięcie mobilnego identyfikatora z systemu.</TranslationEntry>
    <TranslationEntry name="F2A6C498FB90EE345D997F888FCE3B18" fullContext="F2A6C498FB90EE345D997F888FCE3B18" translateForJs="false">Usuń</TranslationEntry>
    <TranslationEntry name="2ECC57C232A22CF5EEA25F200163F9CC" fullContext="2ECC57C232A22CF5EEA25F200163F9CC" translateForJs="false">Aktualizacja modułu</TranslationEntry>
    <TranslationEntry name="25A87DCD54B35FD6184838E869E0D8DA" fullContext="E38BB8D3F703C2E85D3807C167DF1741" translateForJs="false">Kliknij poniższy przycisk, aby zaktualizować firmware dostępnych modułów.</TranslationEntry>
    <TranslationEntry name="687616D658AF227D0D0BBBBC4558D490" fullContext="687616D658AF227D0D0BBBBC4558D490" translateForJs="false">Aktualizuj firmware modułu</TranslationEntry>
    <TranslationEntry name="BF17AC149E2E7A530C677E9BD51D3FD2" fullContext="BF17AC149E2E7A530C677E9BD51D3FD2" translateForJs="false">Moduły</TranslationEntry>
    <TranslationEntry name="266742871C9EB1D62CC7790C398145EC" fullContext="266742871C9EB1D62CC7790C398145EC" translateForJs="false">Moduł nadrzędny</TranslationEntry>
    <TranslationEntry name="2F5014412AA9C47D2A0B196C61902168" fullContext="2F5014412AA9C47D2A0B196C61902168" translateForJs="false">Typ firmware</TranslationEntry>
    <TranslationEntry name="BB21105124AF5BF4D2730E99D095695E" fullContext="BB21105124AF5BF4D2730E99D095695E" translateForJs="false">Wybierz moduły do aktualizacji</TranslationEntry>
    <TranslationEntry name="82CE4FE96406AD6E0EA917C6E4104F60" fullContext="82CE4FE96406AD6E0EA917C6E4104F60" translateForJs="false">Wyczyść zaznaczenie</TranslationEntry>
    <TranslationEntry name="D95DDA311A8C5198EDBD39BCF5D9E75D" fullContext="D95DDA311A8C5198EDBD39BCF5D9E75D" translateForJs="false">Usuń stare urządzenia peryferyjne</TranslationEntry>
    <TranslationEntry name="67163F00FFAFAC8B816BCC1673D2F318" translateForJs="false" rules="paramCheck=true" notes="This string contains special formatting parameters (e.g. &quot;{0}&quot;) that must be preserved in the translation">Brak {0}. Aby dodać nowe {0}, kliknij przycisk Dodaj w przyborniku na górze ekranu</TranslationEntry>
    <TranslationEntry name="DAA25539043FDCDC170C7087C2AC4E40" fullContext="DAA25539043FDCDC170C7087C2AC4E40" translateForJs="false">Duplikuj element</TranslationEntry>
    <TranslationEntry name="7CAD0EF4BAEA228EA9654A179F65D8A3" fullContext="7CAD0EF4BAEA228EA9654A179F65D8A3" translateForJs="false">Masowe usuwanie elementów</TranslationEntry>
    <TranslationEntry name="5FFD7A335DD836B3373F5EC570A58BDC" fullContext="5FFD7A335DD836B3373F5EC570A58BDC" translateForJs="true">Rozwiń wszystko</TranslationEntry>
    <TranslationEntry name="26594668C0A26E22151C3C09863AA8DE" fullContext="26594668C0A26E22151C3C09863AA8DE" translateForJs="false">Usuń wiele elementów</TranslationEntry>
    <TranslationEntry name="F134CDC08FD66836D88E5F2ACB513B14" fullContext="F134CDC08FD66836D88E5F2ACB513B14" translateForJs="false">Usuń elementy</TranslationEntry>
    <TranslationEntry name="89987B53F0E3132591620464B117D5C7" fullContext="89987B53F0E3132591620464B117D5C7" translateForJs="false">Tutaj wpisz nazwę elementu</TranslationEntry>
    <TranslationEntry name="4CE98C4BCDE5921B9C65320648D5A15B" fullContext="4CE98C4BCDE5921B9C65320648D5A15B" translateForJs="false">Wyświetl wszystkie elementy, do których odwołuje się ten element, oraz wszystkie elementy odwołujące się do tego elementu w systemie.</TranslationEntry>
    <TranslationEntry name="AE5FE4A5AB3DA7CEE19C679C30596578" fullContext="AE5FE4A5AB3DA7CEE19C679C30596578" translateForJs="false">Do jakich elementów odwołuje się ten element?</TranslationEntry>
    <TranslationEntry name="5112C5900C12B1DF2FEAB045F7C16D78" fullContext="5112C5900C12B1DF2FEAB045F7C16D78" translateForJs="false">Nazwa elementu</TranslationEntry>
    <TranslationEntry name="1325707FCC94E967CAE1576D0C61D409" fullContext="1325707FCC94E967CAE1576D0C61D409" translateForJs="false">Jak</TranslationEntry>
    <TranslationEntry name="925599CD0E3F7F8AF125C8EA8F4591D6" fullContext="925599CD0E3F7F8AF125C8EA8F4591D6" translateForJs="false">Które elementy odwołują się do tego elementu?</TranslationEntry>
    <TranslationEntry name="F020961AB3EBC0C874A3975A01094994" translateForJs="false" rules="paramCheck=true" notes="This string contains special formatting parameters (e.g. &quot;{0}&quot;) that must be preserved in the translation">Nowe {0} są dodawane przez konfigurowanie modułów sprzętowych.</TranslationEntry>
    <TranslationEntry name="04420D7A0194A43F7E6B4B4629C4F7B7" fullContext="04420D7A0194A43F7E6B4B4629C4F7B7" translateForJs="false">Aby dodać nowy </TranslationEntry>
    <TranslationEntry name="1A1E7860EEFEABD543BD6AC5548532BE" fullContext="1A1E7860EEFEABD543BD6AC5548532BE" translateForJs="false">, przejdź do </TranslationEntry>
    <TranslationEntry name="EF24444B592D265FC8072A9EAFB898E8" fullContext="EF24444B592D265FC8072A9EAFB898E8" translateForJs="false">Edycja sprzętu</TranslationEntry>
    <TranslationEntry name="A16574242B3BBE2FC5EC9DC26FE4DEB2" fullContext="A16574242B3BBE2FC5EC9DC26FE4DEB2" translateForJs="false">stronę.</TranslationEntry>
    <TranslationEntry name="1EAC942D69DB24F7E3F2DBEB716DBAE9" fullContext="1EAC942D69DB24F7E3F2DBEB716DBAE9" translateForJs="false">Nie masz uprawnień do edytowania modułów sprzętowych</TranslationEntry>
    <TranslationEntry name="76B540AB7A4DA7DD59B9FEAB9EDF0153" translateForJs="false" rules="paramCheck=true" notes="This string contains special formatting parameters (e.g. &quot;{0}&quot;) that must be preserved in the translation">Brak {0}. Twój profil strony internetowej nie pozwala na dodawanie nowych {0}.</TranslationEntry>
    <TranslationEntry name="602C47B328B413EEE177FCF7E4A9CB9F" fullContext="602C47B328B413EEE177FCF7E4A9CB9F" translateForJs="false">Konfiguruj certyfikat SSL</TranslationEntry>
    <TranslationEntry name="1D9184BEA4ECD25AFEA6FB58AAC2DA6B" fullContext="1D9184BEA4ECD25AFEA6FB58AAC2DA6B" translateForJs="false">To okno dialogowe umożliwia przesłanie niestandardowego certyfikatu SSL dla dostępu HTTPS lub wygenerowanie certyfikatu SSL z podpisem własnym.</TranslationEntry>
    <TranslationEntry name="A4639B9360D9674C0A79DFCB3131C37D" fullContext="E9F3CA96E39F48C7CF9D9E320EA1B507" translateForJs="false">Interfejs internetowy systemu Inception można skonfigurować, aby umożliwić dostęp przez HTTPS zapewniający wyższy poziom bezpieczeństwa (w porównaniu ze standardowym HTTP) podczas konfigurowania systemu. Dostęp HTTPS można włączyć łącznie z dostępem HTTP lub z wyłączonym HTTP dla najwyższego poziomu bezpieczeństwa i szyfrowania. Gdy dostęp HTTP jest wyłączony, zwykłe żądania HTTP kierowane do kontrolera Inception zostaną przekierowane na protokół HTTPS.</TranslationEntry>
    <TranslationEntry name="2FA8D899B7E7ACC3DD0669A63525798E" fullContext="E9F3CA96E39F48C7CF9D9E320EA1B507" translateForJs="false">Dostęp HTTPS do systemu Inception jest domyślnie włączony z automatycznie generowanym certyfikatem SSL z podpisem własnym wystawionym przez kontroler Inception. Można zachować domyślny certyfikat SSL lub przesłać własny niestandardowy certyfikat SSL wraz z kluczem prywatnym. </TranslationEntry>
    <TranslationEntry name="0A30AB52FED7E26CDBA32DC4EA25DA11" fullContext="E9F3CA96E39F48C7CF9D9E320EA1B507" translateForJs="false"> Wybór certyfikatu z podpisem własnym zapewni szyfrowanie ruchu WWW, ale może spowodować wyświetlenie przez przeglądarkę ostrzeżenia, że „połączenie nie jest prywatne". Certyfikat z podpisem własnym można ręcznie zaimportować do zaufanego magazynu certyfikatów przeglądarki, jednak w bardziej trwałych sytuacjach zaleca się zainstalowanie przez administratora sieci zaufanego niestandardowego certyfikatu SSL.</TranslationEntry>
    <TranslationEntry name="C187A600C08C6EDDBD11031221DB1D86" fullContext="E9F3CA96E39F48C7CF9D9E320EA1B507" translateForJs="false">Jeśli nowej konfiguracji nie można zastosować (np. z powodu nieprawidłowego certyfikatu lub hasła), istniejąca konfiguracja HTTPS i certyfikat pozostaną bez zmian.</TranslationEntry>
    <TranslationEntry name="89BACC9715D030658F2602CE65426A7F" fullContext="E9F3CA96E39F48C7CF9D9E320EA1B507" translateForJs="false">OSTRZEŻENIE:</TranslationEntry>
    <TranslationEntry name="9720C0978ADF3E48098E1F4B9DC6F2D4" fullContext="E9F3CA96E39F48C7CF9D9E320EA1B507" translateForJs="false"> Zdecydowanie zaleca się wykonanie kopii zapasowej bazy danych przed modyfikacją konfiguracji HTTP/S na wypadek, gdyby wpłynęło to na dostęp do interfejsu webowego.</TranslationEntry>
    <TranslationEntry name="C5A4D506D2B29991A872A9640CF6A983" fullContext="C5A4D506D2B29991A872A9640CF6A983" translateForJs="false">Informacje o bieżącym certyfikacie SSL</TranslationEntry>
    <TranslationEntry name="0734CA347AEDF882352B96BABD1D9F8B" fullContext="0734CA347AEDF882352B96BABD1D9F8B" translateForJs="false">Odcisk palca certyfikatu SSL</TranslationEntry>
    <TranslationEntry name="98CDA6492A58DB5CB94DBE1EE81D46F3" fullContext="98CDA6492A58DB5CB94DBE1EE81D46F3" translateForJs="false">Wystawca certyfikatu</TranslationEntry>
    <TranslationEntry name="074DF2A65D2BB390D40F7EB87F4B660C" fullContext="074DF2A65D2BB390D40F7EB87F4B660C" translateForJs="false">Prześlij certyfikat niestandardowy</TranslationEntry>
    <TranslationEntry name="993857D6859FA7B8E4A5E7DD3BE2D6B0" fullContext="993857D6859FA7B8E4A5E7DD3BE2D6B0" translateForJs="false">Generuj certyfikat z podpisem własnym</TranslationEntry>
    <TranslationEntry name="0B39CB9E220C1A1CED294C7D2CBF0494" fullContext="0B39CB9E220C1A1CED294C7D2CBF0494" translateForJs="false">Prześlij certyfikat SSL</TranslationEntry>
    <TranslationEntry name="86F1C71E80C8959AFE890EC5357484B1" fullContext="86F1C71E80C8959AFE890EC5357484B1" translateForJs="false">To okno dialogowe umożliwia przesłanie niestandardowego certyfikatu SSL dla dostępu HTTPS.</TranslationEntry>
    <TranslationEntry name="FB22862E74872DF362D3596741F49DEF" fullContext="B329EB3ED6DEDD6F9A23751CB15B8E82" translateForJs="false">Podczas przesyłania niestandardowego certyfikatu SSL należy posiadać plik certyfikatu w formacie PEM (.crt lub .pem) oraz towarzyszący plik klucza w formacie PEM (.key). Jeśli certyfikat jest w innym formacie pliku (np. .p12/.pfx), należy najpierw przekonwertować go do formatu PEM za pomocą zewnętrznego narzędzia, takiego jak </TranslationEntry>
    <TranslationEntry name="EE302FD5FD2A7A5A3C19FC5BE21F979C" fullContext="B329EB3ED6DEDD6F9A23751CB15B8E82" translateForJs="false">OpenSSL</TranslationEntry>
    <TranslationEntry name="0C0CB5C7E4F86C7186EBEADE59F13A20" fullContext="0C0CB5C7E4F86C7186EBEADE59F13A20" translateForJs="false">Prześlij niestandardowy plik certyfikatu SSL (.crt, .pem)</TranslationEntry>
    <TranslationEntry name="3307B21E95357CA77151D002503D1E65" fullContext="3307B21E95357CA77151D002503D1E65" translateForJs="false">Prześlij niestandardowy plik klucza SSL (.key)</TranslationEntry>
    <TranslationEntry name="535C20B3D2FB0E22530434323E529F22" fullContext="535C20B3D2FB0E22530434323E529F22" translateForJs="false">JavaScript musi być włączony, aby móc korzystać z tej strony WWW. Włącz go przed ponowną próbą.</TranslationEntry>
    <TranslationEntry name="9045A201686A2B2B40ED8C2DE7D82037" fullContext="9045A201686A2B2B40ED8C2DE7D82037" translateForJs="false">Wykryto nieobsługiwaną przeglądarkę</TranslationEntry>
    <TranslationEntry name="B323934D7F4827D5A64835B33A03DF3B" fullContext="B323934D7F4827D5A64835B33A03DF3B" translateForJs="false">Ta przeglądarka nie jest obsługiwana w tej wersji systemu Inception.</TranslationEntry>
    <TranslationEntry name="9A1C5F5353DF01EB62982FDEF181746D" fullContext="9A1C5F5353DF01EB62982FDEF181746D" translateForJs="false">Uwaga: Począwszy od wersji 2.0 systemu Inception, przeglądarka Internet Explorer nie jest już obsługiwana. W przypadku systemu Windows 10 przeglądarka Microsoft Edge jest nadal obsługiwana.</TranslationEntry>
    <TranslationEntry name="87AC9B738C4171702BD82A53C6BC84A7" fullContext="87AC9B738C4171702BD82A53C6BC84A7" translateForJs="false">W przeciwnym razie spróbuj użyć innej przeglądarki, np.</TranslationEntry>
    <TranslationEntry name="E81C4E4F2B7B93B481E13A8553C2AE1B" fullContext="E81C4E4F2B7B93B481E13A8553C2AE1B" translateForJs="false">lub</TranslationEntry>
    <TranslationEntry name="19FAC41D57F8B91DEFCE60D0482A2BC0" fullContext="19FAC41D57F8B91DEFCE60D0482A2BC0" translateForJs="false">Przejścia można zaplanować do automatycznego odblokowania i blokowania na podstawie przedziału czasowego lub tego, czy strefa po jednej stronie przejścia jest uzbrojona, czy nie.</TranslationEntry>
    <TranslationEntry name="3DC44E92611F20DB11254340EEB2E067" fullContext="84FD925AB0E301C3B4294DD74EA6A3E8" translateForJs="false">Aby skonfigurować, kiedy przejście będzie się automatycznie blokować i odblokowywać, wybierz przedział czasowy z </TranslationEntry>
    <TranslationEntry name="573627C8B92E08AC0EB3DF985EE59F88" fullContext="84FD925AB0E301C3B4294DD74EA6A3E8" translateForJs="false"> lista rozwijana lub strefa z </TranslationEntry>
    <TranslationEntry name="D0F7D913CC8DE1152939CE9DEE5FA60C" fullContext="B802B46517809F5E5B7D66060718B155" translateForJs="false"> lista rozwijana.</TranslationEntry>
    <TranslationEntry name="6E2CFE89BCFAF66397A745D401D7D2C3" fullContext="84FD925AB0E301C3B4294DD74EA6A3E8" translateForJs="false"> - Gdy przedział czasowy staje się ważny (bieżący czas mieści się w określonych godzinach), przejście odblokuje się, a gdy przedział czasowy staje się nieważny (bieżący czas jest poza określonymi godzinami), przejście zablokuje się.  </TranslationEntry>
    <TranslationEntry name="223535E999C0BD237E82205DA5B366B7" fullContext="84FD925AB0E301C3B4294DD74EA6A3E8" translateForJs="false">Jest to powszechnie stosowane, gdy wewnętrzne przejście musi być w trybie swobodnego dostępu podczas godzin pracy.</TranslationEntry>
    <TranslationEntry name="CD28F618DF1F803A40D375DABA5CAC3C" fullContext="4DE6F3C5676CA32603A30DE25EB00DA1" translateForJs="false">Przedziały czasowe są programowane i edytowane na </TranslationEntry>
    <TranslationEntry name="048263AE47E8511CB9C7207E422BBB74" fullContext="4DE6F3C5676CA32603A30DE25EB00DA1" translateForJs="false">[Konfiguracja &gt; Harmonogramowanie &gt; Przedziały czasowe]</TranslationEntry>
    <TranslationEntry name="7202D277198969A6AED6F71A6FA0E0FC" fullContext="84FD925AB0E301C3B4294DD74EA6A3E8" translateForJs="false"> - Gdy strefa jest uzbrojona, przejście zostanie automatycznie zablokowane, jednak rozbrojenie strefy nie odblokuje przejścia.   </TranslationEntry>
    <TranslationEntry name="320946C8B7D222A2E06C12CEAE11ED21" fullContext="84FD925AB0E301C3B4294DD74EA6A3E8" translateForJs="false">Jest to powszechnie stosowane, gdy należy zapewnić blokadę przejścia, gdy strefa po wewnętrznej stronie przejścia jest uzbrojona.</TranslationEntry>
    <TranslationEntry name="B3A8BD3C4629D3ADE929DE31D3A97D71" fullContext="84FD925AB0E301C3B4294DD74EA6A3E8" translateForJs="false">Obie opcje można łączyć, uzyskując przejście, które odblokowuje się tylko wtedy, gdy aktywny jest przedział czasowy i strefa jest rozbrojona. Przejście ponownie się zablokuje, gdy przedział czasowy stanie się nieaktywny lub strefa zostanie uzbrojona. Pozwala to na normalne odblokowanie przejścia w ciągu dnia, ale tylko po przybyciu osoby uprawnionej do rozbrojenia strefy.</TranslationEntry>
    <TranslationEntry name="DF63B5339A413005DD7F33BD9FEE9826" fullContext="B802B46517809F5E5B7D66060718B155" translateForJs="false">Aby skonfigurować czas automatycznego uzbrajania strefy, wybierz przedział czasowy z </TranslationEntry>
    <TranslationEntry name="99E0B957C714E95BE92E17DA059AADD0" fullContext="D471604D5BE7B763E59E1566E64FD202" translateForJs="false">Strefa automatycznie uzbroi się, gdy wybrany Harmonogram stanie się aktywny (bieżący czas mieści się w określonych godzinach). Funkcja ta jest powszechnie stosowana do automatycznego uzbrajania strefy późno w nocy, aby zapewnić jej uzbrojenie przez noc na wypadek, gdyby użytkownik zapomniał ją uzbroić. </TranslationEntry>
    <TranslationEntry name="5D449D8BF60E960A8DF43801D88B9469" fullContext="D471604D5BE7B763E59E1566E64FD202" translateForJs="false">Domyślnie strefa nie rozbroi się automatycznie, gdy przedział czasowy stanie się nieaktywny, jednak można to zmienić za pomocą </TranslationEntry>
    <TranslationEntry name="F4F06F9EEA3278B21333F78B0D6C88C0" fullContext="F4F06F9EEA3278B21333F78B0D6C88C0" translateForJs="false">Piętra windy można zaplanować jako dostęp swobodny lub zabezpieczone na podstawie przedziału czasowego lub stanu uzbrojenia strefy na danym piętrze.</TranslationEntry>
    <TranslationEntry name="E90CC01F7BA475B5B58B14E71EE4CFFC" fullContext="4DE6F3C5676CA32603A30DE25EB00DA1" translateForJs="false">Aby skonfigurować, kiedy piętro windy będzie automatycznie ustawiane na wolny dostęp, wybierz przedział czasowy z opcji </TranslationEntry>
    <TranslationEntry name="1ED3188886D046C9F9965888C5CC39CE" fullContext="4DE6F3C5676CA32603A30DE25EB00DA1" translateForJs="false"> listy rozwijanej i ustawienie, czy piętro powinno również śledzić stan strefy na tym piętrze. </TranslationEntry>
    <TranslationEntry name="58DA47F300C123E6680920F066E7BC54" fullContext="4DE6F3C5676CA32603A30DE25EB00DA1" translateForJs="false"> - Gdy przedział czasowy staje się ważny (bieżący czas mieści się w określonych godzinach), piętro zostanie ustawione jako dostępne swobodnie, a gdy przedział czasowy staje się nieważny (bieżący czas jest poza określonymi godzinami), piętro zostanie zabezpieczone. Piętro z dostępem swobodnym umożliwia dowolnemu użytkownikowi wybranie tego piętra w kabinie windy, natomiast zabezpieczone piętro wymaga od użytkownika prezentacji identyfikatora, aby mógł wybrać to piętro.  </TranslationEntry>
    <TranslationEntry name="F5DE60834A32E1ABA7FAAD12D316B7C2" fullContext="4DE6F3C5676CA32603A30DE25EB00DA1" translateForJs="false">Jest to powszechnie stosowane, gdy wspólne piętro wymaga nieograniczonego dostępu o określonych porach dnia.</TranslationEntry>
    <TranslationEntry name="5144298DF93327468A9684FEE63D2974" fullContext="4DE6F3C5676CA32603A30DE25EB00DA1" translateForJs="false"> - Gdy strefa jest uzbrojona, piętro zostanie automatycznie zabezpieczone, jednak rozbrojenie strefy nie ustawi piętra na wolny dostęp.   </TranslationEntry>
    <TranslationEntry name="B0CC42FC96F1105EBE9FD7407C852E5D" fullContext="4DE6F3C5676CA32603A30DE25EB00DA1" translateForJs="false">Jest to powszechnie stosowane, gdy trzeba zapewnić zabezpieczenie piętra, gdy strefa na tym piętrze jest uzbrojona, ograniczając dostęp tylko do osób, które mogą rozbroić strefę.</TranslationEntry>
    <TranslationEntry name="D59B7AFF75249CE373BB1716E5768D89" fullContext="4DE6F3C5676CA32603A30DE25EB00DA1" translateForJs="false">Obie opcje można łączyć, aby uzyskać piętro, które będzie w trybie wolnego dostępu tylko wtedy, gdy przedział czasowy jest aktywny i strefa jest rozbrojona. Piętro powróci do zabezpieczenia, gdy przedział czasowy stanie się nieaktywny lub strefa zostanie uzbrojona. Umożliwia to swobodny dostęp na piętro dla wszystkich użytkowników w ciągu dnia, jednak dopiero po tym, jak osoba uprawniona do rozbrojenia strefy będzie na miejscu.</TranslationEntry>
    <TranslationEntry name="982FF0FD4D82B5A0C6002102F6ABE3A3" translateForJs="false">ŁADOWANIE... W zależności od rozmiaru systemu może to potrwać do 60 sekund.</TranslationEntry>
    <TranslationEntry name="27C2F9B6A209F30DCC6B1769C6327912" fullContext="27C2F9B6A209F30DCC6B1769C6327912" translateForJs="false">Pobierz plik pomocy technicznej</TranslationEntry>
    <TranslationEntry name="BE49BAAFD77E6D5576AB405008802F1C" fullContext="BE49BAAFD77E6D5576AB405008802F1C" translateForJs="false">Tryb serwisowy jest aktualnie</TranslationEntry>
    <TranslationEntry name="E43C39B41227C1FB5539298B84055176" fullContext="E43C39B41227C1FB5539298B84055176" translateForJs="false">Następująca funkcjonalność systemu jest wyłączona:</TranslationEntry>
    <TranslationEntry name="99DB6A7905F21B3F53F842DC65E8F35C" fullContext="99DB6A7905F21B3F53F842DC65E8F35C" translateForJs="false">Tryb serwisowy zakończy się automatycznie o</TranslationEntry>
    <TranslationEntry name="F093A8E9D86BF02E248847FFBBA0898A" fullContext="F093A8E9D86BF02E248847FFBBA0898A" translateForJs="false">Aktualizuj tryb serwisowy</TranslationEntry>
    <TranslationEntry name="2B530122C50CBCAFDB3E0A4C4CF9E788" fullContext="2B530122C50CBCAFDB3E0A4C4CF9E788" translateForJs="false">Włącz tryb serwisowy</TranslationEntry>
    <TranslationEntry name="1A3BDC57E0AE70875CA198EBE642B873" fullContext="1A3BDC57E0AE70875CA198EBE642B873" translateForJs="false">Resetuj system Inception.</TranslationEntry>
    <TranslationEntry name="91A3BC7B7209A62E436EEB118847B0C7" fullContext="91A3BC7B7209A62E436EEB118847B0C7" translateForJs="false">Wyłącz przetwarzanie alarmu strefy</TranslationEntry>
    <TranslationEntry name="34356AFB51196A44E6CCF8E38C0AC5E0" fullContext="34356AFB51196A44E6CCF8E38C0AC5E0" translateForJs="false">Wyłącz raportowanie alarmów</TranslationEntry>
    <TranslationEntry name="49BED67A4A2FA5202A4632928F7FA235" fullContext="49BED67A4A2FA5202A4632928F7FA235" translateForJs="false">Wyłącz sygnalizację zwrotną przejścia</TranslationEntry>
    <TranslationEntry name="0DAA7B56FD4C5FC3A57351C2D33FB1F7" fullContext="0DAA7B56FD4C5FC3A57351C2D33FB1F7" translateForJs="false">Wyłącz sygnalizatory</TranslationEntry>
    <TranslationEntry name="49F96A057A633481231EB86213143C23" fullContext="49F96A057A633481231EB86213143C23" translateForJs="false">Wyłącz powiadamiające</TranslationEntry>
    <TranslationEntry name="654D22E3B4C375CC44FA8FFBC4F93615" fullContext="654D22E3B4C375CC44FA8FFBC4F93615" translateForJs="false">Czas trwania trybu serwisowego</TranslationEntry>
    <TranslationEntry name="06933067AAFD48425D67BCB01BBA5CB6" fullContext="06933067AAFD48425D67BCB01BBA5CB6" translateForJs="false">Aktualizuj</TranslationEntry>
    <TranslationEntry name="805F885ACD309147052051B883C3C963" fullContext="805F885ACD309147052051B883C3C963" translateForJs="false">Opóźnienie przed wyłączeniem</TranslationEntry>
    <TranslationEntry name="BCFACCEBF745ACFD5E75351095A5394A" fullContext="BCFACCEBF745ACFD5E75351095A5394A" translateForJs="false">Wyłącz</TranslationEntry>
    <TranslationEntry name="9883FD314018A6CCF7E07C53F40FEC34" fullContext="9883FD314018A6CCF7E07C53F40FEC34" translateForJs="false">Włączone szczegółowe zdarzenia</TranslationEntry>
    <TranslationEntry name="43345FD23F5DFC2D17B914C8060E7B51" fullContext="43345FD23F5DFC2D17B914C8060E7B51" translateForJs="false">Czas trwania włączenia zdarzeń szczegółowych</TranslationEntry>
    <TranslationEntry name="BE29BDB23B85504793F90F649DA68492" fullContext="792B2A93C4182EF79AEC9BF24E9822B2" translateForJs="false">Zostanie utworzony i pobrany plik pomocy technicznej w postaci pliku zip, zawierający informacje o systemie, które mogą być potrzebne pomocy technicznej do diagnozowania problemów.</TranslationEntry>
    <TranslationEntry name="FF0461FDE792856147759FB8D4DC5F73" fullContext="792B2A93C4182EF79AEC9BF24E9822B2" translateForJs="false">Należy pamiętać, że niektóre dołączone pliki mogą zawierać poufne informacje, a jeśli chcesz wysłać tylko wybrane pliki, będziesz musiał pobrać je ręcznie z odpowiednich stron. W pliku zip z pomocą techniczną zostaną uwzględnione następujące elementy:</TranslationEntry>
    <TranslationEntry name="4273ADFBDDD88A136464195F3F3AC251" fullContext="4273ADFBDDD88A136464195F3F3AC251" translateForJs="false">Nowa kopia zapasowa bazy danych</TranslationEntry>
    <TranslationEntry name="7D541078D8459CEB49916C30ADC177EB" fullContext="7D541078D8459CEB49916C30ADC177EB" translateForJs="false">Dziennik systemowy</TranslationEntry>
    <TranslationEntry name="CB57F66E6BC09EE1564EF54DEFB867F5" fullContext="CB57F66E6BC09EE1564EF54DEFB867F5" translateForJs="false">Rejestr (ostatnie 2 tygodnie)</TranslationEntry>
    <TranslationEntry name="3D31082B26ADF66B52B6AB409B8A4881" fullContext="35DA2F223EBF7A2DE5E96099EEC146FA" translateForJs="false">Informacje o systemie (numery wersji Inception znajdują się w </TranslationEntry>
    <TranslationEntry name="5033242C50CCC64DBE80F0FB6B7C369E" fullContext="35DA2F223EBF7A2DE5E96099EEC146FA" translateForJs="false">, wszystkie informacje w </TranslationEntry>
    <TranslationEntry name="C131783498DAFC6F4989EAF6812B37DE" fullContext="35DA2F223EBF7A2DE5E96099EEC146FA" translateForJs="false">[System &gt; Przegląd systemu &gt; System]</TranslationEntry>
    <TranslationEntry name="C4772589D9AA7F594B8CF2074793049F" fullContext="35DA2F223EBF7A2DE5E96099EEC146FA" translateForJs="false">, oraz szczegóły modułu).</TranslationEntry>
    <TranslationEntry name="C6C7203801656EC1499AFE9F201D496F" fullContext="C6C7203801656EC1499AFE9F201D496F" translateForJs="false">Opcje językowe</TranslationEntry>
    <TranslationEntry name="1A63951E46BD9EA58DA0EBBBF9A9AB32" fullContext="1A63951E46BD9EA58DA0EBBBF9A9AB32" translateForJs="false">Wyczyść porty szeregowe</TranslationEntry>
    <TranslationEntry name="671B111C5426B90927285442EAB7BF4B" fullContext="671B111C5426B90927285442EAB7BF4B" translateForJs="false">Importuj niestandardowy element</TranslationEntry>
    <TranslationEntry name="0B27918290FF5323BEA1E3B78A9CF04E" fullContext="0B27918290FF5323BEA1E3B78A9CF04E" translateForJs="false">Plik</TranslationEntry>
    <TranslationEntry name="72D6D7A1885885BB55A565FD1070581A" fullContext="72D6D7A1885885BB55A565FD1070581A" translateForJs="false">Importuj</TranslationEntry>
    <TranslationEntry name="B1310A247B24E2F38C07EE8CC0139B8E" fullContext="61050BA7CEDB9CF9D8A7D1034518C37E" translateForJs="false">Wprowadź poniżej adres e-mail, na który zostanie wysłana wiadomość testowa. Zostanie ona wysłana przy użyciu ustawień skonfigurowanych w </TranslationEntry>
    <TranslationEntry name="AD2DCFFA46B24242FE59CF028AF46817" fullContext="61050BA7CEDB9CF9D8A7D1034518C37E" translateForJs="false"> sekcja poniżej.</TranslationEntry>
    <TranslationEntry name="719B37BA486F19F92DD9EBB1FEDC1B39" fullContext="719B37BA486F19F92DD9EBB1FEDC1B39" translateForJs="false">UWAGA: Wysłanie wiadomości e-mail może potrwać kilka sekund</TranslationEntry>
    <TranslationEntry name="DD7BF230FDE8D4836917806AFF6A6B27" fullContext="DD7BF230FDE8D4836917806AFF6A6B27" translateForJs="false">Adres</TranslationEntry>
    <TranslationEntry name="6FBCF3580D9E638A70A869393DCF02EA" fullContext="6FBCF3580D9E638A70A869393DCF02EA" translateForJs="false">Kliknięcie opcji Zarządzaj językami spowoduje otwarcie menu Zarządzaj językami, w którym można przesyłać, usuwać i stosować pakiety językowe. Kliknięcie przycisku Pobierz szablon tłumaczenia spowoduje pobranie pliku szablonu tłumaczenia do użycia z narzędziem Inception Translation Tool.</TranslationEntry>
    <TranslationEntry name="DEC7CD9EB43C646034513F8E1E9197E2" fullContext="C5230EEB7961F1D3A38647CFC50A7564" translateForJs="false">Interfejs WWW Inception można wyświetlać w różnych językach dzięki plikom Pakietu językowego Inception (.irlanguage). Pliki te mogą być dostarczane przez Inner Range lub instalatora albo tworzone i edytowane ręcznie za pomocą Narzędzia tłumaczenia Inception, oddzielnej samodzielnej aplikacji. Aby utworzyć pakiet językowy, pierwszym krokiem jest pobranie kopii pliku szablonu pakietu językowego systemu Inception w celu zaimportowania do Narzędzia tłumaczenia Inception. Zawiera on cały tłumaczalny tekst systemu Inception dla bieżącej wersji firmware.</TranslationEntry>
    <TranslationEntry name="174815A2DD4C5E6067EAF4CC3B25F827" fullContext="C5230EEB7961F1D3A38647CFC50A7564" translateForJs="false">Plik szablonu pakietu językowego można pobrać, klikając przycisk Pobierz szablon tłumaczenia w oknie dialogowym Zarządzaj językami. Plik szablonu można zaimportować do narzędzia Inception Translation Tool, aby wygenerować nowy projekt tłumaczenia. Można go też scalić ze starszym projektem tłumaczenia, aby przetłumaczyć tylko tekst dodany w nowym firmware od czasu ostatniego tłumaczenia.</TranslationEntry>
    <TranslationEntry name="FB6C7C44E4160C192668E06D7568ACB4" fullContext="C5230EEB7961F1D3A38647CFC50A7564" translateForJs="false">Po zakończeniu procesu tłumaczenia przy użyciu narzędzia Inception Translation Tool można wyeksportować plik pakietu językowego (.irlanguage), a następnie przesłać go do kontrolera Inception z komputera PC. Aby przesłać pakiet językowy, kliknij przycisk Zarządzaj językami, następnie kliknij przycisk Prześlij i wybierz plik na dysku, który chcesz przesłać. Po pomyślnym przesłaniu, pakiet językowy powinien pojawić się na liście dostępnych języków w oknie dialogowym Zarządzaj językami. Stąd możesz wybrać żądany język z listy i kliknąć Zastosuj, aby zmienić bieżący język kontrolera Inception (ta akcja wymaga ponownego uruchomienia urządzenia).</TranslationEntry>
    <TranslationEntry name="CB939A8252D9C6EFCD5946C1BDB3952C" fullContext="C5230EEB7961F1D3A38647CFC50A7564" translateForJs="false">Jeśli przesyłanie pakietu językowego nie powiedzie się, może to oznaczać, że dane pliku pakietu językowego zostały nieprawidłowo wyeksportowane lub że plik uległ uszkodzeniu podczas transferu. Spróbuj ponownie wyeksportować pakiet językowy z narzędzia Inception Translation Tool, jeśli to możliwe, i ponownie go przesłać.</TranslationEntry>
    <TranslationEntry name="A227D7BC8EF25AA29D8E14D984A713A4" fullContext="A227D7BC8EF25AA29D8E14D984A713A4" translateForJs="false">Zarządzaj językami</TranslationEntry>
    <TranslationEntry name="CD5973459064EBDD311D9428AC6C7C2C" fullContext="CD5973459064EBDD311D9428AC6C7C2C" translateForJs="false">Pobierz szablon tłumaczenia</TranslationEntry>
    <TranslationEntry name="9DEDB8A4D07EBC36D2BA101F937B1C6E" fullContext="9DEDB8A4D07EBC36D2BA101F937B1C6E" translateForJs="false">Wybierz pakiet językowy</TranslationEntry>
    <TranslationEntry name="F40309C7972D85F25B031D3E131F4E21" fullContext="F40309C7972D85F25B031D3E131F4E21" translateForJs="false">Nazwa języka</TranslationEntry>
    <TranslationEntry name="E0A5B782389F3213667ABE32A4FCA783" fullContext="E0A5B782389F3213667ABE32A4FCA783" translateForJs="false">Kod ISO</TranslationEntry>
    <TranslationEntry name="34B6CD75171AFFBA6957E308DCBD92BE" fullContext="34B6CD75171AFFBA6957E308DCBD92BE" translateForJs="false">Wersja</TranslationEntry>
    <TranslationEntry name="770E3B1113B5475D99722D145E5B3D9A" fullContext="26C005E064A3BFF5C0C7C60280485D59" translateForJs="false">Aktualny pakiet językowy:</TranslationEntry>
    <TranslationEntry name="91412465EA9169DFD901DD5E7C96DD99" fullContext="91412465EA9169DFD901DD5E7C96DD99" translateForJs="false">Prześlij</TranslationEntry>
    <TranslationEntry name="D3B206D196CD6BE3A2764C1FB90B200F" fullContext="D3B206D196CD6BE3A2764C1FB90B200F" translateForJs="false">Usuń zaznaczone</TranslationEntry>
    <TranslationEntry name="6CF7CA0984A972A9ED9EC747A8FB83DF" fullContext="96D139E930E64C14FCBF4212A8A6243E" translateForJs="false">Tryb zmiany klucza szyfrowania LAN jest przeznaczony do pomocy w migracji modułów Ethernet LAN (np. Ethernet Bridge) ze starego klucza szyfrowania na bieżący klucz skonfigurowany w Inception. Wszystkie moduły Ethernet LAN w systemie muszą być skonfigurowane z tym samym kluczem szyfrowania co kontroler, aby mogły się komunikować.</TranslationEntry>
    <TranslationEntry name="536F4504DB0E1B9702EA15EF4C7A9A8E" fullContext="96D139E930E64C14FCBF4212A8A6243E" translateForJs="false">Tryb zmiany klucza LAN przełącza kontroler Inception w stan, w którym tymczasowo przez 2 minuty akceptuje wiadomości Ethernet LAN zaszyfrowane alternatywnym określonym kluczem (lub kluczem domyślnym). Gdy Inception otrzyma żądanie połączenia od modułu używającego alternatywnego klucza, automatycznie przeniesie ten moduł na bieżący klucz.</TranslationEntry>
    <TranslationEntry name="257B992D3DDEF2902C7AAA283D7C6533" fullContext="96D139E930E64C14FCBF4212A8A6243E" translateForJs="false">Ten tryb może być przydatny w sytuacji, gdy zmieniono klucz szyfrowania LAN systemu Inception, ale moduł był offline i nie otrzymał komunikatu o zmianie klucza, lub gdy podłączono nowy, nieskonfigurowany moduł Ethernet LAN i konieczna jest zmiana jego klucza w celu umożliwienia rejestracji.</TranslationEntry>
    <TranslationEntry name="B7476E80FE078765D2B3F8E1C7E154FA" fullContext="B7476E80FE078765D2B3F8E1C7E154FA" translateForJs="false">Typ klucza</TranslationEntry>
    <TranslationEntry name="877D097914FC4F661E9F63E26AADB061" fullContext="877D097914FC4F661E9F63E26AADB061" translateForJs="false">Stary klucz szyfrujący</TranslationEntry>
    <TranslationEntry name="EA63374F20839B877B83526544648BA3" fullContext="EA63374F20839B877B83526544648BA3" translateForJs="false">Włącz dostęp użytkownika poziomu 3</TranslationEntry>
    <TranslationEntry name="ED54D680828CBF084E290FBFA0CF9B49" fullContext="ED54D680828CBF084E290FBFA0CF9B49" translateForJs="true">Antykod linii wejściowej</TranslationEntry>
    <TranslationEntry name="921BDA25E37B839B92642B114869E90E" fullContext="921BDA25E37B839B92642B114869E90E" translateForJs="false">Wycisz sygnalizację zwrotną alarmową</TranslationEntry>
    <TranslationEntry name="467F2C2DEF838FD1A7C66C3964B7A87C" fullContext="8DF88973AE547F65A23BF93F1D659A6C" translateForJs="false">Niektóre ostrzeżenia systemowe i komunikaty mogą być kasowane wyłącznie przez użytkownika ze specjalnymi uprawnieniami, co oznacza, że terminale LCD mogą okresowo piszczeć i migać diodami LED do czasu skasowania ostrzeżeń/komunikatów. Jeśli usterka nie może być natychmiast usunięta, przycisk Wycisz w tym oknie dialogowym może zatrzymać okresowe pikanie do czasu zajęcia się ostrzeżeniem/komunikatem. (Uwaga: Nowe komunikaty/ostrzeżenia spowodują, że terminal LCD zacznie ponownie przyciągać uwagę.)</TranslationEntry>
    <TranslationEntry name="00CD7BE4CB21C59179316D7844A8CFC4" fullContext="00CD7BE4CB21C59179316D7844A8CFC4" translateForJs="false">Wycisz</TranslationEntry>
    <TranslationEntry name="454761C561B8A59823E80DFF51FC49D1" fullContext="454761C561B8A59823E80DFF51FC49D1" translateForJs="false">Wyłącz wyciszenie</TranslationEntry>
    <TranslationEntry name="91BF01E02F71E4DEE6A783867AABCF5F" fullContext="91BF01E02F71E4DEE6A783867AABCF5F" translateForJs="false">Czas trwania włączenia dostępu użytkownika poziomu 3 dla</TranslationEntry>
    <TranslationEntry name="9B51864E0247A0212902682252B30F81" fullContext="9B51864E0247A0212902682252B30F81" translateForJs="false">Czas ostatniego odświeżenia</TranslationEntry>
    <TranslationEntry name="5940521BD636AC9E9434DA27431B33AB" fullContext="5940521BD636AC9E9434DA27431B33AB" translateForJs="false">Zalogowani użytkownicy</TranslationEntry>
    <TranslationEntry name="693D946C5C4516961AB15C2E8D3FCDEB" fullContext="693D946C5C4516961AB15C2E8D3FCDEB" translateForJs="false">Bieżący pakiet językowy</TranslationEntry>
    <TranslationEntry name="FE34CE75A31C3A22A303C52F5ED42EEE" translateForJs="false" rules="paramCheck=true" notes="This string contains special formatting parameters (e.g. &quot;{0}&quot;) that must be preserved in the translation">W systemie jest {0} modułów</TranslationEntry>
    <TranslationEntry name="43C65B39EE7680F88F764254874B1888" fullContext="43C65B39EE7680F88F764254874B1888" translateForJs="false">N/A (uruchomiono w systemie Windows)</TranslationEntry>
    <TranslationEntry name="7E75C1D415765E5107A9B4D32A867AD9" fullContext="7E75C1D415765E5107A9B4D32A867AD9" translateForJs="false">Następny zaplanowany test baterii</TranslationEntry>
    <TranslationEntry name="185C008F042764468EEB5D84ECDEA36F" fullContext="185C008F042764468EEB5D84ECDEA36F" translateForJs="false">Bieżąca kolejka alarmów</TranslationEntry>
    <TranslationEntry name="0344B3C873CAB56FC8FA57E9BC01195D" translateForJs="false" rules="paramCheck=true" notes="This string contains special formatting parameters (e.g. &quot;{0}&quot;) that must be preserved in the translation">{0} zdarzeń</TranslationEntry>
    <TranslationEntry name="C97560F0969436E644491FD0A61333C1" fullContext="C97560F0969436E644491FD0A61333C1" translateForJs="false">Ścieżka raportowania Skytunnel</TranslationEntry>
    <TranslationEntry name="F548F2EF08C9A29FF5084CAFBA0E3257" fullContext="F548F2EF08C9A29FF5084CAFBA0E3257" translateForJs="false">Stan połączenia Skytunnel</TranslationEntry>
    <TranslationEntry name="4A6F604D56031CBF92F1A4E234485470" fullContext="4A6F604D56031CBF92F1A4E234485470" translateForJs="false">Następny cykliczny raport testowy Skytunnel</TranslationEntry>
    <TranslationEntry name="B411953B336F0A5530BC7A48EB524F29" fullContext="B411953B336F0A5530BC7A48EB524F29" translateForJs="false">Ścieżka raportowania urządzenia alarmowego</TranslationEntry>
    <TranslationEntry name="07C549CEB327173D3897B7E734385A97" fullContext="07C549CEB327173D3897B7E734385A97" translateForJs="false">Stan połączenia urządzenia alarmowego</TranslationEntry>
    <TranslationEntry name="3A33B0156C0A3950713BB2CAD2197BEF" fullContext="3A33B0156C0A3950713BB2CAD2197BEF" translateForJs="false">Komunikat błędu urządzenia alarmowego</TranslationEntry>
    <TranslationEntry name="2DDD8463026329731369096D9E2EAD1A" fullContext="2DDD8463026329731369096D9E2EAD1A" translateForJs="false">Następny planowy test urządzenia alarmowego</TranslationEntry>
    <TranslationEntry name="1CE38B6D2F9CAA5E61D41E69AEB6D602" fullContext="1CE38B6D2F9CAA5E61D41E69AEB6D602" translateForJs="false">Ścieżka raportowania SIA IP</TranslationEntry>
    <TranslationEntry name="02CDA02D594746F12AF1CA86D5B5C283" fullContext="02CDA02D594746F12AF1CA86D5B5C283" translateForJs="false">Status połączenia SIA IP</TranslationEntry>
    <TranslationEntry name="F544BA3D304F4DFFDF2B1AE198F1526F" fullContext="F544BA3D304F4DFFDF2B1AE198F1526F" translateForJs="false">Komunikat błędu SIA</TranslationEntry>
    <TranslationEntry name="790709C4C2E257D8C9A3E9E1D32AAF16" fullContext="790709C4C2E257D8C9A3E9E1D32AAF16" translateForJs="false">Następny cykliczny raport testowy SIA IP</TranslationEntry>
    <TranslationEntry name="9241AB356969437337B41C500CA80EEE" fullContext="9241AB356969437337B41C500CA80EEE" translateForJs="false">Podgląd kalendarza poniżej służy do sprawdzenia, czy przedział czasowy jest poprawnie zaprogramowany.</TranslationEntry>
    <TranslationEntry name="714A44E33BE383B9FDCC5A1D6E3412A4" fullContext="91D07A48B08794F9E21D4F2DBC3D5EDC" translateForJs="false">Podgląd kalendarza można wykorzystać do wyświetlenia dowolnej daty w przyszłości — będzie pokazywać, kiedy przedział czasowy jest aktywny w danym dniu, uwzględniając wszelkie wyjątki kalendarza lub wyjątki daty i godziny. Jest to przydatne do potwierdzenia, czy wyjątki zaplanowane na przyszłość zostały poprawnie zastosowane.</TranslationEntry>
    <TranslationEntry name="96C81FE9CDC67CCFF8D08BA929ABB570" fullContext="91D07A48B08794F9E21D4F2DBC3D5EDC" translateForJs="false">Gdy wprowadzane są zmiany w przedziale czasowym lub wyjątkach, zaleca się najpierw zaktualizować podgląd kalendarza, klikając </TranslationEntry>
    <TranslationEntry name="41D63A314069A8B29CCFF1A8741AF1ED" fullContext="91D07A48B08794F9E21D4F2DBC3D5EDC" translateForJs="false">. Kalendarz może być wyświetlany w widoku dni, tygodni lub miesięcy przez naciśnięcie odpowiedniego przycisku. W zależności od wybranego trybu wyświetlania można przesuwać kalendarz do przodu i do tyłu za pomocą klawiszy strzałek.</TranslationEntry>
    <TranslationEntry name="1E651AA199DF3799DA840376273AF7A7" fullContext="91D07A48B08794F9E21D4F2DBC3D5EDC" translateForJs="false">Kolor zielony oznacza czasy, w których przedział czasowy będzie aktywny, a biały — czasy nieaktywne. Niektóre czasy mogą być czerwone, co oznacza czasy nieprawidłowe z powodu wyjątków.</TranslationEntry>
    <TranslationEntry name="52A8B4EB9342B61C02C2F0A2D6B85261" fullContext="52A8B4EB9342B61C02C2F0A2D6B85261" translateForJs="false">Linie wyjściowe sterowane przez użytkownika</TranslationEntry>
    <TranslationEntry name="2FC45186DE9F375C6E3D8A117084B389" fullContext="2FC45186DE9F375C6E3D8A117084B389" translateForJs="false">Zbiorczy import/eksport</TranslationEntry>
    <TranslationEntry name="DD9DA3997A60F27308B796CE1B4FF127" fullContext="53229984A88478632D1026C8ED610883" translateForJs="false">Wprowadź adres e-mail tego użytkownika, na który zostanie wysłany kod zaproszenia. Domyślnie to pole jest automatycznie wypełniane adresem e-mail wybranego użytkownika z pola </TranslationEntry>
    <TranslationEntry name="CA1B50F1E7A3E5AC2F78299EA4A93EB2" fullContext="53229984A88478632D1026C8ED610883" translateForJs="false"> pole.</TranslationEntry>
    <TranslationEntry name="556EE96293B12A8F6B1F4366B99BE53E" fullContext="9D4BFA3C4F642C9EAF92564F1E524918" translateForJs="false">Mobilny identyfikator zostanie wygenerowany i przypisany do tego użytkownika ze statusem </TranslationEntry>
    <TranslationEntry name="F98552D4B87007DA82818937E16BECB1" fullContext="9D4BFA3C4F642C9EAF92564F1E524918" translateForJs="false">Zaproszenie wysłane</TranslationEntry>
    <TranslationEntry name="B3F8479572F58C9823C204DA89274179" fullContext="9D4BFA3C4F642C9EAF92564F1E524918" translateForJs="false">. Kod zaproszenia dla tego mobilnego identyfikatora zostanie następnie wysłany do użytkownika, do którego jest przypisany ten powiązany mobilny identyfikator, na podany adres e-mail.</TranslationEntry>
    <TranslationEntry name="CB492B7DF9B5C170D7C87527940EFF3B" fullContext="9D4BFA3C4F642C9EAF92564F1E524918" translateForJs="false" />
    <TranslationEntry name="2D4B0D14FBF4188479F23F8FAE8A03F5" fullContext="2D4B0D14FBF4188479F23F8FAE8A03F5" translateForJs="false">Przydziel identyfikator</TranslationEntry>
    <TranslationEntry name="AE481B4E93FAE50B8A5076AA62245DEF" fullContext="0FC152CB028B6F77CD9A877B0CE5A565" translateForJs="false">Otwiera menu eksportu do pliku CSV w celu wyeksportowania informacji o użytkowniku do pliku .csv. Menu będzie zawierać pola użytkownika, które można wybrać w celu filtrowania eksportowanych danych użytkownika.</TranslationEntry>
    <TranslationEntry name="4CAF1B0C8D73A791831C143B9D0F7C39" fullContext="8C14ADC36354479E947DB63A7B8607FA" translateForJs="false">Otwiera menu importu pliku CSV w celu zaimportowania pliku .csv, który zaktualizuje istniejących użytkowników i utworzy nowych na podstawie nazw użytkowników podanych w pliku .csv.</TranslationEntry>
    <TranslationEntry name="C2C5C27C0EED7F91AE209BC84F96CBC0" fullContext="363DA4DF7E6069DF6AB53D9A5F81C6D2" translateForJs="false">Otwiera menu umożliwiające zbiorczy import zdjęć użytkowników przez przesłanie pliku ZIP z plikami obrazów JPEG. Pliki obrazów powinny być nazwane odpowiednio do użytkownika, do którego zostanie przypisane zdjęcie.</TranslationEntry>
    <TranslationEntry name="B9196526D5FD1BC74837832778395004" fullContext="B9196526D5FD1BC74837832778395004" translateForJs="false">Importowanie użytkowników</TranslationEntry>
    <TranslationEntry name="4833CC0109057F8A93867C2D1EF234F6" fullContext="4833CC0109057F8A93867C2D1EF234F6" translateForJs="false">Importuj zdjęcia użytkowników zbiorczo, przesyłając plik ZIP zawierający wiele plików obrazów JPEG. Nazwy plików obrazów są dopasowywane do użytkowników na podstawie nazwy użytkownika, dlatego zaleca się, aby nazwy użytkowników były unikalne.</TranslationEntry>
    <TranslationEntry name="C64B0AFE77E52C3F071825D2AA71A5CF" fullContext="B3CDEC10B81B03A5BB2867D7A7C3151D" translateForJs="false">Przesłany plik ZIP powinien zawierać wyłącznie pliki obrazów JPEG (.jpg/.jpeg), których nazwy odpowiadają nazwom użytkowników w systemie Inception. Pliki niebędące plikami JPEG lub pliki, których nazwy nie odpowiadają żadnemu użytkownikowi w systemie, będą ignorowane. Wszystkie obrazy powinny znajdować się w głównym katalogu folderu ZIP, a nie w podfolderach. Przesłany plik ZIP nie może przekraczać 100 MB; większe partie obrazów mogą wymagać podziału na wiele plików ZIP.</TranslationEntry>
    <TranslationEntry name="DD0B4F87E4EDD226CBAC4706EF118B28" fullContext="B3CDEC10B81B03A5BB2867D7A7C3151D" translateForJs="false">Maksymalny obsługiwany rozmiar obrazu to 480 x 640 px (proporcje 3:4); obrazy zostaną pomniejszone, jeśli przekroczą te wymiary, dlatego zaleca się przesyłanie zdjęć użytkowników w podobnej rozdzielczości i proporcjach dla optymalnej jakości.</TranslationEntry>
    <TranslationEntry name="05388658E1E8EE95FEFB444DD59B0776" fullContext="05388658E1E8EE95FEFB444DD59B0776" translateForJs="false">Prześlij plik Zip</TranslationEntry>
    <TranslationEntry name="726EE1255E35C7D8A26E56E32A8AA966" fullContext="726EE1255E35C7D8A26E56E32A8AA966" translateForJs="false">Importuj zdjęcia z archiwum ZIP</TranslationEntry>
    <TranslationEntry name="919BC596CC03D86FCA7827D7A3D4900B" fullContext="919BC596CC03D86FCA7827D7A3D4900B" translateForJs="false">Importuj użytkowników zbiorczo, przesyłając plik CSV. Użytkownicy mogą być dodawani lub aktualizowani przez dopasowanie według nazwy użytkownika w pliku CSV. Ponieważ aktualizacja użytkowników jest powiązana z nazwą, zaleca się, aby nazwy użytkowników były unikalne.</TranslationEntry>
    <TranslationEntry name="73C0C9673275AFBAA34FC2C7EAC246F6" fullContext="C59951F75D1665052A2812FFEED68992" translateForJs="false">Pobierz arkusz importu CSV </TranslationEntry>
    <TranslationEntry name="622F83A1DF871A6B50352FB52D80C5B1" fullContext="C59951F75D1665052A2812FFEED68992" translateForJs="false">. Dodaj informacje o użytkowniku do arkusza kalkulacyjnego, zapisz go jako plik CSV i prześlij go w tym menu.</TranslationEntry>
    <TranslationEntry name="9EE781AB385DD8E67B6598E115FBBC54" fullContext="C59951F75D1665052A2812FFEED68992" translateForJs="false">Plik CSV musi zawierać wiersz nagłówka określający kolumny danych użytkownika do zaimportowania, a tytuły kolumn muszą odpowiadać właściwościom użytkownika widocznym na stronie Zarządzaj użytkownikami. Właściwość "Nazwa" jest polem obowiązkowym i musi być dołączona jako jedna z kolumn wiersza nagłówka; wszystkie pozostałe pola są opcjonalne.</TranslationEntry>
    <TranslationEntry name="B3A3AC1CE4A54966E9CE23C02E36F0F9" fullContext="C59951F75D1665052A2812FFEED68992" translateForJs="false">Przykład prawidłowego formatu nagłówka kolumny:</TranslationEntry>
    <TranslationEntry name="4088FEB10D7E05B72BFF9BF27CC5A79C" fullContext="C59951F75D1665052A2812FFEED68992" translateForJs="false">Nazwa*</TranslationEntry>
    <TranslationEntry name="4963DEE1CAB7A9FC8F79C0610AABA9FF" fullContext="C59951F75D1665052A2812FFEED68992" translateForJs="false">* pole obowiązkowe</TranslationEntry>
    <TranslationEntry name="987B2F912C3AC560754C23D00D967B63" fullContext="C59951F75D1665052A2812FFEED68992" translateForJs="false">Każdy wiersz danych musi mieć wypełnioną co najmniej kolumnę Nazwa.</TranslationEntry>
    <TranslationEntry name="364DB6E1A8D350B875AB38D94F013A8A" fullContext="C59951F75D1665052A2812FFEED68992" translateForJs="false">Wpisy dla pola "Uprawnienia" mogą być wyłącznie nazwami istniejących grup uprawnień w systemie (bez uwzględniania wielkości liter); uprawnień użytkownika do poszczególnych elementów nie można przypisywać przez import CSV.</TranslationEntry>
    <TranslationEntry name="B3A266BB13BDF29C7B423B563E8C2935" fullContext="C59951F75D1665052A2812FFEED68992" translateForJs="false">Wpisy dla pól "Identyfikatory" i "Breloki zdalne" powinny zawierać wyłącznie numer identyfikatora/breloka; szablon identyfikatora i szablon breloka są określane poniżej w opcjach importu.</TranslationEntry>
    <TranslationEntry name="00A3872E02C759AA716DB50443562AF4" fullContext="C59951F75D1665052A2812FFEED68992" translateForJs="false">Uwaga: Mobilnych identyfikatorów nie można importować za pomocą pliku CSV.</TranslationEntry>
    <TranslationEntry name="B0C125E9DCF141BF3196EF5D4F294F30" fullContext="C59951F75D1665052A2812FFEED68992" translateForJs="false">Wpisy dla pól typu pole wyboru (np. "Użyj rozszerzonych czasów odblokowania") będą akceptować tylko słowa "true" lub "false" (bez rozróżniania wielkości liter).</TranslationEntry>
    <TranslationEntry name="74BEAFEBA77621D34D627D5F0AFC83FA" fullContext="C59951F75D1665052A2812FFEED68992" translateForJs="false">Pola składające się z list elementów (np. Identyfikatory, Pilot zdalny, Uprawnienia) mogą przyjmować tylko jeden element na raz ze względu na ograniczenia formatu CSV. Dla nowo importowanych użytkowników pojedynczy element stanie się jedynym elementem w polu listy. Dla istniejących użytkowników pojedynczy element zostanie dołączony do istniejącej listy elementów (jeśli nie jest już obecny). W przypadku gdy chcesz zaimportować użytkownika (użytkowników) z przypisanymi 2 identyfikatorami — na przykład: możesz najpierw wykonać import CSV użytkownika (użytkowników) z jednym numerem identyfikatora podanym w polu Identyfikatory, a następnie wykonać kolejny import CSV z tymi samymi nazwami użytkowników, ale z 2. numerem identyfikatora w polu Identyfikatory, a istniejący użytkownik uzyska 2. numer identyfikatora na liście identyfikatorów.</TranslationEntry>
    <TranslationEntry name="A6C9A2EA429D4E2F62E5DAB713DC6841" fullContext="C59951F75D1665052A2812FFEED68992" translateForJs="false">Pola odnoszące się do innych elementów w systemie (np. Profil terminala LCD, Grupy uprawnień, Profil strony internetowej) będą łączone na podstawie pola Nazwa elementu (bez uwzględniania wielkości liter). Jeśli nie zostanie znaleziony żaden element o podanej nazwie, import zakończy się niepowodzeniem.</TranslationEntry>
    <TranslationEntry name="953D928561B7979264C20C87858996A6" fullContext="C59951F75D1665052A2812FFEED68992" translateForJs="false">Pola z listami rozwijanymi opcji (np. Kiedy anulować użytkownika) będą akceptować tylko wartości pasujące do opcji tekstowych na liście rozwijanej (np. "Pierwsza karta lub PIN"). Wartości nie uwzględniają wielkości liter.</TranslationEntry>
    <TranslationEntry name="9FEB02CF09692713AE95635B8DC98EE9" fullContext="C59951F75D1665052A2812FFEED68992" translateForJs="false">Zalecany format danych pól daty/godziny (np. Czas wygaśnięcia użytkownika) to "RRRR-MM-DD GG:MM:SS". Pozwala to uniknąć niejednoznaczności formatu daty. Alternatywne formaty daty mogą być akceptowane, jednak należy je przetestować, aby to potwierdzić, co będzie zależeć od wybranego języka systemu.</TranslationEntry>
    <TranslationEntry name="043B3E1FFB15AD55C24F64104E776DFA" fullContext="C59951F75D1665052A2812FFEED68992" translateForJs="false">Pola "Encrypted Security PIN" i "Encrypted Password" akceptują wyłącznie zaszyfrowane ciągi danych wyeksportowane za pomocą okna dialogowego eksportu CSV użytkowników lub z Inception REST API. Opcja ta umożliwia klonowanie danych użytkowników z jednego systemu Inception do innego bez konieczności przywracania całej kopii zapasowej bazy danych, ponieważ PIN i hasła w postaci zwykłego tekstu nie mogą być eksportowane z Inception ze względów bezpieczeństwa. Aby wprowadzić PIN lub hasła w postaci zwykłego tekstu w imporcie CSV, należy użyć pól "Security PIN" lub "Password". Podczas wprowadzania danych użytkownika unikaj jednoczesnego używania zaszyfrowanych i niezaszyfrowanych wariantów tego samego pola.</TranslationEntry>
    <TranslationEntry name="EDC4810706AD04E7FDD8CFA2AC8752D6" fullContext="C59951F75D1665052A2812FFEED68992" translateForJs="false">Podczas korzystania z importu CSV do aktualizacji użytkowników, jeśli nie zostanie podana wartość dla pola, żadna zmiana nie jest wprowadzana. Oznacza to, że np. w celu aktualizacji adresu e-mail użytkownika nie jest konieczne podawanie grupy uprawnień, PIN, identyfikatora ani notatek.</TranslationEntry>
    <TranslationEntry name="E38A6B1F544BD9721E92E3E79C90B011" fullContext="C59951F75D1665052A2812FFEED68992" translateForJs="false">Istniejące pola danych użytkownika mogą być również usunięte przez wprowadzenie \</TranslationEntry>
    <TranslationEntry name="3FB6E27EF8FD490A5CED998D057E2084" fullContext="96B0F1989B2512F916AE3920FD75AC8E" translateForJs="false"> dla określonego pola. Różni się to od nieuwzględnienia wartości dla pola, co pozostawi pole użytkownika bez zmian. Działa to tylko dla pól, które mogą być puste (np. Notatki, Identyfikatory); pól wymagających odniesienia do innego elementu (Profil strony internetowej, Profil terminala LCD) nie można ustawić jako puste — spowoduje to niepowodzenie importu.</TranslationEntry>
    <TranslationEntry name="DF001C89646742DC8B955E68507923C0" fullContext="96B0F1989B2512F916AE3920FD75AC8E" translateForJs="false">Jeśli import zakończy się niepowodzeniem, proces zostanie przerwany i żaden użytkownik nie zostanie utworzony. Jednak jeśli import był używany do aktualizacji użytkowników, wszelkie aktualizacje, które nastąpiły przed niepowodzeniem, zostaną zachowane w systemie.</TranslationEntry>
    <TranslationEntry name="B56987E92F1F21648ADAD48E9C10B350" fullContext="96B0F1989B2512F916AE3920FD75AC8E" translateForJs="false">Niektóre przyczyny błędów importu to: </TranslationEntry>
    <TranslationEntry name="A7F52DCE1FA407A0646CE81C15D67AEB" fullContext="96B0F1989B2512F916AE3920FD75AC8E" translateForJs="false">Jeden lub więcej użytkowników nie ma nazwy.</TranslationEntry>
    <TranslationEntry name="B76A7E9D6E461768E3798B9CB53B78E5" fullContext="96B0F1989B2512F916AE3920FD75AC8E" translateForJs="false">Nie można znaleźć w systemie podanej nazwy elementu (grupy uprawnień, profilu strony internetowej itp.). </TranslationEntry>
    <TranslationEntry name="0200D24BA2FD0CCB093C20C6CCCE4515" fullContext="96B0F1989B2512F916AE3920FD75AC8E" translateForJs="false">Podany PIN jest już zgodny z istniejącym użytkownikiem lub w pliku importu są zduplikowane numery PIN.</TranslationEntry>
    <TranslationEntry name="4D453CED87B7A4285384F82E4922F939" fullContext="96B0F1989B2512F916AE3920FD75AC8E" translateForJs="false">Podany identyfikator jest już powiązany z istniejącym użytkownikiem lub w pliku importu występują zduplikowane identyfikatory.</TranslationEntry>
    <TranslationEntry name="DE5D0BAED1249A763E472EEFDB1C0B5D" fullContext="96B0F1989B2512F916AE3920FD75AC8E" translateForJs="false">Podane pole danych użytkownika miało nieprawidłowy format (adres e-mail, czas wygaśnięcia konta użytkownika itp.)</TranslationEntry>
    <TranslationEntry name="214831E78544AFEAB1D5C3A50A73AA7B" fullContext="214831E78544AFEAB1D5C3A50A73AA7B" translateForJs="false">Wgraj plik CSV</TranslationEntry>
    <TranslationEntry name="957063E58AB96A17ABA0F30EA629E800" fullContext="957063E58AB96A17ABA0F30EA629E800" translateForJs="false">Szablon breloka</TranslationEntry>
    <TranslationEntry name="1970FCE5BEF64CCA122826AE68DEDC33" fullContext="1970FCE5BEF64CCA122826AE68DEDC33" translateForJs="false">Eksportuj użytkowników do CSV</TranslationEntry>
    <TranslationEntry name="CCD51A46EE33FE1446D53BE660C57E0A" fullContext="CCD51A46EE33FE1446D53BE660C57E0A" translateForJs="false">Wybierz pola, które mają być uwzględnione w danych eksportu użytkowników do CSV.</TranslationEntry>
    <TranslationEntry name="B485C1BA5C76A85D7B7B05F143CBCB96" fullContext="1EAA72D6FFD1611844AE2F922505D4B5" translateForJs="false">Ze względów bezpieczeństwa pola "Security PIN" i "Password" nie eksportują żadnych wrażliwych danych do pliku CSV, jeśli są uwzględnione (pola pozostają puste), jednak nadal mogą być dołączone do wyeksportowanego pliku CSV jako szablon do uzupełnienia podczas importu użytkowników.</TranslationEntry>
    <TranslationEntry name="71F2BCDA3CCCF47E9FC79E37BF66D1ED" fullContext="1EAA72D6FFD1611844AE2F922505D4B5" translateForJs="false">Jeśli chcesz wyeksportować PIN lub hasła z systemu i zaimportować je do innego systemu Inception, wybierz pola "Encrypted Security PIN" i/lub "Encrypted Password". Pola te będą zawierać zaszyfrowaną wersję danych, czytelną tylko dla systemów Inception, i mogą być importowane do innych systemów z zachowaniem wrażliwych danych.</TranslationEntry>
    <TranslationEntry name="0095A9FA74D1713E43E370A7D7846224" fullContext="0095A9FA74D1713E43E370A7D7846224" translateForJs="false">Eksportuj</TranslationEntry>
    <TranslationEntry name="FFEF4A78C30B3FB8C024FD273AE48256" fullContext="FFEF4A78C30B3FB8C024FD273AE48256" translateForJs="false">Konfiguracja 2FA użytkownika</TranslationEntry>
    <TranslationEntry name="524220E2603D49309B5B972822A154CC" fullContext="BE008F6020B735E143B2C3FADD602703" translateForJs="false">Inception obsługuje uwierzytelnianie dwuskładnikowe (2FA) za pomocą smartfona lub tabletu z aplikacją Google Authenticator lub inną zgodną aplikacją uwierzytelniającą opartą na jednorazowym haśle czasowym (TOTP).</TranslationEntry>
    <TranslationEntry name="116F7054D127DDF927C1F10EAEB78CDE" fullContext="71FCEDBD46BDEA76932EB09F78A259EE" translateForJs="false">Korzystając z aplikacji uwierzytelniającej, zeskanuj kod QR aparatem smartfona lub ręcznie wprowadź klucz uwierzytelniający, aby dodać nowe konto 2FA.</TranslationEntry>
    <TranslationEntry name="6DF209F02F30CE2BB9AFDA332BF2DC46" fullContext="C771016A03352F75A70C7561AC296CE7" translateForJs="false">Po utworzeniu konta wprowadź 6-cyfrowy kod z aplikacji uwierzytelniającej i kliknij przycisk Zarejestruj, aby potwierdzić rejestrację 2FA.</TranslationEntry>
    <TranslationEntry name="3840196B3C126EADF992A0571E7D0753" fullContext="3840196B3C126EADF992A0571E7D0753" translateForJs="false">Wprowadź kod</TranslationEntry>
    <TranslationEntry name="0D307B8F5AA1B1372BE1E3AAADEEB25B" fullContext="0D307B8F5AA1B1372BE1E3AAADEEB25B" translateForJs="false">Pobierz kod zapasowy</TranslationEntry>
    <TranslationEntry name="94628B9E4D4131389D59D2C4472D2678" fullContext="94628B9E4D4131389D59D2C4472D2678" translateForJs="false">Wyszukaj/filtruj dane użytkownika</TranslationEntry>
    <TranslationEntry name="AB7A269E98FEE947FA8521258735BB04" fullContext="75D7934B8E304EFFB00781445EBF1502" translateForJs="false">Przeszukaj dane użytkownika, wpisując tekst w </TranslationEntry>
    <TranslationEntry name="2A1ED143C41645047D762EDD26545712" fullContext="CABA1F097719CBEAD4EDF9052DC39974" translateForJs="false">Przeszukaj wszystkie pola</TranslationEntry>
    <TranslationEntry name="234D92DAC00F4CF2BABED9B39739F345" fullContext="75D7934B8E304EFFB00781445EBF1502" translateForJs="false"> pole tekstowe.</TranslationEntry>
    <TranslationEntry name="A532619DD69C99498F6EBAC33914F30F" fullContext="CABA1F097719CBEAD4EDF9052DC39974" translateForJs="false"> pole tekstowe wyszuka wszystkie widoczne pola danych użytkownika i przefiltruje wyniki tabeli, aby wyświetlić tylko użytkowników, których dane zawierają częściowe lub dokładne dopasowanie do tekstu wyszukiwania. Ukryte pola nie są uwzględniane w wynikach wyszukiwania; aby je wyświetlić, należy użyć </TranslationEntry>
    <TranslationEntry name="2995EAFEF23E8ADBA27812106DFF035A" fullContext="CABA1F097719CBEAD4EDF9052DC39974" translateForJs="false"> przycisk, jeśli chcesz przeszukać zawartość tych pól. Opcja </TranslationEntry>
    <TranslationEntry name="F3D1EB4CD37B6D8C8D330249EBDC951A" fullContext="CABA1F097719CBEAD4EDF9052DC39974" translateForJs="false"> pole tekstowe można również stosować w połączeniu z indywidualnymi filtrami kolumn, aby precyzyjniej zawęzić wyniki.</TranslationEntry>
    <TranslationEntry name="B1F928771F50284985EED9C7BD16E0AF" fullContext="B1F928771F50284985EED9C7BD16E0AF" translateForJs="false">Szukaj we wszystkich polach:</TranslationEntry>
    <TranslationEntry name="C03CA67DDA321195D74C951097F240C6" translateForJs="false">Urządzenia</TranslationEntry>
    <TranslationEntry name="78C7901F2DFD2B81AB9D88A093DF3654" fullContext="78C7901F2DFD2B81AB9D88A093DF3654" translateForJs="false">Ponowne parowanie urządzenia bezprzewodowego</TranslationEntry>
    <TranslationEntry name="FEA9F6FA2B90DBBAD2B3B965DB78F1A1" fullContext="FEA9F6FA2B90DBBAD2B3B965DB78F1A1" translateForJs="false">Numer seryjny wybranego urządzenia</TranslationEntry>
    <TranslationEntry name="A60362ADA1399DA62207DDE001A9096E" fullContext="A60362ADA1399DA62207DDE001A9096E" translateForJs="false">Sparowany moduł</TranslationEntry>
    <TranslationEntry name="44841370B0A73F12BB9D3868E885A580" fullContext="44841370B0A73F12BB9D3868E885A580" translateForJs="false">Stan parowania</TranslationEntry>
    <TranslationEntry name="BB083DDA09187D59619E4C3F3D671187" fullContext="BB083DDA09187D59619E4C3F3D671187" translateForJs="false">Dokumentacja Inception REST API</TranslationEntry>
    <TranslationEntry name="32F20763340841A157A7F26CAD54450C" fullContext="32F20763340841A157A7F26CAD54450C" translateForJs="false">Zarządzaj certyfikatem integracji</TranslationEntry>
    <TranslationEntry name="47BBF5E187AD0731C2B9EF6162D8CDB5" fullContext="47BBF5E187AD0731C2B9EF6162D8CDB5" translateForJs="false">To okno dialogowe umożliwia przeglądanie bieżącego zaufanego certyfikatu wybranego Połączenia zintegrowanego oraz dopasowanie przechowywanego zaufanego odcisku palca do odcisku palca połączenia, jeśli nie są zgodne.</TranslationEntry>
    <TranslationEntry name="144DB98564B783D4DF5472757D55B423" fullContext="144DB98564B783D4DF5472757D55B423" translateForJs="false">Odcisk palca bieżącego zaufanego certyfikatu</TranslationEntry>
    <TranslationEntry name="68A9D504E5069ACBA31F4BE8252002F0" fullContext="68A9D504E5069ACBA31F4BE8252002F0" translateForJs="false">Odcisk cyfrowy certyfikatu integracji</TranslationEntry>
    <TranslationEntry name="3140397D736BC0F298FB5B4C41EAB0A0" fullContext="3140397D736BC0F298FB5B4C41EAB0A0" translateForJs="false">Aktualizuj odciski palców certyfikatu</TranslationEntry>
    <TranslationEntry name="58DED5F723B6194D6D53260ACA5DFD62" translateForJs="false">Reinicjalizuj integracje</TranslationEntry>
    <TranslationEntry name="7E2AB1B59CEE9599EFDC122854761279" translateForJs="false">Pobierz skonfigurowane ID integracji</TranslationEntry>
    <TranslationEntry name="1E77CD57F1646378ECFD6626156C12A5" translateForJs="false">Pobierz szczegóły integracji</TranslationEntry>
    <TranslationEntry name="AE1379E6106907DAE861D5DD8132AF5C" translateForJs="false">Pobierz urządzenia</TranslationEntry>
    <TranslationEntry name="53710E5A9F5CBF7B18AD8B90EACD6F5F" translateForJs="false">Zdarzenia uruchamiania</TranslationEntry>
    <TranslationEntry name="0A7D885FA820179D4A190F5D6D9A0148" translateForJs="false">Wywołaj komendę</TranslationEntry>
    <TranslationEntry name="FB284E9EEBB333992ADE81D407351205" translateForJs="false">Skonfigurowane integracje</TranslationEntry>
    <TranslationEntry name="E7B47C58815ACF1D3AFA59A84B5DB7FB" translateForJs="false">Nazwa firmy</TranslationEntry>
    <TranslationEntry name="B9AEFA40A54680BB258F9F9569290FAE" translateForJs="false">Nazwa produktu</TranslationEntry>
    <TranslationEntry name="D32B09AC138EE120400921F2C0294BA3" translateForJs="false">Logo firmy</TranslationEntry>
    <TranslationEntry name="7C9862B3941BF2A4A90D49E639A45D5D" translateForJs="false">Logo produktu</TranslationEntry>
    <TranslationEntry name="8332853ED0DEAC99B0AEC75410DFEF16" fullContext="8332853ED0DEAC99B0AEC75410DFEF16" translateForJs="false">Urządzenia podrzędne</TranslationEntry>
    <TranslationEntry name="3DCCEA1ECB1E52E2D05CF7352DD929D6" translateForJs="false">ID zewnętrzne</TranslationEntry>
    <TranslationEntry name="472A41D52BC263799165BE5660072698" translateForJs="false">NewItem.dat</TranslationEntry>
    <TranslationEntry name="84A9A9216CFE786669E2F23D63924E7D" translateForJs="false">Przeglądaj...</TranslationEntry>
    <TranslationEntry name="54F8617F11C1CA88BA997917D75C4509" translateForJs="false">Folder docelowy:</TranslationEntry>
    <TranslationEntry name="6492D670E42151CC37574D99F4071F85" translateForJs="false">Nazwa pliku:</TranslationEntry>
    <TranslationEntry name="4E6C24E8E08FB9982EDBDDBE68BD280B" translateForJs="false">Generuj plik elementu</TranslationEntry>
    <TranslationEntry name="883D5AD000A2B754DFAC3B3156D7E4E7" translateForJs="false">Kreator elementów niestandardowych Webtegriti</TranslationEntry>
    <TranslationEntry name="7ED0AB14D4C6E5F97BCCF9C134A9021D" translateForJs="false">Plik DB:</TranslationEntry>
    <TranslationEntry name="67A79E9D0F417B29ED791DD430F8A182" translateForJs="false">Folder docelowy wypakowania:</TranslationEntry>
    <TranslationEntry name="4F1EB15F74B642F360129AF6BBD68577" translateForJs="false">Wypakuj pliki</TranslationEntry>
    <TranslationEntry name="C14CE86AEADCA087A22896B2A64A5C58" translateForJs="false">Utwórz kopię zapasową</TranslationEntry>
    <TranslationEntry name="EC8B4FE5F1A150FF15C384E7CC3064DD" translateForJs="false">Dekrypter kopii zapasowej bazy danych Inception</TranslationEntry>
    <TranslationEntry name="8F6C1BEEB74B064F855A2B84803D25BD" translateForJs="false" rules="paramCheck=true" notes="This string contains special formatting parameters (e.g. &quot;{0}&quot;) that must be preserved in the translation">Wersja {0}</TranslationEntry>
    <TranslationEntry name="15ACDEA99B6BBA75800D9FDD25CD65EF" translateForJs="false" rules="paramCheck=true" notes="This string contains special formatting parameters (e.g. &quot;{0}&quot;) that must be preserved in the translation">Nie udało się otworzyć przeglądarki dla {0}</TranslationEntry>
    <TranslationEntry name="2F3C62B09D0382D4238C1F7C5ABE3975" translateForJs="false">Nie można zainicjować przeglądarki usług zeroconf. Upewnij się, że Bonjour jest zainstalowany przed uruchomieniem narzędzia Webtegriti Discovery.</TranslationEntry>
    <TranslationEntry name="19A3C2A371C31882D89C90547925E255" translateForJs="false">Wersja 1.0.0.0</TranslationEntry>
    <TranslationEntry name="5F60FC45F2953E9D8699E47AD90E3467" translateForJs="false">Otwórz w przeglądarce...</TranslationEntry>
    <TranslationEntry name="30C8F0A3EEE65A9AEF84996DC14760F9" translateForJs="false">Nazwa hosta/Numer seryjny</TranslationEntry>
    <TranslationEntry name="516B72DC3E2078F5AE30AEDCF9DE83A8" translateForJs="false">Dostępne urządzenia Inception:</TranslationEntry>
    <TranslationEntry name="98643DF15AE79DD0FA8490213EBCCB97" translateForJs="false">Informacje o urządzeniu:</TranslationEntry>
    <TranslationEntry name="3FBADE33E7953F8BACAB451DC57CC530" translateForJs="false">Narzędzie wykrywania Inception</TranslationEntry>
    <TranslationEntry name="81A28A130BB5DA4DAC65CF292FCE5B44" translateForJs="false">Numer płyty:</TranslationEntry>
    <TranslationEntry name="4D892538E98AA77CC7C3AD28CCBD12E0" translateForJs="false">Numer seryjny Inception:</TranslationEntry>
    <TranslationEntry name="1EE1C44C2DC81681F961235604247B81" translateForJs="false">Tryb:</TranslationEntry>
    <TranslationEntry name="0359A6A0AF3A40BF302FDE5D523ECF79" translateForJs="false">Generator numerów seryjnych Inception</TranslationEntry>
    <TranslationEntry name="B56C3BDA503A8DC4BE356EDB0CC31793" translateForJs="true">Zwiń wszystkie</TranslationEntry>
    <TranslationEntry name="BDC377ED0620E2FB7149D32BF5D91040" translateForJs="true">Generowanie raportu jest już w toku. Czy chcesz zatrzymać bieżący raport, czy poczekać na jego ukończenie?</TranslationEntry>
    <TranslationEntry name="0F68101772BD5397EF8EB1B632798652" translateForJs="true">Czekaj</TranslationEntry>
    <TranslationEntry name="D43EE31A822E70BE200A769223D9B831" translateForJs="true">Zatrzymaj bieżący raport</TranslationEntry>
    <TranslationEntry name="6A7D9DF0D9396A8AB134643EAC348BCB" translateForJs="true">Nieudane: </TranslationEntry>
    <TranslationEntry name="AC2900D4ED15C45C779108AB452BAFB7" translateForJs="true">Do tego przejścia nie przypisano żadnych czytników — czy na pewno chcesz kontynuować?</TranslationEntry>
    <TranslationEntry name="6E17E67B56B6691D78F50F428A16B905" translateForJs="true">Numer EAC musi być prawidłową liczbą całkowitą z zakresu od 1 do 120.</TranslationEntry>
    <TranslationEntry name="E90A827BF4F671B5917F5A2E27E93611" translateForJs="true">OSTRZEŻENIE: Czy na pewno chcesz zresetować wszystkie dane Contact ID? Jeśli to mapowanie zostało przekazane centrum monitorowania, będzie musiało zostać przekazane ponownie po ponownej konfiguracji.</TranslationEntry>
    <TranslationEntry name="51934F2CEBB13FFE23202A0E5C3E2185" translateForJs="true">OSTRZEŻENIE: Wyczyszczenie kolejki alarmów spowoduje utratę wszystkich oczekujących alarmów. Czy na pewno chcesz kontynuować?</TranslationEntry>
    <TranslationEntry name="83A56592F72626B484354B93E98733AE" translateForJs="true">OSTRZEŻENIE: Ta funkcja wygeneruje i wyśle alarm oraz przywrócenie dla każdego możliwego zdarzenia. Wysłanie wszystkich wygenerowanych alarmów może zająć dużo czasu. Czy na pewno chcesz kontynuować?</TranslationEntry>
    <TranslationEntry name="F97D2EB0A66987899D02BB180936AFA3" translateForJs="true">Błąd: </TranslationEntry>
    <TranslationEntry name="1412693E69CEDA14B74CE8476ABFEA19" translateForJs="true">Test obchodowy strefy zakończony — wszystkie linie wejściowe zostały przetestowane</TranslationEntry>
    <TranslationEntry name="E5C75F935EBB540A88BAC4065601DCA0" translateForJs="true">Test obchodowy strefy zatrzymany. </TranslationEntry>
    <TranslationEntry name="A105B303860E83BB08834CE52506EC4F" translateForJs="true">Dla tej strefy nie jest aktualnie aktywny żaden test obchodowy. Uruchom test obchodowy za pomocą powyższych przycisków.</TranslationEntry>
    <TranslationEntry name="7E2971BEB3983D644104770BB63CEF41" translateForJs="true">Na napędzie USB nie znaleziono kopii zapasowych bazy danych.</TranslationEntry>
    <TranslationEntry name="4A621BB00CD2A3A26AD954EACF8C5D1F" translateForJs="true">Nierozpoznane rozszerzenie pliku — obsługiwane są tylko pliki .inceptionbackup.</TranslationEntry>
    <TranslationEntry name="255F35AB6014476955FCCAAE5B09F26A" translateForJs="true">Nie znaleziono żadnych ostatnich zdarzeń odczytu nierozpoznanej karty. Upewnij się, że czytnik jest skonfigurowany w systemie, i ponownie przyłóż kartę.</TranslationEntry>
    <TranslationEntry name="FB7D9B5E3D0305AC8734BE93D7E94F12" translateForJs="true">Zmiana danych instalatora zakończona niepowodzeniem</TranslationEntry>
    <TranslationEntry name="018D6377D7D4473D46FF5D22A10F539A" translateForJs="true">Zmiana hasła nie powiodła się</TranslationEntry>
    <TranslationEntry name="5E4E3344B60F173C004E25F847AB5E6C" translateForJs="true">Nie wybrano pliku firmware!</TranslationEntry>
    <TranslationEntry name="AAD88A3F07D69CEA3BD931BFB8F82886" translateForJs="true">Wybrano więcej niż jeden plik firmware — wybierz tylko jeden plik.</TranslationEntry>
    <TranslationEntry name="BFA9A4C8E80DCF7F348106BBB70A9215" translateForJs="true">Czy na pewno chcesz zaktualizować firmware systemu?</TranslationEntry>
    <TranslationEntry name="B8F81D548D765336CBB18D79407D0477" translateForJs="true">Nowy firmware można zastosować za pomocą przycisku „Zaktualizuj oprogramowanie aplikacji”.</TranslationEntry>
    <TranslationEntry name="CF99F2A20A1561FCECC86C87B552FE03" translateForJs="true">Ostatnia kopia zapasowa bazy danych była wykonana ponad 24 godziny temu. Zalecamy wykonanie kopii zapasowej bazy danych przed aktualizacją firmware kontrolera, aby uniknąć potencjalnej utraty danych.</TranslationEntry>
    <TranslationEntry name="425AF0A38B4189488058799191547EB6" translateForJs="true">Zalecana kopia zapasowa bazy danych</TranslationEntry>
    <TranslationEntry name="44D87061F83167043ACF3694AEA3CF66" translateForJs="true">Kontynuuj mimo to</TranslationEntry>
    <TranslationEntry name="FA4B6FDCA6D8F5D2BA70F3819F454CCA" translateForJs="true">Kod był nieprawidłowy.</TranslationEntry>
    <TranslationEntry name="E6A6C512FA84A697091AF91B8D8DF512" translateForJs="true">Ładowanie kodu QR...</TranslationEntry>
    <TranslationEntry name="3E4687C2FCF78CCF85962D42DEC35079" translateForJs="true">Pomyślnie zarejestrowano użytkownika dla 2FA — kliknij OK, aby przejść do strony pulpitu</TranslationEntry>
    <TranslationEntry name="5C3FD2351BA23D3D36FE9D6708F7CFA6" translateForJs="true">Błąd rejestracji użytkownika dla 2FA: </TranslationEntry>
    <TranslationEntry name="21846F5CC1256D02C4EA4C08DB90437F" translateForJs="true">Twój awaryjny kod logowania 2FA to: </TranslationEntry>
    <TranslationEntry name="186F0E98FE0375E0EFD6725D952D5D35" translateForJs="true">Ładowanie kolejnych zdarzeń...</TranslationEntry>
    <TranslationEntry name="79AD8CCA3DD11F3924658100D6358236" translateForJs="true">Załadowano </TranslationEntry>
    <TranslationEntry name="173FC78956CD8BA9C8CAF8699122D4CE" translateForJs="true"> Zdarzenia</TranslationEntry>
    <TranslationEntry name="EAB3FA5BA27A093AAD147505F590250F" translateForJs="true">Załadowano wszystkie zdarzenia</TranslationEntry>
    <TranslationEntry name="3ED1D2986F23C358EBBC2DB33DD97A7A" translateForJs="true">Nie znaleziono ostatnich nieprzypisanych zdarzeń linii wejściowej RF</TranslationEntry>
    <TranslationEntry name="5F0B2F444AC5A7282C3A5E112BA116D9" translateForJs="true">Nowa integracja IR Video</TranslationEntry>
    <TranslationEntry name="009BAF4BC88A3E4E594DA16E5C1A1E83" translateForJs="true">Wybierz poniżej, jakim typem integracji wideo IR będzie sterowany</TranslationEntry>
    <TranslationEntry name="24CBF6F1CE433820FFB015E352FA5027" translateForJs="true">Zmiany muszą zostać zapisane przed zarządzaniem certyfikatem Zintegrowanego połączenia.</TranslationEntry>
    <TranslationEntry name="821A6F2F46E1A1A17DFA4316F0A059B1" translateForJs="true">Nie udało się pobrać odcisków palców certyfikatów: </TranslationEntry>
    <TranslationEntry name="C15B9A85DF2FDB349FA6BD11757087F2" translateForJs="true">Czy na pewno chcesz ustawić aktualny odcisk palca certyfikatu tego połączenia na odcisk palca certyfikatu Połączenia integracyjnego?</TranslationEntry>
    <TranslationEntry name="DA4FB851E5C38202135522D0BB156DA5" translateForJs="true">Zapisany odcisk palca certyfikatu ustawiony na odcisk palca Połączenia integracyjnego. Strona zostanie teraz przeładowana.</TranslationEntry>
    <TranslationEntry name="462F4B5CEBBD90A8787B6B67286B0AF9" translateForJs="true">Urządzenia pobrane pomyślnie</TranslationEntry>
    <TranslationEntry name="3F7067226F193EB2051A63B22A258D32" translateForJs="true">Błąd pobierania urządzeń</TranslationEntry>
    <TranslationEntry name="2F0DB1BF9B1AF82BB9FE954AB25FA99E" translateForJs="true">Brak urządzeń. Kliknij przycisk Pobierz skonfigurowane urządzenia, aby pobrać urządzenia z połączenia IR Video</TranslationEntry>
    <TranslationEntry name="D0A3ACFE94A10EDB24C79F103B0C9361" translateForJs="true">Brak połączeń z NVR</TranslationEntry>
    <TranslationEntry name="5289BF157522A5CD34676F2777D27048" translateForJs="true">Przywróć</TranslationEntry>
    <TranslationEntry name="BB84F39F8C4A42FF9070C980C3A39104" translateForJs="true">Bez zmian</TranslationEntry>
    <TranslationEntry name="D320D53B8908E57496CD915018EC38C6" translateForJs="true">Połączenie nie powiodło się: </TranslationEntry>
    <TranslationEntry name="2927E27AB7E506F6B7CF5F16F7B7C688" translateForJs="true">Nie udało się zapisać połączenia: </TranslationEntry>
    <TranslationEntry name="FA6DB90117B9BF2A455F6B3EF8027AD6" translateForJs="true">OSTRZEŻENIE: Zmiana języka systemu wymaga ponownego uruchomienia systemu, co spowoduje niedostępność systemu przez około jedną minutę. Czy na pewno chcesz kontynuować?</TranslationEntry>
    <TranslationEntry name="E2E51057C91B59350D6580DA0223D713" translateForJs="true">System zostanie teraz ponownie uruchomiony w celu zastosowania wybranego języka. Odczekaj 60 sekund, a następnie odśwież stronę.</TranslationEntry>
    <TranslationEntry name="40F3604EC45F97E2B689BE6B9CD7F412" translateForJs="true">Zmiana konfiguracji początkowej nie powiodła się</TranslationEntry>
    <TranslationEntry name="E4ADEC3933035F7BCF8BDF6FB17F9FCB" translateForJs="true">Ta akcja spowoduje natychmiastową aktualizację wszystkich kluczy licencyjnych powiązanych z tym systemem Inception. Czy na pewno chcesz kontynuować?</TranslationEntry>
    <TranslationEntry name="0B1635B6650C07944DECAC4D0CFC935E" translateForJs="true">Aktualizacja licencji zakończona pomyślnie</TranslationEntry>
    <TranslationEntry name="66034722E9C7716ED8583F045BAF8A38" translateForJs="true">Aktualizacja licencji nieudana: </TranslationEntry>
    <TranslationEntry name="0E41E9ACF4825B7702E1466263792634" translateForJs="true">Upewnij się, że adres license.innerrange.com na porcie 443 jest dostępny dla systemu Inception.</TranslationEntry>
    <TranslationEntry name="8027264196FFD87AF70C122C2E9D2475" translateForJs="true">Pomyślnie zastosowano klucz licencyjny</TranslationEntry>
    <TranslationEntry name="C8930C6835D33F997358F1204D6B3737" translateForJs="true">Klucz licencyjny został pomyślnie zastosowany w systemie Inception.</TranslationEntry>
    <TranslationEntry name="BB226F516E50C89C76E8963FED7D9A88" translateForJs="true">Zastosowanie klucza licencyjnego nieudane</TranslationEntry>
    <TranslationEntry name="85DB974371AAC067AB5D01587AB10D57" translateForJs="true">Nierozpoznane rozszerzenie pliku — obsługiwane są wyłącznie pliki firmware .dld.</TranslationEntry>
    <TranslationEntry name="6857902909D2A4869A51F3F79DBACAC1" translateForJs="true">OSTRZEŻENIE: Wszystkie urządzenia peryferyjne w trybie offline zostaną usunięte. Czy na pewno chcesz kontynuować?</TranslationEntry>
    <TranslationEntry name="87D1901DC3D3549FB2FFA57C1A78CBB5" translateForJs="true">Czy na pewno chcesz usunąć wszystkie te pozycje?</TranslationEntry>
    <TranslationEntry name="85C81925450F03E7393F49A63633264A" translateForJs="true">OSTRZEŻENIE: Wygenerowanie nowego certyfikatu SSL może wpłynąć na możliwość uzyskania dostępu do interfejsu internetowego Inception. Przed kontynuowaniem zalecane jest wykonanie kopii zapasowej bazy danych. Czy na pewno chcesz kontynuować?</TranslationEntry>
    <TranslationEntry name="AFF55F8935DEC5C6B05FEBB8A75CF03B" translateForJs="true">Wybierz plik certyfikatu SSL do przesłania.</TranslationEntry>
    <TranslationEntry name="CB81BB84799B77F063E3AE53093C64B3" translateForJs="true">OSTRZEŻENIE: Przesłanie nowego certyfikatu SSL może wpłynąć na możliwość uzyskania dostępu do interfejsu internetowego Inception. Przed kontynuowaniem zalecane jest wykonanie kopii zapasowej bazy danych. Czy na pewno chcesz kontynuować?</TranslationEntry>
    <TranslationEntry name="ED3F7356078F9342E8EC6D1CEC30D7C1" translateForJs="true">Konfigurowanie ustawień HTTP...</TranslationEntry>
    <TranslationEntry name="56013A7C76965A6E92E250EEA0B20F8E" translateForJs="true">Nie znaleziono sieci bezprzewodowych.</TranslationEntry>
    <TranslationEntry name="C80D778D76510A7170E9D301BAD1F7F2" translateForJs="true">OSTRZEŻENIE: Zmiany ustawień sieci mogą nie być natychmiast odzwierciedlone przez system — poczekaj do 5 minut na zastosowanie zmian.</TranslationEntry>
    <TranslationEntry name="F2E195CAF572E47313CBF97BBAAE6E8A" translateForJs="true">OSTRZEŻENIE: Ta akcja spowoduje reset całego systemu Inception i sprawi, że system będzie niesprawny przez maksymalnie 60 sekund podczas restartu. Zalecane jest, aby przed resetowaniem systemu upewnić się, że przebywasz na miejscu, na wypadek problemów i niedostępności zdalnego dostępu. Czy na pewno chcesz kontynuować?</TranslationEntry>
    <TranslationEntry name="278F958CC18E308E662417145F9C56E8" translateForJs="true">Wprowadź adres e-mail, na który chcesz wysłać testowy e-mail.</TranslationEntry>
    <TranslationEntry name="58214D4E674804569476E8EB7DC76610" translateForJs="true">Wynik testu e-mail</TranslationEntry>
    <TranslationEntry name="E188F2C9221AA3C62914AC8FE57E8B9A" translateForJs="true">OSTRZEŻENIE: Ta operacja spowoduje, że system zapomni o wszystkich portach szeregowych i wymagane będzie ponowne skonfigurowanie Połączeń itp. Czy na pewno chcesz kontynuować?</TranslationEntry>
    <TranslationEntry name="FD1BE3EFCF102A4183D9445D789574F4" translateForJs="true">Czy na pewno chcesz usunąć ten plik?</TranslationEntry>
    <TranslationEntry name="0EA5B5C4746CA5BD98798BE95AC35C66" translateForJs="true">Kolumna "Nazwa" musi być zaznaczona podczas wykonywania eksportu CSV użytkowników</TranslationEntry>
    <TranslationEntry name="E264CF6F33467A1DAD2D15CD6D26A671" translateForJs="true">Prześlij plik Zip, aby zaimportować zdjęcia użytkowników.</TranslationEntry>
    <TranslationEntry name="448CA7981AEB9E5D93B8D5717242851A" translateForJs="true">Prześlij plik .csv, aby zbiorczo zaimportować użytkowników.</TranslationEntry>
    <TranslationEntry name="543F63C64C6CA9E968F5540B541EA220" translateForJs="true">Wybrany plik musi być mniejszy niż 100 MB.</TranslationEntry>
    <TranslationEntry name="11E98AF918FB3EE4742D2491D723E771" translateForJs="true">Niewystarczająca liczba licencji do przydzielenia mobilnego identyfikatora. Skontaktuj się z administratorem systemu.</TranslationEntry>
    <TranslationEntry name="1C1B48AE979CD919B71E0514BECFDE2B" translateForJs="true">Kod zaproszenia do identyfikatora wysłano na </TranslationEntry>
    <TranslationEntry name="4D05CCD72B44531E34286A10AFAF70C7" translateForJs="true">. Wiadomość e-mail będzie zawierać kod zaproszenia i instrukcje dotyczące akceptacji zaproszenia za pomocą aplikacji Mobile Access.&lt;br&gt;&lt;/br&gt;&lt;p&gt;Wysłany kod zaproszenia identyfikatora: </TranslationEntry>
    <TranslationEntry name="657023B37795890C8F325670DD159BBE" translateForJs="true">Czy na pewno chcesz odwołać identyfikator: </TranslationEntry>
    <TranslationEntry name="8DA6EEC29755BA3D5FE0E0E832219105" translateForJs="true">Mobilny identyfikator został pomyślnie unieważniony.</TranslationEntry>
    <TranslationEntry name="E529913335D290882B2B370E2F4774AE" translateForJs="true">Zapisz zmiany przed dodaniem nowego połączenia.</TranslationEntry>
    <TranslationEntry name="D41D8CD98F00B204E9800998ECF8427E" translateForJs="true" />
    <TranslationEntry name="E0A85784609C968D2849BDD25C662D23" translateForJs="true">Pokaż mniej...</TranslationEntry>
    <TranslationEntry name="230AA1E7153824CF55E34AB16CE320D6" translateForJs="true">Zapisać bieżący element przed opuszczeniem tej strony?</TranslationEntry>
    <TranslationEntry name="E01BA7681DACA80FBDCBA461F60C5C00" translateForJs="true">OSTRZEŻENIE: Ta akcja spowoduje usunięcie całej bazy danych. Upewnij się, że masz kopię zapasową wszystkich ważnych informacji. </TranslationEntry>
    <TranslationEntry name="9102702625C28F417E9FCED20E2BB5CB" translateForJs="true">Czy na pewno chcesz kontynuować?</TranslationEntry>
    <TranslationEntry name="A113FEB22F8C279382F5A99F54B6F77D" translateForJs="true">Spowoduje to pominięcie ostrzeżenia o zabezpieczeniu LAN i brak monitorowania podstawień modułów. Jeśli w przyszłości chcesz zabezpieczyć LAN, można ręcznie wysłać zabezpieczenie LAN ze strony [Stan / Sterowanie &gt; Test sprzętu].</TranslationEntry>
    <TranslationEntry name="83A42E8173FBAFAA83B0C63A7B3C2737" translateForJs="true">Dostępne elementy</TranslationEntry>
    <TranslationEntry name="721AD6AF4DF7AD677867D8E5CCCFFC24" translateForJs="true">Wybrane elementy</TranslationEntry>
    <TranslationEntry name="13230A6B2AA95DE0372C89B600621309" translateForJs="true">Zapisać zmiany w bieżącym elemencie?</TranslationEntry>
    <TranslationEntry name="6A01A68D7C65C681360430B883DBDA3B" translateForJs="true">Dodaj nowy element, aby rozpocząć edycję</TranslationEntry>
    <TranslationEntry name="A73FFBADDFAD414274B2D695728E0E2F" translateForJs="true">Dodać identyfikator z ostatnich odczytów kart czy dodać ręcznie?</TranslationEntry>
    <TranslationEntry name="6DC52E9ECDE35B77D7871A342105DC3B" translateForJs="true">Dodaj identyfikator</TranslationEntry>
    <TranslationEntry name="932487A68901B3CDE6280413737B362C" translateForJs="true">Dodaj z ostatnich odczytów kart</TranslationEntry>
    <TranslationEntry name="98E235DDEDD6A81D77704EDA2E292986" translateForJs="true">Nie znaleziono ostatnich zdarzeń odczytu karty bez przypisania. Upewnij się, że karta nie jest przypisana do kogoś innego, i ponownie odczytaj kartę.</TranslationEntry>
    <TranslationEntry name="12E3D42FBC2BAB7E40FEC2BEB7BBCC5B" translateForJs="true">Dodaj ręcznie</TranslationEntry>
    <TranslationEntry name="86EBF54E7AC0DDAC2BCFE1FB78FA47EE" translateForJs="true">Aby podłączyć nowy pilot zdalnego sterowania, w systemie musi być dodany co najmniej jeden szablon pilota zdalnego sterowania.</TranslationEntry>
    <TranslationEntry name="35088A339C90DE9F1CAE04708166A144" translateForJs="true">Wybrany szablon pilota nie został znaleziony.</TranslationEntry>
    <TranslationEntry name="FD909C819D92CA8BACE9C701DF8B5FD5" translateForJs="true">Nie znaleziono skonfigurowanego bezprzewodowego bramki RF IR. Proszę podłączyć bramkę i skonfigurować ją na stronie Sprzęt przed parowaniem pilota z tym szablonem.</TranslationEntry>
    <TranslationEntry name="64B7AB3D97CD3020899F901B5506DFBA" translateForJs="true">Wybierz sposób przypisania zdalnego.</TranslationEntry>
    <TranslationEntry name="F7EB0E0B8B03CC0401525F1003A1F813" translateForJs="true">Dodaj z ostatniego zdarzenia breloka</TranslationEntry>
    <TranslationEntry name="4509A036E3D9C343B901B021E1C1C5FE" translateForJs="true">Nie znaleziono ostatnich nieprzypisanych zdarzeń breloka. Upewnij się, że brelok zdalny nie jest przypisany do innej osoby, a następnie naciśnij przycisk na breloku ponownie.</TranslationEntry>
    <TranslationEntry name="A9E24D2400F0AF9A7E6F96E5BA67F7E8" translateForJs="true">Nie można odnaleźć powiązanego szablonu identyfikatora — odśwież bieżącą stronę i spróbuj ponownie.</TranslationEntry>
    <TranslationEntry name="E77FD5B4C4C0D4F49AB09D3C91E6F503" translateForJs="true">[Brak elementu]</TranslationEntry>
    <TranslationEntry name="98F069CC7F82C80E8B52C93DE208F53B" translateForJs="true">Wprowadź kod zapasowy</TranslationEntry>
    <TranslationEntry name="E68B62C5DEE2D3510BC20977B041E682" translateForJs="true">Logowanie nie powiodło się — utracono połączenie z kontrolerem.</TranslationEntry>
    <TranslationEntry name="583F00EC2DD7A9F0BC72740B3005874B" translateForJs="true">Wprowadź jednorazowy kod zapasowy</TranslationEntry>
    <TranslationEntry name="E45E42CFF567C3AE7E64FC618C73D75B" translateForJs="true">Ostrzeżenie: Dwa lub więcej czytników podłączonych do wybranego modułu mają ten sam adres OSDP. Polecenie ustawienia adresu używa oryginalnych adresów do znalezienia docelowego czytnika, dlatego zduplikowane adresy mogą skutkować niezamierzonymi konsekwencjami przy konfigurowaniu nowych adresów. Zalecane jest odłączenie zduplikowanych czytników do momentu skonfigurowania unikalnego adresu.</TranslationEntry>
    <TranslationEntry name="A66510A885BDC84533C226F7C493E09A" translateForJs="true">Zduplikowane adresy OSDP</TranslationEntry>
    <TranslationEntry name="A60852F204ED8028C1C58808B746D115" translateForJs="true">Ok</TranslationEntry>
    <TranslationEntry name="FA12DE339CC99AFCB9B1B59C590317A8" translateForJs="true">Bieżący moduł nie posiada podłączonych czytników OSDP online.</TranslationEntry>
    <TranslationEntry name="21216EEED3970E29AE1AECE91A2AF7FA" translateForJs="true">Brak prawidłowych czytników</TranslationEntry>
    <TranslationEntry name="4BC508985A9B4C684419C21994C838A7" translateForJs="true">Wysłano polecenie zmiany adresu OSDP.</TranslationEntry>
    <TranslationEntry name="C18460FABF8A55C5B1D2E3FEB1128025" translateForJs="true">Komenda wysłana</TranslationEntry>
    <TranslationEntry name="EC94E9A9F2C096BF7F839027AF41525C" translateForJs="true">Podany nowy adres OSDP koliduje z innym czytnikiem podłączonym do tego modułu. Zalecana jest zmiana tej wartości na unikalną, w przeciwnym razie czytniki z pokrywającymi się adresami mogą nie łączyć się prawidłowo.</TranslationEntry>
    <TranslationEntry name="1E63F11BFB970EA2B7EBF73B0511053C" translateForJs="true">Kontynuować i zmienić adres mimo to?</TranslationEntry>
    <TranslationEntry name="122F2B3D0DB317251DC640DA67725B58" translateForJs="true">Konflikt adresu OSDP</TranslationEntry>
    <TranslationEntry name="78351948D523D98FC67C4B361B234633" translateForJs="true">Czytniki podłączone do bieżącego modułu nie akceptują tej wartości adresu OSDP. Podany adres musi być liczbą z zakresu od 0 do </TranslationEntry>
    <TranslationEntry name="9740AE56C4358F5C96BA77265B2748A8" translateForJs="true">Nieprawidłowa wartość adresu</TranslationEntry>
    <TranslationEntry name="A9828808BF0DCD0B7AF8E6F20B80AD85" translateForJs="true">Czy na pewno chcesz usunąć ten moduł?</TranslationEntry>
    <TranslationEntry name="96B15F76696565D0A30B9C924CAD5363" translateForJs="true">Czy na pewno chcesz zresetować tryb IO tego kontrolera? Pozwoli to przełączyć kontroler między używaniem prostych linii wejściowych i wyjściowych a możliwością konfigurowania czytników i przejść wbudowanych. 

 Nie wpłynie to na żadne inne elementy w systemie ani na linie wejściowe i wyjściowe powiązane z innym sprzętem.

Uwaga: Wszelkie wcześniej skonfigurowane linie wejściowe, linie wyjściowe, przejścia i czytniki podłączone bezpośrednio do samego kontrolera będą wymagały ponownego zaprogramowania.</TranslationEntry>
    <TranslationEntry name="EFECEEF2EB6E378F4B566BE538580D6B" translateForJs="true">Zapisz i kontynuuj</TranslationEntry>
    <TranslationEntry name="AA6D7D552FC49D539F88133A554EF462" translateForJs="true">Zapisz i poprzedni</TranslationEntry>
    <TranslationEntry name="ABA712F79C4EF816584B6685F6572414" translateForJs="true">Istnieją niezapisane zmiany.</TranslationEntry>
    <TranslationEntry name="5FDDF347EBD03989608C64D16163D51A" translateForJs="true">Zmiany użytkownika muszą zostać zapisane przed wyświetleniem lub ujawnieniem kodów PIN.</TranslationEntry>
    <TranslationEntry name="86FB03AB1F60156D0D23D3D24DFB99D6" translateForJs="true">Niezapisane zmiany</TranslationEntry>
    <TranslationEntry name="317E1C4CCA206289C0ED21A5A7531C64" translateForJs="true">PIN wysłany</TranslationEntry>
    <TranslationEntry name="03032C8AC980D20D7CAADF89DC11B1DD" translateForJs="true">Wysyłanie PIN e-mailem nie powiodło się</TranslationEntry>
    <TranslationEntry name="40CD2C0B5FBFF8543DBC799E4B5612CA" translateForJs="true">Ujawnianie PIN nie powiodło się</TranslationEntry>
    <TranslationEntry name="A7A7F421674DD2EC974165D711996C95" translateForJs="true">PIN ujawniony</TranslationEntry>
    <TranslationEntry name="4B15593862FDB038A2AA0DFAD686DC72" translateForJs="true">PIN użytkownika: </TranslationEntry>
    <TranslationEntry name="BC5D6AC66CAA235C7EEDB510641980DE" translateForJs="true">Generowanie PIN nie powiodło się</TranslationEntry>
    <TranslationEntry name="862C488B327CE89B9340D40B5454A536" translateForJs="true">Wygenerowano nowy losowy PIN</TranslationEntry>
    <TranslationEntry name="F86F7BA1A05BA92A71354D13E890CD6F" translateForJs="true">Nowy PIN to: </TranslationEntry>
    <TranslationEntry name="ADE8DA3CD0875D1AA0015C625D891060" translateForJs="true">Powiązano użytkownika IR Connect</TranslationEntry>
    <TranslationEntry name="8DF392F94615B762A00480198C5FFDCB" translateForJs="true">Czy na pewno chcesz odłączyć tego użytkownika IR Connect? Tej akcji nie można cofnąć</TranslationEntry>
    <TranslationEntry name="54C1DD7B9149DDA0D43F05CB8FDA023F" translateForJs="true">Wygenerowano token API użytkownika</TranslationEntry>
    <TranslationEntry name="28A7E6A31A2D7907B1E3AA13A803DFA3" translateForJs="true">Czy na pewno chcesz odłączyć bieżący token API użytkownika? Tej operacji nie można cofnąć, a token przestanie być używalny.</TranslationEntry>
    <TranslationEntry name="C432AAD38BBAD198DB9600D285449595" translateForJs="true">Token API użytkownika odłączony</TranslationEntry>
    <TranslationEntry name="57CF3C5CA3C57EA323809D2DB1C18C98" translateForJs="true">Token API użytkownika skopiowany do schowka</TranslationEntry>
    <TranslationEntry name="44B5ADB1BE4AC7398C2A209F696AB603" translateForJs="true">Uwierzytelnianie dwuskładnikowe (2FA) nie jest włączone. 2FA można włączyć na stronie [Konfiguracja &gt; Ogólne &gt; System]. Strona Zarządzaj użytkownikami musi zostać odświeżona po włączeniu 2FA.</TranslationEntry>
    <TranslationEntry name="5964AE3E8E3B7CFFE32D662A4F31261E" translateForJs="true">Ten użytkownik jest już zarejestrowany do 2FA.</TranslationEntry>
    <TranslationEntry name="F21FE99F9A2C660AD0F471A30B50460C" translateForJs="true">Pomyślnie zarejestrowano użytkownika dla 2FA.</TranslationEntry>
    <TranslationEntry name="469AE83085DE12FDDEFEABC8C7A5F7D1" translateForJs="true">Nie udało się zarejestrować użytkownika: </TranslationEntry>
    <TranslationEntry name="79BF2A912AC0A560032333055F5279A5" translateForJs="true">Ostrzeżenie: Wyrejestrowanie tego użytkownika z uwierzytelniania dwuskładnikowego spowoduje unieważnienie wszystkich istniejących kodów logowania z zarejestrowanych urządzeń. Czy na pewno chcesz kontynuować? Tej akcji nie można cofnąć.</TranslationEntry>
    <TranslationEntry name="5F4A7BF663A0395B78678D78CC9F5838" translateForJs="true">Błąd wyrejestrowania użytkownika: </TranslationEntry>
    <TranslationEntry name="FE8F5B6C3139AD6031C79553C3CAED8A" translateForJs="true">Nie można pobrać pliku pomocy technicznej</TranslationEntry>
    <TranslationEntry name="104C7B733CEFA56C245E4703DE92672D" translateForJs="true">Ujawnienie hasła nie powiodło się</TranslationEntry>
    <TranslationEntry name="F3B9DE34364942606EBB991132523F83" translateForJs="true">Wystąpił nieznany błąd.</TranslationEntry>
    <TranslationEntry name="976936CEC261BF169B94DC939FC5D2D6" translateForJs="true">Hasło ujawnione</TranslationEntry>
    <TranslationEntry name="F2D0E7946BFAABC500F4E64FF2163107" translateForJs="true">Hasło: </TranslationEntry>
    <TranslationEntry name="27B96AAAB9928AA61E762AE1FB7F7BDA" translateForJs="true">Połączenie utracone o </TranslationEntry>
    <TranslationEntry name="2BD32A1262681E76C853DE781219A402" translateForJs="true">Próba ponownego połączenia...</TranslationEntry>
    <TranslationEntry name="7C73A4C13F3DADF0B4892B9A1C0BD932" translateForJs="true">Pomyślnie zweryfikowano anti-kod.</TranslationEntry>
    <TranslationEntry name="340B0398C24D94E3957095AB8CF22ECA" translateForJs="true">Nie można zweryfikować kodu anty-dostępu.</TranslationEntry>
    <TranslationEntry name="5FEA6E80DD94E3618773DFC0E3FE3578" translateForJs="true">Użytkownik powiązany z tym mobilnym identyfikatorem został usunięty, więc identyfikatorem nie można już zarządzać. Czy chcesz usunąć ten mobilny identyfikator?</TranslationEntry>
    <TranslationEntry name="379B7AF104742D01E78C790F60369ECB" translateForJs="true">Mobilne identyfikatory zostały już przypisane.</TranslationEntry>
    <TranslationEntry name="1E3A2EB901BF600E0A52647424D9EE92" translateForJs="true">Kod zaproszenia wysłany pomyślnie.</TranslationEntry>
    <TranslationEntry name="7ADB2C7CF9F9AE831EADB84E2E6CA7ED" translateForJs="true">Zmiany użytkownika muszą zostać zapisane przed cofnięciem mobilnych identyfikatorów temu użytkownikowi.</TranslationEntry>
    <TranslationEntry name="0C23CC238773DA91A69575ED9ED8A5AB" translateForJs="true">Mobilny identyfikator został pomyślnie usunięty.</TranslationEntry>
    <TranslationEntry name="8C84F62977F1C3569932B5422A89EA97" translateForJs="true">Pomyślnie połączono z systemem Mobile Access</TranslationEntry>
    <TranslationEntry name="97BB0F36AE2C21914C0BC616CADE9040" translateForJs="true">System dostępu mobilnego odłączony pomyślnie</TranslationEntry>
    <TranslationEntry name="D6C3500E6B93070516BE2EA4270334FC" translateForJs="true">Mobilne identyfikatory zostały ponownie zsynchronizowane pomyślnie</TranslationEntry>
    <TranslationEntry name="C26FA70234499B5E4D368EB7B901BD7C" translateForJs="true">Brak dostępnych licencji do przydziału mobilnych identyfikatorów. Skontaktuj się z administratorem systemu.</TranslationEntry>
    <TranslationEntry name="4BF6DB5A6534494F35AEC037D31EBADB" translateForJs="true">Zmiany użytkownika muszą zostać zapisane przed przydzieleniem dodatkowych mobilnych identyfikatorów temu użytkownikowi.</TranslationEntry>
    <TranslationEntry name="3E0D19167019C46D4D311DFF275DB8B7" translateForJs="true">Zmiany użytkownika muszą zostać zapisane przed usunięciem jakichkolwiek mobilnych identyfikatorów tego użytkownika.</TranslationEntry>
    <TranslationEntry name="FAE38A7B6FDFA3553BCCDC5A9B82BCB6" translateForJs="true">Czy na pewno chcesz usunąć identyfikator: </TranslationEntry>
    <TranslationEntry name="AF8E0D760709AD7F2590FD5A235163F1" translateForJs="true">Mobilny identyfikator został pomyślnie usunięty.</TranslationEntry>
    <TranslationEntry name="E79C74C8AE2ED9DDC8644394FE326E58" translateForJs="true">Czy na pewno chcesz usunąć wybrane identyfikatory?</TranslationEntry>
