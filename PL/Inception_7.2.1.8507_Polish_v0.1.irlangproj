    <TranslationEntry name="87D3175632CD03E6FCF8E3B07EEDA938" translateForJs="false" rules="paramCheck=true" notes="This string contains special formatting parameters (e.g. &quot;{0}&quot;) that must be preserved in the translation">Odebrano zdarzenie połączenia zintegrowanego {0}</TranslationEntry>
    <TranslationEntry name="962EEA2E645479EA69E15BC25C6D0FFA" translateForJs="false" rules="paramCheck=true" notes="This string contains special formatting parameters (e.g. &quot;{0}&quot;) that must be preserved in the translation">Zintegrowane połączenie {0}</TranslationEntry>
    <TranslationEntry name="AF74C3404FAD209399F594F803B98F87" translateForJs="false" rules="paramCheck=true" notes="This string contains special formatting parameters (e.g. &quot;{0}&quot;) that must be preserved in the translation">System skasował ręczne nadpisanie dla piętra z powodu zmiany stanu uzbrojenia strefy o godzinie {0}</TranslationEntry>
    <TranslationEntry name="67934E4713D235D89D6C3F6036C0CD63" translateForJs="false" rules="paramCheck=true" notes="This string contains special formatting parameters (e.g. &quot;{0}&quot;) that must be preserved in the translation">System skasował ręczne nadpisanie piętra z powodu zmiany przedziału czasowego swobodnego dostępu o {0}</TranslationEntry>
    <TranslationEntry name="FD40AF6BDBFFCDD635CE674ADC7F7BF3" translateForJs="false">Nie znaleziono piętra</TranslationEntry>
    <TranslationEntry name="B1DE4F0D45E0982ECA82284041349242" translateForJs="false" rules="paramCheck=true" notes="This string contains special formatting parameters (e.g. &quot;{0}&quot;) that must be preserved in the translation">Nie można {0} pięter, nie masz do tego uprawnień. Aby {0} piętra, administrator musi przyznać Ci uprawnienia na stronie [Konfiguracja &gt; Użytkownicy &gt; Zarządzaj użytkownikami].</TranslationEntry>
    <TranslationEntry name="D15BCD0409C5D707AB4B264805F70AE2" translateForJs="false" rules="paramCheck=true" notes="This string contains special formatting parameters (e.g. &quot;{0}&quot;) that must be preserved in the translation">Żądanie piętra {0} przetworzone</TranslationEntry>
    <TranslationEntry name="E59837A99B5F235ADA73670F9F0CCEA2" translateForJs="false">Nie podano pliku certyfikatu SSL.</TranslationEntry>
    <TranslationEntry name="A4FE20E614A3A85E3BD76415D6E1789B" translateForJs="false">Nie podano pliku klucza prywatnego SSL.</TranslationEntry>
    <TranslationEntry name="9F5712AF93AAEEA42BCCDE087DC52DB8" translateForJs="false">Stosowanie niestandardowego certyfikatu SSL...</TranslationEntry>
    <TranslationEntry name="3F8672ED857B24FAC16F796377F25409" translateForJs="false">Nie udało się zastosować niestandardowego certyfikatu SSL. Certyfikat lub plik klucza miał nieprawidłowy format.</TranslationEntry>
    <TranslationEntry name="6248B1ADC9F3F567908AB55427E0348B" translateForJs="false">Nie udało się zastosować niestandardowego certyfikatu SSL. Klucz publiczny certyfikatu i pliku klucza nie pasują do siebie.</TranslationEntry>
    <TranslationEntry name="67607FA68711383FE805E058D6939E31" translateForJs="false">Nie udało się zastosować niestandardowego certyfikatu SSL. Nie można skopiować certyfikatu lub pliku klucza.</TranslationEntry>
    <TranslationEntry name="5847EE60F6100BA9CF659451DFBD66F8" translateForJs="false">Certyfikat SSL został pomyślnie zastosowany. Poczekaj 10 sekund i ręcznie odśwież przeglądarkę.</TranslationEntry>
    <TranslationEntry name="2EB260EB0D43F066F5B7666AEB326EE5" translateForJs="false">Generowanie samopodpisanego certyfikatu SSL...</TranslationEntry>
    <TranslationEntry name="09E9EA4941ADEB92460FDEB3BB47352F" translateForJs="false">Nie udało się wygenerować samopodpisanego certyfikatu SSL.</TranslationEntry>
    <TranslationEntry name="EA9AB4F506B360D9E82E4C7A7C72A877" translateForJs="false">Samopodpisany certyfikat SSL został pomyślnie wygenerowany. Odczekaj 10 sekund i ręcznie odśwież przeglądarkę.</TranslationEntry>
    <TranslationEntry name="75C920D81451E73367B4CCA7419E9ACE" translateForJs="false" rules="paramCheck=true" notes="This string contains special formatting parameters (e.g. &quot;{0}&quot;) that must be preserved in the translation">OSTRZEŻENIE: Numer wersji wybranego pliku firmware ({0}) jest starszy lub równy wersji aktualnie załadowanego firmware ({1}). Czy na pewno chcesz kontynuować?</TranslationEntry>
    <TranslationEntry name="9A63FC79DD6CBFAC038722D8FFDF1131" translateForJs="false">OSTRZEŻENIE: TRWA AKTUALIZACJA FIRMWARE SYSTEMU — NIE MOŻNA JEJ ANULOWAĆ. NIE WYŁĄCZAJ SYSTEMU PODCZAS AKTUALIZACJI!</TranslationEntry>
    <TranslationEntry name="E9794D5A1CD52DD023270E8B69B376BB" translateForJs="false">Aktualizacja firmware zakończona pomyślnie! Urządzenie uruchomi się ponownie za kilka sekund. Poczekaj 60 sekund i odśwież stronę.</TranslationEntry>
    <TranslationEntry name="893B063FA8A5C46AF6DFB32D392A20AE" translateForJs="false">Nie można wykonać aktualizacji firmware: aktualna wersja firmware jest zbyt stara</TranslationEntry>
    <TranslationEntry name="FF0314390D609DDACDD92856216E17B5" translateForJs="false">Nie można wykonać aktualizacji firmware: wybrana wersja firmware jest zbyt stara</TranslationEntry>
    <TranslationEntry name="6098AC990631549D6ADA1C37B54B8B19" translateForJs="false">Nie można wykonać aktualizacji firmware: Przełączanie między wydaniem wewnętrznym a publicznym nie jest obsługiwane</TranslationEntry>
    <TranslationEntry name="6399D9D8E48AAFFDB2F92A11936F437D" translateForJs="false">Nie można wykonać aktualizacji firmware: Nie udało się zweryfikować wyodrębnionych plików. Spróbuj ponownie przeprowadzić aktualizację.</TranslationEntry>
    <TranslationEntry name="30D08793FEACDBB07B5B969C047C3B37" translateForJs="false">OSTRZEŻENIE: Aktualizacja do tej wersji firmware wymaga przywrócenia ustawień fabrycznych. Spowoduje to usunięcie wszystkich danych konfiguracyjnych zapisanych w kontrolerze.</TranslationEntry>
    <TranslationEntry name="E59A8670D79CFA17AA16C0C73E51638A" translateForJs="false">Nie można wykonać downgrade firmware: wybrana wersja firmware jest niższa niż aktualna. Spróbuj użyć nowszej wersji firmware.</TranslationEntry>
    <TranslationEntry name="AB5CE5FA31C6C4C0149550B5E2F51840" translateForJs="false" rules="paramCheck=true" notes="This string contains special formatting parameters (e.g. &quot;{0}&quot;) that must be preserved in the translation">Nie można wykonać aktualizacji firmware: nieznana przyczyna. Kod błędu: {0}</TranslationEntry>
    <TranslationEntry name="1ED70A2CC77128764FD59DEE10BCC3A6" translateForJs="false">Nie można rozpocząć aktualizacji firmware, ponieważ inna aktualizacja firmware jest już w toku.</TranslationEntry>
    <TranslationEntry name="1F004E412319B7ED472624E011B3D2BA" translateForJs="false">Aktualizacja zakończona pomyślnie!</TranslationEntry>
    <TranslationEntry name="82E49719CEC7DAFFAA83495CC7D58A9A" translateForJs="false" rules="paramCheck=true" notes="This string contains special formatting parameters (e.g. &quot;{0}&quot;) that must be preserved in the translation">Sesja Mobile Access wygasła — spróbuj ponownie.</TranslationEntry>
    <TranslationEntry name="E43ED15B40905F119A3877BEA5A5EAD6" translateForJs="false">Identyfikator usunięty, ale połączenie z systemem dostępu mobilnego zostało wyłączone i nie będzie synchronizować usunięcia do czasu ponownego włączenia.</TranslationEntry>
    <TranslationEntry name="305B2A95018A39C4BF9E6AA7F63E22F6" translateForJs="false">Identyfikator usunięty, ale synchronizacja z systemem Mobile Access nie powiodła się — identyfikator nie pojawi się jako usunięty w systemie Mobile Access do momentu ponownego nawiązania połączenia.</TranslationEntry>
    <TranslationEntry name="47709E76ACE0284D0ED9ECC0DEBE4378" translateForJs="false">Status identyfikatora zaktualizowany, ale połączenie z systemem Mobile Access zostało wyłączone — synchronizacja nie nastąpi do momentu ponownego włączenia połączenia.</TranslationEntry>
    <TranslationEntry name="1DD3D9CB709FECAE1C513AF48AD14BE2" translateForJs="false" rules="paramCheck=true" notes="This string contains special formatting parameters (e.g. &quot;{0}&quot;) that must be preserved in the translation">Status identyfikatora zaktualizowany, ale synchronizacja z systemem Mobile Access nie powiodła się — identyfikator nie zostanie zsynchronizowany do momentu ponownego nawiązania połączenia.</TranslationEntry>
    <TranslationEntry name="56ECEF8D6D75DA8CBEE8A9139AD41AFA" translateForJs="false" rules="paramCheck=true" notes="This string contains special formatting parameters (e.g. &quot;{0}&quot;) that must be preserved in the translation">Kod obiektu {0}</TranslationEntry>
    <TranslationEntry name="89FE8A3AF3FC3B7D65643FFB69A2D8C2" translateForJs="false">Nie znaleziono czytnika</TranslationEntry>
    <TranslationEntry name="F02DD90CE5CD215882E5752322C0D0F5" translateForJs="false">Czytnik jest zablokowany.</TranslationEntry>
    <TranslationEntry name="FEA23DF347CB9C1C8775026A7F43AEC2" translateForJs="false" rules="paramCheck=true" notes="This string contains special formatting parameters (e.g. &quot;{0}&quot;) that must be preserved in the translation">ID szablonu: {0}</TranslationEntry>
    <TranslationEntry name="D4676968CA4DA3F37E3EA05EEF6BD108" translateForJs="false">Podano nieznany szablon karty.</TranslationEntry>
    <TranslationEntry name="E0CD5CDF532B97F26CCC6D835D416AC2" translateForJs="false" rules="paramCheck=true" notes="This string contains special formatting parameters (e.g. &quot;{0}&quot;) that must be preserved in the translation">(REST API) Numer identyfikatora {0}</TranslationEntry>
    <TranslationEntry name="CEC9696371830A3D1DA846FC5731B5D7" translateForJs="false">Nie znaleziono pasującego użytkownika dla podanego identyfikatora.</TranslationEntry>
    <TranslationEntry name="E4C646B48AE12ECD92A413328C2A62B7" translateForJs="false" rules="paramCheck=true" notes="This string contains special formatting parameters (e.g. &quot;{0}&quot;) that must be preserved in the translation">Stan podanego identyfikatora użytkownika był nieaktywny ({0}).</TranslationEntry>
    <TranslationEntry name="45B401914649D7E95644799E2C8E3F93" translateForJs="false">Odczyt identyfikatora zakończony pomyślnie</TranslationEntry>
    <TranslationEntry name="29F54357F75CE30E2B01FED94D005A1E" translateForJs="false">Nie znaleziono pasującego użytkownika dla podanego PIN-u.</TranslationEntry>
    <TranslationEntry name="39964324A82188BD48093259523407D7" translateForJs="false">Wprowadzanie danych PIN zakończone pomyślnie</TranslationEntry>
    <TranslationEntry name="A410B709E60179D5148BAB658F34F500" translateForJs="false">(Przywrócony)</TranslationEntry>
    <TranslationEntry name="BF0E6B7F1CCCD42C6328893F3090ECB3" translateForJs="false"> (Izoluj)</TranslationEntry>
    <TranslationEntry name="98A0AB378604F6995C92A78C698E94EF" translateForJs="false"> (Przywrócony)</TranslationEntry>
