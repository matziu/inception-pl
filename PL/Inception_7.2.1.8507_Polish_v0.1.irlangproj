    <TranslationEntry name="87C1513C8BBC6217F20F2CBB5F240ABC" translateForJs="false">Filtruj do określonych jednostek (boksów)</TranslationEntry>
    <TranslationEntry name="29CB1DFC766C0BC0B6D65419FB1FA653" fullContext="872B6708824135ABD395AFB291B9AB88" translateForJs="false">Opcjonalnie ogranicz wyniki raportu tylko do wybranych Jednostek (boksów). Domyślnie (gdy lista jest pusta) w raporcie uwzględniane są wszystkie Jednostki (boksy).</TranslationEntry>
    <TranslationEntry name="43D1CCED5B7A3D37918BD38DCD68FF59" translateForJs="false">Pokaż zdarzenia zablokowania/odblokowania</TranslationEntry>
    <TranslationEntry name="DF54949A2A1AA34B6BA4A1A8538C4440" fullContext="7B06F7E86E53DC0F47EFB4F1789E762E" translateForJs="false">Opcjonalnie filtruj raport, aby uwzględniać tylko zdarzenia zabezpieczenia lub odblokowania.</TranslationEntry>
    <TranslationEntry name="1585BE984E307A6A0C463D990C64C761" fullContext="7B06F7E86E53DC0F47EFB4F1789E762E" translateForJs="false"> — Pokaż wszystkie zdarzenia Zablokowania/Odblokowania.</TranslationEntry>
    <TranslationEntry name="A34BB6ECEFFF2B815A6E71A971E72880" fullContext="7B06F7E86E53DC0F47EFB4F1789E762E" translateForJs="false"> - Pokaż tylko zdarzenia bezpieczne.</TranslationEntry>
    <TranslationEntry name="70F2151E1B83FAF2B5EB5433BEAA96A7" fullContext="7B06F7E86E53DC0F47EFB4F1789E762E" translateForJs="false"> — Pokaż tylko zdarzenia odblokowania.</TranslationEntry>
    <TranslationEntry name="E5505F00194E4BB9B9AFAF0D96CD0496" fullContext="D4DB8891EECBE1FFEA99117C0C432C82" translateForJs="false"> — Pokaż tylko pomyślne zdarzenia zabezpieczenia/odblokowania.</TranslationEntry>
    <TranslationEntry name="2625A3D12B027D21641DB2E46E49116F" fullContext="D4DB8891EECBE1FFEA99117C0C432C82" translateForJs="false"> - Pokazuj tylko nieudane zdarzenia zabezpieczenia/odblokowania.</TranslationEntry>
    <TranslationEntry name="31E0570430AC3C1AF1C9208897D68701" translateForJs="false">Uwzględnij zdarzenia wakatów</TranslationEntry>
    <TranslationEntry name="FF7A68A40E352802CC518B8B37AD0B11" fullContext="87121AA2E673AFD4996046F6D4692A74" translateForJs="false">Opcjonalnie uwzględnij zdarzenia wakatu.</TranslationEntry>
    <TranslationEntry name="1A6B92B4FF5026F3C2E90D0BDC277188" fullContext="87121AA2E673AFD4996046F6D4692A74" translateForJs="false">Zwolnienie wolnego miejsca</TranslationEntry>
    <TranslationEntry name="3B3239BCFF88622F5386A343DA55974A" fullContext="87121AA2E673AFD4996046F6D4692A74" translateForJs="false"> zdarzenia są sklasyfikowane jako </TranslationEntry>
    <TranslationEntry name="59F6465F5F72043A0EE1DCD5B0228D12" fullContext="87121AA2E673AFD4996046F6D4692A74" translateForJs="false"> zdarzenia. </TranslationEntry>
    <TranslationEntry name="44FB5E7D70F64A6D2686913B045162E0" fullContext="87121AA2E673AFD4996046F6D4692A74" translateForJs="false"> zdarzeń.</TranslationEntry>
    <TranslationEntry name="B8BC91B8FC816F7F41B3BE44E8936AD6" fullContext="300DA2F24F6B004361A0F5F04D2A4061" translateForJs="false">Czytniki wejściowe</TranslationEntry>
    <TranslationEntry name="DED5EECFB8C29CFEBF1A98ABE420E425" fullContext="EE6A8F36CC5A32E4E9314B60FC5921E1" translateForJs="false">Wybiera czytniki, które mają być używane jako czytniki odczytu wejścia w raporcie. Wymagany jest co najmniej jeden czytnik odczytu wejścia do wygenerowania raportu. Czytniki nie mogą znajdować się w </TranslationEntry>
    <TranslationEntry name="DE6E528B155F0A99FA34505FB23FF071" fullContext="300DA2F24F6B004361A0F5F04D2A4061" translateForJs="false"> listy, jeśli znajdują się również na </TranslationEntry>
    <TranslationEntry name="C8A632AEFF12DB0B91A6072C6D42E0D0" fullContext="300DA2F24F6B004361A0F5F04D2A4061" translateForJs="false">Czytniki wyjściowe</TranslationEntry>
    <TranslationEntry name="3C8F8D96FB322AB40D23558E9029B5C9" fullContext="B6765C9F8E52ACABA22386176CF380E0" translateForJs="false"> lista.</TranslationEntry>
    <TranslationEntry name="AC1A3A113057491B5F310512E210448B" fullContext="300DA2F24F6B004361A0F5F04D2A4061" translateForJs="false">Wybiera czytniki, które mają być używane jako czytniki odczytu wyjścia w raporcie. Wymagany jest co najmniej jeden czytnik odczytu wyjścia do wygenerowania raportu. Czytniki nie mogą znajdować się w </TranslationEntry>
    <TranslationEntry name="2FF9F085BF76338FE0AEE224DE6E7EFB" translateForJs="false">Filtruj do wybranych przejść</TranslationEntry>
    <TranslationEntry name="A933CD979FE4D2D3C4668B69A55ED11F" fullContext="B4EF4A781F8D68FCBE3C5733CD2FF45D" translateForJs="false">Opcjonalnie filtruj wyniki raportu, aby uwzględnić tylko wybrane przejścia. Domyślnie (gdy lista jest pusta) wszystkie przejścia są uwzględniane w raporcie.</TranslationEntry>
    <TranslationEntry name="72B84163085AACABD0FB8034FAFDFA89" translateForJs="false" rules="unique=APVEventFilter" notes="Must be unique amongst all &quot;APVEventFilter&quot; entries">Zarówno naruszenia, jak i anulowania</TranslationEntry>
    <TranslationEntry name="7D09934733827FA95E37122ACDCB821B" translateForJs="false" rules="unique=APVEventFilter" notes="Must be unique amongst all &quot;APVEventFilter&quot; entries">Tylko naruszenia</TranslationEntry>
    <TranslationEntry name="1D8CBD9AB2FBF9723F01E89E20CD3760" translateForJs="false" rules="unique=APVEventFilter" notes="Must be unique amongst all &quot;APVEventFilter&quot; entries">Tylko anulowania naruszeń</TranslationEntry>
    <TranslationEntry name="62D1AC53E227A3EE8CC3C67706D96331" translateForJs="false">Pokaż naruszenia/anulowania anti-passback</TranslationEntry>
    <TranslationEntry name="93FEE4FA643938EF75F803843A673E90" fullContext="F768F002379B61B1DB5982D781A482D9" translateForJs="false">Określa, czy uwzględniać tylko zdarzenia naruszeń, tylko zdarzenia anulowania naruszeń, czy oba typy (domyślnie wyświetlane są oba).</TranslationEntry>
    <TranslationEntry name="2F474C999FE3B98C77D3D9A8C1E962D6" translateForJs="false">Filtruj do określonych urządzeń</TranslationEntry>
    <TranslationEntry name="360A7FCC985DC048F91751F3908E66DA" fullContext="6310CA203A85355C3F22044EC758E8F1" translateForJs="false">Opcjonalnie ogranicz wyniki raportu tylko do wybranych Urządzeń zintegrowanych. Domyślnie (gdy lista jest pusta) w raporcie uwzględniane są zdarzenia ze wszystkich Urządzeń zintegrowanych.</TranslationEntry>
    <TranslationEntry name="1BF3EF47CDEDD2B9C534571DB54456E5" translateForJs="false" rules="unique=ReportingPacketType" notes="Must be unique amongst all &quot;ReportingPacketType&quot; entries">Otwarcie/zamknięcie strefy</TranslationEntry>
    <TranslationEntry name="8FE7F79C433CF90AECC61964F5FF2B30" translateForJs="false" rules="unique=ReportingPacketType" notes="Must be unique amongst all &quot;ReportingPacketType&quot; entries">Zdarzenie stanu linii wejściowej</TranslationEntry>
    <TranslationEntry name="09365F79B744CD3D5116DA0BFCE802A5" translateForJs="false" rules="unique=ReportingPacketType" notes="Must be unique amongst all &quot;ReportingPacketType&quot; entries">Raport testowy</TranslationEntry>
    <TranslationEntry name="4C9CDFA6CC6ADEA5325597BA8C13226D" translateForJs="false" rules="unique=ReportingPacketType" notes="Must be unique amongst all &quot;ReportingPacketType&quot; entries">Problem ze sprawnością modułu</TranslationEntry>
    <TranslationEntry name="86F409E7120C93A5F0AADB14A3AE3249" translateForJs="false" rules="unique=ReportingPacketType" notes="Must be unique amongst all &quot;ReportingPacketType&quot; entries">Awaria komunikacji</TranslationEntry>
    <TranslationEntry name="48FB3AD26BAFE1AD9308FC887CD84EC1" translateForJs="false" rules="unique=ReportingPacketType" notes="Must be unique amongst all &quot;ReportingPacketType&quot; entries">Technik na miejscu</TranslationEntry>
    <TranslationEntry name="4ED0E9FA323CFB1B6607B6AE0A8D62DA" translateForJs="false" rules="unique=ReportingPacketType" notes="Must be unique amongst all &quot;ReportingPacketType&quot; entries">Zdarzenie potwierdzenia</TranslationEntry>
    <TranslationEntry name="8EA0C9566BBF76F5D72BB6BB4551045B" translateForJs="false" rules="unique=ReportingDataPath" notes="Must be unique amongst all &quot;ReportingDataPath&quot; entries">Dowolna ścieżka</TranslationEntry>
    <TranslationEntry name="E43F5A4F7331F64B54472D1EB93DC830" translateForJs="false" rules="unique=ReportingDataPath" notes="Must be unique amongst all &quot;ReportingDataPath&quot; entries">SkyTunnel</TranslationEntry>
    <TranslationEntry name="F2A4A3323207BD0F3F9FFEF73AE8883C" translateForJs="false" rules="unique=ReportingDataPath" notes="Must be unique amongst all &quot;ReportingDataPath&quot; entries">SIA IP</TranslationEntry>
    <TranslationEntry name="E7A9C0596043730A9B3054513BF38187" fullContext="E7A9C0596043730A9B3054513BF38187" translateForJs="false" rules="unique=InputStateReportingType" notes="Must be unique amongst all &quot;InputStateReportingType&quot; entries">Izoluj</TranslationEntry>
    <TranslationEntry name="F4B37C01CA682DEAB6ECD69BF5E06FE5" translateForJs="false" rules="unique=InputStateReportingType" notes="Must be unique amongst all &quot;InputStateReportingType&quot; entries">Orient</TranslationEntry>
    <TranslationEntry name="69DE9F5478F1BC9048D4B3AF04986FAA" translateForJs="false" rules="unique=InputStateReportingType" notes="Must be unique amongst all &quot;InputStateReportingType&quot; entries">Potwierdzony intruz</TranslationEntry>
    <TranslationEntry name="6BFAB8EDEDEB0786763271A90A065D0F" translateForJs="false" rules="unique=InputStateReportingType" notes="Must be unique amongst all &quot;InputStateReportingType&quot; entries">Potwierdzony przymus</TranslationEntry>
    <TranslationEntry name="1C1D8E3C047AD2E7F36BCA65A619332B" translateForJs="false" rules="unique=SystemResetReason" notes="Must be unique amongst all &quot;SystemResetReason&quot; entries">Brak zasilania</TranslationEntry>
    <TranslationEntry name="D3AFB5F42A0D4C608898D9FFC8B1B602" translateForJs="false" rules="unique=SystemResetReason" notes="Must be unique amongst all &quot;SystemResetReason&quot; entries">Baza danych przywrócona</TranslationEntry>
    <TranslationEntry name="AE96B00D2AEF6724C4D6C85507516926" translateForJs="false" rules="unique=SystemResetReason" notes="Must be unique amongst all &quot;SystemResetReason&quot; entries">Resetowanie identyfikatorów instalatora</TranslationEntry>
