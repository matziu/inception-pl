    <TranslationEntry name="7E3208F96375206B78E040544F73B8FC" translateForJs="false">Aktualizacja raportu uruchomienia</TranslationEntry>
    <TranslationEntry name="BFEA0DF4686EBAE5EE9CB0757FCB5786" translateForJs="false">Aktualizacje raportu uruchomienia</TranslationEntry>
    <TranslationEntry name="BD5A074E2D6248710546BCB5C02D7472" fullContext="BD5A074E2D6248710546BCB5C02D7472" translateForJs="false">Zaplanowane zadanie</TranslationEntry>
    <TranslationEntry name="25F7347236B51A5EAE4BA01A7862CB55" fullContext="331B158352203C5E0CAEC312FDEA882B" translateForJs="false">Harmonogram</TranslationEntry>
    <TranslationEntry name="4867EDCE2EA4AF256792B967E77A52D5" fullContext="331B158352203C5E0CAEC312FDEA882B" translateForJs="false">Akcja do wykonania</TranslationEntry>
    <TranslationEntry name="D1A5E2A3ED353C39E1C3DAE82EE20B37" translateForJs="false">Sposób obsługi wyniku</TranslationEntry>
    <TranslationEntry name="FD69C5CF902969E6FB71D043085DDEE6" fullContext="331B158352203C5E0CAEC312FDEA882B" translateForJs="false">Wyniki</TranslationEntry>
    <TranslationEntry name="45BC912F5C6CDC9A2A48EC08B7158EA8" fullContext="45BC912F5C6CDC9A2A48EC08B7158EA8" translateForJs="true" rules="unique=ScheduledTaskResultType" notes="Must be unique amongst all &quot;ScheduledTaskResultType&quot; entries">Utwórz kopię zapasową bazy danych</TranslationEntry>
    <TranslationEntry name="B0C50459EA82E265FE68F6A12CE6DEBD" fullContext="B0C50459EA82E265FE68F6A12CE6DEBD" translateForJs="false" rules="unique=ScheduledTaskResultType" notes="Must be unique amongst all &quot;ScheduledTaskResultType&quot; entries">Utwórz raport</TranslationEntry>
    <TranslationEntry name="2315DDB187371B2CA67D3A775EF61931" fullContext="58BAE57280903CFA6523DFBF5E1B52F5" translateForJs="false">Określa rodzaj akcji, którą ma wykonać to zaplanowane zadanie podczas uruchamiania.</TranslationEntry>
    <TranslationEntry name="888ED0BFE3DA7E453954539C486B2E0C" fullContext="58BAE57280903CFA6523DFBF5E1B52F5" translateForJs="false"> — Tworzy plik kopii zapasowej bazy danych zawierający jej zawartość w momencie uruchomienia zaplanowanego zadania.</TranslationEntry>
    <TranslationEntry name="7B6B58C1C8370298F739CF3F28A44976" fullContext="58BAE57280903CFA6523DFBF5E1B52F5" translateForJs="false"> - Tworzy raport z podanymi parametrami. Umożliwia tworzenie dowolnego typu raportu, który można wygenerować ze strony Raporty.</TranslationEntry>
    <TranslationEntry name="70EBFF6F0C30B9EF71C5FDCF96AB4573" translateForJs="false">Konfiguracja raportu</TranslationEntry>
    <TranslationEntry name="AE83EA9C6AAEAB175DE8FE6C13D67B3F" fullContext="331B158352203C5E0CAEC312FDEA882B" translateForJs="false" rules="unique=ScheduledTaskSendPathType" notes="Must be unique amongst all &quot;ScheduledTaskSendPathType&quot; entries">Wyślij jako załącznik e-mail</TranslationEntry>
    <TranslationEntry name="30B649D441CDEA9F6579E961ED38F07F" fullContext="331B158352203C5E0CAEC312FDEA882B" translateForJs="false" rules="unique=ScheduledTaskSendPathType" notes="Must be unique amongst all &quot;ScheduledTaskSendPathType&quot; entries">Kopiuj na podłączony dysk USB</TranslationEntry>
    <TranslationEntry name="EB02293C7E9916FA7EFD5411CD4C1993" fullContext="331B158352203C5E0CAEC312FDEA882B" translateForJs="false" rules="unique=ScheduledTaskSendPathType" notes="Must be unique amongst all &quot;ScheduledTaskSendPathType&quot; entries">Kopiuj do folderu sieciowego</TranslationEntry>
    <TranslationEntry name="30924764C6A981C0E38BBA40E4227ABB" fullContext="470B67B8ABFF10F5CDA04A3C2C29F045" translateForJs="false">Określa sposób, w jaki zaplanowane zadanie powinno wysyłać wynikowy plik wyjściowy po jego wyprodukowaniu.</TranslationEntry>
    <TranslationEntry name="AB7917FFC0F487E144C0943FCA8A9859" fullContext="470B67B8ABFF10F5CDA04A3C2C29F045" translateForJs="false"> — wyślij plik wyjściowy do jednego lub więcej Użytkowników na ich adres e-mail.</TranslationEntry>
    <TranslationEntry name="CF78E601337EED229C982C478DA85081" fullContext="470B67B8ABFF10F5CDA04A3C2C29F045" translateForJs="false"> — zapisuje plik wyjściowy w folderze głównym podłączonego dysku USB, jeśli jest aktualnie podłączony do urządzenia Inception i dostępny.</TranslationEntry>
    <TranslationEntry name="C41FDA1F74C55723381FBC592E7C7BAB" fullContext="470B67B8ABFF10F5CDA04A3C2C29F045" translateForJs="false"> — kopiuje plik wyjściowy do folderu sieciowego Samba przy użyciu podanych danych uwierzytelniających użytkownika/domeny.</TranslationEntry>
    <TranslationEntry name="ED08A63228E88E3E02874074F702D3E7" translateForJs="false">Użytkownicy do powiadomienia e-mail</TranslationEntry>
    <TranslationEntry name="A4CDEC3BFA831A7B341BA2B32891BE50" fullContext="A8C94F568850ADD31386EC65641BC1D5" translateForJs="false">Określa listę użytkowników, do których ma zostać wysłany plik wynikowy pocztą e-mail. Jeśli żaden użytkownik nie jest określony lub wszyscy określeni użytkownicy mają nieprawidłowy lub brakujący adres e-mail, zadanie nie wyśle pliku wynikowego.</TranslationEntry>
    <TranslationEntry name="E93EC72467853A8EB3FBCC41996FF24F" translateForJs="false">Ścieżka folderu sieciowego</TranslationEntry>
    <TranslationEntry name="3A0447A4390ADBD3ADF77F7B0AFB0B07" fullContext="2A6BBA10FB734DDB53F333EC935143FE" translateForJs="false">Określa udostępniony folder sieciowy, do którego ma zostać skopiowany plik wynikowy, np.: </TranslationEntry>
    <TranslationEntry name="E48809A2BFAF1C6A6E74EBA52F19043F" fullContext="2A6BBA10FB734DDB53F333EC935143FE" translateForJs="false">//example-server/shared</TranslationEntry>
    <TranslationEntry name="0E4C624434DE425A5663F470777874A7" fullContext="2A6BBA10FB734DDB53F333EC935143FE" translateForJs="false">UWAGA: Folder wskazany w ścieżce sieciowej musi już istnieć, aby operacja zakończyła się pomyślnie.</TranslationEntry>
    <TranslationEntry name="7789C3D5DACFC40B83E7F8DD3E2BA91D" fullContext="6CE15EA91C0D88BC7E884ADE05FDFA43" translateForJs="false">Określa nazwę użytkownika do uwierzytelniania sieciowego/domenowego. W przypadku sieci domenowej może być konieczne podanie domeny przed znakiem /, np. </TranslationEntry>
    <TranslationEntry name="C2DC111A52ACC35B2E12EBA4EFB16FB9" fullContext="5A3AE0BC898A75AC3BAF3250CE4D9222" translateForJs="false">domena/nazwa_użytkownika</TranslationEntry>
    <TranslationEntry name="4AA6B51747D2A840D21C336B1C1C8FC8" fullContext="678D0E5FA6385C2C2BA1454073E181FA" translateForJs="false">Określa hasło użytkownika do uwierzytelniania sieciowego/domenowego.</TranslationEntry>
    <TranslationEntry name="9B6545E4CEA9B4AD4979D41BB9170E2B" fullContext="9B6545E4CEA9B4AD4979D41BB9170E2B" translateForJs="false" rules="unique=ScheduledTaskRecurringTimeType" notes="Must be unique amongst all &quot;ScheduledTaskRecurringTimeType&quot; entries">Zaawansowany</TranslationEntry>
    <TranslationEntry name="90B406E0799281DA9FD535257678F5D8" translateForJs="false">Częstotliwość harmonogramu</TranslationEntry>
    <TranslationEntry name="3FE806306EFD2C914D071CC68F91E647" fullContext="2A381FBB8036EEF51F068C978B6F18B9" translateForJs="false">Określa, jak często to zaplanowane zadanie powinno być automatycznie uruchamiane.</TranslationEntry>
    <TranslationEntry name="21F34C286303DDE0E05D94DF2D082D4B" fullContext="2A381FBB8036EEF51F068C978B6F18B9" translateForJs="false"> - To zadanie nie będzie uruchamiane w regularnych odstępach czasu. Użyj tej opcji, jeśli planujesz wykonywać to zadanie ręcznie lub tylko w określonych warunkach, np. wyzwalając je jako część akcji automatycznej.</TranslationEntry>
    <TranslationEntry name="88CF1103978C461170E051244D2B2E5E" fullContext="2A381FBB8036EEF51F068C978B6F18B9" translateForJs="false"> — To zadanie będzie wykonywane w ustalonych równomiernych odstępach czasu, np. codziennie, co tydzień, co miesiąc, o określonej porze dnia.</TranslationEntry>
    <TranslationEntry name="DD51264869329CAA5E3D7865F8002074" fullContext="2A381FBB8036EEF51F068C978B6F18B9" translateForJs="false"> - Wykorzystuje elementy kalendarza w systemie Inception (skonfigurowane przez </TranslationEntry>
    <TranslationEntry name="78BBC4742A477D95F9DADE8B2E95B26C" fullContext="331B158352203C5E0CAEC312FDEA882B" translateForJs="false">[Konfiguracja &gt; Harmonogramowanie &gt; Kalendarze]</TranslationEntry>
    <TranslationEntry name="60185D6DF18CAAA2C12659B1A0C3667F" fullContext="2A381FBB8036EEF51F068C978B6F18B9" translateForJs="false"> strona). To zadanie będzie uruchamiane w zestawie dni określonych przez oddzielny element Kalendarza, o określonej porze dnia. Można określić wiele kombinacji Kalendarza/Pory dnia, aby zadanie uruchamiało się w dodatkowych godzinach.</TranslationEntry>
    <TranslationEntry name="E224F738EC974CC8917D8A4C79C8F1BE" fullContext="E4600329EAEDE4D6856743C3FD0A377F" translateForJs="false" rules="unique=ScheduledTaskBasicFrequency" notes="Must be unique amongst all &quot;ScheduledTaskBasicFrequency&quot; entries">Co tydzień</TranslationEntry>
    <TranslationEntry name="8C4FB2DBE62C8C19F1B5879922810AE0" fullContext="E4600329EAEDE4D6856743C3FD0A377F" translateForJs="false" rules="unique=ScheduledTaskBasicFrequency" notes="Must be unique amongst all &quot;ScheduledTaskBasicFrequency&quot; entries">Co 2 tygodnie</TranslationEntry>
    <TranslationEntry name="FED1AD05CCC1DF002601B591C62D0ABC" fullContext="E4600329EAEDE4D6856743C3FD0A377F" translateForJs="false" rules="unique=ScheduledTaskBasicFrequency" notes="Must be unique amongst all &quot;ScheduledTaskBasicFrequency&quot; entries">Co 4 tygodnie</TranslationEntry>
    <TranslationEntry name="7CF395303CE3665A9834721D4B748E4B" translateForJs="false">Częstotliwość</TranslationEntry>
    <TranslationEntry name="BD825CED97B67B55C16F311C5C0396A6" fullContext="E4600329EAEDE4D6856743C3FD0A377F" translateForJs="false">Określa interwał wyznaczający czas oczekiwania między kolejnymi wykonaniami zadania.</TranslationEntry>
    <TranslationEntry name="772FCE4B90B0EA77CF0727ABC8B10F9A" fullContext="E4600329EAEDE4D6856743C3FD0A377F" translateForJs="false"> - Zadanie będzie wykonywane codziennie o określonej </TranslationEntry>
    <TranslationEntry name="69AC429AAB4A0E0C893B407F0CCD24A9" fullContext="E4600329EAEDE4D6856743C3FD0A377F" translateForJs="false">Godzina</TranslationEntry>
    <TranslationEntry name="C799EFF6D1EDFAD93803A79A30110FC3" fullContext="E4600329EAEDE4D6856743C3FD0A377F" translateForJs="false"> - Zadanie będzie uruchamiane co tydzień w określony </TranslationEntry>
    <TranslationEntry name="BA4A99F240F39130A863CA8823DA3AC7" fullContext="E4600329EAEDE4D6856743C3FD0A377F" translateForJs="false">Dzień tygodnia</TranslationEntry>
    <TranslationEntry name="1241B1FF7590132915EBB3FDEC85F1D9" fullContext="E4600329EAEDE4D6856743C3FD0A377F" translateForJs="false">, o określonym </TranslationEntry>
    <TranslationEntry name="F53B93A99E019ED1608EE767616A20AB" fullContext="E4600329EAEDE4D6856743C3FD0A377F" translateForJs="false"> - Zadanie będzie wykonywane co 2 tygodnie w określonym </TranslationEntry>
    <TranslationEntry name="2A2E6AF1E26B98C72016BEBEEC63C1D2" fullContext="E4600329EAEDE4D6856743C3FD0A377F" translateForJs="false">, rozpoczynając od najbliższego przyszłego odpowiedniego dnia/godziny w momencie zapisania elementu zaplanowanego zadania.</TranslationEntry>
    <TranslationEntry name="1699C13595670B7083A51F60A532F7F0" fullContext="E4600329EAEDE4D6856743C3FD0A377F" translateForJs="false"> - Zadanie będzie wykonywane co 4 tygodnie w określonym </TranslationEntry>
    <TranslationEntry name="355584BEEF73685611FE43E1529E776F" fullContext="9CFCA61AE295D079599775525EA5106D" translateForJs="false">Określa dzień tygodnia, w którym to zadanie powinno być uruchamiane, zgodnie z pozostałymi ustawieniami konfiguracji harmonogramu.</TranslationEntry>
    <TranslationEntry name="6034387AC1CA4A749742A997725503E0" fullContext="9CFCA61AE295D079599775525EA5106D" translateForJs="false">Nie dotyczy, jeśli </TranslationEntry>
    <TranslationEntry name="79AA53B3626C7E5ADE940752F8AA7CAE" fullContext="9CFCA61AE295D079599775525EA5106D" translateForJs="false"> jest wybrana jako częstotliwość.</TranslationEntry>
    <TranslationEntry name="F2CDFD1CB859B72DD0E4F36276D47AB4" fullContext="2AC61D80F040D9D5B13F6C5DF007DD7D" translateForJs="false">Określa porę dnia, o której to zadanie powinno być uruchamiane, zgodnie z pozostałymi ustawieniami konfiguracji harmonogramu.</TranslationEntry>
    <TranslationEntry name="9FAD5708B8784597E92DC72AA1D63A34" translateForJs="false">Godziny kalendarza</TranslationEntry>
    <TranslationEntry name="AC729C36D2AD7194F68B66F18BE44383" fullContext="E26946D6A96E875A52FA52CD89F14D41" translateForJs="false">Określa elementy Kalendarza i godziny, o których zaplanowane zadanie powinno być uruchamiane. Zaplanowane zadanie będzie uruchamiane o określonej godzinie, w dniach wyznaczonych przez kalendarz.</TranslationEntry>
    <TranslationEntry name="9B36C39F6C4136D10D976D6AB65CEDB6" fullContext="E26946D6A96E875A52FA52CD89F14D41" translateForJs="false">Każdy wiersz definiuje inny wpis harmonogramu. Na przykład można zdefiniować 2 elementy Kalendarza reprezentujące odpowiednio Weekendy i Święta publiczne, ustawiając zadanie na uruchamianie o 14:00 w weekendy i 17:00 w święta — zadanie będzie uruchamiane każdego dnia, w którym którykolwiek z odpowiednich Kalendarzy jest aktywny, o odpowiednio zaplanowanej godzinie.</TranslationEntry>
    <TranslationEntry name="BF602C11184170547D78F08E46410EE4" translateForJs="false">Porty szeregowe</TranslationEntry>
    <TranslationEntry name="396F5943922AF37A2EB76D67DDB3D76B" translateForJs="false" rules="paramCheck=true" notes="This string contains special formatting parameters (e.g. &quot;{0}&quot;) that must be preserved in the translation">Port szeregowy {0}</TranslationEntry>
    <TranslationEntry name="0253AF77EBD8CC95CAF699598E47B50E" translateForJs="false">Odłączony</TranslationEntry>
    <TranslationEntry name="FF03B044D240715F8C9D483E62CD70F7" translateForJs="false">W użyciu przez </TranslationEntry>
    <TranslationEntry name="CA0E0A81C546AC7D2B002C92B4EF2CA9" translateForJs="false">Nieużywane</TranslationEntry>
    <TranslationEntry name="A7641CBCB492243DB39B77E187A23234" fullContext="3BFAE1DF6C6C81F4DF88ADD5FF3622F0" translateForJs="false">Czytniki wejściowe</TranslationEntry>
    <TranslationEntry name="ED17C4A9E602D1AF93FB8F69D372C5C6" fullContext="1F07D902EB17A577393A019D914C442E" translateForJs="false">Określa czytniki, które mogą sterować punktami wejścia do tego bloku magazynowego, umożliwiając użytkownikowi prezentację PIN, karty lub innego identyfikatora. W razie potrzeby do tego samego bloku magazynowego można przypisać wiele czytników, co umożliwia montaż czytników w różnych lokalizacjach lub różnych typów.</TranslationEntry>
    <TranslationEntry name="7DE1CD702285B68CF4DF7AA6D6A4C625" fullContext="1F07D902EB17A577393A019D914C442E" translateForJs="false">Wybrane czytniki mogą być również podłączone do innych elementów, takich jak przejścia lub bramki, co umożliwia jednoczesne sterowanie jednostkami w bloku magazynowym przy żądaniu dostępu użytkownika do bramki wejściowej lub budynku.</TranslationEntry>
    <TranslationEntry name="1A06E6F6D20EF80429970EF3AFBF4376" fullContext="1F07D902EB17A577393A019D914C442E" translateForJs="false">Po pomyślnym odczycie identyfikatora użytkownika system odblokuje wszystkie jednostki w bloku, do których użytkownik ma </TranslationEntry>
    <TranslationEntry name="E322E26842D84D8B8AE6313776296048" fullContext="E322E26842D84D8B8AE6313776296048" translateForJs="false">Sterowanie dostępem do bloku</TranslationEntry>
    <TranslationEntry name="10E01768184F40B972D6EFCFFCDC3EDF" fullContext="1F07D902EB17A577393A019D914C442E" translateForJs="false"> uprawnienia do. Umożliwia to automatyczne odblokowanie jednostki (boksu) użytkownika po jego wejściu na teren obiektu.</TranslationEntry>
    <TranslationEntry name="2DE49768DF38B1601B7FD32C05FCFA15" fullContext="524FBD0FAC791491009CB7E73E79D00D" translateForJs="false">Aby dodać czytnik do bloku jednostek, kliknij </TranslationEntry>
    <TranslationEntry name="A5F0A18CB51F997CC08131529834DF39" fullContext="3BFAE1DF6C6C81F4DF88ADD5FF3622F0" translateForJs="false">Czytniki wyjściowe</TranslationEntry>
    <TranslationEntry name="1E27733714E8F4DC642D28413FF4098C" fullContext="524FBD0FAC791491009CB7E73E79D00D" translateForJs="false">Określa czytniki kontrolujące punkty wyjścia z tego bloku magazynowego, przy których użytkownik może podać PIN, przyłożyć kartę lub użyć innego identyfikatora. Do tego samego bloku magazynowego można przypisać wiele czytników, co pozwala na montaż czytników w różnych lokalizacjach lub zastosowanie różnych typów czytników.</TranslationEntry>
    <TranslationEntry name="C3BE1983C77FC12C0C45878F82B64269" fullContext="524FBD0FAC791491009CB7E73E79D00D" translateForJs="false">Wybrane czytniki mogą być również podłączone do innych elementów, takich jak przejścia lub bramki, co umożliwia jednoczesne sterowanie jednostkami w bloku magazynowym przy żądaniu dostępu użytkownika do bramki wyjściowej lub wyjścia z budynku.</TranslationEntry>
    <TranslationEntry name="DBFB28A8E3E950DE2984D799DF03DFDC" fullContext="524FBD0FAC791491009CB7E73E79D00D" translateForJs="false">Po pomyślnym odczycie identyfikatora użytkownika system zabezpieczy wszystkie jednostki w bloku, do których użytkownik posiada </TranslationEntry>
    <TranslationEntry name="2EBC348C1D2FDD7601F62E5F4C043545" fullContext="524FBD0FAC791491009CB7E73E79D00D" translateForJs="false"> uprawnienia do. Umożliwia to automatyczne zabezpieczenie jednostki (boksu) użytkownika podczas opuszczania budynku lub obiektu po użyciu przycisku wyjścia.</TranslationEntry>
    <TranslationEntry name="EFD3D4D97B4AC80780082D68E503392E" fullContext="3BFAE1DF6C6C81F4DF88ADD5FF3622F0" translateForJs="false">Blokuj linie wyjściowe</TranslationEntry>
    <TranslationEntry name="A0470C9232702FFB6D4FB97FC2175E63" fullContext="054525A803E8C130C8A61C7B2FFC2ABB" translateForJs="false">Umożliwia powiązanie jednej lub więcej linii wyjściowych z tym blokiem jednostek (boksów). Jeśli którakolwiek z jednostek w bloku jest odblokowana, zabezpieczona lub w stanie alarmu, linie wyjściowe na tej liście będą działać zgodnie z zachowaniem linii wyjściowej. Jeśli zachowanie linii wyjściowej to oświetlenie, linia wyjściowa zostanie włączona, gdy jednostka jest odblokowana. Jeśli zachowanie linii wyjściowej to wskaźnik stanu zabezpieczenia, linia wyjściowa zostanie włączona, gdy jednostka jest zabezpieczona. Jeśli zachowanie linii wyjściowej to wskaźnik alarmu, linia wyjściowa zostanie włączona, gdy jednostka jest w stanie alarmu.</TranslationEntry>
    <TranslationEntry name="B09354E6DA1A7303259FB2B7498BDB0A" fullContext="054525A803E8C130C8A61C7B2FFC2ABB" translateForJs="false">Na przykład, linie wyjściowe mogą być używane do sterowania oświetleniem, wskaźnikiem stanu bezpiecznego i wskaźnikiem alarmu w określonej sekcji budynku — włączając się, gdy którakolwiek jednostka w tej sekcji jest odblokowana, zabezpieczona lub w stanie alarmu.</TranslationEntry>
    <TranslationEntry name="9C2443C9CB8A8AD3DFA123086B405C71" fullContext="054525A803E8C130C8A61C7B2FFC2ABB" translateForJs="false">Aby dodać linie wyjściowe do bloku jednostek (boksów), kliknij </TranslationEntry>
    <TranslationEntry name="62852397156B0EF58C6671C1E02EA219" fullContext="69856929F2617ED37B376A6385AA13B5" translateForJs="false"> przycisk — otworzy się okno, w którym możesz wybrać linie wyjściowe do dodania. Jeśli w tym oknie nie ma żadnych linii wyjściowych, nowe można skonfigurować, przechodząc do </TranslationEntry>
    <TranslationEntry name="6A24832A0DC69727D96167219BA4A43C" translateForJs="false">Opóźnienie wyłączenia linii wyjściowej</TranslationEntry>
    <TranslationEntry name="EE5C2FC4E93F4A98D567DF8CDC7682DA" fullContext="D6E0A650AB192D51B2511CC35FD37D32" translateForJs="false">Opcjonalnie określa opóźnienie przed </TranslationEntry>
    <TranslationEntry name="3710D4AA1CE376539BF851C477638E71" fullContext="D6E0A650AB192D51B2511CC35FD37D32" translateForJs="false"> są wyłączone. Gdy ustawiono </TranslationEntry>
    <TranslationEntry name="963B1BCC225E90A7B24B30E20BF20258" fullContext="D6E0A650AB192D51B2511CC35FD37D32" translateForJs="false">, te linie wyjściowe zostaną natychmiast wyłączone. Gdy ustawiona jest dowolna inna wartość, linie wyjściowe będą czekać określony czas przed wyłączeniem.</TranslationEntry>
    <TranslationEntry name="F058254E6648882695676301AB87B743" fullContext="D6E0A650AB192D51B2511CC35FD37D32" translateForJs="false">Jest to przydatne w scenariuszach, gdy ostatnia jednostka (boks) została zabezpieczona na klawiaturze wewnątrz obiektu i potrzeba trochę czasu przed wyłączeniem wewnętrznych świateł.</TranslationEntry>
    <TranslationEntry name="2FC0162AFCCB243DD17C7B9C4872CBE9" translateForJs="false">Blokuj jednostki</TranslationEntry>
    <TranslationEntry name="E356E0581F71A4C7DD9E9C3173968897" fullContext="3BFAE1DF6C6C81F4DF88ADD5FF3622F0" translateForJs="false">Czas automatycznego ponownego zabezpieczenia jednostki</TranslationEntry>
    <TranslationEntry name="78D6E1DCF33BF18ECA8825883203453E" fullContext="0D7F64E7D6AC018B36BAC40DD5ADCAD3" translateForJs="false">Jeśli skonfigurowano, jednostki (boksy) w tym bloku magazynowym będą automatycznie ponownie zabezpieczane po upływie określonego czasu. </TranslationEntry>
    <TranslationEntry name="A42057AA8EA4D6033D9C198786C9FAC8" fullContext="0D7F64E7D6AC018B36BAC40DD5ADCAD3" translateForJs="false">Pomaga to zapewnić, że jednostka automatycznie ponownie się zabezpieczy po pewnym czasie i nie pozostanie w stanie odblokowanym.</TranslationEntry>
    <TranslationEntry name="E502C7FC05B454755C6A477807058659" fullContext="0D7F64E7D6AC018B36BAC40DD5ADCAD3" translateForJs="false">Ponieważ ta opcja wymaga znajomości stanu drzwi jednostki (boksu), jednostka musi mieć co najmniej jedną linię wejściową z </TranslationEntry>
    <TranslationEntry name="D06263308C256251EC14D975A36E0619" fullContext="D55D5C30072BF1966DD101E654CA737F" translateForJs="false" rules="unique=UnitInputType" notes="Must be unique amongst all &quot;UnitInputType&quot; entries">Czujnik otwarcia drzwi</TranslationEntry>
    <TranslationEntry name="C5EAB28261C57638C1192E9FD4A4B393" fullContext="0D7F64E7D6AC018B36BAC40DD5ADCAD3" translateForJs="false"> zachowanie.</TranslationEntry>
    <TranslationEntry name="68C51B2D0AE5ECF9138A918D11822376" fullContext="6F0D349EE2370B90F0EE144944C0DD22" translateForJs="false"> zostanie wybrany, logika ponownego zabezpieczenia nie zostanie uruchomiona.</TranslationEntry>
    <TranslationEntry name="31318FC279D261C29E5788B956558404" fullContext="6F0D349EE2370B90F0EE144944C0DD22" translateForJs="false">Jeśli jednostka (boks) jest częścią więcej niż jednego bloku, najkrótszy czas, który nie jest </TranslationEntry>
    <TranslationEntry name="DD9419AB5091BEB285DFAAF9AE24A27E" fullContext="6F0D349EE2370B90F0EE144944C0DD22" translateForJs="false"> jest wybrane dla tej jednostki.</TranslationEntry>
    <TranslationEntry name="D240379EDB7D5C0837881166BF98F4A5" translateForJs="false">Wyzwolenie timera automatycznego zabezpieczenia</TranslationEntry>
    <TranslationEntry name="8901A2C0F9EAAFF0AA31ED6ADCF17A2D" fullContext="6F0D349EE2370B90F0EE144944C0DD22" translateForJs="false">Jeśli skonfigurowano, jednostki w tym bloku pamięci masowej wejdą w stan </TranslationEntry>
    <TranslationEntry name="31CAB84D4B0A9E7113EC0E244BBB85F6" fullContext="6F0D349EE2370B90F0EE144944C0DD22" translateForJs="false"> stan, jeśli jednostka (boks) pozostaje odblokowana przez określony czas. Ten stan jest anulowany po zabezpieczeniu jednostki lub oznaczeniu jej jako wolnej.</TranslationEntry>
    <TranslationEntry name="C9B3AE2714D251643EA04E3BE3F94E2D" fullContext="6F0D349EE2370B90F0EE144944C0DD22" translateForJs="false">Pomaga to ustalić, czy jednostka (boks) została przypadkowo pozostawiona odblokowana przez dłuższy czas. Pomaga również ustalić, czy użytkownicy celowo odblokowują i pozostają w jednostce.</TranslationEntry>
    <TranslationEntry name="703A6EE6A67BD15B61B506890170C011" translateForJs="false">Wymuś zabezpieczenie jednostek z aktywnymi liniami wejściowymi</TranslationEntry>
    <TranslationEntry name="315C75185BA36EA2FB423A761ECEAE93" translateForJs="false">Akcja kasowania wolnego miejsca przy aktywnych liniach wejściowych</TranslationEntry>
    <TranslationEntry name="94EE279525CE7EADEFA96F5902D8E644" translateForJs="false">Wyczyść wakat przy poprawnym odczycie karty</TranslationEntry>
    <TranslationEntry name="D483FB832B009791251F74B131F104AB" fullContext="17938230C868F1836F9EFD0D87CE5F70" translateForJs="false">To ustawienie określa reakcję na zaplombowanie wszystkich linii wejściowych jednostki (boksu) znajdującej się w stanie alarmu. </TranslationEntry>
    <TranslationEntry name="AE21971A738EA240159CB58093D7CC76" fullContext="17938230C868F1836F9EFD0D87CE5F70" translateForJs="false">Pozostawiając tę opcję wyłączoną, jednostka (boks) pozostanie w stanie Alarmu do czasu, gdy </TranslationEntry>
    <TranslationEntry name="4BEFD48D8A36493A1063F0A475CE8B44" fullContext="17938230C868F1836F9EFD0D87CE5F70" translateForJs="false"> akcja wystąpi dla jednostki, zatrzaskując stan alarmu. Skasowanie alarmu może nastąpić przez przyłożenie identyfikatora przez lokatora jednostki do czytnika wejściowego bloku w celu jej odblokowania, lub przez sterowanie jednostką przez użytkownika za pośrednictwem strony </TranslationEntry>
    <TranslationEntry name="2818D4D1F2E08C55C96477860A300857" fullContext="17938230C868F1836F9EFD0D87CE5F70" translateForJs="false">[Stan / Sterowanie &gt; Steruj jednostkami (boksami)]</TranslationEntry>
    <TranslationEntry name="3DB151A35D0939F369B00152EBAE3FFB" fullContext="17938230C868F1836F9EFD0D87CE5F70" translateForJs="false"> strona w interfejsie internetowym Inception. Umożliwia to użytkownikom łatwe zidentyfikowanie, która jednostka wyzwoliła alarm, a stacje monitorowania mogą wiedzieć, kiedy zdarzenie alarmowe zostało faktycznie przywrócone.</TranslationEntry>
    <TranslationEntry name="284970FC0A6DE23ABD4F16A5A7BB1A34" fullContext="17938230C868F1836F9EFD0D87CE5F70" translateForJs="false">Jeśli ta opcja jest włączona, stan alarmu jednostki zostanie wyczyszczony, gdy tylko wszystkie linie wejściowe w bezpiecznej jednostce zostaną uszczelnione lub gdy jednostka zostanie odblokowana. Pozwala to stanowi alarmu jednostki śledzić stan jej linii wejściowych, ale ma tę konsekwencję, że jeśli jednostka ma tylko czujnik drzwi, ktoś mógłby otworzyć drzwi bezpiecznej jednostki, wejść, a następnie natychmiast je zamknąć, i jednostka nie byłaby już w stanie alarmu.</TranslationEntry>
    <TranslationEntry name="045B4738E0D729021C5056305EFB46F4" fullContext="17938230C868F1836F9EFD0D87CE5F70" translateForJs="false">W przypadku niezamieszkałych obiektów z jednostkami (boksami), zaleca się wyłączenie tej opcji oraz skonfigurowanie strefy monitorującej stany alarmowe jednostek z opcją </TranslationEntry>
    <TranslationEntry name="2C4EDC61A93FF53F9A45564E6A911ACF" fullContext="17938230C868F1836F9EFD0D87CE5F70" translateForJs="false">Skasuj alarm gdy wszystkie linie wejściowe bezpieczne</TranslationEntry>
    <TranslationEntry name="9F7FC261A4D6C72A7A1FFB718E135F52" fullContext="17938230C868F1836F9EFD0D87CE5F70" translateForJs="false"> opcja włączona. Umożliwi to uruchomienie sygnalizatorów i alarmów w przypadku dostępu do zabezpieczonej jednostki (boksu), ale jeśli był to przypadek, najemca jednostki może ją odblokować i alarm może zostać anulowany. </TranslationEntry>
    <TranslationEntry name="98C67589410560997CAE58CC54F268DC" translateForJs="false">Włącz linie wyjściowe oświetlenia gdy jednostka jest wolna</TranslationEntry>
    <TranslationEntry name="90BDD668E1182C3075825BC20F8F6680" fullContext="90BDD668E1182C3075825BC20F8F6680" translateForJs="false">Linie wyjściowe z zachowaniem Oświetlenie zostaną włączone, gdy jednostka (boks) jest wolna, jeśli opcja Włącz linie wyjściowe oświetlenia gdy jednostka jest wolna jest aktywna</TranslationEntry>
    <TranslationEntry name="BC288AD00AB28252F12DBD5A2BF8CB8E" fullContext="2A41CBCD74D25C3E2FC26FBC7F5A2C6F" translateForJs="false">Umożliwia wybór jednostek (boksów) należących do tego bloku. Żądania dostępu przy </TranslationEntry>
    <TranslationEntry name="F5BB233D9DD7365691D001B7E5354BBD" fullContext="2A41CBCD74D25C3E2FC26FBC7F5A2C6F" translateForJs="false"> określony powyżej może automatycznie odblokować jednostki z tej listy, a </TranslationEntry>
    <TranslationEntry name="F8007C5AF0B58F9D975AAD2B1A9AA36A" fullContext="2A41CBCD74D25C3E2FC26FBC7F5A2C6F" translateForJs="false"> będzie sterowana na podstawie stanów jednostek (boksów).</TranslationEntry>
    <TranslationEntry name="719D4B68A324B38C347187462C24B652" fullContext="2A41CBCD74D25C3E2FC26FBC7F5A2C6F" translateForJs="false">Stan tych jednostek jest podsumowany dla tego bloku, wskazując, czy wszystkie jednostki są zabezpieczone, czy któraś jest odblokowana, odblokowana zbyt długo, w alarmie lub została naruszona sabotażem.</TranslationEntry>
    <TranslationEntry name="02DC34CE1B973A2948CC64E8952D9014" fullContext="2A41CBCD74D25C3E2FC26FBC7F5A2C6F" translateForJs="false">Aby dodać jednostkę do bloku przechowywania, kliknij </TranslationEntry>
    <TranslationEntry name="2C93E7EDA528FE8EAA16E2124BBB4AA1" fullContext="2A41CBCD74D25C3E2FC26FBC7F5A2C6F" translateForJs="false"> przycisk spowoduje otwarcie okna, w którym można wybrać jednostki do dodania. Jeśli w tym oknie nie ma żadnych jednostek, nowe jednostki można skonfigurować, przechodząc do </TranslationEntry>
    <TranslationEntry name="F70D6DB7528E39148DC8DE4AB352AF0A" fullContext="47FC05850EF7C1CD89468FC8A6908112" translateForJs="false">[Konfiguracja &gt; Kontrola dostępu &gt; Jednostka magazynowa &gt; Jednostki magazynowe]</TranslationEntry>
    <TranslationEntry name="C8D39D4DC530B3B0B84415B88356F56D" translateForJs="false">Linie wejściowe jednostki</TranslationEntry>
    <TranslationEntry name="B3B57824D08906AB2DA5F0E77634E5A9" fullContext="D55D5C30072BF1966DD101E654CA737F" translateForJs="false">Określa linie wejściowe używane do monitorowania tej jednostki. Dla każdej linii wejściowej można określić Zachowanie, które decyduje o tym, jak stan tej linii wejściowej wpływa na jednostkę.</TranslationEntry>
    <TranslationEntry name="BD15F678B79509CF0A97D77F77AC4A06" fullContext="D55D5C30072BF1966DD101E654CA737F" translateForJs="false"> - Linia wejściowa o tym zachowaniu informuje system, czy drzwi jednostki (boksu) są aktualnie otwarte czy zamknięte. Ponadto, jeśli jednostka jest zabezpieczona, aktywacja tej linii wejściowej spowoduje przejście jednostki w stan alarmu.</TranslationEntry>
    <TranslationEntry name="903C5E6F63040342F015C504044C8D30" fullContext="D55D5C30072BF1966DD101E654CA737F" translateForJs="false"> - Linia wejściowa o tym zachowaniu spowoduje przejście jednostki (boksu) w stan alarmu po aktywacji</TranslationEntry>
    <TranslationEntry name="9E6E922DF020C92FD6B31306B4F4DCEB" fullContext="D55D5C30072BF1966DD101E654CA737F" translateForJs="false">Jeśli linia wejściowa zostanie naruszona sabotażem, jednostka przejdzie w stan sabotażu.</TranslationEntry>
    <TranslationEntry name="C25099108603D072F42F4DEC8DDA77B1" fullContext="D55D5C30072BF1966DD101E654CA737F" translateForJs="false">Aby dodać linie wejściowe do jednostki, kliknij </TranslationEntry>
    <TranslationEntry name="CBAECCF7A25D94E6DAD4DE788574F1B1" fullContext="D55D5C30072BF1966DD101E654CA737F" translateForJs="false"> przycisk, co spowoduje otwarcie okna, w którym można wybrać linie wejściowe do dodania. Jeśli w tym oknie nie ma żadnych linii wejściowych, nowe linie wejściowe można skonfigurować, przechodząc do </TranslationEntry>
    <TranslationEntry name="FF604AB9C77A03184D6C3AF8AC31BD9A" fullContext="C10D0AB41101ADDCE07EC3E3C419EBD3" translateForJs="false">Linie wyjściowe jednostki (boksu)</TranslationEntry>
    <TranslationEntry name="98FF6BE0BA523EFC15C681D88CD53831" fullContext="69856929F2617ED37B376A6385AA13B5" translateForJs="false">Umożliwia skojarzenie jednej lub więcej linii wyjściowych z tą jednostką. Jeśli jednostka jest odblokowana, linie wyjściowe na tej liście zostaną włączone, a gdy jednostka jest zabezpieczona, zostaną wyłączone.</TranslationEntry>
    <TranslationEntry name="5A0DFB82C5CD9AD293937EFD03167192" fullContext="69856929F2617ED37B376A6385AA13B5" translateForJs="false">Na przykład te linie wyjściowe mogą być używane do sterowania oświetleniem jednostki lub zamkiem drzwi. Mogą być również używane jako wskaźnik wizualny, czy jednostka jest zabezpieczona (jeśli podłączone do </TranslationEntry>
    <TranslationEntry name="671994B69CBF133ACD420D1800B2A834" fullContext="69856929F2617ED37B376A6385AA13B5" translateForJs="false"> styki przekaźnika, lub jeśli </TranslationEntry>
    <TranslationEntry name="C13175449441678FC1DDCCD34CAD8AEC" fullContext="69856929F2617ED37B376A6385AA13B5" translateForJs="false"> opcja jest włączona dla tej linii wyjściowej na </TranslationEntry>
    <TranslationEntry name="241EC45BA7F75A272FEF59D2F2E172BC" fullContext="222A4C34A9165D4300B0FC26D421FF5D" translateForJs="false">[Konfiguracja &gt; Linie wyjściowe &gt; Linie wyjściowe sprzętowe]</TranslationEntry>
    <TranslationEntry name="6C732474297030949C0EC3D2DB94F2AD" fullContext="69856929F2617ED37B376A6385AA13B5" translateForJs="false">Aby dodać linie wyjściowe do jednostki (boksu), kliknij </TranslationEntry>
    <TranslationEntry name="2E4B97FDE8CF63085EC969FCC7E490C0" translateForJs="false" rules="unique=UnitOutputType" notes="Must be unique amongst all &quot;UnitOutputType&quot; entries">Oświetlenie</TranslationEntry>
    <TranslationEntry name="AE11D95BCEC152360AE423AF2F31DD7B" translateForJs="false" rules="unique=UnitOutputType" notes="Must be unique amongst all &quot;UnitOutputType&quot; entries">Wskaźnik zabezpieczenia</TranslationEntry>
    <TranslationEntry name="338E96DB289862FD640DE1A9D3731908" translateForJs="false" rules="unique=UnitOutputType" notes="Must be unique amongst all &quot;UnitOutputType&quot; entries">Wskaźnik alarmu</TranslationEntry>
    <TranslationEntry name="989A75E9EBE00077CB8F81D726330183" translateForJs="false" rules="unique=LicensedFeatureType" notes="Must be unique amongst all &quot;LicensedFeatureType&quot; entries">Inner Range Mobile Credentials</TranslationEntry>
    <TranslationEntry name="2BBC845892F400626BAAB5AF687527C5" fullContext="2BBC845892F400626BAAB5AF687527C5" translateForJs="false">Czas rozpoczęcia</TranslationEntry>
    <TranslationEntry name="C91A577B72313356FAD611C55F43C10F" fullContext="C91A577B72313356FAD611C55F43C10F" translateForJs="false">Czas zakończenia</TranslationEntry>
    <TranslationEntry name="50666A57CB6438677E9E9779D64FB3B6" fullContext="B6E7B6873953E926C1F287B35D668530" translateForJs="false">Cały dzień (24 godz.)</TranslationEntry>
    <TranslationEntry name="D2F70A7F038B7EA21029DA70C765ABD6" translateForJs="false">Przedział czasowy stał się aktywny</TranslationEntry>
    <TranslationEntry name="502996D9790340C5FD7B86A5B93B1C9F" translateForJs="false">Priorytet</TranslationEntry>
    <TranslationEntry name="F7FE751A41EC9EDBB0D51A3ECB736345" fullContext="F7FE751A41EC9EDBB0D51A3ECB736345" translateForJs="false">Wybierz wyjątki kalendarza do zastosowania w tym Przedziale czasowym.</TranslationEntry>
    <TranslationEntry name="6C5CDB2CD7DFAB79673D3759BB49EEA5" fullContext="4D3BFE97185B7B896F5D348BA9D7CC46" translateForJs="false">Te wyjątki to dni/godziny, w których ten przedział czasowy będzie nieaktywny. Są one definiowane w menu Kalendarze.</TranslationEntry>
    <TranslationEntry name="027FFBD15E15A388586002537B92E23D" fullContext="9EC7F7E05C89514F2ABC920802804116" translateForJs="false">Tygodniowe czasy cykliczne</TranslationEntry>
    <TranslationEntry name="F711099D22F3ED62FE299C1B364CCF56" fullContext="B6E7B6873953E926C1F287B35D668530" translateForJs="false">Definiuje godziny rozpoczęcia i zakończenia przedziału czasowego dla każdego dnia tygodnia. W tych godzinach i w wybranych dniach przedział czasowy będzie ważny/aktywny.</TranslationEntry>
    <TranslationEntry name="C1ABC06AC4C4AEC42EE38CD01C4ADD55" fullContext="B6E7B6873953E926C1F287B35D668530" translateForJs="false">Jeśli godzina rozpoczęcia jest wcześniejsza niż godzina zakończenia (np. 9:00 -&gt; 17:00), przedział czasowy będzie aktywny w tych godzinach w podanym dniu. Alternatywnie, jeśli godzina rozpoczęcia i zakończenia są takie same (17:00 -&gt; 17:00) lub godzina zakończenia jest wcześniejsza niż godzina rozpoczęcia (22:00 -&gt; 2:00), aktywny blok rozpocznie się w podanym dniu i zakończy następnego dnia. Umożliwia to łatwe określanie bloków czasowych obejmujących północ. Oznacza to, że np. 22:00 -&gt; 2:00 w środę będzie aktywne od 22:00 do północy w środy i od północy do 2:00 w czwartki. Podobnie, jeśli godziny rozpoczęcia i zakończenia są zgodne, 17:00 -&gt; 17:00 w środę będzie aktywne przez 24 godziny od 17:00 w środę do 17:00 w czwartek.</TranslationEntry>
    <TranslationEntry name="8DE535FEF48859E335F86600748558DA" fullContext="B6E7B6873953E926C1F287B35D668530" translateForJs="false">Aby przedział czasowy był ważny przez cały dzień, można skonfigurować 0:00 -&gt; 0:00, lub </TranslationEntry>
    <TranslationEntry name="5A6397924BB066A93B4659228C429F90" fullContext="B6E7B6873953E926C1F287B35D668530" translateForJs="false"> można wybrać.</TranslationEntry>
    <TranslationEntry name="F2EBEFE85D3819F00C0B900BA5410451" fullContext="B6E7B6873953E926C1F287B35D668530" translateForJs="false">Aby dodać kolejne bloki czasowe, kliknij </TranslationEntry>
    <TranslationEntry name="7BB0CADD3EEB8448D211E2340DB38486" fullContext="B6E7B6873953E926C1F287B35D668530" translateForJs="false"> przycisk spowoduje otwarcie okna, w którym można wybrać godziny i dni.</TranslationEntry>
    <TranslationEntry name="B3AC111FD7521343DD1A3FABCE8279C2" translateForJs="false">Razy</TranslationEntry>
    <TranslationEntry name="86DB25D32B2C2E4E84D859EE26194BE4" fullContext="AC6A8A42154E4083A40EA3C3EDA22DC9" translateForJs="false">Wyjątki kalendarza</TranslationEntry>
    <TranslationEntry name="A5EEFA5329D3E3C21F335627D946A919" fullContext="9EC7F7E05C89514F2ABC920802804116" translateForJs="false">Lista wyjątków obowiązujących w dniach, gdy powiązany z nimi kalendarz jest aktywny (wyższe priorytety zastępują niższe). Przedział czasowy zawierający wyjątki kalendarza będzie miał swój aktywny lub nieaktywny stan zastąpiony przez wyjątek kalendarza w dniach, dla których jest on skonfigurowany. </TranslationEntry>
    <TranslationEntry name="9412C70B603C3853781CF0C24625723B" fullContext="9EC7F7E05C89514F2ABC920802804116" translateForJs="false">Wyjątki kalendarza są stosowane, gdy ta sama zmiana czasu dla danego dnia powinna być powtarzana w wielu dniach w ciągu roku. Kalendarz może być aktualizowany, co może mieć spójny wpływ na wiele Przedziałów czasowych. Typowym przykładem zastosowania wyjątków kalendarza są dni z wydłużonymi godzinami handlowymi, w których godziny handlowe zmieniają się systematycznie w ciągu roku. Taki kalendarz może mieć zastosowanie do wielu przedziałów czasowych, takich jak godziny pracy, automatyczne godziny otwarcia przejść i automatyczne czasy uzbrajania, z których każdy reaguje na ten sam kalendarz. Użytkownik może następnie aktualizować kalendarz przez cały rok, a system reaguje prawidłowo.</TranslationEntry>
    <TranslationEntry name="76E28D1214EC32BBD45C9263CFFE49DA" fullContext="9EC7F7E05C89514F2ABC920802804116" translateForJs="false">Czas rozpoczęcia i zakończenia wyjątku jest programowany w taki sam sposób jak </TranslationEntry>
    <TranslationEntry name="72C4FAA4E1BA8230E1320A2AF5340C14" fullContext="9EC7F7E05C89514F2ABC920802804116" translateForJs="false"> opcja powyżej, gdzie godzina rozpoczęcia wcześniejsza niż godzina zakończenia (np. 9:00 -&gt; 17:00) dotyczy jednego dnia, ale ta sama godzina rozpoczęcia i zakończenia (17:00 -&gt; 17:00) lub wcześniejsza godzina zakończenia (22:00 -&gt; 2:00) obejmie północ i obejmie również następny dzień. Więcej szczegółów można znaleźć w podpowiedzi dla </TranslationEntry>
    <TranslationEntry name="06F7C66F80BC06610D4605E94D245E70" fullContext="C49F38FE4193740AEBD3EB67E88DCEDB" translateForJs="false"> opcja powyżej.</TranslationEntry>
    <TranslationEntry name="6F1B12BB5E7FA9551207BEFCEFAAEB8F" fullContext="9EC7F7E05C89514F2ABC920802804116" translateForJs="false">Aby dodać wyjątek kalendarza, kliknij </TranslationEntry>
    <TranslationEntry name="08F8958CAB4213AACC5CC8CBFD951653" fullContext="9EC7F7E05C89514F2ABC920802804116" translateForJs="false"> przycisk — otworzy to okno zawierające wszystkie dostępne kalendarze. Jeśli nie ma żadnych kalendarzy, można je utworzyć w </TranslationEntry>
    <TranslationEntry name="D5F1381C5F97F928DF4EF8D18C2A27C0" translateForJs="false">Wyjątki</TranslationEntry>
    <TranslationEntry name="691E25DD99AB63FC4672E5283C23A9CE" fullContext="AAA33982C0B35634D455FF048B99BC77" translateForJs="false">Lista indywidualnych wyjątków opartych na czasie i dacie, które zastępują listę cotygodniowych godzin cyklicznych (wyższe priorytety zastępują niższe). Wyjątki zachowują się tak samo jak wyjątki kalendarza, zastępując aktywny lub nieaktywny stan cotygodniowych godzin cyklicznych przedziału czasowego, jednak wyjątki te istnieją wyłącznie w ramach tego konkretnego przedziału czasowego. </TranslationEntry>
    <TranslationEntry name="E2309F42345383996D6CDF68CACA0BED" fullContext="AAA33982C0B35634D455FF048B99BC77" translateForJs="false">Zwykle używane do dodawania tymczasowej konkretnej zmiany w normalnym działaniu przedziału czasowego bez zmiany godzin cyklicznych, które można też dodać z wyprzedzeniem. Na przykład zamknięcie na okres konserwacji lub krótki okres przedłużonych godzin handlowych.</TranslationEntry>
    <TranslationEntry name="B1C4855DE75699A58DC800E85C61737C" fullContext="AAA33982C0B35634D455FF048B99BC77" translateForJs="false">Aby dodać kolejny wyjątek, kliknij </TranslationEntry>
    <TranslationEntry name="8D7BCC4FA4EB8B31CDAF32633C824145" fullContext="AAA33982C0B35634D455FF048B99BC77" translateForJs="false"> przycisk, co spowoduje dodanie pustego wyjątku.</TranslationEntry>
    <TranslationEntry name="C486EC380FC26E0FFD6E447B7667E4BF" fullContext="C59951F75D1665052A2812FFEED68992" translateForJs="false">PIN zabezpieczający</TranslationEntry>
    <TranslationEntry name="925964A23FD75028967E29BFC90ED44D" fullContext="6FB095C9484DBAC8F8CC22A2514FDF74" translateForJs="false">PIN bezpieczeństwa to unikalny kod, który umożliwia użytkownikowi sterowanie strefami i liniami wyjściowymi z Terminala LCD lub uzyskanie dostępu do przejścia za pomocą czytnika z klawiaturą Wiegand. </TranslationEntry>
    <TranslationEntry name="7E8B6E701A401CBBED6182F4404844B3" fullContext="6FB095C9484DBAC8F8CC22A2514FDF74" translateForJs="false">PIN może być również używany do logowania do interfejsu internetowego zamiast hasła. PIN nie będzie widoczny po zapisaniu użytkownika; jeśli użytkownik zapomniał swojego PIN, możesz nacisnąć przycisk Wyślij PIN. Otworzy to nowe okno umożliwiające wysłanie pocztą e-mail wiadomości z PIN i podstawowymi danymi do użytkownika. W przeciwnym razie inny użytkownik z wyższymi uprawnieniami (np. instalator) posiadający uprawnienia Ujawnij PIN może użyć tego przycisku, aby ujawnić i wyświetlić PIN.</TranslationEntry>
    <TranslationEntry name="5FD1CA81A87FC6AC5083EEFACDD39254" fullContext="6FB095C9484DBAC8F8CC22A2514FDF74" translateForJs="false">Kody PIN zabezpieczeń muszą być unikalne dla każdego użytkownika — nie będzie można zapisać zmian dla użytkownika, jeśli zostanie wprowadzony duplikat PIN. Aby wygenerować unikalny PIN dla użytkownika, kliknij </TranslationEntry>
    <TranslationEntry name="6325ECA9D84516D3E0DB6513C45E299B" fullContext="FA09F60845167DBD14651658A32EEABB" translateForJs="false">Automatyczne generowanie PIN</TranslationEntry>
    <TranslationEntry name="96BE8B9669AB9FFFAF30D401881AC606" fullContext="6FB095C9484DBAC8F8CC22A2514FDF74" translateForJs="false"> przycisk — otworzy się okno zawierające nowy PIN. Domyślne wymagania dotyczące długości PIN to minimum 2 cyfry i maksymalnie 4 cyfry. Jeśli wprowadzisz PIN poza tymi wymaganiami, nie będziesz mógł zapisać zmian. Limity długości PIN mogą zostać zmienione przez administratora przez przejście do </TranslationEntry>
    <TranslationEntry name="E94DB824242B207CF19FF883965AC708" fullContext="6FB095C9484DBAC8F8CC22A2514FDF74" translateForJs="false">. Uwaga: jeśli zwiększasz limity długości PIN, terminale LCD akceptują co najwyżej 8-cyfrowe kody PIN, a </TranslationEntry>
    <TranslationEntry name="8CC1A110E8A781CAED4CA9A170796E33" fullContext="FA09F60845167DBD14651658A32EEABB" translateForJs="false"> jest ograniczone do maksymalnie 10 cyfr.</TranslationEntry>
    <TranslationEntry name="E7076002620C730B68D6938D001932D3" fullContext="0361551A09A9513AAEB347BD9E1F8124" translateForJs="false">Identyfikator to unikalnie numerowana karta, brelok lub inny typ identyfikowalnych danych (np. biometryczny odcisk palca lub skan twarzy). Numer identyfikatora jest odczytywany przez czytnik przy przejściu w celu identyfikacji użytkownika próbującego uzyskać dostęp.</TranslationEntry>
    <TranslationEntry name="1DC9FEEFFCDA82B818A50B4FC56529A5" fullContext="0361551A09A9513AAEB347BD9E1F8124" translateForJs="false">Identyfikator może być przypisany tylko do jednego użytkownika — jeśli zostanie przypisany zduplikowany identyfikator, nie będzie możliwe zapisanie użytkownika. Użytkownicy mogą mieć przypisanych wiele identyfikatorów, jeśli np. w obiekcie używane są różne typy kart lub technologie czytników biometrycznych.</TranslationEntry>
    <TranslationEntry name="C193E261D4D6C47D2E5B65787C5F07C3" fullContext="0361551A09A9513AAEB347BD9E1F8124" translateForJs="false">Aby dodać identyfikator do użytkownika, kliknij przycisk </TranslationEntry>
    <TranslationEntry name="2AF4355B4390A390C84EC5FC9F8101A2" fullContext="0361551A09A9513AAEB347BD9E1F8124" translateForJs="false"> przycisk, co otworzy okno, w którym wybierasz szablon identyfikatora. Jeśli w tym oknie nie ma żadnych szablonów, można skonfigurować szablon, przechodząc do </TranslationEntry>
    <TranslationEntry name="DD1AF69F58E4B036D4ABCFA14F20353A" fullContext="1621168F891D726FC86EAE5894F0477A" translateForJs="false">[Konfiguracja &gt; Kontrola dostępu &gt; Szablony identyfikatorów]</TranslationEntry>
    <TranslationEntry name="32DFF5272CD59DB127A018C06CE73165" fullContext="0361551A09A9513AAEB347BD9E1F8124" translateForJs="false">Po wybraniu szablonu wpisz numer wydrukowany na karcie (lub innym typie identyfikatora). Jeśli na karcie nie ma numeru, numer identyfikatora można sprawdzić, przechodząc do </TranslationEntry>
    <TranslationEntry name="9D238A9C6BF6F51999EE687D00A6DCD1" fullContext="0361551A09A9513AAEB347BD9E1F8124" translateForJs="false"> a następnie odczycie identyfikatora na czytniku, znajdź najnowsze zdarzenie </TranslationEntry>
    <TranslationEntry name="E46D027558EECC6E99EE12EC02E9FE8E" fullContext="0361551A09A9513AAEB347BD9E1F8124" translateForJs="false">Odczyt identyfikatora nieudany — identyfikator nieprzypisany</TranslationEntry>
    <TranslationEntry name="46728A0479AD67BB87597895C348453D" fullContext="0361551A09A9513AAEB347BD9E1F8124" translateForJs="false"> zdarzenie, to zdarzenie będzie zawierać numer identyfikatora.</TranslationEntry>
    <TranslationEntry name="F4AE9ECE11B0FF60653400914AB0C4B0" fullContext="0361551A09A9513AAEB347BD9E1F8124" translateForJs="false">Identyfikatory zawierają również pole stanu (domyślnie ustawione na Aktywny), które określa, czy identyfikator będzie akceptowany przez czytniki przy przejściach. Czytniki przy przejściach będą akceptować wyłącznie identyfikatory oznaczone jako </TranslationEntry>
    <TranslationEntry name="8337107504A5D680EC9C3266FA10DF16" fullContext="0361551A09A9513AAEB347BD9E1F8124" translateForJs="false">, identyfikatory oznaczone jako </TranslationEntry>
    <TranslationEntry name="848E72A6679E99F1DDD1118A87789196" fullContext="0361551A09A9513AAEB347BD9E1F8124" translateForJs="false">Nieaktywny - Utracony</TranslationEntry>
    <TranslationEntry name="B0B8C0780DBE8276C116B608A69EAF28" fullContext="0361551A09A9513AAEB347BD9E1F8124" translateForJs="false">Nieaktywny - Skradziony</TranslationEntry>
    <TranslationEntry name="F612E748D688CEA966EFCFEDA361EC8E" fullContext="0361551A09A9513AAEB347BD9E1F8124" translateForJs="false"> na przykład zostanie odrzucony, a zdarzenie rejestru i komunikat systemowy dotyczący użycia nieaktywnego identyfikatora zostanie zapisany. Wszystkie identyfikatory oznaczone jako </TranslationEntry>
    <TranslationEntry name="C2261F6B7C44C60338832D3DADA02C0E" fullContext="0361551A09A9513AAEB347BD9E1F8124" translateForJs="false"> są obsługiwane przez system w ten sam sposób; dodatkowe informacje, takie jak </TranslationEntry>
    <TranslationEntry name="29AD5FEC374ADEFACC37D964A7C4B3E1" fullContext="0361551A09A9513AAEB347BD9E1F8124" translateForJs="false">Skradziony</TranslationEntry>
    <TranslationEntry name="8CB13C9E8BF33F1D071E08865EA76797" fullContext="0361551A09A9513AAEB347BD9E1F8124" translateForJs="false"> jest dostarczane wyłącznie w celach informacyjnych. Ta funkcjonalność może być przydatna do wyłączenia użycia identyfikatora w przypadku, gdy identyfikator użytkownika zostanie zgłoszony jako zgubiony/skradziony, bez konieczności usuwania wpisu identyfikatora z danych użytkownika.</TranslationEntry>
    <TranslationEntry name="840D7F2B5552DB03DF48CE73E6AD6A65" fullContext="1621168F891D726FC86EAE5894F0477A" translateForJs="false">Mobilne identyfikatory to unikalnie ponumerowane karty używane jako identyfikacja dla tego użytkownika, obsługiwane przez system Mobile Access. Wymaga połączenia systemu Mobile Access przez </TranslationEntry>
    <TranslationEntry name="F59D69F40B4E06CCA8C2A6E2897DFF43" fullContext="1621168F891D726FC86EAE5894F0477A" translateForJs="false">[Konfiguracja &gt; Kontrola dostępu &gt; Dostęp mobilny &gt; Ustawienia połączenia z dostępem mobilnym]</TranslationEntry>
    <TranslationEntry name="756089B0631F7C8213F0BC238C087BF0" fullContext="1621168F891D726FC86EAE5894F0477A" translateForJs="false">Gdy system został powiązany, przycisk Przydziel mobilny identyfikator będzie dostępny. Spowoduje to przydzielenie mobilnego identyfikatora użytkownikowi, z zaproszeniem e-mail wysłanym na podany adres e-mail. Zaproszenie można zaakceptować na telefonie za pomocą aplikacji Mobile Access. Dany użytkownik może mieć tylko jeden mobilny identyfikator z danego systemu.</TranslationEntry>
    <TranslationEntry name="450031A8F306EA9FBF522C1F6D3050E0" fullContext="1621168F891D726FC86EAE5894F0477A" translateForJs="false">System używa wstępnie skonfigurowanego szablonu identyfikatora Mobile Access, który można znaleźć w </TranslationEntry>
    <TranslationEntry name="754DA827953EDCED0BE742FD3F75EFDD" fullContext="1621168F891D726FC86EAE5894F0477A" translateForJs="false">. Kod obiektu tego szablonu będzie kodem obiektu podanym podczas łączenia systemu Mobile Access.</TranslationEntry>
    <TranslationEntry name="16B88FA414547AE3F37F542EB15FD130" fullContext="96D69678355327037F400D75F13777CB" translateForJs="false">Pilot zdalnego sterowania to bezprzewodowy brelok z 1 lub 4 przyciskami, używany do zdalnego sterowania strefami, przejściami, liniami wyjściowymi itp. Pilot jednoprzyciski może być również używany jako mobilny przycisk napadowy.</TranslationEntry>
    <TranslationEntry name="E6005911A660EA2353892E69B311C707" fullContext="96D69678355327037F400D75F13777CB" translateForJs="false">Pilot zdalnego sterowania może być przypisany tylko do jednego użytkownika — jeśli zostanie przypisany zduplikowany brelok, nie będzie można zapisać użytkownika.</TranslationEntry>
    <TranslationEntry name="3109084A54F9C54673E71D67B8BBF65B" fullContext="96D69678355327037F400D75F13777CB" translateForJs="false">Aby dodać brelok zdalny do użytkownika, kliknij </TranslationEntry>
    <TranslationEntry name="5043E906506A8695937CF9F406865F44" fullContext="96D69678355327037F400D75F13777CB" translateForJs="false"> przycisk spowoduje otwarcie okna, w którym wybierasz szablon breloka. Szablon breloka określa funkcjonalność przycisków pilota. Jeśli w tym oknie nie ma żadnych szablonów, szablon można skonfigurować, przechodząc do </TranslationEntry>
    <TranslationEntry name="AC893DB5707403CECDE0A426396E157C" fullContext="96D69678355327037F400D75F13777CB" translateForJs="false">[Konfiguracja &gt; Kontrola dostępu &gt; Szablony pilotów zdalnych]</TranslationEntry>
    <TranslationEntry name="5EC0B0F186C3569D6A33A5D4E7941575" fullContext="96D69678355327037F400D75F13777CB" translateForJs="false">Po wybraniu szablonu wprowadź sześciocyfrowy numer seryjny wydrukowany na breloku zdalnym. Jeśli na pilocie nie ma numeru, numer seryjny można zidentyfikować, przechodząc do </TranslationEntry>
    <TranslationEntry name="5C0F27CC9558C36343565BE8299FF0E7" fullContext="96D69678355327037F400D75F13777CB" translateForJs="false"> a następnie naciśnięcie przycisku na pilotce breloka. Znajdź najnowsze </TranslationEntry>
    <TranslationEntry name="876650B73B8811C714F4A520BB127FBD" fullContext="96D69678355327037F400D75F13777CB" translateForJs="false">Przycisk breloka zdalnego z nieznanego breloka</TranslationEntry>
    <TranslationEntry name="CBF6F2DE20D440CCC2FDF46116B47338" fullContext="96D69678355327037F400D75F13777CB" translateForJs="false"> zdarzenie, to zdarzenie będzie zawierać numer seryjny.</TranslationEntry>
    <TranslationEntry name="891859D37A4A95194A7065995297C0B2" fullContext="96D69678355327037F400D75F13777CB" translateForJs="false">Funkcjonalność pilota przypisanego do użytkownika zależy od programowania szablonu breloka dostępnego w </TranslationEntry>
    <TranslationEntry name="D32367B0766ADF3DE03803840101F5CA" fullContext="ACB4F26BB0840AE56738E668B35971D9" translateForJs="false">Uprawnienia określają, do jakich stref, przejść, linii wyjściowych i pięter windy użytkownik ma dostęp lub może nimi sterować w systemie. Uprawnienia określają również, którymi elementami użytkownik może sterować przez interfejs WWW. </TranslationEntry>
    <TranslationEntry name="1702EE81E034DEDFAEBC1B1F0DA88989" fullContext="ACB4F26BB0840AE56738E668B35971D9" translateForJs="false">Aby dodać uprawnienia użytkownikowi, kliknij </TranslationEntry>
    <TranslationEntry name="AE16914EA7935F2EC72F9FD9B177DD41" fullContext="ACB4F26BB0840AE56738E668B35971D9" translateForJs="false"> przycisk; spowoduje to otwarcie okna zawierającego wszystkie dozwolone elementy. Te elementy można dodawać pojedynczo lub jako wstępnie zdefiniowaną grupę uprawnień.</TranslationEntry>
    <TranslationEntry name="326FED3F268C0B37FEF82E266F4582A1" fullContext="ACB4F26BB0840AE56738E668B35971D9" translateForJs="false">Grupy uprawnień to zbiór uprawnień tworzonych w </TranslationEntry>
    <TranslationEntry name="D7CC302A06754A63D28FBBF7FC23E28D" fullContext="ACB4F26BB0840AE56738E668B35971D9" translateForJs="false">[Konfiguracja &gt; Użytkownicy &gt; Grupy uprawnień]</TranslationEntry>
    <TranslationEntry name="7552DC23DBDB41C8840B78A51275E60C" fullContext="ACB4F26BB0840AE56738E668B35971D9" translateForJs="false"> strona. Grupy uprawnień są tworzone odpowiednio do roli jednego lub więcej użytkowników w firmie, na przykład pracownicy magazynu lub personel administracyjny. Umożliwia to przypisanie tego samego zestawu uprawnień wielu użytkownikom.</TranslationEntry>
    <TranslationEntry name="CC93CD2A893BD671175AA78E5D060EC2" fullContext="ACB4F26BB0840AE56738E668B35971D9" translateForJs="false">Uprawnienia przypisane do użytkownika zawsze obowiązują. Bardziej zaawansowane sterowanie, takie jak ograniczenie </TranslationEntry>
    <TranslationEntry name="B20743A66C9732E5533E9C1CA6AF9576" fullContext="ACB4F26BB0840AE56738E668B35971D9" translateForJs="false"> użytkownik może coś zrobić, jest dostępna w grupach uprawnień. Umożliwia to tworzenie bardziej złożonych uprawnień zgodnych z zasadami obiektu, ograniczając dostęp na podstawie przedziału czasowego lub czegoś innego w systemie, przy jednoczesnym uproszczeniu interfejsu używanego przez użytkowników końcowych.</TranslationEntry>
    <TranslationEntry name="694E6DC3EACBCCF932818B5FAE757D87" fullContext="ACB4F26BB0840AE56738E668B35971D9" translateForJs="false">, wówczas użytkownik nie będzie mógł wykonać tej akcji. </TranslationEntry>
    <TranslationEntry name="4B06AB0C9D3B24F94877DF563DF6E402" fullContext="ACB4F26BB0840AE56738E668B35971D9" translateForJs="false"> uprawnienia zastępują </TranslationEntry>
    <TranslationEntry name="7FC9F378D1FB6F9CF3D07C8DF0DD2114" fullContext="ACB4F26BB0840AE56738E668B35971D9" translateForJs="false"> uprawnienia — jeśli ktoś ma dostęp przez przejście dzięki grupie uprawnień, odmowa dostępu do przejścia zastąpi to uprawnienie. Może to być używane, gdy użytkownik powinien mieć wszystkie uprawnienia z grupy uprawnień z jednym lub dwoma wyjątkami. Te wyjątki można wtedy dodać jako </TranslationEntry>
    <TranslationEntry name="B75C5F76E8D73E699E13F328FF045B75" fullContext="ACB4F26BB0840AE56738E668B35971D9" translateForJs="false"> wiersz.</TranslationEntry>
    <TranslationEntry name="87BDF383B8A6C43D2478E216438CDB62" fullContext="4D17A0377396E2D5D65D493DF6B8C2E7" translateForJs="false">Profil terminala LCD określa, jakie menu użytkownik może wyświetlać po zalogowaniu się do terminala LCD. Użytkownik będzie wymagał </TranslationEntry>
    <TranslationEntry name="5D52ECF86942710FCEDB69E80D72C039" fullContext="4D17A0377396E2D5D65D493DF6B8C2E7" translateForJs="false"> aby móc zalogować się do terminala LCD. Profil terminala nie wpłynie na funkcjonalność terminala LCD w trybie wylogowanym, taką jak sterowanie linią wyjściową w trybie wylogowanym i sterowanie przejściem za pomocą przycisku OK. </TranslationEntry>
    <TranslationEntry name="D4663DE1022A829BE4EB27116D00E447" fullContext="4D17A0377396E2D5D65D493DF6B8C2E7" translateForJs="false">Profil określa wyłącznie, które opcje menu użytkownik może przeglądać i z nich korzystać za pośrednictwem Terminala LCD. Jeśli profil umożliwia użytkownikowi dostęp do menu sterowania strefami, przejściami lub liniami wyjściowymi, użytkownik może zobaczyć aktualny stan tych elementów, ale nadal potrzebuje odpowiednich uprawnień do sterowania nimi w swoich </TranslationEntry>
    <TranslationEntry name="080A7E4665C196A7BF8362FC5E3B8292" fullContext="4D17A0377396E2D5D65D493DF6B8C2E7" translateForJs="false"> poniżej.</TranslationEntry>
    <TranslationEntry name="90A1AAAA481C76628FF69CC0679911F0" fullContext="4D17A0377396E2D5D65D493DF6B8C2E7" translateForJs="false">Kliknij listę rozwijaną, aby wybrać profil terminala LCD. Ponieważ jest to system bezpieczeństwa i kontroli dostępu chroniący obiekt, przy wyborze profilu zaleca się wybranie takiego, który pozwala użytkownikowi wykonywać i widzieć wszystko, czego potrzebuje, ale nic ponadto. </TranslationEntry>
    <TranslationEntry name="13B8239F807546C19C30C48DBB737AE6" fullContext="4D17A0377396E2D5D65D493DF6B8C2E7" translateForJs="false">Profile terminala LCD są konfigurowane na </TranslationEntry>
    <TranslationEntry name="FE9BF18D785CE3ECCC6687C4E3E9A4D8" fullContext="4D17A0377396E2D5D65D493DF6B8C2E7" translateForJs="false">[Konfiguracja &gt; Użytkownicy &gt; Profile terminali]</TranslationEntry>
    <TranslationEntry name="E59A4EA82E81FEEEE498A726E5115ABD" fullContext="CA110B773FBAE87626F1F3CA493C8F56" translateForJs="false">Jeśli włączone, gdy temu użytkownikowi zostanie przyznany dostęp do przejścia, drzwi odblokują się na czas zaprogramowany w jego </TranslationEntry>
    <TranslationEntry name="49B566465726A6656428C1CA91392035" fullContext="CA110B773FBAE87626F1F3CA493C8F56" translateForJs="false">, zamiast jego </TranslationEntry>
    <TranslationEntry name="2C9F052292EC0EFF3C154B841828E0DD" fullContext="CA110B773FBAE87626F1F3CA493C8F56" translateForJs="false">. Ta opcja jest przeznaczona dla użytkowników potrzebujących dodatkowego czasu na wejście przez drzwi, takich jak kierowca dostawczy wnoszący przesyłki lub użytkownik z niepełnosprawnością lub ograniczoną mobilnością.</TranslationEntry>
    <TranslationEntry name="CADD408BAD73D3321B7D37F0BB31A574" fullContext="CA110B773FBAE87626F1F3CA493C8F56" translateForJs="false">Rozszerzony czas blokady można skonfigurować indywidualnie dla każdego przejścia i zaprogramować w ustawieniu </TranslationEntry>
    <TranslationEntry name="70D7CA399ED96F51C48658ED00A94580" translateForJs="false">Trwale dodaj do pamięci podręcznej SLAM</TranslationEntry>
    <TranslationEntry name="CDCAE909C04AA0C99029F2807A7B1165" fullContext="1EBAA95101735B585E25D458895A22ED" translateForJs="false">Jeśli włączone, karty tego użytkownika będą trwale przechowywane w wewnętrznych pamięciach podręcznych kart wszystkich Standardowych modułów dostępu LAN (SLAM) w sieci modułów.</TranslationEntry>
    <TranslationEntry name="908E3ACFF0D094AEA5DDA3D2C527B4B1" fullContext="1EBAA95101735B585E25D458895A22ED" translateForJs="false">Moduł SLAM może przechowywać 2000 kart w wewnętrznej pamięci podręcznej, śledząc, czy dostęp był przyznany przy ostatniej prezentacji przy czytniku i zapamiętując to dla każdego przejścia sterowanego przez SLAM. Jeśli komunikacja między modułem SLAM a systemem Inception zostanie utracona, SLAM może używać tej pamięci podręcznej kart do określenia, czy karta użytkownika powinna zostać przepuszczona przez przejście, co umożliwia zachowanie offline.</TranslationEntry>
    <TranslationEntry name="A437A57A2187F6C1FD0C01130137040C" fullContext="1EBAA95101735B585E25D458895A22ED" translateForJs="false">Karty są automatycznie usuwane z tej pamięci podręcznej z kilku powodów: jeśli dostęp do przejścia zostanie odmówiony przy użyciu karty, po 1 miesiącu nieaktywności lub jeśli zostanie osiągnięty limit 2000 kart — wtedy, gdy nowe karty są dodawane do pamięci podręcznej, najstarsze karty są usuwane. Ma to na celu umożliwienie inteligentnego zachowania offline, gdzie osoby, które ostatnio używały przejścia, nadal będą mogły uzyskać do niego dostęp w przypadku, gdy moduł przejścia utraci łączność z kontrolerem Inception.</TranslationEntry>
    <TranslationEntry name="64DED38DFC496058D259D26081F6AECA" fullContext="1EBAA95101735B585E25D458895A22ED" translateForJs="false">Ta opcja może jednak wymusić pozostanie karty w pamięci podręcznej, nawet jeśli nie była używana przez długi czas. Pozwala to ważnym kartom, takim jak należące do menedżerów, służb ratunkowych lub strażaków itp., pozostać sprawne w przypadku awarii głównego kontrolera, nawet jeśli są rzadko używane.</TranslationEntry>
    <TranslationEntry name="55AB7242F665B55851096D763B09BE35" fullContext="1EBAA95101735B585E25D458895A22ED" translateForJs="false">Należy pamiętać, że karty nie są automatycznie dodawane do pamięci podręcznej kart każdego modułu SLAM — karta musi być zaprezentowana przy każdym czytniku każdego przejścia, a dostęp musi być pomyślnie przyznany, aby karta mogła zostać dodana do pamięci podręcznej danego modułu.</TranslationEntry>
    <TranslationEntry name="9B9BEE4358FB51637B43CC8F99608F2D" translateForJs="false">Dostęp zdalny / przez Internet</TranslationEntry>
    <TranslationEntry name="B3D52E4FFE419A1AB431719AD7C892B1" fullContext="04A3CA846E99506B172C4F75BE0ED45F" translateForJs="false">Włącz logowanie przez sieć</TranslationEntry>
    <TranslationEntry name="5BED5407A15E9AEDAA5E123B975964ED" fullContext="04A3CA846E99506B172C4F75BE0ED45F" translateForJs="false">Jeśli włączone, użytkownik będzie miał dostęp do interfejsu internetowego przy użyciu nazwy użytkownika i hasła podanych poniżej. Dostęp do interfejsu internetowego można uzyskać na dowolnym urządzeniu z obsługiwaną przeglądarką internetową. Urządzenie musi być w tej samej sieci lokalnej co kontroler Inception lub być podłączone do punktu dostępowego Wi-Fi kontrolera Inception (wymaga opcjonalnego adaptera bezprzewodowego Inception). Użytkownik może również zdalnie połączyć się z interfejsem internetowym za pomocą usługi Skytunnel — bezproblemowej metody połączenia internetowego. </TranslationEntry>
    <TranslationEntry name="8FD89CA6294CB37827EA19EE9480B5D7" fullContext="04A3CA846E99506B172C4F75BE0ED45F" translateForJs="false"> opcja powinna być włączona tylko wtedy, gdy użytkownik musi edytować programowanie, sterować strefami, przejściami, liniami wyjściowymi i liniami wejściowymi lub wykonywać zadania administracyjne przez interfejs WWW.</TranslationEntry>
    <TranslationEntry name="5AC474EA01576A8EFE7732F4DD36D1EC" fullContext="04A3CA846E99506B172C4F75BE0ED45F" translateForJs="false">Musisz przypisać profil strony internetowej do użytkownika, aby określić, które strony użytkownik może wyświetlać i z którymi może wchodzić w interakcje. Jeśli wybrany profil internetowy umożliwia sterowanie elementami takimi jak strefy, przejścia lub linie wyjściowe, użytkownik będzie mógł sterować tylko elementami przypisanymi w jego uprawnieniach użytkownika. Jeśli użytkownik ma uprawnienia do sterowania strefą tylko w godzinach pracy, to samo ograniczenie dotyczy sterowania strefą z interfejsu internetowego.</TranslationEntry>
    <TranslationEntry name="60D10BF431683BBDC90AC9927EA6A11F" fullContext="8C8DD889BCE09F42C17BF8A0002F655F" translateForJs="false">Nazwa logowania używana do identyfikacji użytkownika i umożliwienia dostępu do interfejsu internetowego. Nazwa użytkownika może mieć dowolną długość i dowolną kombinację liter, cyfr i znaków.</TranslationEntry>
    <TranslationEntry name="7921971BB8D75263FBD81A1057AC71B4" fullContext="8C8DD889BCE09F42C17BF8A0002F655F" translateForJs="false">Każdy użytkownik wymaga unikalnej nazwy użytkownika — nie będzie można zapisać programowania użytkownika, jeśli zostanie wprowadzona zduplikowana nazwa użytkownika.</TranslationEntry>
    <TranslationEntry name="05D17FCED2BC20891F1159D2348D271F" fullContext="47621023CA686DEA5FDE8F0A3CEFB718" translateForJs="false">Tajna sekwencja cyfr lub liter używana wraz z nazwą użytkownika w celu uzyskania dostępu do interfejsu WWW. Hasło może mieć dowolną długość i zawierać dowolną kombinację liter, cyfr i znaków. </TranslationEntry>
    <TranslationEntry name="45B31E7F33D398EB4F3D212049E38384" fullContext="47621023CA686DEA5FDE8F0A3CEFB718" translateForJs="false">Ponieważ Inception jest produktem bezpieczeństwa, zaleca się, aby hasło było utrzymywane w poufności przez użytkownika, któremu zostało przypisane. Zaleca się również, aby hasło nie było zapisywane przez przeglądarkę używaną do uzyskiwania dostępu do interfejsu internetowego. Interfejs internetowy kontrolera Inception może być również dostępny przez internet za pośrednictwem architektury Skytunnel, dlatego ważne jest posiadanie bezpiecznego hasła, którego nie można zgadnąć.</TranslationEntry>
    <TranslationEntry name="E6849C35D5864D8593B84370FE038CCE" translateForJs="false">Konfiguracja uwierzytelniania dwuskładnikowego (2FA)</TranslationEntry>
    <TranslationEntry name="4C2CC2BDF5487742091354EA3E4E5092" fullContext="6C78226E2DE2F4F0F388D61797F79312" translateForJs="false">Status rejestracji uwierzytelniania dwuskładnikowego (2FA) użytkownika. Użytkownicy zarejestrowani w 2FA muszą wprowadzić dodatkowy kod zabezpieczający z osobistego urządzenia przed zalogowaniem się do interfejsu internetowego. Kliknij przycisk linku, aby otworzyć okno dialogowe rejestracji użytkownika w 2FA. UWAGA: 2FA musi być włączone w ustawieniach systemowych Inception, aby móc rejestrować użytkowników w 2FA.</TranslationEntry>
    <TranslationEntry name="6CFCE9506069FC0039BEF271A7ED524D" fullContext="6C78226E2DE2F4F0F388D61797F79312" translateForJs="false">Po rejestracji użytkownika w systemie 2FA zostanie wyświetlony monit o wprowadzenie kodu zabezpieczającego wygenerowanego przez urządzenie osobiste w celu potwierdzenia pomyślnej rejestracji.</TranslationEntry>
    <TranslationEntry name="B77D4A05027B5EE419594B01644F2213" fullContext="6C78226E2DE2F4F0F388D61797F79312" translateForJs="false">Naciśnięcie przycisku X spowoduje usunięcie istniejącej konfiguracji 2FA dla użytkownika. Spowoduje to, że istniejące konta 2FA użytkownika w aplikacjach na smartfony staną się nieaktualne, a użytkownik będzie musiał ponownie zarejestrować się w 2FA Inception, aby z niego korzystać.</TranslationEntry>
    <TranslationEntry name="7EF8466A4453C66A8627D9A360D55C75" fullContext="6C78226E2DE2F4F0F388D61797F79312" translateForJs="false">Po początkowej rejestracji użytkownika w 2FA, okno dialogowe rejestracji nie będzie dostępne przez kliknięcie przycisku linku ze względów bezpieczeństwa — konfiguracja 2FA będzie musiała zostać usunięta i ponownie utworzona w celu ponownej rejestracji.</TranslationEntry>
    <TranslationEntry name="6C2887152DE2157A3EB2D72BD627A01B" translateForJs="true">Niezarejestrowany</TranslationEntry>
    <TranslationEntry name="3E8D7ADC098C38BD17F14059D4F45C82" fullContext="861A0F4264535344969B196B607A19C8" translateForJs="false">Określa, które strony webowe w interfejsie webowym użytkownik może wyświetlać oraz jak może z nimi wchodzić w interakcję; na przykład wyłącznie przeglądanie, modyfikowanie i sterowanie. </TranslationEntry>
    <TranslationEntry name="34825E3C585CD28DC377DBA6FDC66330" fullContext="861A0F4264535344969B196B607A19C8" translateForJs="false">Kliknij listę rozwijaną, aby wybrać profil strony internetowej. Ponieważ jest to system bezpieczeństwa i kontroli dostępu chroniący obiekt, przy wyborze profilu zaleca się wybranie takiego, który pozwala użytkownikowi wykonywać i widzieć wszystko, czego potrzebuje, ale nic ponadto. </TranslationEntry>
    <TranslationEntry name="26A33BAACD3CEA58AF07A702071C1EB4" fullContext="861A0F4264535344969B196B607A19C8" translateForJs="false">Profile WWW można konfigurować na stronie </TranslationEntry>
    <TranslationEntry name="22FF64E185037E9FCBBC8ACCB253696D" fullContext="861A0F4264535344969B196B607A19C8" translateForJs="false">[Konfiguracja &gt; Użytkownicy &gt; Profile stron internetowych]</TranslationEntry>
    <TranslationEntry name="4094240216B869479B780A6608DF168A" fullContext="3B090617F338C0F72F3BF18048FF1CEC" translateForJs="false">Konto IR Connect powiązane z tym użytkownikiem. Kliknij przycisk linku, aby wprowadzić konto IR Connect użytkownika (adres e-mail). Jeśli użytkownik nie ma jeszcze konta IR Connect, zostanie automatycznie wysłana do niego wiadomość e-mail z instrukcją zakładania darmowego konta.</TranslationEntry>
    <TranslationEntry name="04D94829957F6CB30F99083AD80CB688" fullContext="3B090617F338C0F72F3BF18048FF1CEC" translateForJs="false">Powiązanie konta IR Connect z tym użytkownikiem umożliwia mu zdalne sterowanie strefami, przejściami i liniami wyjściowymi za pomocą aplikacji IR Connect na smartfon. Aplikacja jest bezpłatna i wymaga jedynie aktywnego połączenia z Internetem kontrolera Inception. W aplikacji widoczne będą tylko te elementy, do których użytkownik ma uprawnienia. Naciśnięcie przycisku X spowoduje odłączenie użytkownika od konta IR Connect i uniemożliwi mu logowanie.</TranslationEntry>
    <TranslationEntry name="C76BB039B56890B7B558BCC4C0C294EF" fullContext="3B090617F338C0F72F3BF18048FF1CEC" translateForJs="false">Konto IR Connect umożliwia również użytkownikowi zdalne monitorowanie systemu przez otrzymywanie alertów powiadomień push na smartfonie. Wysyłane powiadomienia są konfigurowane na stronie </TranslationEntry>
    <TranslationEntry name="CEE7BB293449E2B2E35156A41919B6D9" fullContext="3B090617F338C0F72F3BF18048FF1CEC" translateForJs="false">[Konfiguracja &gt; System &gt; Powiadamiacze]</TranslationEntry>
    <TranslationEntry name="BC52456EB28B20EB3E35BE2DF1D78E53" translateForJs="false">Token API użytkownika</TranslationEntry>
    <TranslationEntry name="C72EC6FFEF1B2F995F3E3AAB73325149" fullContext="A373601034CAFA1C29E85DEEB8AF6B1D" translateForJs="false">Token API powiązany z tym użytkownikiem, który może być używany w nagłówku autoryzacji żądań REST API do składania żądań w imieniu tego użytkownika bez konieczności logowania się za pomocą oddzielnego żądania.</TranslationEntry>
    <TranslationEntry name="746854159494B44DFCD2F6D9F0A82B8A" fullContext="A373601034CAFA1C29E85DEEB8AF6B1D" translateForJs="false">Jeśli token API zostanie utworzony przez monit na przycisku łącza, można go skopiować i dodać do nagłówka autoryzacji żądań REST API (poprzedzony typem 'APIToken').</TranslationEntry>
    <TranslationEntry name="CE140ED1014C056D52C6C450B25CCF28" fullContext="A373601034CAFA1C29E85DEEB8AF6B1D" translateForJs="false">Odłączenie tokenu API za pomocą przycisku 'X' spowoduje usunięcie tokenu API wygenerowanego dla użytkownika i uczynienie go bezużytecznym.</TranslationEntry>
    <TranslationEntry name="EE7DAD31FEA478292F8E2DD24133C6A9" translateForJs="false">Dane osobowe</TranslationEntry>
    <TranslationEntry name="38B6A18590655AB6D278D2209DEA3996" fullContext="D2AC374A5DC3708533A76B7AD5AE8394" translateForJs="false">Pole Zdjęcie użytkownika to pole opcjonalne, w którym można przesłać plik obrazu i powiązać go z użytkownikiem.</TranslationEntry>
    <TranslationEntry name="87FC04C192144A1C2D1C1241722FDE0A" fullContext="D2AC374A5DC3708533A76B7AD5AE8394" translateForJs="false">Zdjęcia użytkowników będą wyświetlane wraz z ich imionami i nazwiskami w kolumnie Kto w </TranslationEntry>
    <TranslationEntry name="C9AD0AD4C63A8FC70DF559CBB4C1BB29" fullContext="D2AC374A5DC3708533A76B7AD5AE8394" translateForJs="false">[Zdarzenia]</TranslationEntry>
    <TranslationEntry name="4CA39A369D75A0208139FBF20D5BCB85" fullContext="D2AC374A5DC3708533A76B7AD5AE8394" translateForJs="false"> strona, gdy w systemie wystąpią zdarzenia dotyczące tego użytkownika, np. zdarzenia uzbrojenia/rozbrojenia strefy lub dostępu do przejścia. Użytkownicy bez zdjęć będą mieli wyświetlane tylko swoje imię w kolumnie Kto.</TranslationEntry>
    <TranslationEntry name="8873C49623C34D03B8454A36853ABC4F" fullContext="D2AC374A5DC3708533A76B7AD5AE8394" translateForJs="false">Plik graficzny można przypisać do użytkownika poprzez przeciągnięcie i upuszczenie pliku bezpośrednio na obszar przesyłania obrazu (w przypadku korzystania z komputera PC) lub przez kliknięcie obszaru przesyłania i wybranie obrazu, który chcesz przesłać. Wymiary obrazu zostaną zmniejszone do 480 x 640 pikseli (proporcje 3:4), jeśli przekroczą tę wartość, dlatego zaleca się, aby przesyłane obrazy spełniały te wymagania w celu uzyskania optymalnej jakości. Obraz można przyciąć za pomocą przycisku Edytuj lub usunąć za pomocą przycisku Usuń.</TranslationEntry>
    <TranslationEntry name="0B12D0A75AB5D243B5D4EF5F51B0E54E" fullContext="D2AC374A5DC3708533A76B7AD5AE8394" translateForJs="false">Zdjęcia można przypisywać do użytkowników zbiorczo przy użyciu </TranslationEntry>
    <TranslationEntry name="266E68E7AE13E3C9B917CC46C6603DB9" fullContext="266E68E7AE13E3C9B917CC46C6603DB9" translateForJs="false">Importuj zdjęcia użytkowników</TranslationEntry>
    <TranslationEntry name="458D823822DB53231E14F9E4D51C20EC" fullContext="D2AC374A5DC3708533A76B7AD5AE8394" translateForJs="false"> przycisk, aby przesłać plik ZIP z wieloma plikami obrazów dla różnych użytkowników. Aby uzyskać więcej informacji, kliknij </TranslationEntry>
    <TranslationEntry name="FB8ABC447C2F4009DAD7C73A3AADA875" fullContext="D2AC374A5DC3708533A76B7AD5AE8394" translateForJs="false"> przycisk, aby otworzyć okno dialogowe importu.</TranslationEntry>
    <TranslationEntry name="92A5A170977865D175F19DC21C08BB2C" fullContext="5AA06008B37D4C0E5D8795293EFDC920" translateForJs="false">Adres e-mail używany do wysyłania powiadomień e-mail do tego użytkownika.</TranslationEntry>
    <TranslationEntry name="177B1B3F8218CFD8ED00528B85D00952" fullContext="5AA06008B37D4C0E5D8795293EFDC920" translateForJs="false">Tę opcję można pozostawić pustą, jeśli powiadomienia e-mail dla tego użytkownika nie są używane. W przeciwnym razie adres musi mieć prawidłowy format, taki jak jsmith@example.com.</TranslationEntry>
    <TranslationEntry name="DB15410F3C267D4DBE17D24B34A97C13" translateForJs="false">Wygaśnięcie / Anulowanie</TranslationEntry>
    <TranslationEntry name="0352EDE804A9C221513C9E6D563A13AF" fullContext="DEC2AF7DDB168383C3A5A0456760FBE1" translateForJs="false">Włącz wygaśnięcie użytkownika</TranslationEntry>
    <TranslationEntry name="3B3701EDF8DACFDE53D39CBF037B1337" fullContext="B7406145C6C6857E9DC6F6604446E792" translateForJs="false">Jeśli włączone, użytkownik nie będzie miał dostępu do systemu przed </TranslationEntry>
    <TranslationEntry name="466BE8FC3E50D2C5685FF7B4C8F3D947" fullContext="C59951F75D1665052A2812FFEED68992" translateForJs="false">Czas rozpoczęcia użytkownika</TranslationEntry>
    <TranslationEntry name="12DDD08FD8E599B7BCDD8842DA5D2CF3" fullContext="B7406145C6C6857E9DC6F6604446E792" translateForJs="false"> jeśli zostało podane, lub po </TranslationEntry>
    <TranslationEntry name="3B1417F3A62844249B7AE30F492793F8" fullContext="C59951F75D1665052A2812FFEED68992" translateForJs="false">Czas wygaśnięcia użytkownika</TranslationEntry>
    <TranslationEntry name="89D26259E3A4D4094CEA8F4A6C2A9A8D" fullContext="B7406145C6C6857E9DC6F6604446E792" translateForJs="false"> jeśli jest podany. Jeśli użytkownik jest pozbawiony dostępu do systemu, wyłączenie tej opcji lub zmiana czasu rozpoczęcia lub wygaśnięcia ponownie aktywuje użytkownika.</TranslationEntry>
    <TranslationEntry name="958A9DA229B7C48BA446C4FC05F8179F" fullContext="B7406145C6C6857E9DC6F6604446E792" translateForJs="false">Wygasanie konta użytkownika jest powszechnie stosowane dla wykonawców lub innych użytkowników, którzy wymagają dostępu do systemu przez ograniczony czas. Umożliwia skonfigurowanie konta z wyprzedzeniem z identyfikatorami i uprawnieniami, ale aktywację dopiero w przyszłym czasie. Podobnie użytkownik może być automatycznie ograniczony w celu uniemożliwienia dostępu w określonej dacie i godzinie w przyszłości, eliminując konieczność ręcznej edycji lub usuwania użytkownika przez administratora.</TranslationEntry>
    <TranslationEntry name="CAE53252C3CA2AF3FC88288B7B9D6BDB" fullContext="B7406145C6C6857E9DC6F6604446E792" translateForJs="false">Po wygaśnięciu ten użytkownik nie będzie mógł wchodzić w interakcję z systemem w żaden sposób — dostęp do interfejsu internetowego i terminala LCD zostanie zablokowany, identyfikatory przestaną działać przy czytnikach, pilot RF nie będzie działać i użytkownik nie będzie już otrzymywał powiadomień.</TranslationEntry>
    <TranslationEntry name="5E046C7A90CA8FCC7734FD1A9F3388CA" fullContext="335EBED8318AF93F04132DDA7B0ECD9F" translateForJs="false">Określa datę i godzinę, od której ten użytkownik staje się ważny. Jeśli ustawione w przyszłości, użytkownik nie będzie miał dostępu do systemu. Ta opcja będzie stosowana tylko gdy </TranslationEntry>
    <TranslationEntry name="D3570493B7D9A9228EC623916FC23B14" fullContext="335EBED8318AF93F04132DDA7B0ECD9F" translateForJs="false"> opcja powyżej jest włączona. Jeśli puste, nie będzie używana żadna godzina rozpoczęcia.</TranslationEntry>
    <TranslationEntry name="ED960F3B7A2CE8855B43BABD7533D58D" fullContext="DEC2AF7DDB168383C3A5A0456760FBE1" translateForJs="false">Zapoznaj się z opisem opcji włączenia powyżej, aby uzyskać więcej informacji na temat wygasania konta użytkownika.</TranslationEntry>
    <TranslationEntry name="3F07B1817A7A9D248F48806CFEB83E2E" fullContext="DEC2AF7DDB168383C3A5A0456760FBE1" translateForJs="false">Określa datę i czas wygaśnięcia użytkownika. Ta opcja będzie stosowana tylko wtedy, gdy </TranslationEntry>
    <TranslationEntry name="7B9DB767EBD905F9E16D28180FCD3FDB" fullContext="DEC2AF7DDB168383C3A5A0456760FBE1" translateForJs="false"> opcja powyżej jest włączona. Jeśli pole jest puste, nie zostanie zastosowana data wygaśnięcia.</TranslationEntry>
    <TranslationEntry name="36A73022A5584D172C891C3F0F83E2D9" translateForJs="false">Kiedy anulować użytkownika</TranslationEntry>
    <TranslationEntry name="502E810C608B2327B81B126369D0590C" fullContext="6B4A05F6B5763C9CE66CAB6C47B7F742" translateForJs="false">Jeśli skonfigurowano, użytkownik zostanie anulowany, gdy pierwszy raz przedstawi swój identyfikator systemowi. W zależności od konfiguracji może to być karta lub PIN.</TranslationEntry>
    <TranslationEntry name="BC3A921612E0BB7A399755F17799A631" fullContext="6B4A05F6B5763C9CE66CAB6C47B7F742" translateForJs="false">Ta funkcja jest często stosowana, gdy jednorazowe identyfikatory są wydawane gościom w celu uzyskania dostępu do obiektu, co uniemożliwia nieograniczony dostęp w przypadku kradzieży karty. Powyższe opcje wygasania konta użytkownika mogą być również używane do zarządzania kartami gości, umożliwiając dostęp tylko przez dany dzień. Ta opcja natomiast pozwala na wcześniejsze tworzenie wielu kart (po jednej na użytkownika) i wydawanie ich według potrzeb, bez konieczności logowania się do systemu Inception i aktualizowania czasu wygaśnięcia na dany dzień.</TranslationEntry>
    <TranslationEntry name="70B5B3850AF3E041BF00805BCF1F499F" fullContext="6B4A05F6B5763C9CE66CAB6C47B7F742" translateForJs="false">Po użyciu identyfikatora i anulowaniu przez użytkownika, pole wyboru Anulowane przez użytkownika poniżej zostanie automatycznie zaznaczone. Aby zresetować użytkownika i umożliwić ponowne użycie identyfikatora, odznacz to pole i zapisz użytkownika.</TranslationEntry>
    <TranslationEntry name="A8CEA4F8F7E2E921C4822A2F4CB56FB4" translateForJs="false">Anulowano przez użytkownika</TranslationEntry>
    <TranslationEntry name="383A4BF7665C75791BB0303F73141EDA" fullContext="02F6752B0F90C5A2A9F297A85A7E234F" translateForJs="false">Jeśli włączone, użytkownik będzie pozbawiony dostępu do systemu w jakikolwiek sposób, podobnie jak w przypadku wygaśnięcia użytkownika opisanego powyżej. Ta opcja jest automatycznie włączana po użyciu powyższej opcji Kiedy anulować użytkownika.</TranslationEntry>
    <TranslationEntry name="243176C27AB5777A2232BD28B37A405F" fullContext="02F6752B0F90C5A2A9F297A85A7E234F" translateForJs="false">Użytkownika można zresetować przez odznaczenie tej opcji i zapisanie użytkownika.</TranslationEntry>
    <TranslationEntry name="56DDF8D6DD1DEFE43BA14CB278CF8227" translateForJs="false">Odwołaj mobilne identyfikatory po wygaśnięciu</TranslationEntry>
    <TranslationEntry name="44B7437DD9AE9B90784327EACB9700E7" fullContext="170AD0632B107256F74FD8D7F2E00946" translateForJs="false">Jeśli włączone, mobilne identyfikatory tego użytkownika zostaną unieważnione po upływie czasu wygaśnięcia użytkownika. Domyślnie ta opcja jest odznaczona.</TranslationEntry>
    <TranslationEntry name="F1BFC63F41D77D70877B65839A2C7B4E" translateForJs="false">Użytkownicy alarmowi</TranslationEntry>
    <TranslationEntry name="BB5FE5CD9C8C778E81B05EF53C166612" fullContext="BB5FE5CD9C8C778E81B05EF53C166612" translateForJs="false">Dozwolone</TranslationEntry>
    <TranslationEntry name="DC357E6904380D5B6971AB214A6BAF99" fullContext="DC357E6904380D5B6971AB214A6BAF99" translateForJs="false">Dodaj uprawnienia do tego użytkownika. Można dodawać uprawnienia do konkretnych przejść, stref lub linii wyjściowych albo dodawać całe grupy uprawnień.</TranslationEntry>
    <TranslationEntry name="27D4CF7DA57F6748F79254F7BE42CCA3" translateForJs="false" rules="unique=ConditionInvert" notes="Must be unique amongst all &quot;ConditionInvert&quot; entries">Jest</TranslationEntry>
    <TranslationEntry name="701519CA6569F5C49F01859407602744" translateForJs="false" rules="unique=ConditionInvert" notes="Must be unique amongst all &quot;ConditionInvert&quot; entries">Nie jest</TranslationEntry>
    <TranslationEntry name="5789318115BC66337C7899FE2FE7B321" translateForJs="false">Filtruj wg typu alarmu</TranslationEntry>
    <TranslationEntry name="AD647E4AE904C7ED54EE93040D8298C7" translateForJs="false" rules="unique=UserCountOption" notes="Must be unique amongst all &quot;UserCountOption&quot; entries">Mniejszy niż</TranslationEntry>
    <TranslationEntry name="B08FB2EF6BFAA1668F29E0688B3A8D6B" translateForJs="false" rules="unique=UserCountOption" notes="Must be unique amongst all &quot;UserCountOption&quot; entries">Mniejszy lub równy</TranslationEntry>
    <TranslationEntry name="495C04002891BEBF41BC3B56507F6D6B" translateForJs="false" rules="unique=UserCountOption" notes="Must be unique amongst all &quot;UserCountOption&quot; entries">Równe</TranslationEntry>
    <TranslationEntry name="F4378D495AB4BF1E4B2A4F7911988B6D" translateForJs="false" rules="unique=UserCountOption" notes="Must be unique amongst all &quot;UserCountOption&quot; entries">Większy lub równy</TranslationEntry>
    <TranslationEntry name="05824B7BE006782AAEFD1FDB97C71E06" translateForJs="false" rules="unique=UserCountOption" notes="Must be unique amongst all &quot;UserCountOption&quot; entries">Większy niż</TranslationEntry>
    <TranslationEntry name="054B4F3EA543C990F6B125F41AF6EBF7" translateForJs="false">Opcja</TranslationEntry>
    <TranslationEntry name="EFA0E73AB3C65289E2F1C85E194DEF73" fullContext="EFA0E73AB3C65289E2F1C85E194DEF73" translateForJs="false">Liczba użytkowników</TranslationEntry>
    <TranslationEntry name="77BEE7B9DE717D1997969D983932597F" translateForJs="false">Akcja czytnika</TranslationEntry>
    <TranslationEntry name="FD00DD3C4E88A3620CDDC9D79373ED88" translateForJs="false" rules="unique=ReaderAction" notes="Must be unique amongst all &quot;ReaderAction&quot; entries">Prawidłowy PIN</TranslationEntry>
    <TranslationEntry name="5CE7844059C214F9678F73DA24691ADE" translateForJs="false" rules="unique=ReaderAction" notes="Must be unique amongst all &quot;ReaderAction&quot; entries">Pojedynczy odczyt</TranslationEntry>
    <TranslationEntry name="B1DC91013F31460A71A619FF2A20D42E" translateForJs="false" rules="unique=ReaderAction" notes="Must be unique amongst all &quot;ReaderAction&quot; entries">Akcja 2-krotnego odczytu karty</TranslationEntry>
    <TranslationEntry name="B840A50ED310B89ACE43EFB79D01365C" translateForJs="false" rules="unique=ReaderAction" notes="Must be unique amongst all &quot;ReaderAction&quot; entries">Akcja 3-krotnego odczytu karty</TranslationEntry>
    <TranslationEntry name="A5B739036B4D0B2BC966291747198D9B" translateForJs="true">Zarejestrowany</TranslationEntry>
    <TranslationEntry name="9CE6F77A29FCBC22956D59FE0AC263E6" fullContext="28AF362531F9F7BC894A4113BC6153D0" translateForJs="false">Uprawnienia do edycji elementów</TranslationEntry>
    <TranslationEntry name="DA88797D7AC94A89FF7606683A5055A9" fullContext="A9CB4B60E371C8EEBB3A7AD2EA8BDC82" translateForJs="false">Określa możliwość interakcji użytkownika z </TranslationEntry>
    <TranslationEntry name="70E32069D64DC6DA7398246EB735FE96" fullContext="3B0AFF68AE5895245BFD12431E933A65" translateForJs="false">[Raportowanie alarmów]</TranslationEntry>
    <TranslationEntry name="C3A464F0A63B91D1FF779D0935ACA7A5" fullContext="6B8EF1D1AA5AFA0C5C2D728CA9B7EC97" translateForJs="false"> - Strona nie będzie dostępna. </TranslationEntry>
    <TranslationEntry name="4351CFEBE4B61D8AA5EFA1D020710005" fullContext="A9CB4B60E371C8EEBB3A7AD2EA8BDC82" translateForJs="false">Wyświetl</TranslationEntry>
    <TranslationEntry name="C3468975B85E6F61D6D6DAA00AE17B41" fullContext="3B0AFF68AE5895245BFD12431E933A65" translateForJs="false"> strona może być wyświetlana, umożliwiając użytkownikowi podgląd bieżących ustawień bez możliwości ich modyfikacji. Użytkownik będzie mógł wysłać ręczny raport testowy, lecz nie będzie mógł pobrać </TranslationEntry>
    <TranslationEntry name="45114C7EE968DB751FAD87AF7B5F0EF0" fullContext="3B0AFF68AE5895245BFD12431E933A65" translateForJs="false">Raport Contact ID</TranslationEntry>
    <TranslationEntry name="7F090BBAB1CC7F9C08BF4E54D932D3C0" fullContext="A9CB4B60E371C8EEBB3A7AD2EA8BDC82" translateForJs="false" rules="unique=OperatorPermission" notes="Must be unique amongst all &quot;OperatorPermission&quot; entries">Modyfikuj</TranslationEntry>
    <TranslationEntry name="C2C9AF8BDB41DBD2F9622CA668488D7B" fullContext="3B0AFF68AE5895245BFD12431E933A65" translateForJs="false"> strona może być wyświetlana, a ustawienia mogą być edytowane. Użytkownik będzie mógł pobrać </TranslationEntry>
    <TranslationEntry name="634421F0AA9CF407232E7A1141B396D2" fullContext="DD3A449EA80B9B8C688C9BE5B354E9F9" translateForJs="false">[Edytuj strefy]</TranslationEntry>
    <TranslationEntry name="420508534515B704C39887A0F8FF73EB" fullContext="6E0E9EE32ADF90C026F9F75434458712" translateForJs="false">[Tworzenie strefy]</TranslationEntry>
    <TranslationEntry name="CE99D65100571E56B86D92D60D803C77" fullContext="6E0E9EE32ADF90C026F9F75434458712" translateForJs="false">[Test strefy]</TranslationEntry>
    <TranslationEntry name="FB734D56765BC48D3D7113C1DA8FAACC" fullContext="B80EBB85C768670EABEE7298C017EC47" translateForJs="false"> stron.</TranslationEntry>
    <TranslationEntry name="77D8E930B4E86425376E53E38A83A849" fullContext="6E0E9EE32ADF90C026F9F75434458712" translateForJs="false"> strony będą niedostępne. </TranslationEntry>
    <TranslationEntry name="D4367E115F5987D36CF75957142A87B2" fullContext="6E0E9EE32ADF90C026F9F75434458712" translateForJs="false"> strony mogą być wyświetlane, umożliwiając użytkownikowi podgląd bieżących ustawień bez możliwości ich modyfikacji. </TranslationEntry>
    <TranslationEntry name="88A99E9B306B4AB3076A421579985F63" fullContext="6E0E9EE32ADF90C026F9F75434458712" translateForJs="false"> strony będą niedostępne.</TranslationEntry>
    <TranslationEntry name="C407FE00095F87E803F575C9F07F3662" fullContext="6E0E9EE32ADF90C026F9F75434458712" translateForJs="false"> strona może być przeglądana, a ustawienia mogą być edytowane.  </TranslationEntry>
    <TranslationEntry name="73136513474BA867FF54D8D85091A76A" fullContext="6E0E9EE32ADF90C026F9F75434458712" translateForJs="false"> strony mogą być przeglądane, a ustawienia mogą być edytowane.</TranslationEntry>
    <TranslationEntry name="F3628BFF617623E57EC7CA4BE79C5CC6" fullContext="6E0E9EE32ADF90C026F9F75434458712" translateForJs="false">Uwaga: możliwość sterowania strefami przez użytkownika na </TranslationEntry>
    <TranslationEntry name="5319258BAC6CEA0EDFD8167206F589A0" fullContext="6E0E9EE32ADF90C026F9F75434458712" translateForJs="false"> strona jest określana przez uprawnienia użytkownika oraz </TranslationEntry>
    <TranslationEntry name="69622FD468984C89A48BA110D63031D2" fullContext="6E0E9EE32ADF90C026F9F75434458712" translateForJs="false">Stan strefy</TranslationEntry>
    <TranslationEntry name="593667064F407BBA35F88E0A10487D31" fullContext="28AF362531F9F7BC894A4113BC6153D0" translateForJs="false">Uprawnienia monitorowania elementów</TranslationEntry>
    <TranslationEntry name="0BB3B6AD14C43422F805C4E0BBBAC9B8" fullContext="6E0E9EE32ADF90C026F9F75434458712" translateForJs="false"> sekcji ich profilu strony internetowej.</TranslationEntry>
    <TranslationEntry name="7A8BB3FA32F0F70BE641C397FE7452BB" fullContext="903F806917407F7BCDDE420AB8D31C11" translateForJs="false">[Akcje automatyczne]</TranslationEntry>
    <TranslationEntry name="7E434FD6205F46281009E6D281DC2988" fullContext="0DABD2458FAAB4C35FE598572B2D3D85" translateForJs="false"> strona może być wyświetlana, umożliwiając użytkownikowi podgląd bieżących ustawień bez możliwości ich modyfikacji. </TranslationEntry>
    <TranslationEntry name="8DE6967A947A03ED8A54C72A93A8AF1B" fullContext="B3BEECC00F853BD688B7C23EC464FAB4" translateForJs="false"> strona może być przeglądana, a ustawienia mogą być edytowane.</TranslationEntry>
    <TranslationEntry name="F94BE691055584C1246F12E2651731EF" fullContext="AC6A8A42154E4083A40EA3C3EDA22DC9" translateForJs="false">[Kalendarz]</TranslationEntry>
