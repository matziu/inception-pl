    <TranslationEntry name="0ABDFD715970BD0EF7D5574DAA0E6D0B" translateForJs="false" rules="unique=CalculatedWeek" notes="Must be unique amongst all &quot;CalculatedWeek&quot; entries">Piąty</TranslationEntry>
    <TranslationEntry name="D55B30607C2A9A2616347D6EDB789F6B" translateForJs="false" rules="unique=CalculatedWeek" notes="Must be unique amongst all &quot;CalculatedWeek&quot; entries">Ostatni</TranslationEntry>
    <TranslationEntry name="B55FF07B999F2C9F3A9342486D220074" translateForJs="false" rules="unique=CalculatedWeek" notes="Must be unique amongst all &quot;CalculatedWeek&quot; entries">Wszystkie tygodnie</TranslationEntry>
    <TranslationEntry name="86F5978D9B80124F509BDB71786E929E" translateForJs="false" rules="unique=CalculatedMonth" notes="Must be unique amongst all &quot;CalculatedMonth&quot; entries">Styczeń</TranslationEntry>
    <TranslationEntry name="659E59F062C75F81259D22786D6C44AA" translateForJs="false" rules="unique=CalculatedMonth" notes="Must be unique amongst all &quot;CalculatedMonth&quot; entries">Luty</TranslationEntry>
    <TranslationEntry name="FA3E5EDAC607A88D8FD7ECB9D6D67424" translateForJs="false" rules="unique=CalculatedMonth" notes="Must be unique amongst all &quot;CalculatedMonth&quot; entries">Marzec</TranslationEntry>
    <TranslationEntry name="3FCF026BBFFFB63FB24B8DE9D0446949" translateForJs="false" rules="unique=CalculatedMonth" notes="Must be unique amongst all &quot;CalculatedMonth&quot; entries">Kwiecień</TranslationEntry>
    <TranslationEntry name="195FBB57FFE7449796D23466085CE6D8" translateForJs="false" rules="unique=CalculatedMonth" notes="Must be unique amongst all &quot;CalculatedMonth&quot; entries">Maj</TranslationEntry>
    <TranslationEntry name="688937CCAF2A2B0C45A1C9BBBA09698D" translateForJs="false" rules="unique=CalculatedMonth" notes="Must be unique amongst all &quot;CalculatedMonth&quot; entries">Czerwiec</TranslationEntry>
    <TranslationEntry name="1B539F6F34E8503C97F6D3421346B63C" translateForJs="false" rules="unique=CalculatedMonth" notes="Must be unique amongst all &quot;CalculatedMonth&quot; entries">Lipiec</TranslationEntry>
    <TranslationEntry name="41BA70891FB6F39327D8CCB9B1DAFB84" translateForJs="false" rules="unique=CalculatedMonth" notes="Must be unique amongst all &quot;CalculatedMonth&quot; entries">Sierpień</TranslationEntry>
    <TranslationEntry name="CC5D90569E1C8313C2B1C2AAB1401174" translateForJs="false" rules="unique=CalculatedMonth" notes="Must be unique amongst all &quot;CalculatedMonth&quot; entries">Wrzesień</TranslationEntry>
    <TranslationEntry name="ECA60AE8611369FE28A02E2AB8C5D12E" translateForJs="false" rules="unique=CalculatedMonth" notes="Must be unique amongst all &quot;CalculatedMonth&quot; entries">Październik</TranslationEntry>
    <TranslationEntry name="7E823B37564DA492CA1629B4732289A8" translateForJs="false" rules="unique=CalculatedMonth" notes="Must be unique amongst all &quot;CalculatedMonth&quot; entries">Listopad</TranslationEntry>
    <TranslationEntry name="82331503174ACBAE012B2004F6431FA5" translateForJs="false" rules="unique=CalculatedMonth" notes="Must be unique amongst all &quot;CalculatedMonth&quot; entries">Grudzień</TranslationEntry>
    <TranslationEntry name="BE873CEBF52D0CAE5ADF462C301D30C9" translateForJs="false" rules="unique=CalculatedMonth" notes="Must be unique amongst all &quot;CalculatedMonth&quot; entries">Nieparzyste miesiące</TranslationEntry>
    <TranslationEntry name="4468F933EB1CE32F32D6BC920852005A" translateForJs="false" rules="unique=CalculatedMonth" notes="Must be unique amongst all &quot;CalculatedMonth&quot; entries">Parzyste miesiące</TranslationEntry>
    <TranslationEntry name="ABBA00A10BFEAA1F2FF41A9FA7636E5E" translateForJs="false" rules="unique=CalculatedMonth" notes="Must be unique amongst all &quot;CalculatedMonth&quot; entries">Wszystkie miesiące</TranslationEntry>
    <TranslationEntry name="D2CE009594DCC60BEFA6A4E6CBEB71FC" translateForJs="false">Tydzień</TranslationEntry>
    <TranslationEntry name="7CBB885AA1164B390A0BC050A64E1812" translateForJs="false">Miesiąc</TranslationEntry>
    <TranslationEntry name="8FF922BBCD8AD41CDFC48D3C5163B2AB" fullContext="331B158352203C5E0CAEC312FDEA882B" translateForJs="false">Kalendarz</TranslationEntry>
    <TranslationEntry name="D3EAD10143F061065B48FFEFF5E89D79" translateForJs="false">Pojedyncze daty</TranslationEntry>
    <TranslationEntry name="1048BB26F45C7D518CF59A4735A29FC5" fullContext="BC62BFD3687B9D269891CF66D64A8660" translateForJs="false">Dodaje konkretną datę, w której ten kalendarz powinien być aktywny, z możliwością corocznego powtarzania. Można go użyć do tworzenia wyjątków jednodniowych, takich jak święta publiczne. </TranslationEntry>
    <TranslationEntry name="EEFC93CC05391D383BF72CD741AB1190" fullContext="BC62BFD3687B9D269891CF66D64A8660" translateForJs="false">Aby dodać kolejne pojedyncze daty, kliknij </TranslationEntry>
    <TranslationEntry name="36E8CB0443861F0B7070BC3D3FFEB089" fullContext="BC62BFD3687B9D269891CF66D64A8660" translateForJs="false"> przycisk — spowoduje to dodanie pustego elementu pojedynczej daty.</TranslationEntry>
    <TranslationEntry name="C687854CD101B9AC8BEC968EC16386BB" translateForJs="false">Zakresy dat</TranslationEntry>
    <TranslationEntry name="1D686C69BB199C728471E7EFB8FC8C2A" fullContext="7640E471D7A5372DCCC54E88AF8AEAA0" translateForJs="false">Dodaje zakres dat, w których ten kalendarz powinien być aktywny, z możliwością corocznego powtarzania. Można go użyć do tworzenia wyjątków zakresów dat, takich jak ferie szkolne. </TranslationEntry>
    <TranslationEntry name="765F6219CFAAA99481464A287CC8370E" fullContext="7640E471D7A5372DCCC54E88AF8AEAA0" translateForJs="false">Aby dodać kolejne zakresy dat, kliknij </TranslationEntry>
    <TranslationEntry name="DA53A060AFBC2304D69490694508C195" fullContext="7640E471D7A5372DCCC54E88AF8AEAA0" translateForJs="false"> przycisk — spowoduje to dodanie pustego elementu zakresu dat.</TranslationEntry>
    <TranslationEntry name="D8D4184C6DB6425C563FD051842AE901" translateForJs="false">Obliczone daty</TranslationEntry>
    <TranslationEntry name="7BD2073E4A5607DEDC524150441E44A7" fullContext="2DC7686EC87ECB866C5DCD4B2FD062F5" translateForJs="false">Ustawia zdarzenie kalendarza, które nie mieści się w formacie pojedynczej daty lub zakresu dat. Można go użyć do tworzenia obliczeniowego wyjątku datowego określającego, kiedy ten kalendarz powinien być aktywny, np. drugiego wtorku każdego miesiąca. </TranslationEntry>
    <TranslationEntry name="0B59D1BCB54759D897E4D59E06AC0EFB" fullContext="2DC7686EC87ECB866C5DCD4B2FD062F5" translateForJs="false">Aby dodać kolejne daty obliczeniowe, kliknij </TranslationEntry>
    <TranslationEntry name="074DF222865FC0081A424C1E016DD9E4" fullContext="2DC7686EC87ECB866C5DCD4B2FD062F5" translateForJs="false"> przycisk — spowoduje to dodanie pustego elementu daty wyliczonej.</TranslationEntry>
    <TranslationEntry name="111B743E2D0F187ACF7592BABD941F55" fullContext="96BAB33EA2D1E9AB3B5570E8F64D3434" translateForJs="false">Format karty</TranslationEntry>
    <TranslationEntry name="21CF28139E717C69CB23E8DC994758C3" translateForJs="false">Formaty kart</TranslationEntry>
    <TranslationEntry name="55029D3079DA7455D85ECD89621B2AE5" translateForJs="false">Parametry kodu obiektu</TranslationEntry>
    <TranslationEntry name="077CFEBBF3441D079573DAA2F7CF4791" translateForJs="false">Łączna liczba bitów</TranslationEntry>
    <TranslationEntry name="4C011A42E50D9ADE09ED790A44C41FCF" translateForJs="false">Łączna liczba bitów danych karty.</TranslationEntry>
    <TranslationEntry name="6B34486801CA6D30840A53E60713716C" fullContext="6B34486801CA6D30840A53E60713716C" translateForJs="false">Szablon identyfikatora</TranslationEntry>
    <TranslationEntry name="0DB377921F4CE762C62526131097968F" fullContext="0DB377921F4CE762C62526131097968F" translateForJs="false">Ogólny</TranslationEntry>
    <TranslationEntry name="733D720CFFCCF190FC732EAA2F0C2B11" fullContext="3F44E5EB3241850433259EFF15F790E5" translateForJs="false">Typ identyfikatora</TranslationEntry>
    <TranslationEntry name="16FAFD2A47E3647C22D026A6B2A642B8" fullContext="B2958F54BA8537D6303C09FF6BBA34A8" translateForJs="false">Typ identyfikatora określa, w jaki sposób system będzie kategoryzować i przetwarzać dane identyfikatora pasujące do danego szablonu identyfikatora. Jeśli używasz uwierzytelniania dwu- lub trójskładnikowego do kontroli dostępu do przejść, musisz utworzyć odpowiednią liczbę szablonów identyfikatorów różnych typów, aby spełnić wymagania dostępu do przejścia. Na przykład: w przypadku przejścia skonfigurowanego z uwierzytelnianiem dwuskładnikowym może być wymagane, aby użytkownik przedstawił jednocześnie unikalną kartę oraz identyfikator biometryczny — odcisk palca, zanim zostanie mu przyznany dostęp przez przejście.</TranslationEntry>
    <TranslationEntry name="1D565B9E5303987BB1B1938D5D458BCA" fullContext="1AB4E4DEDE57D499781EB0378B5F9F8C" translateForJs="false" rules="unique=CredentialTemplateCategory" notes="Must be unique amongst all &quot;CredentialTemplateCategory&quot; entries">Karta</TranslationEntry>
    <TranslationEntry name="700A98323EB53D18E37FBD44518F9C94" fullContext="B2958F54BA8537D6303C09FF6BBA34A8" translateForJs="false"> - Identyfikatory korzystające z tego szablonu będą klasyfikowane jako karty. </TranslationEntry>
    <TranslationEntry name="762541BE63FD48CE7283EA3882161A6A" fullContext="1AB4E4DEDE57D499781EB0378B5F9F8C" translateForJs="false" rules="unique=CredentialTemplateCategory" notes="Must be unique amongst all &quot;CredentialTemplateCategory&quot; entries">Biometryczny - Odcisk palca</TranslationEntry>
    <TranslationEntry name="AC5491260574348014D0AB9F416F14E4" fullContext="B2958F54BA8537D6303C09FF6BBA34A8" translateForJs="false"> - Identyfikatory korzystające z tego szablonu będą klasyfikowane jako dane ze skanowania linii papilarnych.</TranslationEntry>
    <TranslationEntry name="1B1A0FF428E0BB3EB3D85211E83D5CAE" fullContext="1AB4E4DEDE57D499781EB0378B5F9F8C" translateForJs="false" rules="unique=CredentialTemplateCategory" notes="Must be unique amongst all &quot;CredentialTemplateCategory&quot; entries">Biometryczny — rozpoznawanie twarzy</TranslationEntry>
    <TranslationEntry name="8C45290D7B7F566A4604C156A0BBD7C0" fullContext="B2958F54BA8537D6303C09FF6BBA34A8" translateForJs="false"> - Identyfikatory korzystające z tego szablonu będą klasyfikowane jako dane ze skanowania twarzy.</TranslationEntry>
    <TranslationEntry name="DD7700B32A0646AAC1BC2DBD61C0DB30" fullContext="1AB4E4DEDE57D499781EB0378B5F9F8C" translateForJs="false" rules="unique=CredentialTemplateCategory" notes="Must be unique amongst all &quot;CredentialTemplateCategory&quot; entries">Biometryczny - tęczówka</TranslationEntry>
    <TranslationEntry name="13FFF67724EAA2953306A459AD474BB4" fullContext="B2958F54BA8537D6303C09FF6BBA34A8" translateForJs="false"> - Identyfikatory korzystające z tego szablonu będą przetwarzane jako dane skanu tęczówki/oka.</TranslationEntry>
    <TranslationEntry name="F126B8FC4427A670744EE55FD9A5E4BF" translateForJs="false">Typ szablonu</TranslationEntry>
    <TranslationEntry name="9603B8004FAB2E3852BDCFC410690C25" fullContext="2BC16735DF793FD7ABF58456887E1D2C" translateForJs="false" rules="unique=CredentialTemplateCategory" notes="Must be unique amongst all &quot;CredentialTemplateCategory&quot; entries">Rozpoznawanie tablic rejestracyjnych (LPR)</TranslationEntry>
    <TranslationEntry name="048BB203ABDDA4DFB0E4422576968F4F" translateForJs="false" rules="unique=TemplateType" notes="Must be unique amongst all &quot;TemplateType&quot; entries">Kod obiektu + numer identyfikatora</TranslationEntry>
    <TranslationEntry name="2C37DB5761727358B07F88BFD5B9B16D" fullContext="96BAB33EA2D1E9AB3B5570E8F64D3434" translateForJs="false" rules="unique=TemplateType" notes="Must be unique amongst all &quot;TemplateType&quot; entries">Surowy (bezpośrednie wprowadzanie)</TranslationEntry>
    <TranslationEntry name="E01AECB528730F3BFE10F9D57F1317BF" translateForJs="false" rules="unique=TemplateType" notes="Must be unique amongst all &quot;TemplateType&quot; entries">Integracje</TranslationEntry>
    <TranslationEntry name="F94D81150CE1E4F2384B3A8C27987BD7" fullContext="96BAB33EA2D1E9AB3B5570E8F64D3434" translateForJs="false">Typ szablonu określa, w jaki sposób system będzie przechowywał i używał danych identyfikatora. </TranslationEntry>
    <TranslationEntry name="E4F45B3609F22885865384E4BA7C185D" fullContext="96BAB33EA2D1E9AB3B5570E8F64D3434" translateForJs="false">Kod obiektu i numer identyfikatora</TranslationEntry>
    <TranslationEntry name="8C928FEDF80A93AF07CB9D9BCD95A6F4" fullContext="96BAB33EA2D1E9AB3B5570E8F64D3434" translateForJs="false"> wybrany typ szablonu, </TranslationEntry>
    <TranslationEntry name="AA144854B75E83025AD6FC2EE303BF4A" fullContext="96BAB33EA2D1E9AB3B5570E8F64D3434" translateForJs="false">Kod obiektu</TranslationEntry>
    <TranslationEntry name="7CE087D4A6F9F6D330B6A637701E9E2F" fullContext="96BAB33EA2D1E9AB3B5570E8F64D3434" translateForJs="false"> pola będą widoczne poniżej. Podczas przypisywania identyfikatora do użytkownika najpierw wybierz szablon, a następnie wprowadź numer identyfikatora. </TranslationEntry>
    <TranslationEntry name="45DFC8BC9F3A4A71C81F894D9D8C0A60" fullContext="96BAB33EA2D1E9AB3B5570E8F64D3434" translateForJs="false"> pola nie będą widoczne poniżej. Podczas przypisywania identyfikatora do użytkownika najpierw wybierz szablon, przyłóż identyfikator do czytnika i skopiuj surowe dane identyfikatora z </TranslationEntry>
    <TranslationEntry name="034284AE651535CEAB87B843B86031E0" fullContext="8A5FFA7911C9A3201038BEC48A15161D" translateForJs="false">[Stan / Sterowanie &gt; Rejestr zdarzeń]</TranslationEntry>
    <TranslationEntry name="CFA7D127019D331D732BE6C799E2C4EC" fullContext="4DE6F3C5676CA32603A30DE25EB00DA1" translateForJs="false"> strona.</TranslationEntry>
    <TranslationEntry name="734CF81EF3261C8B4F277322E2EC751C" fullContext="306F094EA6322BCC6D8FCC01F6615AC8" translateForJs="false">Wybierz format karty odpowiadający używanym kartom. Jeśli używany jest więcej niż jeden format karty, konieczne będzie utworzenie dodatkowych szablonów identyfikatorów. </TranslationEntry>
    <TranslationEntry name="8D661E98295FF4529E46BA3DC0DA8D34" fullContext="306F094EA6322BCC6D8FCC01F6615AC8" translateForJs="false">Jeśli nie wiesz, jaki format mają Twoje karty, otwórz </TranslationEntry>
    <TranslationEntry name="29CE60D99522B38318BAC51D9DB9ECE0" fullContext="DE610CBB2B243D1B1A3F5320A9CFC4B1" translateForJs="false"> strona i przyłóż kartę do czytnika. Najnowszy </TranslationEntry>
    <TranslationEntry name="17E2FE91C8D88D7F29F045DD534594F6" fullContext="306F094EA6322BCC6D8FCC01F6615AC8" translateForJs="false">Odczyt identyfikatora nie powiódł się z powodu nieznanego kodu obiektu</TranslationEntry>
    <TranslationEntry name="481F034A273C13303CD440406E713E68" fullContext="306F094EA6322BCC6D8FCC01F6615AC8" translateForJs="false"> komunikat będzie zawierał format karty.</TranslationEntry>
    <TranslationEntry name="549C603554741876A9834C010A143148" fullContext="306F094EA6322BCC6D8FCC01F6615AC8" translateForJs="false">Jeśli wymagany format karty nie jest dostępny, Inner Range może być w stanie dostarczyć plik aktualizacji za opłatą, aby umożliwić systemowi Inception obsługę niestandardowych kart. Ceny i dostępność zależą od uznania Inner Range.</TranslationEntry>
    <TranslationEntry name="BDE8BEAB67EB9B69617E1B1CFC3077FF" fullContext="DE610CBB2B243D1B1A3F5320A9CFC4B1" translateForJs="false">Kod obiektu zaprogramowany na używanych kartach. Jeśli używany jest więcej niż jeden kod obiektu, należy utworzyć dodatkowe szablony identyfikatorów. </TranslationEntry>
    <TranslationEntry name="A0BDAB61BB76B4AA81F9CEC74AB8E320" fullContext="DE610CBB2B243D1B1A3F5320A9CFC4B1" translateForJs="false">Jeśli nie znasz kodu obiektu kart, otwórz </TranslationEntry>
    <TranslationEntry name="9FE5EBB3A8FD4983C7C3F870B016F214" fullContext="DE610CBB2B243D1B1A3F5320A9CFC4B1" translateForJs="false">Odczyt karty nieudany — nieznany kod obiektu</TranslationEntry>
    <TranslationEntry name="1044072055EC4FD7410246059A212243" fullContext="DE610CBB2B243D1B1A3F5320A9CFC4B1" translateForJs="false"> komunikat będzie zawierał kod obiektu.</TranslationEntry>
    <TranslationEntry name="57585610E517D34838097B79B286EC48" translateForJs="false" rules="unique=CredentialTemplateIntegrationType" notes="Must be unique amongst all &quot;CredentialTemplateIntegrationType&quot; entries">NEDAP ANPR 64-bit</TranslationEntry>
    <TranslationEntry name="4995B157B35789D58194F9CF71264ADC" translateForJs="false" rules="unique=CredentialTemplateIntegrationType" notes="Must be unique amongst all &quot;CredentialTemplateIntegrationType&quot; entries">NEDAP ANPR 26-bit</TranslationEntry>
    <TranslationEntry name="4F088775C07666E297BF50DA6A1915B0" translateForJs="false" rules="unique=CredentialTemplateIntegrationType" notes="Must be unique amongst all &quot;CredentialTemplateIntegrationType&quot; entries">Paxton MIFARE 32-bit (8-cyfrowy CSN)</TranslationEntry>
    <TranslationEntry name="1FE52A3F4BF15801B0B3693BCB412598" translateForJs="false">Typ integracji</TranslationEntry>
    <TranslationEntry name="C987C15292F35E3FFA02853F697D070F" translateForJs="false">Postęp uruchomienia</TranslationEntry>
    <TranslationEntry name="5255D3DAAA0A6276B844D61401E6F493" fullContext="4DEB2E5AD82111820AC01FC00515DA9F" translateForJs="false" rules="unique=ConnectionDetailsType" notes="Must be unique amongst all &quot;ConnectionDetailsType&quot; entries">Szeregowy</TranslationEntry>
    <TranslationEntry name="A58CC2FE3575B87902C17914A19972A5" fullContext="D5871C86AD90ED9D49758749BD004155" translateForJs="false" rules="unique=ConnectionDetailsType" notes="Must be unique amongst all &quot;ConnectionDetailsType&quot; entries">TCP (Klient)</TranslationEntry>
    <TranslationEntry name="C4B534438FFBF410160A206D9BFB2DDA" fullContext="D5871C86AD90ED9D49758749BD004155" translateForJs="false" rules="unique=ConnectionDetailsType" notes="Must be unique amongst all &quot;ConnectionDetailsType&quot; entries">TCP (serwer)</TranslationEntry>
    <TranslationEntry name="62265827DD76752547AB4AE0FE5C131C" fullContext="D5871C86AD90ED9D49758749BD004155" translateForJs="false" rules="unique=ConnectionDetailsType" notes="Must be unique amongst all &quot;ConnectionDetailsType&quot; entries">HTTP (Wyślij)</TranslationEntry>
    <TranslationEntry name="E788EC91948476C316CB2C16E1ADC117" fullContext="D5871C86AD90ED9D49758749BD004155" translateForJs="false" rules="unique=ConnectionDetailsType" notes="Must be unique amongst all &quot;ConnectionDetailsType&quot; entries">HTTP (odbieranie)</TranslationEntry>
    <TranslationEntry name="E279C07F8FB282C171724E558925C858" translateForJs="false">Typ połączenia</TranslationEntry>
    <TranslationEntry name="590AB94B95CC7B48D86AD514AF586823" fullContext="038F9EDC4DF8F20FCCB87277BBA621C0" translateForJs="false">Wybiera metodę połączenia, którą powinien wykorzystywać ten element Połączenia. Aby uzyskać bardziej szczegółowe wyjaśnienie działania różnych typów połączeń, zapoznaj się z opisem strony Połączenia na górze tej strony.</TranslationEntry>
    <TranslationEntry name="109349AA5EEA0DA2372D514043A37629" fullContext="038F9EDC4DF8F20FCCB87277BBA621C0" translateForJs="false"> - Połączenie wysyła i odbiera dane przez określony port szeregowy. Porty szeregowe mogą być używane z konwerterami USB na port szeregowy, a wiele portów można uzyskać za pomocą koncentratora USB. Ten typ połączenia jest najbardziej odpowiedni, gdy wymagana jest dwukierunkowa komunikacja między Inception a zewnętrznym systemem.</TranslationEntry>
    <TranslationEntry name="7F806C08FE1C65A6F54A0185D17CD2E8" fullContext="038F9EDC4DF8F20FCCB87277BBA621C0" translateForJs="false"> - Połączenie działa jako klient TCP i próbuje otworzyć połączenie z określonym adresem IP i portem. Ten typ połączenia jest najbardziej odpowiedni w przypadkach, gdy to urządzenie Inception jest odpowiedzialne za inicjowanie połączenia i wysyłanie wiadomości do zewnętrznego systemu.</TranslationEntry>
    <TranslationEntry name="5297E6FF644E7FC29E79701885882888" fullContext="038F9EDC4DF8F20FCCB87277BBA621C0" translateForJs="false"> - Połączenie działa jako serwer TCP i nasłuchuje przychodzących połączeń na określonym porcie. Ten typ połączenia jest najbardziej odpowiedni w przypadkach, gdy to zewnętrzny system jest odpowiedzialny za inicjowanie połączenia z urządzeniem Inception i wysyłanie wiadomości.</TranslationEntry>
    <TranslationEntry name="6741D0EA8330D8ED717B8044E58ECF9A" fullContext="038F9EDC4DF8F20FCCB87277BBA621C0" translateForJs="false"> - Połączenie wysyła żądania HTTP do serwera pod określonym adresem URL/IP/nazwą hosta, a </TranslationEntry>
    <TranslationEntry name="DE70938849B75D3DB63BBA421C93E018" fullContext="038F9EDC4DF8F20FCCB87277BBA621C0" translateForJs="false">komunikaty</TranslationEntry>
    <TranslationEntry name="CF77F48494FE5CCBE6A1A821CA2B9FEE" fullContext="038F9EDC4DF8F20FCCB87277BBA621C0" translateForJs="false"> wysyłane przez połączenie są traktowane jako koniec adresu URL i/lub ciągu zapytania. Na przykład: przy adresie URL połączenia ustawionym na </TranslationEntry>
    <TranslationEntry name="F1777111F5D0F1C81FFA04DE751128FA" fullContext="D5871C86AD90ED9D49758749BD004155" translateForJs="false">http://www.example.com/</TranslationEntry>
    <TranslationEntry name="99EC72FDE713284B9ABF2FEDE5327B7D" fullContext="038F9EDC4DF8F20FCCB87277BBA621C0" translateForJs="false">, wysyłając komunikat o </TranslationEntry>
    <TranslationEntry name="E10C7B148CF7FF381FD00B7FEA7E30F1" fullContext="2990332DB5A58997F8E2F6223B2674D7" translateForJs="false">action?value=123&amp;enable=true</TranslationEntry>
    <TranslationEntry name="FBE9A8BA1665E9050895B5268C48EC7C" fullContext="038F9EDC4DF8F20FCCB87277BBA621C0" translateForJs="false"> powoduje, że połączenie wysyła żądanie GET pod adres URL </TranslationEntry>
    <TranslationEntry name="9D2268DAB965FB712ED42679A39DF995" fullContext="2990332DB5A58997F8E2F6223B2674D7" translateForJs="false">http://www.example.com/action?value=123&amp;enable=true</TranslationEntry>
    <TranslationEntry name="D722030F6D304D539217F561625337C7" fullContext="038F9EDC4DF8F20FCCB87277BBA621C0" translateForJs="false">. Połączenia HTTP mogą wysyłać wyłącznie komunikaty, nie można nimi odbierać komunikatów. Połączenia HTTP mogą opcjonalnie używać uwierzytelniania Basic lub Digest dla API wymagających prawidłowych danych uwierzytelniających użytkownika. Połączeń HTTP Send nie można używać do odbierania komunikatów; do tego celu należy utworzyć oddzielne połączenie HTTP (Receive).</TranslationEntry>
    <TranslationEntry name="E32237F6D8278B257B12E807C07A1A76" fullContext="038F9EDC4DF8F20FCCB87277BBA621C0" translateForJs="false"> - Połączenie odbiera żądania HTTP kierowane do określonego punktu końcowego serwera WWW Inception (/receive_http_connection), z parametrem zapytania URL (key) identyfikującym, do którego połączenia przeznaczona jest wiadomość, poprzez dopasowanie do pola Ciąg klucza. Połączenia HTTP Receive mogą odbierać wiadomości zarówno z żądań GET zawierających tekst w </TranslationEntry>
    <TranslationEntry name="78E731027D8FD50ED642340B7C9A63B3" fullContext="D5871C86AD90ED9D49758749BD004155" translateForJs="false">komunikat</TranslationEntry>
    <TranslationEntry name="88EDEA8408B87DD49ED009F47957298C" fullContext="038F9EDC4DF8F20FCCB87277BBA621C0" translateForJs="false"> parametr zapytania URL (np. </TranslationEntry>
    <TranslationEntry name="9CEF45A074B2275521D8D7C389C7D0FE" fullContext="038F9EDC4DF8F20FCCB87277BBA621C0" translateForJs="false">/receive_http_connection?key=example&amp;message=test</TranslationEntry>
    <TranslationEntry name="F5C122B097FF51EF395CD14E2F5CA39C" fullContext="038F9EDC4DF8F20FCCB87277BBA621C0" translateForJs="false"> aby wysłać wiadomość do połączenia z Ciągiem klucza o nazwie example), lub żądań POST zawierających tekst w treści żądania. Połączenia HTTP Receive mogą opcjonalnie wymagać nazwy użytkownika i hasła do uwierzytelnienia HTTP Basic (uwierzytelnienie Digest nie jest obsługiwane dla odbierania).</TranslationEntry>
    <TranslationEntry name="5F93F983524DEF3DCA464469D2CF9F3E" translateForJs="false" rules="unique=SerialBaudRate" notes="Must be unique amongst all &quot;SerialBaudRate&quot; entries">110</TranslationEntry>
    <TranslationEntry name="94F6D7E04A4D452035300F18B984988C" translateForJs="false" rules="unique=SerialBaudRate" notes="Must be unique amongst all &quot;SerialBaudRate&quot; entries">300</TranslationEntry>
    <TranslationEntry name="D490D7B4576290FA60EB31B5FC917AD1" translateForJs="false" rules="unique=SerialBaudRate" notes="Must be unique amongst all &quot;SerialBaudRate&quot; entries">600</TranslationEntry>
    <TranslationEntry name="FE2D010308A6B3799A3D9C728EE74244" translateForJs="false" rules="unique=SerialBaudRate" notes="Must be unique amongst all &quot;SerialBaudRate&quot; entries">1200</TranslationEntry>
    <TranslationEntry name="03CF87174DEBACCD689C90C34577B82F" translateForJs="false" rules="unique=SerialBaudRate" notes="Must be unique amongst all &quot;SerialBaudRate&quot; entries">2400</TranslationEntry>
    <TranslationEntry name="0C4A4DF48A930B56E7D71EC5A34B8257" translateForJs="false" rules="unique=SerialBaudRate" notes="Must be unique amongst all &quot;SerialBaudRate&quot; entries">4800</TranslationEntry>
    <TranslationEntry name="7551617774BCD665E4ABE990DB4F6F83" translateForJs="false" rules="unique=SerialBaudRate" notes="Must be unique amongst all &quot;SerialBaudRate&quot; entries">9600</TranslationEntry>
    <TranslationEntry name="F827B5406C7AA5B4FE10062AE06A137B" translateForJs="false" rules="unique=SerialBaudRate" notes="Must be unique amongst all &quot;SerialBaudRate&quot; entries">14400</TranslationEntry>
    <TranslationEntry name="2DE3E2308ADF7C9E1DE8B6BE9371DAFB" translateForJs="false" rules="unique=SerialBaudRate" notes="Must be unique amongst all &quot;SerialBaudRate&quot; entries">19200</TranslationEntry>
    <TranslationEntry name="CC83EE3E84C79E7FBF27CB415C68BBCF" translateForJs="false" rules="unique=SerialBaudRate" notes="Must be unique amongst all &quot;SerialBaudRate&quot; entries">28800</TranslationEntry>
    <TranslationEntry name="3C091577BE6349ED5429131FE38513EB" translateForJs="false" rules="unique=SerialBaudRate" notes="Must be unique amongst all &quot;SerialBaudRate&quot; entries">38400</TranslationEntry>
    <TranslationEntry name="FDAE1B43D72411791CA6145B2A88D10A" translateForJs="false" rules="unique=SerialBaudRate" notes="Must be unique amongst all &quot;SerialBaudRate&quot; entries">56000</TranslationEntry>
    <TranslationEntry name="F5D994CE3DF227089208ED4137DB8688" translateForJs="false" rules="unique=SerialBaudRate" notes="Must be unique amongst all &quot;SerialBaudRate&quot; entries">57600</TranslationEntry>
    <TranslationEntry name="690778DA76F76812A7C9160B81E4D139" translateForJs="false" rules="unique=SerialBaudRate" notes="Must be unique amongst all &quot;SerialBaudRate&quot; entries">115200</TranslationEntry>
    <TranslationEntry name="37B6BD7FE61D651735CEC3D3B0356C66" translateForJs="false" rules="unique=SerialParityOption" notes="Must be unique amongst all &quot;SerialParityOption&quot; entries">Nieparzyste</TranslationEntry>
    <TranslationEntry name="35537FBC25D87FFE59E4F35FEFCD34B7" translateForJs="false" rules="unique=SerialParityOption" notes="Must be unique amongst all &quot;SerialParityOption&quot; entries">Parzyste</TranslationEntry>
    <TranslationEntry name="B82A9A13F4651E9ABCBDE90CD24CE2CB" translateForJs="false" rules="unique=SerialParityOption" notes="Must be unique amongst all &quot;SerialParityOption&quot; entries">Znacznik</TranslationEntry>
    <TranslationEntry name="D511F8439ECDE36647437FBBA67A4394" translateForJs="false" rules="unique=SerialParityOption" notes="Must be unique amongst all &quot;SerialParityOption&quot; entries">Spacja</TranslationEntry>
    <TranslationEntry name="6008647277C4454CECD97D33C069F0CA" translateForJs="false" rules="unique=SerialStopBitsOption" notes="Must be unique amongst all &quot;SerialStopBitsOption&quot; entries">1.5</TranslationEntry>
    <TranslationEntry name="A32C2363568E4050573247574749F81E" translateForJs="false">Port szeregowy</TranslationEntry>
    <TranslationEntry name="672459562EBDC3EB5E888E732CBB4BC1" fullContext="1DFC1FDE9852575B9203183997FB8F09" translateForJs="false">Określa port szeregowy, z którym Połączenie powinno próbować się połączyć. Każdy wykryty port szeregowy zostanie wyświetlony na liście wraz z informacją, czy jest aktualnie podłączony i czy został już przypisany do czegoś innego w systemie.</TranslationEntry>
    <TranslationEntry name="CFAC219F0E14FA2B24E6DEB85EB47366" fullContext="1DFC1FDE9852575B9203183997FB8F09" translateForJs="false">Odłączenie portów szeregowych i odświeżenie strony zaktualizuje </TranslationEntry>
    <TranslationEntry name="0BFC4AEE2FD16046EB4C70C046C8C01A" fullContext="1DFC1FDE9852575B9203183997FB8F09" translateForJs="false">Podłączony</TranslationEntry>
    <TranslationEntry name="CA74169773450861FE12354E490E028E" fullContext="1DFC1FDE9852575B9203183997FB8F09" translateForJs="false"> stan, umożliwiając łatwą identyfikację portów szeregowych.</TranslationEntry>
    <TranslationEntry name="E1922718E1E0957D1E3C7280C94A5555" fullContext="1DFC1FDE9852575B9203183997FB8F09" translateForJs="false">Wybieranie </TranslationEntry>
    <TranslationEntry name="FC3637B815B30183F154B1737DE7B946" fullContext="1DFC1FDE9852575B9203183997FB8F09" translateForJs="false"> spowoduje, że Połączenie podejmie próbę połączenia z pierwszym podłączonym i nieprzypisanym urządzeniem szeregowym.</TranslationEntry>
    <TranslationEntry name="83657602DE08AA6D6F7485068FEA1EAE" translateForJs="false">Prędkość transmisji</TranslationEntry>
    <TranslationEntry name="6BC3985A9E80F9965546F19A794DEDA2" fullContext="2D90E41935C3625DC491F854066DD0DE" translateForJs="false">Szybkość wysyłania/odbierania danych do i z wybranego portu szeregowego. Niektóre urządzenia szeregowe obsługują tylko określone szybkości transmisji — sprawdź u producenta urządzenia, które szybkości są obsługiwane.</TranslationEntry>
    <TranslationEntry name="3167AAD8BF64B42843D398527EDE7470" translateForJs="false">Bity danych</TranslationEntry>
    <TranslationEntry name="4A73A7EC75EAEB0E2F98EF0AE2AD0603" fullContext="4324DF724AF2322C435F03C03D927D66" translateForJs="false">Liczba bitów danych używanych dla połączenia szeregowego (domyślnie 8).</TranslationEntry>
    <TranslationEntry name="427B4EBD6FFAC5B0997D92AB813F8978" translateForJs="false">Bit parzystości</TranslationEntry>
    <TranslationEntry name="D15A3C9350D757B41C873601A5C5B5ED" fullContext="6D91DFDF6FF6D925201DB923408AD3B3" translateForJs="false">Ustawienie bitu parzystości używanego dla połączenia szeregowego (domyślnie Brak).</TranslationEntry>
    <TranslationEntry name="FA6B98EEF051853269C476791F1F185E" translateForJs="false">Bity stopu</TranslationEntry>
    <TranslationEntry name="57C32DA616064DA14890CB3EBBFECA59" fullContext="2E018C2974F33367D905F7F6C77F3D1B" translateForJs="false">Liczba bitów stopu używanych dla połączenia szeregowego (domyślnie 1).</TranslationEntry>
    <TranslationEntry name="84D033BB79B4F1992559194861817C39" fullContext="1A4F0160FAD4640D9034A2200996722B" translateForJs="false">Port TCP serwera, z którym to połączenie powinno otworzyć połączenie TCP.</TranslationEntry>
    <TranslationEntry name="D3E14CE2E18F6F5877F992B4496A7AD4" fullContext="1A4F0160FAD4640D9034A2200996722B" translateForJs="false">W przypadku połączeń z klientami prawidłowe numery portów wynoszą od 1 do 65535 (włącznie).</TranslationEntry>
    <TranslationEntry name="66C23E12D1662AB8A5CEB87FABEA2D62" fullContext="1A4F0160FAD4640D9034A2200996722B" translateForJs="false">Dla połączeń serwerowych prawidłowe numery portów mieszczą się między 1025 a 65535 (włącznie).</TranslationEntry>
    <TranslationEntry name="6724F391B71D187182948F9BA5C8BA4F" fullContext="C134704D5F636AE786B7895794A28891" translateForJs="false">Adres IP serwera, z którym to połączenie powinno otworzyć połączenie TCP.</TranslationEntry>
    <TranslationEntry name="C03B48E650ABC34E994DBAF7FD83E9E9" fullContext="CBED8755A3E4F330B6068C008BC32844" translateForJs="false" rules="unique=HttpAuthenticationMethod" notes="Must be unique amongst all &quot;HttpAuthenticationMethod&quot; entries">Brak (Anonimowy)</TranslationEntry>
    <TranslationEntry name="972E73B7A882D0802A4E3A16946A2F94" fullContext="331B158352203C5E0CAEC312FDEA882B" translateForJs="false" rules="unique=HttpAuthenticationMethod" notes="Must be unique amongst all &quot;HttpAuthenticationMethod&quot; entries">Podstawowy</TranslationEntry>
    <TranslationEntry name="E5CFC515F312C9E85F367E9854D9963E" fullContext="D5871C86AD90ED9D49758749BD004155" translateForJs="false" rules="unique=HttpAuthenticationMethod" notes="Must be unique amongst all &quot;HttpAuthenticationMethod&quot; entries">Skrót wiadomości</TranslationEntry>
    <TranslationEntry name="7528035A93EE69CEDB1DBDDB2F0BFCC8" translateForJs="false" rules="unique=HttpPayloadType" notes="Must be unique amongst all &quot;HttpPayloadType&quot; entries">GET</TranslationEntry>
    <TranslationEntry name="A02439EC229D8BE0E74B0C1602392310" translateForJs="false" rules="unique=HttpPayloadType" notes="Must be unique amongst all &quot;HttpPayloadType&quot; entries">POST</TranslationEntry>
    <TranslationEntry name="FD7A3FC2B48679EAD223EF7174D404C1" translateForJs="false">Ścieżka URL</TranslationEntry>
    <TranslationEntry name="B2F523763329776DE0F8B460004821A6" fullContext="2990332DB5A58997F8E2F6223B2674D7" translateForJs="false">Adres IP, nazwa hosta lub URL, do którego połączenie będzie wysyłać żądania HTTP.</TranslationEntry>
    <TranslationEntry name="BBF29958CBE9E3180861C097CB9781A1" fullContext="2990332DB5A58997F8E2F6223B2674D7" translateForJs="false">UWAGA: To pole powinno zawierać wyłącznie część domenową/ścieżkę docelowego URL; nazwa zasobu i wszelkie parametry zapytania powinny być umieszczone w </TranslationEntry>
    <TranslationEntry name="744A6F453FE9D9556FD481219E1E61E2" fullContext="2990332DB5A58997F8E2F6223B2674D7" translateForJs="false"> pole, które jest dołączane do ścieżki podanej w polu Ścieżka URL. Na przykład, jeśli chcesz wysłać żądanie HTTP pod adres URL </TranslationEntry>
    <TranslationEntry name="51CC0CBE7122B620FE8788BA1669FF48" fullContext="2990332DB5A58997F8E2F6223B2674D7" translateForJs="false">, wpisałbyś </TranslationEntry>
    <TranslationEntry name="4C36ED26199A12A3BA1BA52F1DBEE0D7" fullContext="2990332DB5A58997F8E2F6223B2674D7" translateForJs="false"> w polu ścieżki URL i wyślij </TranslationEntry>
    <TranslationEntry name="4223C6ED36A80170D935D9D29483C19D" fullContext="2990332DB5A58997F8E2F6223B2674D7" translateForJs="false"> jako Komunikat. Ścieżka żądania musi być podana w ten sposób, aby upewnić się, że zostanie wysłana pod prawidłowy URL.</TranslationEntry>
    <TranslationEntry name="63288C2099AEAFECBC30EC7B12C0FDB5" translateForJs="false">Typ ładunku</TranslationEntry>
    <TranslationEntry name="B220F5828DFF8DAFF4DF5E5DF47B5FBA" fullContext="A606D52BC47EF6BC47F802DF75A4F9A9" translateForJs="false">W przypadku połączenia HTTP (Send) metoda wysyłania powinna być GET lub POST.</TranslationEntry>
    <TranslationEntry name="E3B53A2AC9ACF2B55B5549505CA313CF" fullContext="A606D52BC47EF6BC47F802DF75A4F9A9" translateForJs="false"> Po wybraniu opcji GET ładunek jest dołączany do URL. Po wybraniu opcji POST ładunek zostanie wstawiony do treści żądania.</TranslationEntry>
    <TranslationEntry name="FEF1C0ADCBD39F7CB971D3E78B3179AF" translateForJs="false">Metoda uwierzytelniania</TranslationEntry>
    <TranslationEntry name="9560560A224C943D12B586421DC1BA33" fullContext="CBED8755A3E4F330B6068C008BC32844" translateForJs="false">Połączenia HTTP mogą opcjonalnie używać metody uwierzytelniania do komunikacji z interfejsami API HTTP innych systemów wymagających prawidłowych danych logowania użytkownika w celu wykonywania akcji.</TranslationEntry>
    <TranslationEntry name="7C32C97556ABBCC9F5739B8A510B3A4A" fullContext="CBED8755A3E4F330B6068C008BC32844" translateForJs="false"> - Do żądań HTTP wysyłanych przez to połączenie nie są dodawane żadne informacje uwierzytelniające.</TranslationEntry>
    <TranslationEntry name="7C7BBAA0AA3F532B19F706A366E5B56A" fullContext="CBED8755A3E4F330B6068C008BC32844" translateForJs="false"> - Dane uwierzytelniania Basic są dodawane do nagłówka Authorization żądań HTTP wysyłanych przez to połączenie. Uwierzytelnianie Basic wymaga podania nazwy użytkownika i hasła. Ta opcja uwierzytelniania jest najczęściej stosowana. </TranslationEntry>
    <TranslationEntry name="46C20F137AE5B408EF5AD7099A26BE21" fullContext="CBED8755A3E4F330B6068C008BC32844" translateForJs="false"> - Do nagłówka Authorization żądań HTTP wysyłanych przez to połączenie dodawane są dane uwierzytelniające w postaci skrótu. Uwierzytelnianie Digest wymaga podania nazwy użytkownika, hasła i realm.</TranslationEntry>
    <TranslationEntry name="D5EE5FA5AF03513BB37E959EC54624F0" translateForJs="false">Wymagaj ważnego certyfikatu HTTPS</TranslationEntry>
    <TranslationEntry name="93D23ADC6A5C384DF24B29623149D162" fullContext="B376265A3384D80642B6FD5F331E43E6" translateForJs="false">Po zaznaczeniu Inception będzie wymagać od zdalnego serwera poprawnie autoryzowanego certyfikatu podczas nawiązywania tego połączenia przez HTTPS. Certyfikaty stanowią dodatkową warstwę zabezpieczeń zapewniającą, że połączenie jest zaufane i bezpieczne.</TranslationEntry>
    <TranslationEntry name="E6FBF5892FB6B299544D33D25685697B" fullContext="B376265A3384D80642B6FD5F331E43E6" translateForJs="false">Gdy ta opcja jest odznaczona, akceptowane są wszystkie certyfikaty, w tym certyfikaty z podpisem własnym i nieprawidłowe.</TranslationEntry>
    <TranslationEntry name="F6039D44B29456B20F8F373155AE4973" fullContext="F6039D44B29456B20F8F373155AE4973" translateForJs="false">Nazwa użytkownika</TranslationEntry>
    <TranslationEntry name="D28A053ABBF627328B391EBFA5E971BA" fullContext="1CAE3B7808DE29457DA3ADA886756365" translateForJs="false">Nazwa użytkownika do uwierzytelniania HTTP.</TranslationEntry>
    <TranslationEntry name="3BD9F348199A470E671AD416715C5F89" fullContext="6642CBAC32AE12E7728EED6C12A78D0B" translateForJs="false">Hasło do uwierzytelniania HTTP.</TranslationEntry>
    <TranslationEntry name="47A6A6184C5FF4B95DF9ADD769A6366B" translateForJs="false">Realm/Domain</TranslationEntry>
    <TranslationEntry name="821CD2D4F480D11264D469421D509121" fullContext="63B03F9B8395553EB90444F37F179594" translateForJs="false">Obszar do uwierzytelniania HTTP Digest.</TranslationEntry>
    <TranslationEntry name="D51C6C12EE4A70A758E4C9B741B6704D" translateForJs="false">Ciąg klucza</TranslationEntry>
    <TranslationEntry name="F1A5E9DE35A35B269CED0B382DE52E99" fullContext="C00E4DE73ED20F48F51C0EB0AFA75109" translateForJs="false">Ciąg klucza, po którym to połączenie będzie identyfikowane. Gdy przychodzące połączenie HTTP zostanie odebrane przez urządzenie Inception, decyduje ono, do którego połączenia przekazać wiadomość na podstawie ciągu klucza w URL w </TranslationEntry>
    <TranslationEntry name="3C6E0B8A9C15224A8228B9A98CA1531D" fullContext="D5871C86AD90ED9D49758749BD004155" translateForJs="false">klucz</TranslationEntry>
    <TranslationEntry name="E9C355D83AB2A4523D3D0C3F97117C6A" fullContext="C00E4DE73ED20F48F51C0EB0AFA75109" translateForJs="false"> parametr zapytania, na przykład: </TranslationEntry>
    <TranslationEntry name="E54CF151485F14A7B010EC7078ADF52E" fullContext="C00E4DE73ED20F48F51C0EB0AFA75109" translateForJs="false">GET http://in123456.local/receive_http_connection?key=example&amp;message=test</TranslationEntry>
    <TranslationEntry name="CADBF648682B1A85F84C32BB7ED6A5E3" fullContext="C00E4DE73ED20F48F51C0EB0AFA75109" translateForJs="false"> wyśle komunikat do połączenia z kluczem o wartości </TranslationEntry>
    <TranslationEntry name="1A79A4D60DE6718E8E5B326E338AE533" fullContext="D5871C86AD90ED9D49758749BD004155" translateForJs="false">przykład</TranslationEntry>
    <TranslationEntry name="662265E3C0D753A935CCDC5A91E0C733" fullContext="C00E4DE73ED20F48F51C0EB0AFA75109" translateForJs="false">. Ciąg klucza musi być unikalny wśród wszystkich innych połączeń HTTP receive i może zawierać wyłącznie litery (małe i duże), cyfry, znak podkreślenia (_) i znak łącznika (-).</TranslationEntry>
    <TranslationEntry name="0A0D9142E86868CCB7557516E24FA3B6" fullContext="2CE28E8BF9D1FFEBD1D7A046747DEC41" translateForJs="false">Metoda uwierzytelniania HTTP, której to połączenie oczekuje od klientów.</TranslationEntry>
    <TranslationEntry name="14F0F6B9D2B006122DBE57A0F9C60F18" fullContext="937D3680004ED2025FB07607AF5F4CA0" translateForJs="false">Określa nazwę użytkownika wymaganą do uwierzytelniania HTTP Basic, jeśli jest włączone.</TranslationEntry>
    <TranslationEntry name="1F327E4967A2E4282C5AEB6D08E667E2" fullContext="E27A47603893C46A9183868B2218B56A" translateForJs="false">Określa hasło wymagane do uwierzytelniania HTTP Basic, jeśli jest włączone.</TranslationEntry>
    <TranslationEntry name="2FAEC1F9F8CC7F8F40D521C4DD574F49" fullContext="2FAEC1F9F8CC7F8F40D521C4DD574F49" translateForJs="false">Włącz</TranslationEntry>
    <TranslationEntry name="913E5301F6FEDDCF9E2B233B0818E776" translateForJs="false">Szczegóły połączenia</TranslationEntry>
    <TranslationEntry name="236B5D58B57ABEAA21641EBB12507284" fullContext="3FE41285E684BD4C2FBC3A28DD8F965B" translateForJs="false">To pole wyboru włącza i wyłącza połączenie. Można go użyć do tymczasowego wyłączenia połączenia, gdy sieć jest niedostępna lub cel połączenia jest niedostępny.</TranslationEntry>
    <TranslationEntry name="531FFCAAD2DC3E900D83901EFE2F409F" fullContext="6FE2C2ED6C842DD3F9DABE08427EAE45" translateForJs="false">Włącz ponowne próby wysyłania komunikatów</TranslationEntry>
    <TranslationEntry name="8315CEB6C553E9D9928812FC00E52C66" fullContext="4DEB2E5AD82111820AC01FC00515DA9F" translateForJs="false">Gdy to pole wyboru jest zaznaczone, Połączenie będzie próbować ponownie wysłać wiadomości, których wysłanie początkowo zakończyło się niepowodzeniem z powodu awarii sieci, błędnej konfiguracji itp. W przeciwnym razie wiadomości są odrzucane w przypadku niepowodzenia wysyłania. UWAGA: Ta opcja dotyczy wyłącznie </TranslationEntry>
    <TranslationEntry name="B263591D0BE7C35C0BFC6E557E707354" fullContext="4DEB2E5AD82111820AC01FC00515DA9F" translateForJs="false"> Połączenia; nie ma wpływu na </TranslationEntry>
    <TranslationEntry name="A6880994E2A6839973FEABE5EE2F0379" translateForJs="false">Limit czasu ponownych prób wysyłania komunikatów</TranslationEntry>
    <TranslationEntry name="5F37EE3126D3CA9EB5012DE9A4D51F40" fullContext="6FE2C2ED6C842DD3F9DABE08427EAE45" translateForJs="false">Gdy </TranslationEntry>
    <TranslationEntry name="3C28085D46B5F2B9221BCBC4F051409C" fullContext="6FE2C2ED6C842DD3F9DABE08427EAE45" translateForJs="false"> jest włączone, ustawia limit czasu określający, jak długo to połączenie powinno próbować ponownie wysłać pojedynczy komunikat przed jego odrzuceniem.</TranslationEntry>
    <TranslationEntry name="E5EABD2E8D73C52764C48B64C8641007" translateForJs="false">Prefiks wysyłanych komunikatów</TranslationEntry>
    <TranslationEntry name="C1CAF1A15263C1DF1320A6275E749BC6" translateForJs="false">Ramkowanie danych</TranslationEntry>
    <TranslationEntry name="16116E26767132579A17470C37A2C6DE" fullContext="E8DC0347A66CCF4FED1C60F902CD9226" translateForJs="false">Opcjonalnie dodaj sekwencję znaków na początku każdej wysyłanej wiadomości. Powinny one odpowiadać sekwencji znaków początku wiadomości oczekiwanej przez drugi system.</TranslationEntry>
    <TranslationEntry name="20FAFC24992D9DF6C0BA0512FDA5CE7C" fullContext="F9166658359CB41123F45FF2BFEB0533" translateForJs="false">Znaki specjalne (np. powrót karetki, znak nowej linii) można określać za pomocą specjalnych sekwencji znaków. Inne znaki można określać przez ich reprezentację szesnastkową.</TranslationEntry>
    <TranslationEntry name="9668AF1D9A385FBE8CD82D032BD2152F" fullContext="F9166658359CB41123F45FF2BFEB0533" translateForJs="false">\
</TranslationEntry>
    <TranslationEntry name="E33E85B4800457A4688A481651103E92" fullContext="F9166658359CB41123F45FF2BFEB0533" translateForJs="false"> - Powrót karetki</TranslationEntry>
    <TranslationEntry name="58EBF9960B86A9629DD60C465BFA26BD" fullContext="F9166658359CB41123F45FF2BFEB0533" translateForJs="false">\
</TranslationEntry>
    <TranslationEntry name="C137E5D3BF35C77FA51BD93B922CC025" fullContext="F9166658359CB41123F45FF2BFEB0533" translateForJs="false"> - Nowa linia/wysuw wiersza</TranslationEntry>
    <TranslationEntry name="7BA493BE01CCB70C1B31C1B0F9509703" fullContext="F9166658359CB41123F45FF2BFEB0533" translateForJs="false">\	</TranslationEntry>
    <TranslationEntry name="3E7FF50029C48CFB675700F53299C507" fullContext="F9166658359CB41123F45FF2BFEB0533" translateForJs="false"> - Tab</TranslationEntry>
    <TranslationEntry name="C5CBADECD8DACDC93F89218995096EDC" fullContext="F9166658359CB41123F45FF2BFEB0533" translateForJs="false">\\0</TranslationEntry>
    <TranslationEntry name="CF16AB28324A87DF1D0BB5D827029AC5" fullContext="F9166658359CB41123F45FF2BFEB0533" translateForJs="false"> - Null</TranslationEntry>
    <TranslationEntry name="C55AFAC70B5C0B7C79A14FFBB790BC92" fullContext="F9166658359CB41123F45FF2BFEB0533" translateForJs="false">\\\\</TranslationEntry>
    <TranslationEntry name="FD7A8C890A05CA9D8BFFCF7BC87FEC6E" fullContext="F9166658359CB41123F45FF2BFEB0533" translateForJs="false"> - Ukośnik odwrotny</TranslationEntry>
    <TranslationEntry name="C8D5CBE772E49F3C5DC226FE480D2F0E" fullContext="F9166658359CB41123F45FF2BFEB0533" translateForJs="false">\\xXX </TranslationEntry>
    <TranslationEntry name="C9F711E17EE78D5F4EA2FD70A4AD9B73" fullContext="F9166658359CB41123F45FF2BFEB0533" translateForJs="false">(\\x00 - \\xFF)</TranslationEntry>
    <TranslationEntry name="A681B72DD513D1DE35375E967F0896CB" fullContext="F9166658359CB41123F45FF2BFEB0533" translateForJs="false"> - Określa dowolną wartość bajtu jako 2-cyfrową liczbę szesnastkową między 0 (00) a 255 (FF)</TranslationEntry>
    <TranslationEntry name="91A446408572EF455A67ACFC3FB75FB8" translateForJs="false">Sufiks wysyłanych komunikatów</TranslationEntry>
    <TranslationEntry name="D8136D1FC1CE4718F18AF8FE03D83A53" fullContext="985A9C59E7D069592BC9EA0A64D9905B" translateForJs="false">Opcjonalnie dołącz sekwencję znaków na końcu każdego wysłanego komunikatu. Powinna ona odpowiadać sekwencji znaków końca komunikatu oczekiwanej przez drugi system.</TranslationEntry>
    <TranslationEntry name="C3C22A739A2C39A1037742DE35E7F23C" fullContext="F9166658359CB41123F45FF2BFEB0533" translateForJs="false">Zaleca się używanie sufiksów dla wiadomości, aby poprawnie zidentyfikować koniec wiadomości. W przeciwnym razie istnieje ryzyko, że wiadomość zostanie podzielona na pół i przetworzona oddzielnie lub kilka wiadomości zostanie połączonych razem.</TranslationEntry>
    <TranslationEntry name="0394D2BCF3D89682F3AFA74896D4EE08" translateForJs="false">Prefiks wiadomości przychodzących</TranslationEntry>
    <TranslationEntry name="7DAEEE2A6D5C2BB9DD66E6DF7A22F2E3" fullContext="90A4CE674EE7F81FE647595B6FB1BFF5" translateForJs="false">Określa oczekiwany prefiks wiadomości odbieranych z innego systemu. Jeśli to pole jest niepuste, przychodzące wiadomości będą odrzucane do momentu dopasowania prawidłowego prefiksu.</TranslationEntry>
    <TranslationEntry name="0C6840723FD6A0904884E91815DE7137" translateForJs="false">Sufiks wiadomości przychodzących</TranslationEntry>
    <TranslationEntry name="DB59DFABB182C8C16496D333E8178551" fullContext="F9166658359CB41123F45FF2BFEB0533" translateForJs="false">Określa oczekiwany sufiks wiadomości odbieranych z innego systemu. Jeśli to pole jest niepuste, przychodzące wiadomości będą przetwarzane dopiero po odebraniu sekwencji znaków sufiksu.</TranslationEntry>
    <TranslationEntry name="3ED9AECA6B7C1CA66EB606432ADDBEDA" fullContext="7B93394277D1592BC2DAD75EC906AF63" translateForJs="false">Ogranicz wartości min./maks.</TranslationEntry>
    <TranslationEntry name="E4B1151D84352E6B3C79023B5ECB2CEA" fullContext="136663071A751D01B2C0047CD28F7BE5" translateForJs="false">Jeśli to pole wyboru jest włączone, pola Wartość minimalna i Wartość maksymalna mogą być użyte do ustawienia limitów wartości tego licznika.</TranslationEntry>
    <TranslationEntry name="702A538A7348A9E52B08913558867F70" fullContext="7B93394277D1592BC2DAD75EC906AF63" translateForJs="false">Wartość minimalna</TranslationEntry>
    <TranslationEntry name="D98E7FD5CBC94D32CD32EE52D7B292C9" fullContext="6F98B1D87878AA9A069F0D62726DB15B" translateForJs="false">Minimalna dozwolona wartość dla tego licznika. Wartość ta nie może być wyższa niż pole Wartość maksymalna. Próba ustawienia licznika na niższą wartość spowoduje ustawienie go na tę wartość minimalną.</TranslationEntry>
    <TranslationEntry name="48B0ECE3CDD23C3605C8D7EE617C43CA" fullContext="7B93394277D1592BC2DAD75EC906AF63" translateForJs="false">Wartość maksymalna</TranslationEntry>
    <TranslationEntry name="7DBF6788EE48DDDAB8556CC75F4280EF" fullContext="0253AD2EF230E4D0E07BE064C0169D7C" translateForJs="false">Maksymalna dozwolona wartość dla tego licznika. Wartość ta nie może być niższa niż pole Wartość minimalna. Próba ustawienia licznika na wyższą wartość spowoduje ustawienie go na tę wartość maksymalną.</TranslationEntry>
    <TranslationEntry name="03BC142E6422DBB9B288AD2CABEE08C7" translateForJs="false">Identyfikator</TranslationEntry>
    <TranslationEntry name="2DAF1CB573C2C61422FAF64610CF9402" fullContext="C59951F75D1665052A2812FFEED68992" translateForJs="false">Identyfikatory</TranslationEntry>
    <TranslationEntry name="BA5FFA777D6DCF703DC9972AC7284555" fullContext="BA5FFA777D6DCF703DC9972AC7284555" translateForJs="false">Wybierz szablon identyfikatora dla karty, która zostanie przypisana temu użytkownikowi.</TranslationEntry>
    <TranslationEntry name="785DEF63103C1BEBD53A964F22234240" translateForJs="false">Numer identyfikatora</TranslationEntry>
    <TranslationEntry name="46A2A41CC6E552044816A2D04634545D" fullContext="46A2A41CC6E552044816A2D04634545D" translateForJs="false">Stan</TranslationEntry>
    <TranslationEntry name="BF1B3FE9A1E2D2F9600DB28A618DE7E6" translateForJs="false">Mobilny identyfikator</TranslationEntry>
    <TranslationEntry name="B62FC72681F1246144574C4E21B58547" translateForJs="false">Podstawowe informacje</TranslationEntry>
    <TranslationEntry name="D913C3A51C8F9C3D1D125EC485C000E5" translateForJs="false">Szablon karty</TranslationEntry>
    <TranslationEntry name="0F2CCE30F5D2CB1517A572ED67525E80" fullContext="D3B7C3CB275A5EFC65D43F72372591E4" translateForJs="false">Tylko informacyjnie: Szablon identyfikatora używany dla tego mobilnego identyfikatora. Szablon mobilnego identyfikatora jest automatycznie generowany przez system Inception podczas łączenia z systemem dostępu mobilnego i jest oparty na kodzie obiektu skonfigurowanym podczas procesu wstępnego łączenia.</TranslationEntry>
    <TranslationEntry name="931D3A3AD177DD96A28C9642FEC11B01" translateForJs="false">Numer karty</TranslationEntry>
    <TranslationEntry name="23BDF6BC07FB24341C5EB21223D31EB9" fullContext="FF4481FE56FEB9B62103F5904C999492" translateForJs="false">Tylko informacja: numer karty przypisany do tego mobilnego identyfikatora. Numer ten jest generowany automatycznie i nie można go zmienić.</TranslationEntry>
    <TranslationEntry name="D217D74E75904C10CFAF30430083AD75" translateForJs="false">Dane identyfikatora</TranslationEntry>
    <TranslationEntry name="B1CABF98479FB8505C4B5B049267709D" translateForJs="false">Powiązany użytkownik</TranslationEntry>
    <TranslationEntry name="12F5A38E7502709F201BCA6E70A9CE6A" fullContext="F372100056DD0576C1FA677C82576654" translateForJs="false">Tylko informacja: użytkownik, z którym powiązany jest ten mobilny identyfikator.</TranslationEntry>
    <TranslationEntry name="EC53A8C4F07BAED5D8825072C89799BE" fullContext="EC53A8C4F07BAED5D8825072C89799BE" translateForJs="false">Status</TranslationEntry>
    <TranslationEntry name="92D259A0F84A9F3B51B7D127ED3467DA" translateForJs="false" rules="unique=MobileCredentialType" notes="Must be unique amongst all &quot;MobileCredentialType&quot; entries">IR Mobile Access</TranslationEntry>
    <TranslationEntry name="4695654D9A54210407E32E78A14D5CBB" translateForJs="false" rules="unique=MobileCredentialType" notes="Must be unique amongst all &quot;MobileCredentialType&quot; entries">HID</TranslationEntry>
    <TranslationEntry name="A1FA27779242B4902F7AE3BDD5C6D508" fullContext="A1FA27779242B4902F7AE3BDD5C6D508" translateForJs="true">Typ</TranslationEntry>
    <TranslationEntry name="5F7169016F03DEEFD7188126F2275BFF" fullContext="589C5E0F525AA1483F3F01DBCF20F849" translateForJs="false">Tylko informacja: typ tego mobilnego identyfikatora dostępu.</TranslationEntry>
    <TranslationEntry name="CC66624F3D8E19DD2A9F684BF4F802C7" translateForJs="false">E-mail z zaproszeniem</TranslationEntry>
    <TranslationEntry name="1FE533E026BC900CB204E745050DCA7E" fullContext="2E53A76375D917588D29C234C260C6FC" translateForJs="false">Tylko informacja: adres e-mail użyty do wysłania ostatniego kodu zaproszenia dla tego identyfikatora.</TranslationEntry>
    <TranslationEntry name="0D74C82019412335BADA472FD7EC9429" fullContext="E2092012D09196F628A489496EEFBB35" translateForJs="false">Domyślny czas odblokowania</TranslationEntry>
    <TranslationEntry name="6FE4EE2A60C144F668BB63F0D622754F" fullContext="9B36EADF7242E55CA6FBCFDECAA078A0" translateForJs="false">Czas, przez który przejście będzie odblokowane po odblokowaniu przez odczyt karty, dostęp PIN, linie wejściowe REX/REN lub przycisk </TranslationEntry>
    <TranslationEntry name="2D8131F6A6C82DF457EEE9392EC754C8" fullContext="2D8131F6A6C82DF457EEE9392EC754C8" translateForJs="false">Przyznaj dostęp</TranslationEntry>
    <TranslationEntry name="E438D9D1E4F952A6C0A9940EC6874976" fullContext="A9CB4B60E371C8EEBB3A7AD2EA8BDC82" translateForJs="false"> komendę.</TranslationEntry>
    <TranslationEntry name="966EAB815068D26AEEB1E18A23FD23A6" fullContext="CA110B773FBAE87626F1F3CA493C8F56" translateForJs="false">Wydłużony czas odblokowania</TranslationEntry>
    <TranslationEntry name="DC4E7D1EB015A7FA9D370496C8CDADCC" fullContext="62053606AB46E30D5954C1516B819187" translateForJs="false">Czas trwania odblokowania przejścia dla użytkownika wymagającego dłuższego czasu niż domyślny czas odblokowania. Wydłużony czas odblokowania działa dla każdego użytkownika indywidualnie i wymaga </TranslationEntry>
    <TranslationEntry name="D80DEAA5ECCC6117A5820190A0A1D0A1" fullContext="28247A89310AFA8E4677920C02935272" translateForJs="false">Użyj wydłużonych czasów odblokowania</TranslationEntry>
    <TranslationEntry name="904B12CB4753ED6B48E96C6EE0179505" fullContext="4AEA72B3A19DCE7F7ADBF6A805F0FF0C" translateForJs="false"> opcja musi być włączona w </TranslationEntry>
    <TranslationEntry name="C28A72C9590CB9B358D502C59E23370B" fullContext="331B158352203C5E0CAEC312FDEA882B" translateForJs="false">[Konfiguracja &gt; Użytkownicy &gt; Zarządzaj użytkownikami]</TranslationEntry>
    <TranslationEntry name="85D659FFAEE1FC6EC5EA642150920FBC" fullContext="EC466519A3340053F45FC982258265AA" translateForJs="false"> strona. </TranslationEntry>
    <TranslationEntry name="26E29A883A58C04D7C047A52EECADFAC" fullContext="62053606AB46E30D5954C1516B819187" translateForJs="false">Ta opcja jest przeznaczona dla użytkowników potrzebujących dodatkowego czasu na wejście przez drzwi, takich jak kierowca dostawczy wnoszący przesyłki lub użytkownik z niepełnosprawnością lub ograniczoną mobilnością.</TranslationEntry>
    <TranslationEntry name="E3283F1FA3A9123F7B08FA8BAC36A368" fullContext="2CC306E97C3E4A8ED8A671C717B9BDEF" translateForJs="false">Czas przytrzymania (DOTL)</TranslationEntry>
    <TranslationEntry name="148458AC9366FD6F850AB53F456F5CC8" fullContext="CEEE39E581990B2B32A367CDD48A8A3F" translateForJs="false">Czas, przez który czujnik otwarcia drzwi lub kontaktron języczkowy mogą pozostawać w stanie alarmu, gdy przejście jest zablokowane. Odliczanie czasu rozpoczyna się po ponownym zablokowaniu przejścia. Po upływie tego czasu wszelkie linie wyjściowe z zachowaniem DOTL/przytrzymania lub sygnalizatorem podłączone do tego przejścia włączą się, a czytniki SIFER/OSDP podłączone do przejścia wyślą sygnalizację zwrotną. </TranslationEntry>
    <TranslationEntry name="66F0034E40B9FE73D70B24FC5B960367" fullContext="BFA1025F317BCE0C6A3429323F1768AD" translateForJs="false">Czas ostrzeżenia o przytrzymaniu (DOTL)</TranslationEntry>
    <TranslationEntry name="AD14072F9891B0D7D59231F455E6924A" fullContext="CEEE39E581990B2B32A367CDD48A8A3F" translateForJs="false"> jest skonfigurowany, uruchomi się timer ostrzeżenia, w przeciwnym razie przejście przechodzi w stan </TranslationEntry>
    <TranslationEntry name="EFFE06CC3BBFDD18FA0D95A403CD2D3F" fullContext="CFFA3515719C9927087E811A62016E65" translateForJs="false">Przytrzymany</TranslationEntry>
    <TranslationEntry name="0F82AB054180E1429CC3A27185B1DB72" fullContext="CFFA3515719C9927087E811A62016E65" translateForJs="false"> stan i </TranslationEntry>
    <TranslationEntry name="281FD59820D0B8C7F72BA1BD16415FB5" fullContext="CEEE39E581990B2B32A367CDD48A8A3F" translateForJs="false"> linia wejściowa dla tego przejścia jest aktywna. Tę linię wejściową można monitorować w celu raportowania do stacji monitorowania, a czas ostrzeżenia daje użytkownikowi krótki czas na prawidłowe zamknięcie drzwi przed zgłoszeniem zdarzenia.</TranslationEntry>
    <TranslationEntry name="CBF47FF848AA194F643824F732841C3F" fullContext="CEEE39E581990B2B32A367CDD48A8A3F" translateForJs="false">Ta opcja wymaga, aby przejście było wyposażone w kontaktron lub wejście językowe w celu określenia, czy drzwi są otwarte, czy zamknięte. </TranslationEntry>
    <TranslationEntry name="AC6AB1EB5D38F507522FE7249492C5ED" fullContext="CEEE39E581990B2B32A367CDD48A8A3F" translateForJs="false">Stan przytrzymania można zakończyć przez zamknięcie drzwi lub odblokowanie przejścia.</TranslationEntry>
    <TranslationEntry name="7681CE338839BD8B4A305C0879A82822" fullContext="CFFA3515719C9927087E811A62016E65" translateForJs="false">Czas trwania po </TranslationEntry>
    <TranslationEntry name="3540E0588DF9B863EC5E395206651D63" fullContext="CFFA3515719C9927087E811A62016E65" translateForJs="false"> wygasa, przez który czujnik otwarcia drzwi lub linie wejściowe zatrzasku mogą pozostawać w stanie alarmu. Po upływie tego czasu przejście przechodzi w stan </TranslationEntry>
    <TranslationEntry name="3E8FDBA77938794D3DE1382C4D5FAF30" fullContext="CFFA3515719C9927087E811A62016E65" translateForJs="false"> linia wejściowa przechodzi w stan alarmu. Te same linie wyjściowe (DOTL / przytrzymana i sygnalizatory brzęczyka) oraz czytniki SIFER/OSDP, które zostały aktywowane, gdy </TranslationEntry>
    <TranslationEntry name="D8C7944E73CB68078BA95D22EAD3C3F1" fullContext="CFFA3515719C9927087E811A62016E65" translateForJs="false"> po wygaśnięciu będą kontynuować sygnalizację zwrotną.</TranslationEntry>
    <TranslationEntry name="32E3D44B41CBF4D8759AE0B034B4AB2E" fullContext="32E3D44B41CBF4D8759AE0B034B4AB2E" translateForJs="false">Czas wolnego dostępu</TranslationEntry>
    <TranslationEntry name="56A4836501AD33747E8DBEC53FAD339C" fullContext="31C6771DC66B12F7B9A3F2C4F814719A" translateForJs="false">Umożliwia harmonogramowi sterowanie przejściem. Gdy przedział czasowy jest ważny, przejście odblokuje się, a gdy jest nieważny — zablokuje. Tej funkcji można używać razem z </TranslationEntry>
    <TranslationEntry name="DDE28E930B7C246116288FEBAC9D3E2A" fullContext="DDE28E930B7C246116288FEBAC9D3E2A" translateForJs="false">Strefa do śledzenia</TranslationEntry>
    <TranslationEntry name="F1171D0A039FE56CAF3C066E7B180DE8" fullContext="31C6771DC66B12F7B9A3F2C4F814719A" translateForJs="false"> funkcja na tej stronie. W takim przypadku przejście zostanie odblokowane, gdy przedział czasowy jest aktywny i strefa jest rozbrojona. W przeciwnym razie, jeśli śledzona strefa jest uzbrojona lub przedział czasowy jest nieaktywny, przejście pozostanie zablokowane. </TranslationEntry>
    <TranslationEntry name="D84AA627545DFCC53F97AF291ADD625D" fullContext="0CED56F1ED709CDAF6633E49056B0D7C" translateForJs="false">Można to wykorzystać na przykład do umożliwienia wolnego dostępu przez przejście w godzinach pracy, ale dopiero po tym, gdy pracownik po raz pierwszy przejdzie przez to przejście, a co za tym idzie strefa po drugiej stronie przejścia zostanie rozbrojona. </TranslationEntry>
    <TranslationEntry name="BE360EBF68B4CAD4C038B6BB331DF10E" fullContext="31C6771DC66B12F7B9A3F2C4F814719A" translateForJs="false">Uwaga: Jeśli użytkownik nadpisał stan przejścia na zablokowane lub odblokowane z poziomu interfejsu internetowego, nadpisanie ma priorytet. Jednak gdy przedział czasowy zmienia stan, nadpisanie (o ile nie jest to Wyłączenie z dostępu) jest automatycznie usuwane, a przejście domyślnie powraca do normalnego zachowania.  </TranslationEntry>
    <TranslationEntry name="1898B8B077D034E3C89BD174DD0CF4DF" fullContext="1898B8B077D034E3C89BD174DD0CF4DF" translateForJs="false">Sterowanie wolnym dostępem</TranslationEntry>
    <TranslationEntry name="F893D003B8D675017CF6775CB91240A1" fullContext="60E16C4C5C7E23DBB16C925F192A2F54" translateForJs="false">Umożliwia użytkownikowi odblokowanie przejścia przez dwukrotny lub trzykrotny odczyt karty przy powiązanym czytniku i usunięcie nadpisania przez jednokrotny lub dwukrotny odczyt karty. Użytkownik musi mieć uprawnienie nadpisania dla przejścia, aby odblokować lub usunąć stan nadpisania.</TranslationEntry>
    <TranslationEntry name="F385C809A0C0CF7B9C93420B7E27D516" fullContext="60E16C4C5C7E23DBB16C925F192A2F54" translateForJs="false">Można to wykorzystać do szybkiego odblokowania przejść na dłuższe okresy bez użycia interfejsu webowego.</TranslationEntry>
    <TranslationEntry name="8347856F5EF55A8BFA2824331AA26EA1" fullContext="60E16C4C5C7E23DBB16C925F192A2F54" translateForJs="false"> - Domyślne zachowanie — wielokrotne odczyty karty nie będą nadpisywać stanu blokady przejścia.</TranslationEntry>
    <TranslationEntry name="FFD3B7903018D0B4A724AB683B3D9A1C" fullContext="60E16C4C5C7E23DBB16C925F192A2F54" translateForJs="false" rules="unique=FreeAccessControlType" notes="Must be unique amongst all &quot;FreeAccessControlType&quot; entries">2-krotny odczyt karty — swobodny dostęp, 1-krotny — kasowanie</TranslationEntry>
    <TranslationEntry name="BF89549CE6DDC8A4C07D0ADB9CD880E4" fullContext="60E16C4C5C7E23DBB16C925F192A2F54" translateForJs="false"> — Prawidłowa akcja 2-krotnego odczytu karty odblokuje przejście, a pojedynczy odczyt karty wyczyści nadpisanie.</TranslationEntry>
    <TranslationEntry name="EA3A35CCFCF18A212F020F6F05471CB7" fullContext="60E16C4C5C7E23DBB16C925F192A2F54" translateForJs="false" rules="unique=FreeAccessControlType" notes="Must be unique amongst all &quot;FreeAccessControlType&quot; entries">3-krotny odczyt karty — swobodny dostęp, 2-krotny — kasowanie</TranslationEntry>
    <TranslationEntry name="18859BA80684C6601E25590725C5AB50" fullContext="60E16C4C5C7E23DBB16C925F192A2F54" translateForJs="false"> - prawidłowy 3-krotny odczyt karty odblokuje przejście, a 2-krotny odczyt karty skasuje nadpisanie.</TranslationEntry>
    <TranslationEntry name="2D0EA22FD5759164E1216D98935C10BE" translateForJs="false">Automatyczne czyszczenie zastąpień</TranslationEntry>
    <TranslationEntry name="E35E62146B255A53F2000C5FF05D71A8" fullContext="E5DAF4A7C5A23B04EB295E87D237E9F4" translateForJs="false">Umożliwia użytkownikowi wybranie, kiedy stan nadpisania tego przejścia jest automatycznie usuwany (nie dotyczy to przypadku, gdy nadpisanie to Wyłączenie z dostępu).</TranslationEntry>
    <TranslationEntry name="5B85734D8C226963A88DE25A8E2FCC4A" fullContext="E5DAF4A7C5A23B04EB295E87D237E9F4" translateForJs="false">Domyślnie przejścia czyszczą swój stan nadpisania, gdy zmienia się przedział czasowy wolnego dostępu lub gdy zmienia się stan uzbrojenia strefy. Można to zmienić tak, aby czyszczenie nastąpiło tylko przy jednym z tych zdarzeń lub w ogóle nigdy.</TranslationEntry>
    <TranslationEntry name="909B0ED2C094F4BAF6FE488B1BEC7F36" translateForJs="false">Ukryj stan siłowego otwarcia</TranslationEntry>
    <TranslationEntry name="0035B64344DB12A74DE7545B1099DB2B" fullContext="24C3AE2B11F44E57E08ECAC57C1A1888" translateForJs="false">Jeśli opcja jest włączona, powoduje, że przejście pomija </TranslationEntry>
    <TranslationEntry name="FE1FB6EEF17677C46460F88BB5D88744" fullContext="24C3AE2B11F44E57E08ECAC57C1A1888" translateForJs="false"> stan, który jest zazwyczaj wyzwalany przez otwarcie czujnika kontaktronowego drzwi, gdy drzwi nadal pozostają w stanie </TranslationEntry>
    <TranslationEntry name="28B0CCCBC2A20245D70FD64467A94AC5" fullContext="24C3AE2B11F44E57E08ECAC57C1A1888" translateForJs="false"> stan. Ta opcja jest odpowiednia w sytuacjach, gdy stan siłowego otwarcia może być wyświetlany nieodpowiednio podczas normalnego użytkowania, na przykład gdy mechanizm blokujący przejścia zawsze umożliwia otwarcie drzwi od wewnątrz nawet podczas zablokowania przejścia (np. przy swobodnym wyjściu).</TranslationEntry>
    <TranslationEntry name="7429DCED641BCC3854E23FC24BD00D76" fullContext="24C3AE2B11F44E57E08ECAC57C1A1888" translateForJs="false">Należy pamiętać, że nie ma to wpływu na linię wejściową siłowego otwarcia drzwi, która nadal będzie aktywna i może służyć do monitorowania alarmów.</TranslationEntry>
    <TranslationEntry name="537D341DBB9D5D82EA2D77392268E196" translateForJs="false">REX wycisza (omija) stan siłowego otwarcia</TranslationEntry>
    <TranslationEntry name="6912ECB7CBBFF924AFCB86B72DF7322E" fullContext="6A9C169E059281C2D1547195F43A0806" translateForJs="false">Naciśnięcie przycisku REX/REN nie odblokuje przejścia i zamiast tego wygasi stan Siłowego otwarcia i nie aktywuje linii wejściowej Siłowego otwarcia. Używane w przypadku przejść, które można otworzyć od wewnątrz bez potrzeby aktywacji samego zamka.</TranslationEntry>
    <TranslationEntry name="7E16D55E0DCB665454B7A19F3F1B5918" fullContext="6A9C169E059281C2D1547195F43A0806" translateForJs="false">Gdy ten tryb jest włączony i linia wejściowa aktywuje się, linia wyjściowa zamka nie włączy się i przejście nie zmieni stanu na odblokowany. Timer DOTL nadal aktywuje się, a przejście nie wejdzie w stan 'Siłowego otwarcia' po otwarciu. </TranslationEntry>
    <TranslationEntry name="9AC5924B8E1120DF9222989275FD806C" translateForJs="false">Konfiguracja strony przejścia</TranslationEntry>
    <TranslationEntry name="CF8A1CFDCD58A101882DE35FE96EB693" fullContext="CF8A1CFDCD58A101882DE35FE96EB693" translateForJs="false" rules="unique=FollowAreaStateMode" notes="Must be unique amongst all &quot;FollowAreaStateMode&quot; entries">Poza strefą</TranslationEntry>
    <TranslationEntry name="CE4F39B3B4F153C3202C7969CF3C5932" fullContext="731A9CABC970D7F92E0B49BAC1CBAED9" translateForJs="false">Określa strefę znajdującą się na zewnątrz przejścia. Jest używana do uzbrajania stref, sterowania strefą śledzącej przejście oraz śledzenia lokalizacji użytkowników. </TranslationEntry>
    <TranslationEntry name="2183ADDA4D8D8D838A32E3FAE5C805F1" fullContext="2183ADDA4D8D8D838A32E3FAE5C805F1" translateForJs="false" rules="unique=FollowAreaStateMode" notes="Must be unique amongst all &quot;FollowAreaStateMode&quot; entries">Wewnątrz strefy</TranslationEntry>
    <TranslationEntry name="4FEF49360E9B9EB897D7DC87AB121663" fullContext="44BCF6D6081ABBB4D27DCAB1D70FC4E7" translateForJs="false">Określa strefę znajdującą się wewnątrz przejścia. Jest używana do uzbrajania stref, sterowania strefą śledzącej przejście oraz śledzenia lokalizacji użytkowników.</TranslationEntry>
    <TranslationEntry name="7507BE22EA1E642B62B28FDF164307B3" fullContext="7507BE22EA1E642B62B28FDF164307B3" translateForJs="false">Tryb dostępu zewnętrznego</TranslationEntry>
    <TranslationEntry name="5FB25A0E329699AF81AC93043C60DB0F" fullContext="D2DDEAFBA670BD03E8A4A99746043F1E" translateForJs="false">Określa, ile różnych typów identyfikatorów jest wymaganych do uzyskania dostępu przez przejście od zewnątrz. To pole jest używane w połączeniu z </TranslationEntry>
    <TranslationEntry name="99ED09CCD5D43DCF403A94FE38C5FD76" fullContext="D2DDEAFBA670BD03E8A4A99746043F1E" translateForJs="false">Zewnętrzny tryb dostępu — Określone identyfikatory</TranslationEntry>
    <TranslationEntry name="EBFD05049AA31A1B40795635E8A71A99" fullContext="BD5E281CD255E13019918F0C5435FF50" translateForJs="false"> pole, aby określić, które typy identyfikatorów to przejście będzie akceptować lub odrzucać (w konfiguracji domyślnej akceptowane są wszystkie typy identyfikatorów).</TranslationEntry>
    <TranslationEntry name="4C089FD51CE964DF98467413D9683FF4" fullContext="CFB367B710A358A5A74D5694F0C0ABA3" translateForJs="false" rules="unique=AuthenticationFactor" notes="Must be unique amongst all &quot;AuthenticationFactor&quot; entries">Uwierzytelnianie jednym identyfikatorem</TranslationEntry>
    <TranslationEntry name="0546D22B297BBC3E73B84892FDC6FAFB" fullContext="2B83FDC64148CCF4BC90DDE5B9180053" translateForJs="false"> - pojedynczy prawidłowy identyfikator (akceptowanego typu) odblokuje przejście.</TranslationEntry>
    <TranslationEntry name="CBE40FEE0223D1A1CCA259CFFC7260BC" fullContext="1AB4E4DEDE57D499781EB0378B5F9F8C" translateForJs="false" rules="unique=AuthenticationFactor" notes="Must be unique amongst all &quot;AuthenticationFactor&quot; entries">Uwierzytelnianie dwoma identyfikatorami</TranslationEntry>
    <TranslationEntry name="342CF15E6C81328FCA7433C945C1C590" fullContext="2B83FDC64148CCF4BC90DDE5B9180053" translateForJs="false"> - wymagane są dwa identyfikatory różnych typów (np. Karta i PIN), aby odblokować przejście. Drugi identyfikator musi być przedstawiony w ciągu 10 sekund od pierwszego.</TranslationEntry>
    <TranslationEntry name="88E3EB28EC8847B987D5E49EC9939EAC" fullContext="CFB367B710A358A5A74D5694F0C0ABA3" translateForJs="false" rules="unique=AuthenticationFactor" notes="Must be unique amongst all &quot;AuthenticationFactor&quot; entries">Uwierzytelnianie potrójnym identyfikatorem</TranslationEntry>
    <TranslationEntry name="86C70E499F1AA97EB98099CD63F81126" fullContext="2B83FDC64148CCF4BC90DDE5B9180053" translateForJs="false"> - wymagane są trzy identyfikatory różnych typów (np. Karta, PIN i Biometria — odcisk palca), aby odblokować przejście. Każdy identyfikator musi być przedstawiony w ciągu 10 sekund od poprzedniego.</TranslationEntry>
    <TranslationEntry name="86D4F2427B16CDE5ADC26C323D592E4F" fullContext="51580C76AA3773B070874C0B83956CD0" translateForJs="false">Określa typy identyfikatorów wymagane do dostępu do przejścia od zewnątrz. Gdy lista jest pusta, akceptowane są wszystkie typy identyfikatorów; gdy lista zawiera pozycje, akceptowane są tylko typy identyfikatorów z listy, a inne identyfikatory są odrzucane. Gdy identyfikator zostanie zaprezentowany przy czytniku, odebrane dane mogą być przetwarzane inaczej w zależności od tego, któremu szablonowi identyfikatora w systemie odpowiada. </TranslationEntry>
    <TranslationEntry name="43218DB05F7E76AC7FAF1E4D3C678AA8" fullContext="1AB4E4DEDE57D499781EB0378B5F9F8C" translateForJs="false"> pole na </TranslationEntry>
    <TranslationEntry name="6CD5AD6FECE48DBB43A0EF0CB3C588AC" fullContext="1AB4E4DEDE57D499781EB0378B5F9F8C" translateForJs="false">[Kontrola dostępu &gt; Szablony identyfikatorów]</TranslationEntry>
    <TranslationEntry name="3BDAE1E7577397EED4CE95698CBD21F9" fullContext="1AB4E4DEDE57D499781EB0378B5F9F8C" translateForJs="false"> strona określa, jako jaki typ identyfikatora dane zostaną przetworzone.</TranslationEntry>
    <TranslationEntry name="B70BB3351E6B1E6A4442E28231785AC7" fullContext="1AB4E4DEDE57D499781EB0378B5F9F8C" translateForJs="false">To pole jest używane w połączeniu z </TranslationEntry>
    <TranslationEntry name="7E14EE240D9C54E2A3D6B2C8626009ED" fullContext="1AB4E4DEDE57D499781EB0378B5F9F8C" translateForJs="false"> pole, aby skonfigurować zaawansowane wymagania dostępu dla stref zabezpieczonych, na przykład można skonfigurować </TranslationEntry>
    <TranslationEntry name="F71AF6364D2C359A8F1667DCFDFDE374" fullContext="2BC16735DF793FD7ABF58456887E1D2C" translateForJs="false"> na przejściu i sprawić, by akceptowało tylko </TranslationEntry>
    <TranslationEntry name="07200056C66B81FD51121FAA4E9B092D" fullContext="1AB4E4DEDE57D499781EB0378B5F9F8C" translateForJs="false"> typ identyfikatorów. Każdy unikalny typ identyfikatora na liście zostanie zaliczony jako ważna próba dostępu, ale wielokrotne prezentowanie tego samego typu nie zostanie uwzględnione. Na przykład gdy </TranslationEntry>
    <TranslationEntry name="B33231BD970B20F93B01A871B1EF513D" fullContext="2BC16735DF793FD7ABF58456887E1D2C" translateForJs="false"> jest włączone dla przejścia, a użytkownik z 2 </TranslationEntry>
    <TranslationEntry name="364C570010FCB299F6672CBE3659791D" fullContext="2BC16735DF793FD7ABF58456887E1D2C" translateForJs="false"> typ identyfikatorów przyłoży oba kolejno do czytnika, drugi odczyt karty nie otworzy przejścia — do ukończenia próby dostępu wymagany jest identyfikator innej kategorii.</TranslationEntry>
    <TranslationEntry name="0051428EE292ECD3BF4109A2E49D0177" fullContext="1AB4E4DEDE57D499781EB0378B5F9F8C" translateForJs="false"> - Akceptuje identyfikatory typu Karta.</TranslationEntry>
    <TranslationEntry name="CDBC895D08B5D92DB04174533A8548F7" fullContext="CDBC895D08B5D92DB04174533A8548F7" translateForJs="false" rules="unique=AcceptedCredentialType" notes="Must be unique amongst all &quot;AcceptedCredentialType&quot; entries">PIN</TranslationEntry>
    <TranslationEntry name="D8C9C8AF471219E82BC180C9F34516CD" fullContext="1AB4E4DEDE57D499781EB0378B5F9F8C" translateForJs="false"> - Akceptuje identyfikatory typu PIN.</TranslationEntry>
    <TranslationEntry name="99EF507036798AFA4B237FB503A55CA1" fullContext="1AB4E4DEDE57D499781EB0378B5F9F8C" translateForJs="false"> - Akceptuje identyfikatory typu odcisk palca.</TranslationEntry>
    <TranslationEntry name="14F27D8F93BB791EDFA4868763B8FCF3" fullContext="1AB4E4DEDE57D499781EB0378B5F9F8C" translateForJs="false"> - Akceptuje identyfikatory typu iris/oko.</TranslationEntry>
    <TranslationEntry name="0D3A6089C5E140CBF038710AFF78888E" fullContext="1AB4E4DEDE57D499781EB0378B5F9F8C" translateForJs="false"> - Akceptuje identyfikatory typu twarz.</TranslationEntry>
    <TranslationEntry name="8D5E5840E40367129CFCF5E9698F4F3C" fullContext="2BC16735DF793FD7ABF58456887E1D2C" translateForJs="false"> - Akceptuje identyfikatory typu LPR.</TranslationEntry>
    <TranslationEntry name="79EFD518460B1A9051E56FF98B7A0E36" fullContext="79EFD518460B1A9051E56FF98B7A0E36" translateForJs="false">Tryb dostępu wewnętrznego</TranslationEntry>
    <TranslationEntry name="A6BFAB9C55A72809E2BC85885443B5F6" fullContext="BD5E281CD255E13019918F0C5435FF50" translateForJs="false">Określa, ile różnych typów identyfikatorów jest wymaganych do uzyskania dostępu przez przejście od wewnątrz. To pole jest używane w połączeniu z polem </TranslationEntry>
    <TranslationEntry name="DDBF81C71EA19ED5A925837E75CAC38B" fullContext="BD5E281CD255E13019918F0C5435FF50" translateForJs="false">Wewnętrzny tryb dostępu — Określone identyfikatory</TranslationEntry>
    <TranslationEntry name="A8A5B6B72C3E9197C6AB6D644F28E466" fullContext="2BC16735DF793FD7ABF58456887E1D2C" translateForJs="false">Określa typy identyfikatorów wymagane do dostępu do przejścia od wewnątrz. Gdy lista jest pusta, akceptowane są wszystkie typy identyfikatorów; gdy lista zawiera pozycje, akceptowane są tylko typy identyfikatorów z listy, a inne identyfikatory są odrzucane. Gdy identyfikator zostanie zaprezentowany przy czytniku, odebrane dane mogą być przetwarzane inaczej w zależności od tego, któremu szablonowi identyfikatora w systemie odpowiada. </TranslationEntry>
    <TranslationEntry name="6793B669722645859ADAB59B241E90E8" fullContext="6793B669722645859ADAB59B241E90E8" translateForJs="false">Rozbrój strefę przy dostępie</TranslationEntry>
    <TranslationEntry name="B2B19A18008967B6D01C40110CF1381D" fullContext="8DE6F02D54958663F23E0375DD05AE2D" translateForJs="false">Jeśli włączone, odczyt karty przez użytkownika w celu wejścia przez przejście automatycznie rozbroi strefę po przeciwnej stronie przejścia względem miejsca, w którym znajduje się użytkownik. Użytkownik musi mieć odpowiednie uprawnienia do rozbrojenia strefy. Może to być wygodne, gdyż eliminuje konieczność rozbrajania strefy z poziomu Terminala LCD przy użyciu PIN użytkownika.</TranslationEntry>
    <TranslationEntry name="289E754A9F20BA1BEF9969CC357E1355" fullContext="8DE6F02D54958663F23E0375DD05AE2D" translateForJs="false">Może to jednak stanowić zagrożenie bezpieczeństwa. Jeśli karta zostałaby upuszczona poza przejściem i znaleziona przez inną osobę, mogłaby ona wejść przez przejście i rozbroić strefę, bez konieczności znajomości dodatkowego numeru PIN.</TranslationEntry>
    <TranslationEntry name="C0A8A05E077D1D1A79169454B7ED14F3" fullContext="0CED56F1ED709CDAF6633E49056B0D7C" translateForJs="false">Umożliwia strefie wewnętrznej lub zewnętrznej sterowanie przejściem. Gdy wybrana strefa jest uzbrojona, przejście zablokuje się, jednak po rozbrójeniu nie odblokuje się automatycznie. Funkcję tę można łączyć z </TranslationEntry>
    <TranslationEntry name="38E9A65E77BA834BF5A880A4EBBA7B57" fullContext="0CED56F1ED709CDAF6633E49056B0D7C" translateForJs="false"> opcja na tej stronie. W takim przypadku przejście odblokuje się, gdy przedział czasowy będzie ważny i strefa będzie rozbrojona. W przeciwnym razie, jeśli śledzona strefa jest uzbrojona lub przedział czasowy jest nieważny, przejście pozostanie zablokowane. </TranslationEntry>
    <TranslationEntry name="9702C698F345A336EB6702A5888EAA2B" fullContext="0CED56F1ED709CDAF6633E49056B0D7C" translateForJs="false">Uwaga: Jeśli użytkownik nadpisał stan przejścia na zablokowane lub odblokowane za pomocą interfejsu internetowego, nadpisanie ma priorytet. Jednak gdy stan uzbrojenia powiązanej strefy się zmieni, nadpisanie (o ile nie ustawiono trybu blokady) jest automatycznie kasowane i przejście powraca do normalnego zachowania. </TranslationEntry>
    <TranslationEntry name="B31F756265D0DBC5A1B3049061C7CBE7" translateForJs="false">Alternatywne tryby przejścia</TranslationEntry>
    <TranslationEntry name="4971232786441B20A30F445959B45BEF" fullContext="2B83FDC64148CCF4BC90DDE5B9180053" translateForJs="false">Włącz alternatywne tryby przejścia</TranslationEntry>
    <TranslationEntry name="525EE59C21CEB7252C828F31439C212A" fullContext="9174AD005342812ABD54D055AA4C6B56" translateForJs="false">Jeśli włączone, umożliwia temu przejściu korzystanie z alternatywnego programowania przejścia, jeśli przypisany harmonogram jest aktywny. Umożliwia to zmianę niektórych opcji dostępu dla przejścia w zależności od pory dnia. Należy pamiętać, że jeśli jest włączone, </TranslationEntry>
    <TranslationEntry name="3E3E45B24725BBDE211055688B4D6BE4" fullContext="CFB367B710A358A5A74D5694F0C0ABA3" translateForJs="false">Harmonogram trybu alternatywnego</TranslationEntry>
    <TranslationEntry name="A3BE219BB66BC687782440904A459759" fullContext="1D5606C9BAD767E81ED799F9D96443F5" translateForJs="false"> opcja musi być skonfigurowana.</TranslationEntry>
    <TranslationEntry name="3DE06CA093F78E0685BF4B184B06E075" fullContext="9174AD005342812ABD54D055AA4C6B56" translateForJs="false">W ciągu dnia użytkownik może korzystać z Karty lub PIN, aby uzyskać dostęp do przejścia dla wygody, jednak poza godzinami pracy obiekt może wymagać użycia zarówno Karty, jak i PIN w celu zwiększenia bezpieczeństwa. Podobnie tryby dostępu mogą się różnić w zależności od dni roboczych a weekendów itd.</TranslationEntry>
    <TranslationEntry name="3E7D9F2AEDC4F8DD7F55B642A8EECF1A" fullContext="8EE705946A0DD718482882C54305725A" translateForJs="false">Aby alternatywne programowanie przejścia było stosowane, musi być skonfigurowany harmonogram. Harmonogram może składać się z jednego lub więcej warunków wyzwalających, które przyjmują wartość Prawda lub Fałsz (np. gdy przedział czasowy jest aktywny lub gdy strefa jest uzbrojona), przetwarzanych łącznie w celu obliczenia, czy harmonogram powinien być aktywny. Logika harmonogramu może przetwarzać warunki tak, że alternatywny harmonogram trybu jest aktywny tylko wtedy, gdy WSZYSTKIE warunki są prawdziwe, lub gdy DOWOLNY z warunków jest prawdziwy. Gdy stan harmonogramu jest aktywny, zostanie zastosowany alternatywny zestaw opcji poniżej, zastępując domyślne programowanie przejścia.</TranslationEntry>
    <TranslationEntry name="20143F93887236ABE01B98204681632F" fullContext="51580C76AA3773B070874C0B83956CD0" translateForJs="false">Alternatywny tryb dostępu zewnętrznego</TranslationEntry>
    <TranslationEntry name="01D2ACDF5CFAE8D2838FCC583FD8972D" fullContext="6F0D349EE2370B90F0EE144944C0DD22" translateForJs="false">Jeżeli </TranslationEntry>
    <TranslationEntry name="6FE50B4A867B4B17B4B0AD36D0DA4977" fullContext="CFB367B710A358A5A74D5694F0C0ABA3" translateForJs="false"> jest włączone i stan </TranslationEntry>
    <TranslationEntry name="4D6283FEC2BEBE7FF11C610A5260AE1F" fullContext="2B83FDC64148CCF4BC90DDE5B9180053" translateForJs="false"> warunek jest aktywny, ta opcja będzie używana zamiast </TranslationEntry>
    <TranslationEntry name="444F7C537541C62ACAC12CA7779C6EB3" fullContext="CFB367B710A358A5A74D5694F0C0ABA3" translateForJs="false">Podobnie jak w normalnym trybie </TranslationEntry>
    <TranslationEntry name="A0ECEC5884C3A31B98B6F71497983468" fullContext="2B83FDC64148CCF4BC90DDE5B9180053" translateForJs="false"> opcja, ta opcja określa, jakie typy identyfikatorów są wymagane do dostępu do przejścia od zewnątrz.</TranslationEntry>
    <TranslationEntry name="33517817E8DEDA7E7566A5DA48678EE2" translateForJs="false">Alternatywny tryb dostępu od zewnątrz — określone identyfikatory</TranslationEntry>
    <TranslationEntry name="2B132FCBD7B0970E0FD0739A2768598A" fullContext="2BC16735DF793FD7ABF58456887E1D2C" translateForJs="false">Alternatywny tryb dostępu wewnętrznego</TranslationEntry>
    <TranslationEntry name="C12DBA2F90D9A575EE2778A5A3B62A4F" translateForJs="false">Alternatywny wewnętrzny tryb dostępu — Określone identyfikatory</TranslationEntry>
    <TranslationEntry name="C9E3E182E3AE290758A353ED03C3F40E" fullContext="6688DEF26EF250DB143F5DC5EE9F6337" translateForJs="false">Konfiguracja anti-passback</TranslationEntry>
    <TranslationEntry name="1CFB0016F37E60163CEA1DB015A880C2" translateForJs="false">Anti-passback włączony</TranslationEntry>
    <TranslationEntry name="904DF3492D017CF9E727517689F14445" fullContext="DE25258EB500BDA13B95866CEF75BBA7" translateForJs="false">Włącza logikę anti-passback dla tego przejścia. Anti-passback dodaje dodatkową weryfikację żądań dostępu użytkownika, sprawdzając, czy użytkownik już znajduje się w strefie, do której próbuje uzyskać dostęp. Funkcja ta korzysta z ostatniego znane lokalizacji użytkownika i ma na celu zapobieganie tailgatingu, poruszaniu się po budynku bez przestrzegania procedur kontroli dostępu lub przekazywaniu karty w celu umożliwienia innej osobie dostępu do strefy. Należy pamiętać, że użytkownik nadal musi mieć uprawnienie do korzystania z przejścia.</TranslationEntry>
    <TranslationEntry name="5D23F07933480BDCE3B7056E0BB54811" fullContext="DE25258EB500BDA13B95866CEF75BBA7" translateForJs="false">Jeśli użytkownik zawsze przedstawia swój identyfikator dostępu podczas przechodzenia przez przejścia, nawet gdy współpracownik przytrzymuje dla niego drzwi, lokalizacja użytkownika będzie zawsze dokładna i nigdy nie zostanie zatrzymany przez anti-passback. Naruszenia mają miejsce tylko wtedy, gdy użytkownik znajdzie się w innej strefie niż ta, o której wie system. Może to nastąpić przez zmianę stref bez przedstawiania identyfikatora lub przez przedstawienie identyfikatora przy przejściu, ale zmianę zdania i nieprzejście przez przejście.</TranslationEntry>
    <TranslationEntry name="FE93BB7C2EEF2948A437FA29B5F6113F" fullContext="DE25258EB500BDA13B95866CEF75BBA7" translateForJs="false">Anti-passback jest powszechnie stosowany w obiektach, których zasady opierają się na dokładnych lokalizacjach użytkowników. Może to służyć do raportów czasu na obiekcie, dokładnych raportów zbiórki dla zgodności BHP i bezpieczeństwa lub bezpiecznych lokalizacji w budynku. Może również pomóc w ochronie zasobów, takich jak parking, uniemożliwiając wjazd na parking, a następnie przekazanie karty innemu kierowcy korzystającemu z tego samego identyfikatora.</TranslationEntry>
    <TranslationEntry name="AF37C30C58B981D8BB40B40A29E8E2D2" fullContext="DE25258EB500BDA13B95866CEF75BBA7" translateForJs="false">Zaleca się, aby przejścia z włączoną logiką anti-passback posiadały czytnik identyfikatorów po obu stronach przejścia w celu prawidłowej aktualizacji lokalizacji.</TranslationEntry>
    <TranslationEntry name="DAF694985266E7B6D543EBEBCA98DE08" fullContext="DE25258EB500BDA13B95866CEF75BBA7" translateForJs="false">Poniższe opcje konfiguracji mogą określać, kiedy stosowane są zasady anti-passback, dodatkowe reguły dotyczące przyczyn naruszenia i sposobu reagowania systemu na naruszenie. Jeśli dostęp jest odmówiony z powodu naruszenia, anulowanie naruszenia lub </TranslationEntry>
    <TranslationEntry name="EF1837646263F7A56E082846AE8E9250" fullContext="DE25258EB500BDA13B95866CEF75BBA7" translateForJs="false">amnestia</TranslationEntry>
    <TranslationEntry name="AFEE0AABEF9B8BC6FF4809D250DB8DCB" fullContext="DE25258EB500BDA13B95866CEF75BBA7" translateForJs="false"> może być przyznana przez </TranslationEntry>
    <TranslationEntry name="13D0E96AD7E3881B1C3340972834FBE0" fullContext="DE25258EB500BDA13B95866CEF75BBA7" translateForJs="false">[Stan / Sterowanie &gt; Widok użytkowników]</TranslationEntry>
    <TranslationEntry name="437AAB01E942DBE9CBEAF667D1B7BD37" translateForJs="false">Harmonogram anti-passback</TranslationEntry>
    <TranslationEntry name="87C6039D51E253FAE005543CF4841E37" fullContext="AF22205B64EDF2AD46B31C1315097326" translateForJs="false">Logika anti-passback dla tego przejścia może opcjonalnie być ograniczona do określonych godzin dnia. Może to pozwolić np. na egzekwowanie zasad anti-passback w ciągu dnia, gdy inni są obecni i mogą anulować naruszenia, ale nie stosowanie ich w nocy, gdy użytkownik mógłby zostać zablokowany w środku.</TranslationEntry>
    <TranslationEntry name="3A6DE3943FE29A6F6CC925BD7F4C832F" fullContext="AF22205B64EDF2AD46B31C1315097326" translateForJs="false">Jeśli wybrany jest przedział czasowy, reguły anti-passback będą obowiązywać tylko wtedy, gdy przedział czasowy jest aktywny. W przeciwnym razie reguły anti-passback będą obowiązywać zawsze.</TranslationEntry>
    <TranslationEntry name="A0085BCFA2DD473A6483AFB76F7C9400" translateForJs="false">Weryfikuj również strefę wyjścia użytkownika</TranslationEntry>
    <TranslationEntry name="11520D8769D19490907282D9E16BF770" fullContext="1749D94A21B91D4E58783E5F60F0F5A8" translateForJs="false">Domyślnie logika anti-passback sprawdza jedynie, czy użytkownik nie znajduje się aktualnie w strefie, do której próbuje uzyskać dostęp. Jeśli ta opcja jest włączona, system sprawdzi również, czy użytkownik znajduje się w strefie, z której wychodzi. Jeśli ta opcja jest stosowana, zdecydowanie zaleca się używanie czytników identyfikatorów po obu stronach przejść w całym obiekcie, aby lokalizacje użytkowników były prawidłowo aktualizowane. </TranslationEntry>
    <TranslationEntry name="49852496C8A38003BBC5551757DC8248" fullContext="1749D94A21B91D4E58783E5F60F0F5A8" translateForJs="false">Umożliwia bardziej zaawansowaną logikę anti-passback, zapewniając, że użytkownicy zawsze używają swoich identyfikatorów dostępu do poruszania się po budynku.</TranslationEntry>
    <TranslationEntry name="5C10905ADACFA36F886D5F99010B47D2" fullContext="1749D94A21B91D4E58783E5F60F0F5A8" translateForJs="false">Bezpieczeństwo obiektu jest poprawione dzięki tej opcji, ponieważ zduplikowana karta nie zadziała, jeśli prawdziwy właściciel jest już na obiekcie. Podobnie, dostęp do obiektu przez właściwe punkty wejścia i wyjścia może być egzekwowany, ponieważ dostęp przez wewnętrzne przejście nie zadziała, jeśli aktualna lokalizacja użytkownika jest na zewnątrz.</TranslationEntry>
    <TranslationEntry name="955603C245F9549EAC731D2FC71F88D0" fullContext="1749D94A21B91D4E58783E5F60F0F5A8" translateForJs="false">Ten typ anti-passback nie musi być stosowany na wszystkich przejściach w systemie. Może być ograniczony na przykład do sekcji obiektu, gdzie wymagana jest ścisła kontrola dostępu. </TranslationEntry>
    <TranslationEntry name="3D553A689E10ECF350A197759D61B599" fullContext="1749D94A21B91D4E58783E5F60F0F5A8" translateForJs="false">Dla użytkowników zaznajomionych z innymi produktami Inner Range ta opcja jest podobna do </TranslationEntry>
    <TranslationEntry name="215FB5E5C7CFB0FA8C9904881B084142" fullContext="1749D94A21B91D4E58783E5F60F0F5A8" translateForJs="false">Niewłaściwa strefa</TranslationEntry>
    <TranslationEntry name="B13907E2448AF77546EEBBA5888FDA0D" fullContext="1749D94A21B91D4E58783E5F60F0F5A8" translateForJs="false"> logika z systemów Concept 4000 lub </TranslationEntry>
    <TranslationEntry name="C6AD8B5C4DF40D2F69EE833A8A56681E" fullContext="1749D94A21B91D4E58783E5F60F0F5A8" translateForJs="false">Trudniejsze</TranslationEntry>
    <TranslationEntry name="C68388A70DBA047C37D44282C0F34649" fullContext="1749D94A21B91D4E58783E5F60F0F5A8" translateForJs="false"> typ anti-passback z Integriti.</TranslationEntry>
    <TranslationEntry name="9966F99FB3B3DFD0C13F456E18E6B533" fullContext="82FE85BD9E1A09BC4054B1C18F6847DB" translateForJs="false">Odmów dostępu przy naruszeniu</TranslationEntry>
    <TranslationEntry name="3B766ACE1065422076D9B08C968BAF5E" fullContext="BEB56B9FDB37C9BA20CA80AADCF59971" translateForJs="false">Gdy wystąpi naruszenie anti-passback, zdarzenie rejestru zostanie automatycznie zarejestrowane, zostanie utworzony komunikat systemowy (niebieski komunikat na stronie Przegląd systemu wymagający potwierdzenia) i opcjonalnie mogą być wysłane powiadomienia do użytkowników.</TranslationEntry>
    <TranslationEntry name="BD70010D4A1875887D9CF2A45AF63E02" fullContext="BEB56B9FDB37C9BA20CA80AADCF59971" translateForJs="false">Ta opcja określa, czy użytkownik będzie miał odmówiony dostęp do przejścia z powodu naruszenia. Ta funkcjonalność stanowi różnicę między </TranslationEntry>
    <TranslationEntry name="682160FC6AD12F783F70608A9B46B9B9" fullContext="BEB56B9FDB37C9BA20CA80AADCF59971" translateForJs="false">Miękki</TranslationEntry>
    <TranslationEntry name="3656183169810334A96B91129DC9D881" fullContext="BEB56B9FDB37C9BA20CA80AADCF59971" translateForJs="false">Twardy</TranslationEntry>
    <TranslationEntry name="835F9B6CFD07776B415403212EC680DE" fullContext="BEB56B9FDB37C9BA20CA80AADCF59971" translateForJs="false"> typy anti-passback w innych systemach.</TranslationEntry>
    <TranslationEntry name="A8953942718BDC9A7D60D44E8D90829A" fullContext="BEB56B9FDB37C9BA20CA80AADCF59971" translateForJs="false">Jeśli dostęp nie jest odmówiony, użytkownik może przejść przez przejście mimo wystąpienia naruszenia. Jednak administrator może zająć się tym naruszeniem w przyszłości. Ta opcja może być stosowana w obiekcie w celu pomocy w wprowadzeniu i szkoleniu użytkowników w zakresie anti-passback, generując naruszenia bez opóźniania użytkowników lub wpływania na produktywność.</TranslationEntry>
    <TranslationEntry name="0E914E0486174F60DF8CE1A1AB6DB0A8" fullContext="BEB56B9FDB37C9BA20CA80AADCF59971" translateForJs="false">Jeśli opcja jest włączona, użytkownikowi zostanie odmówiony dostęp przez przejście w przypadku naruszenia zasad. W takim przypadku użytkownik będzie musiał uzyskać od administratora anulowanie naruszenia lub amnestię, co daje mu jednorazowy wyjątek pozwalający przejść przez przejście z anti-passback i skorygować swoją lokalizację. Alternatywnie użytkownik może skorygować swoją lokalizację, korzystając z przejścia bez anti-passback lub gdy ktoś inny otworzy mu drzwi. </TranslationEntry>
    <TranslationEntry name="86122F16256458B16F692089F2857550" fullContext="BEB56B9FDB37C9BA20CA80AADCF59971" translateForJs="false">Automatyczne anulowanie naruszeń anti-passback (amnestia)</TranslationEntry>
    <TranslationEntry name="24F84CBC6FAF07CB7B23C0A746C6C4DB" fullContext="BEB56B9FDB37C9BA20CA80AADCF59971" translateForJs="false"> opcja poniżej stanie się również dostępna.</TranslationEntry>
    <TranslationEntry name="2E04814A6120343BAE250F5531C906B6" fullContext="82FE85BD9E1A09BC4054B1C18F6847DB" translateForJs="false"> odpowiedź jest włączona powyżej, użytkownikowi zostanie odmówiony dostęp do przejścia w przypadku naruszenia anti-passback. Aby uzyskać dostęp do przejścia, ktoś musi otworzyć dla niego drzwi lub musi skontaktować się z administratorem systemu w celu anulowania naruszenia, co może zająć czas.</TranslationEntry>
    <TranslationEntry name="2D2589932401CCE182D813241773CCA5" fullContext="82FE85BD9E1A09BC4054B1C18F6847DB" translateForJs="false">Ta opcja pozwala ustawić konfigurowalny czas, po którym naruszenie użytkownika zostanie automatycznie anulowane. Pozwala to na pewną niedogodność dla użytkownika, który spowodował naruszenie — np. zatrzymanie na 20 sekund — bez nadmiernych utrudnień, takich jak konieczność zgłoszenia się do recepcji lub kontaktu z kimś. Użytkownik może nauczyć się korzystać z czytników kontroli dostępu, a inni użytkownicy nie muszą stale anulować naruszeń w miarę ich pojawiania się.</TranslationEntry>
    <TranslationEntry name="268F2EEF73A1A563ED79F4D423B1EF3A" fullContext="82FE85BD9E1A09BC4054B1C18F6847DB" translateForJs="false">Dłuższe okresy od minut do godzin można wybrać, aby zapewnić automatyczne anulowanie naruszenia, jeśli utrzymuje się zbyt długo. Przykładem może być sytuacja nocna, gdy użytkownik naruszył anti-passback opuszczając budynek. Kolega mógł go wypuścić, ale naruszenie pozostaje. Dzięki długiemu czasowi automatycznego anulowania naruszenie zostanie wyczyszczone w nocy i użytkownik będzie mógł uzyskać dostęp do budynku następnego ranka.</TranslationEntry>
    <TranslationEntry name="D76AF35F980696D4EDA14DB95DE433BA" translateForJs="false">Ustawienia sprzętowe</TranslationEntry>
    <TranslationEntry name="1DD52D0438B43F17B33969E081130B34" fullContext="BFA1025F317BCE0C6A3429323F1768AD" translateForJs="false">Linia wyjściowa zamka</TranslationEntry>
    <TranslationEntry name="2F4DA9E7F9E643DC6F80F947AACB70B7" fullContext="D6A8D92C747DC2A44422A7D041D2F0B4" translateForJs="false">Tylko informacja: wyświetla linię wyjściową zamka skonfigurowaną dla przejścia przez </TranslationEntry>
    <TranslationEntry name="0CC82809623B846ED5645048CBC671A1" fullContext="FC2808F0BDC98A24DC42E402A90C5649" translateForJs="false">[Konfiguracja &gt; Sprzęt]</TranslationEntry>
    <TranslationEntry name="4DF86D712B1F6C58CD0E01B973CB0C2F" translateForJs="false">Połączone linie wejściowe</TranslationEntry>
    <TranslationEntry name="2662894AB86C7A76856FAC4885204587" fullContext="7D355E987A9855585E95396F401BD3DD" translateForJs="false">Tylko informacja: wyświetla linie wejściowe i ich zachowanie skonfigurowane dla przejścia przez </TranslationEntry>
    <TranslationEntry name="1F41D2CD84DF52552EBD7F4298C2EF52" translateForJs="false">Powiązane linie wyjściowe</TranslationEntry>
    <TranslationEntry name="3ADDE92EE1F62428A9E09281B5476345" fullContext="A9A06E2DA215BC7F345DFA937BED1182" translateForJs="false">Tylko informacja: wyświetla linie wyjściowe i ich zachowanie skonfigurowane dla przejścia przez </TranslationEntry>
    <TranslationEntry name="6E7B34FA59E1BD229B207892956DC41C" fullContext="6E7B34FA59E1BD229B207892956DC41C" translateForJs="false" rules="unique=AutomaticOverrideClearingType" notes="Must be unique amongst all &quot;AutomaticOverrideClearingType&quot; entries">Nigdy</TranslationEntry>
    <TranslationEntry name="1333BE9C6B0F1D55787ABF710DB28D0C" translateForJs="false" rules="unique=AutomaticOverrideClearingType" notes="Must be unique amongst all &quot;AutomaticOverrideClearingType&quot; entries">Kasuj tylko po zmianie przedziału czasowego swobodnego dostępu</TranslationEntry>
    <TranslationEntry name="E97A75D654F776901370D6A870B50AEB" translateForJs="false" rules="unique=AutomaticOverrideClearingType" notes="Must be unique amongst all &quot;AutomaticOverrideClearingType&quot; entries">Kasuj tylko po zmianie stanu uzbrojenia strefy</TranslationEntry>
    <TranslationEntry name="4B5275D37EB2E9311D086DA9E99E95C5" translateForJs="false" rules="unique=AutomaticOverrideClearingType" notes="Must be unique amongst all &quot;AutomaticOverrideClearingType&quot; entries">Zawsze kasuj</TranslationEntry>
    <TranslationEntry name="63697BF452FFAB6774F88D7EF4B88D6E" translateForJs="false" rules="unique=CredentialAccessMode" notes="Must be unique amongst all &quot;CredentialAccessMode&quot; entries">Tylko karta</TranslationEntry>
    <TranslationEntry name="EDA9F5E401E530243550612AAFEDB33C" translateForJs="false" rules="unique=CredentialAccessMode" notes="Must be unique amongst all &quot;CredentialAccessMode&quot; entries">Tylko PIN</TranslationEntry>
    <TranslationEntry name="FBE5825765353CACBE951EA9A25DC3CE" translateForJs="false" rules="unique=CredentialAccessMode" notes="Must be unique amongst all &quot;CredentialAccessMode&quot; entries">Karta lub PIN</TranslationEntry>
    <TranslationEntry name="AE74F7BCFA2E1E6AABF5B5C0A69E7D32" translateForJs="false" rules="unique=CredentialAccessMode" notes="Must be unique amongst all &quot;CredentialAccessMode&quot; entries">Karta i PIN</TranslationEntry>
